---
const text = Astro.props.text as string;
const Tag = (Astro.props.as || "h1") as "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "p" | "span";
const className = (Astro.props.className || "") as string;
const staggerMs = (Astro.props.staggerMs || 0.06) as number;
const chars: string[] = text.split("");
const staggerItems: { char: string; delay: number; isSpace: boolean }[] = chars.map(function(char: string, i: number) { return { char, delay: i * staggerMs, isSpace: char === " " }; });
---

<Tag class={className}>
  {staggerItems.map(function(item) {
    return <span class="stagger-char" style={`animation-delay: ${item.delay}s`}>{item.isSpace ? "\u00A0" : item.char}</span>;
  })}
</Tag>
<script is:inline>
(function() {
  var el = document.currentScript.previousElementSibling;
  if (!el) return;
  var obs = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        el.querySelectorAll(".stagger-char").forEach(function(c) {
          c.classList.add("visible");
        });
        obs.unobserve(el);
      }
    });
  }, { threshold: 0.1 });
  obs.observe(el);
})();
</script>

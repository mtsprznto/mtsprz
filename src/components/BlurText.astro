---
const text = Astro.props.text as string;
const Tag = (Astro.props.as || "h1") as "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "p" | "span";
const className = (Astro.props.className || "") as string;
const words: string[] = text.split(" ");
const id = `bt-${Math.random().toString(36).slice(2, 8)}`;
const blurItems: { word: string; delay: number; space: string }[] = words.map(function(word: string, i: number) { return { word, delay: i * 0.1, space: i < words.length - 1 ? " " : "" }; });
---

<Tag class={className} id={id}>
  {blurItems.map(function(item) {
    return <span class="blur-word" style={`animation-delay: ${item.delay}s`}>{item.word}{item.space}</span>;
  })}
</Tag>
<script data-id={id} is:inline>
(function() {
  var s = document.currentScript;
  var el = document.getElementById(s.getAttribute("data-id"));
  if (!el) return;

  var obs = new IntersectionObserver(
    function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          el.querySelectorAll(".blur-word").forEach(function(w) {
            w.classList.add("visible");
          });
          obs.unobserve(el);
        }
      });
    },
    { threshold: 0.1 }
  );

  obs.observe(el);
})();
</script>

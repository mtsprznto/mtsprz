<div id="cotizar-modal" class="fixed inset-0 z-[100] flex items-center justify-center px-4 transition-opacity duration-300 opacity-0 pointer-events-none" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Cotización">
  <div class="absolute inset-0 bg-[#010101]/70 backdrop-blur-sm" id="cotizar-overlay"></div>
  <div class="relative w-full max-w-md rounded-2xl bg-[#0a0a0b] border border-white/[0.06] shadow-2xl p-8 sm:p-10 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none opacity-20" style="background: radial-gradient(600px circle at 50% -100px, rgba(99,102,241,0.15), transparent)"></div>

    <button id="cotizar-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full text-white/30 hover:text-white hover:bg-white/[0.06] transition-all" aria-label="Cerrar">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="relative z-[1]">
      <div id="cotizar-step-1" class="space-y-5">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto rounded-xl bg-[#6366f1]/10 border border-[#6366f1]/20 flex items-center justify-center mb-4">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-[#6366f1]"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-white tracking-[-0.5px]">Solicita tu Cotización</h3>
          <p class="mt-2 text-sm text-white/50 font-body leading-relaxed">Déjanos tu correo y te enviaremos un código de verificación para comenzar.</p>
        </div>
        <div class="space-y-3">
          <input
            type="email"
            id="cotizar-email"
            placeholder="tu@correo.com"
            autocomplete="email"
            class="w-full px-4 py-3 rounded-xl bg-white/[0.04] border border-white/[0.08] text-sm text-white placeholder-white/30 font-body outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
          />
          <p id="cotizar-email-error" class="text-xs text-red-400 font-body hidden"></p>
          <button id="cotizar-send-btn"
            class="w-full py-3 rounded-xl bg-[#6366f1] text-sm font-medium text-white hover:bg-[#5558e6] transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
          >
            <span id="cotizar-send-text">Enviar código</span>
            <svg id="cotizar-send-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
          </button>
        </div>
      </div>

      <div id="cotizar-step-2" class="hidden space-y-5">
        <div class="text-center">
          <div class="w-12 h-12 mx-auto rounded-xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-4">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-emerald-400"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <h3 class="text-xl font-heading font-bold text-white tracking-[-0.5px]">Verifica tu Correo</h3>
          <p class="mt-2 text-sm text-white/50 font-body leading-relaxed">Ingresa el código de 6 dígitos que enviamos a <strong id="cotizar-email-display" class="text-white/70 font-medium"></strong></p>
        </div>
        <div class="space-y-3">
          <div class="flex justify-center gap-2">
            <input
              type="text"
              id="cotizar-code-0"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              autocomplete="one-time-code"
              class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
            />
            <input
              type="text"
              id="cotizar-code-1"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
            />
            <input
              type="text"
              id="cotizar-code-2"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
            />
            <span class="flex items-center text-white/20 text-lg font-heading font-bold">—</span>
            <input
              type="text"
              id="cotizar-code-3"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
            />
            <input
              type="text"
              id="cotizar-code-4"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
            />
            <input
              type="text"
              id="cotizar-code-5"
              maxlength="1"
              inputmode="numeric"
              pattern="[0-9]"
              class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
            />
          </div>
          <p id="cotizar-code-error" class="text-xs text-red-400 font-body text-center hidden"></p>
          <button id="cotizar-verify-btn"
            class="w-full py-3 rounded-xl bg-[#6366f1] text-sm font-medium text-white hover:bg-[#5558e6] transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
          >
            <span id="cotizar-verify-text">Verificar código</span>
            <svg id="cotizar-verify-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
          </button>
          <button id="cotizar-resend-btn" class="block mx-auto text-xs text-white/30 hover:text-[#6366f1] transition-colors font-body">Reenviar código</button>
        </div>
      </div>

      <div id="cotizar-step-3" class="hidden space-y-5 text-center">
        <div class="w-16 h-16 mx-auto rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <div>
          <h3 class="text-xl font-heading font-bold text-white tracking-[-0.5px]">¡Correo Verificado!</h3>
          <p class="mt-2 text-sm text-white/50 font-body leading-relaxed">Gracias por tu interés <strong id="cotizar-email-confirm" class="text-white/70 font-medium"></strong>. Uno de nuestros asesores te contactará a la brevedad con una cotización personalizada.</p>
        </div>
        <a href="/contacto" class="block w-full py-3 rounded-xl bg-[#6366f1] text-sm font-medium text-white hover:bg-[#5558e6] transition-all text-center">Ir a contacto</a>
        <button id="cotizar-close-success" class="block mx-auto text-xs text-white/30 hover:text-white/60 transition-colors font-body">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  var $ = function(id) { return document.getElementById(id); };

  var modal = $('cotizar-modal');
  if (!modal) return;

  var overlay = $('cotizar-overlay');
  var close = $('cotizar-close');
  var closeSuccess = $('cotizar-close-success');
  var step1 = $('cotizar-step-1');
  var step2 = $('cotizar-step-2');
  var step3 = $('cotizar-step-3');
  var emailInput = $('cotizar-email');
  var emailError = $('cotizar-email-error');
  var emailDisplay = $('cotizar-email-display');
  var emailConfirm = $('cotizar-email-confirm');
  var sendBtn = $('cotizar-send-btn');
  var sendText = $('cotizar-send-text');
  var sendSpinner = $('cotizar-send-spinner');
  var verifyBtn = $('cotizar-verify-btn');
  var verifyText = $('cotizar-verify-text');
  var verifySpinner = $('cotizar-verify-spinner');
  var codeError = $('cotizar-code-error');
  var resendBtn = $('cotizar-resend-btn');
  var codeInputs = [
    $('cotizar-code-0'), $('cotizar-code-1'), $('cotizar-code-2'),
    $('cotizar-code-3'), $('cotizar-code-4'), $('cotizar-code-5'),
  ];

  var currentEmail = '';

  function openModal() {
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    step1.classList.remove('hidden');
    step2.classList.add('hidden');
    step3.classList.add('hidden');
    emailInput.value = '';
    emailError.classList.add('hidden');
    codeError.classList.add('hidden');
    codeInputs.forEach(function(inp) { if (inp) inp.value = ''; });
    setTimeout(function() { if (emailInput) emailInput.focus(); }, 200);
  }

  function closeModal() {
    modal.classList.remove('opacity-100', 'pointer-events-auto');
    modal.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  function showError(el, msg) {
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function setLoading(btn, spinner, text, loading) {
    if (!btn || !spinner || !text) return;
    if (loading) {
      btn.disabled = true;
      spinner.classList.remove('hidden');
      text.textContent = '...';
    } else {
      btn.disabled = false;
      spinner.classList.add('hidden');
      text.textContent = text.getAttribute('data-restore') || text.textContent;
    }
  }

  if (overlay) overlay.addEventListener('click', closeModal);
  if (close) close.addEventListener('click', closeModal);
  if (closeSuccess) closeSuccess.addEventListener('click', closeModal);

  if (emailInput) {
    emailInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && sendBtn) sendBtn.click();
    });
  }

  if (sendBtn) {
    sendBtn.addEventListener('click', async function() {
      if (!emailInput || !emailError || !sendText || !sendSpinner) return;
      var email = emailInput.value.trim().toLowerCase();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError(emailError, 'Ingresa un correo electrónico válido');
        return;
      }
      emailError.classList.add('hidden');

      sendText.setAttribute('data-restore', 'Enviar código');
      setLoading(sendBtn, sendSpinner, sendText, true);

      try {
        var res = await fetch('/api/send-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(emailError, data.error || 'Error al enviar el código');
          setLoading(sendBtn, sendSpinner, sendText, false);
          return;
        }
        currentEmail = email;
        if (emailDisplay) emailDisplay.textContent = email;
        step1.classList.add('hidden');
        step2.classList.remove('hidden');
        if (codeInputs[0]) codeInputs[0].focus();
      } catch(e) {
        showError(emailError, 'Error de conexión. Intenta de nuevo.');
      }
      setLoading(sendBtn, sendSpinner, sendText, false);
    });
  }

  if (codeInputs[0]) {
    codeInputs.forEach(function(inp, i) {
      if (!inp) return;
      inp.addEventListener('input', function() {
        if (this.value.length >= 1 && i < codeInputs.length - 1 && codeInputs[i + 1]) {
          codeInputs[i + 1].focus();
        }
        if (codeError) codeError.classList.add('hidden');
      });
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !this.value && i > 0 && codeInputs[i - 1]) {
          codeInputs[i - 1].focus();
        }
        if (e.key === 'Enter' && verifyBtn) {
          verifyBtn.click();
        }
      });
      inp.addEventListener('paste', function(e) {
        e.preventDefault();
        var paste = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
        for (var j = 0; j < paste.length; j++) {
          if (codeInputs[j]) codeInputs[j].value = paste[j];
        }
        var next = Math.min(paste.length, 5);
        if (codeInputs[next]) codeInputs[next].focus();
      });
    });
  }

  if (verifyBtn) {
    verifyBtn.addEventListener('click', async function() {
      if (!codeInputs || !codeError || !verifyText || !verifySpinner) return;
      var code = codeInputs.map(function(inp) { return inp ? inp.value : ''; }).join('');
      if (code.length !== 6) {
        showError(codeError, 'Ingresa el código completo de 6 dígitos');
        return;
      }

      verifyText.setAttribute('data-restore', 'Verificar código');
      setLoading(verifyBtn, verifySpinner, verifyText, true);

      try {
        var res = await fetch('/api/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail, code: code }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(codeError, data.error || 'Código incorrecto');
          setLoading(verifyBtn, verifySpinner, verifyText, false);
          return;
        }
        window.location.href = '/cotizar?email=' + encodeURIComponent(currentEmail);
      } catch(e) {
        showError(codeError, 'Error de conexión. Intenta de nuevo.');
      }
      setLoading(verifyBtn, verifySpinner, verifyText, false);
    });
  }

  if (resendBtn) {
    resendBtn.addEventListener('click', function() {
      if (!currentEmail) return;
      resendBtn.disabled = true;
      resendBtn.textContent = 'Enviando...';
      fetch('/api/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: currentEmail }),
      }).then(function() {
        resendBtn.textContent = '¡Reenviado!';
        setTimeout(function() {
          resendBtn.disabled = false;
          resendBtn.textContent = 'Reenviar código';
        }, 3000);
      }).catch(function() {
        resendBtn.disabled = false;
        resendBtn.textContent = 'Reenviar código';
      });
    });
  }

  window.openCotizarModal = openModal;
  window.closeCotizarModal = closeModal;
})();
</script>
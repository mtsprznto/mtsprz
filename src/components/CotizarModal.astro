<div id="cotizar-modal" class="fixed inset-0 z-[100] flex items-end sm:items-center justify-center transition-opacity duration-300 opacity-0 pointer-events-none" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Cotización">

  <!-- Backdrop cinemático -->
  <div class="absolute inset-0" id="cotizar-overlay" style="background:rgba(1,1,1,0.85); backdrop-filter:blur(4px);"></div>

  <!-- Panel — sin border-radius, editorial -->
  <div class="relative w-full sm:max-w-md overflow-hidden" style="background:#0A0A0A; border-top:1px solid rgba(255,255,255,0.07); border-left:1px solid rgba(255,255,255,0.04); border-right:1px solid rgba(255,255,255,0.04);">

    <!-- Noise subtle -->
    <div class="absolute inset-0 pointer-events-none" style="opacity:0.02; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>

    <!-- Close -->
    <button id="cotizar-close"
      class="absolute top-4 right-4 flex items-center justify-center transition-colors"
      style="width:2rem;height:2rem;color:rgba(255,255,255,0.2);"
      onmouseover="this.style.color='rgba(255,255,255,0.7)'" onmouseout="this.style.color='rgba(255,255,255,0.2)'"
      aria-label="Cerrar">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <div class="relative z-[1]" style="padding:2.5rem;">

      <!-- STEP 1: Email -->
      <div id="cotizar-step-1">
        <p style="font-size:0.55rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Paso 1 / 2</p>
        <h3 style="font-size:clamp(1.5rem,4vw,2rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; line-height:0.92; margin:0 0 0.6rem;">
          COTIZA<br /><span style="color:rgba(255,255,255,0.2);">GRATIS</span>
        </h3>
        <p style="font-size:0.72rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); font-weight:300; line-height:1.65; margin-bottom:2rem;">
          Déjanos tu correo y te enviamos un código para comenzar.
        </p>
        <div style="display:flex; flex-direction:column; gap:0.6rem;">
          <input
            type="email"
            id="cotizar-email"
            placeholder="tu@correo.com"
            autocomplete="email"
            style="width:100%; padding:0.875rem 1rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); color:#fff; font-size:0.82rem; font-family:var(--font-body); outline:none; box-sizing:border-box; transition:border-color 0.2s;"
            onfocus="this.style.borderColor='rgba(255,255,255,0.25)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
          />
          <p id="cotizar-email-error" class="hidden" style="font-size:0.68rem; color:#f87171; font-family:var(--font-body);"></p>
          <button id="cotizar-send-btn"
            style="width:100%; padding:0.875rem 1rem; background:#1A1A1A; color:#fff; font-size:0.62rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 0.2s;"
            onmouseover="this.style.background='#2a2a2a'" onmouseout="this.style.background='#1A1A1A'">
            <span id="cotizar-send-text">Enviar código</span>
            <svg id="cotizar-send-spinner" class="hidden" style="width:13px;height:13px;animation:modal-spin 1s linear infinite;" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
          </button>
        </div>
      </div>

      <!-- STEP 2: Código -->
      <div id="cotizar-step-2" class="hidden">
        <p style="font-size:0.55rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Paso 2 / 2</p>
        <h3 style="font-size:clamp(1.5rem,4vw,2rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; line-height:0.92; margin:0 0 0.6rem;">
          CÓDIGO<br /><span style="color:rgba(255,255,255,0.2);">6 DÍGITOS</span>
        </h3>
        <p style="font-size:0.72rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); font-weight:300; line-height:1.65; margin-bottom:2rem;">
          Enviamos el código a <strong id="cotizar-email-display" style="color:rgba(255,255,255,0.55); font-weight:500;"></strong>
        </p>
        <div style="display:flex; flex-direction:column; gap:0.6rem;">
          <div style="display:flex; justify-content:center; gap:0.4rem;">
            <input type="text" id="cotizar-code-0" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code"
              style="width:2.8rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:800;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(255,255,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
            <input type="text" id="cotizar-code-1" maxlength="1" inputmode="numeric" pattern="[0-9]"
              style="width:2.8rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:800;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(255,255,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
            <input type="text" id="cotizar-code-2" maxlength="1" inputmode="numeric" pattern="[0-9]"
              style="width:2.8rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:800;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(255,255,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
            <span style="display:flex;align-items:center;color:rgba(255,255,255,0.15);font-size:1rem;font-weight:700;padding:0 0.1rem;">—</span>
            <input type="text" id="cotizar-code-3" maxlength="1" inputmode="numeric" pattern="[0-9]"
              style="width:2.8rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:800;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(255,255,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
            <input type="text" id="cotizar-code-4" maxlength="1" inputmode="numeric" pattern="[0-9]"
              style="width:2.8rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:800;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(255,255,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
            <input type="text" id="cotizar-code-5" maxlength="1" inputmode="numeric" pattern="[0-9]"
              style="width:2.8rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:800;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='rgba(255,255,255,0.3)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
          </div>
          <p id="cotizar-code-error" class="hidden" style="font-size:0.68rem; color:#f87171; font-family:var(--font-body); text-align:center;"></p>
          <button id="cotizar-verify-btn"
            style="width:100%; padding:0.875rem 1rem; background:#1A1A1A; color:#fff; font-size:0.62rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 0.2s;"
            onmouseover="this.style.background='#2a2a2a'" onmouseout="this.style.background='#1A1A1A'">
            <span id="cotizar-verify-text">Verificar código</span>
            <svg id="cotizar-verify-spinner" class="hidden" style="width:13px;height:13px;animation:modal-spin 1s linear infinite;" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
          </button>
          <button id="cotizar-resend-btn"
            style="background:none; border:none; cursor:pointer; font-size:0.65rem; color:rgba(255,255,255,0.2); font-family:var(--font-body); text-decoration:underline; text-underline-offset:3px; padding:0.4rem 0; transition:color 0.2s;"
            onmouseover="this.style.color='rgba(255,255,255,0.5)'" onmouseout="this.style.color='rgba(255,255,255,0.2)'">
            Reenviar código
          </button>
        </div>
      </div>

      <!-- STEP 3: Éxito -->
      <div id="cotizar-step-3" class="hidden" style="text-align:center; padding:1rem 0;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.5)" stroke-width="2" stroke-linecap="round" style="display:block; margin:0 auto 1.5rem;"><polyline points="20 6 9 17 4 12"/></svg>
        <h3 style="font-size:clamp(1.25rem,4vw,1.75rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; line-height:0.92; margin:0 0 0.75rem;">
          VERIFICADO
        </h3>
        <p style="font-size:0.75rem; color:rgba(255,255,255,0.35); font-family:var(--font-body); font-weight:300; line-height:1.65; margin-bottom:2rem;">
          Te redirigimos a tu cotización personalizada.<br />
          <strong id="cotizar-email-confirm" style="color:rgba(255,255,255,0.55); font-weight:500;"></strong>
        </p>
        <a href="/cotizar"
          style="display:block; width:100%; padding:0.875rem 1rem; background:#1A1A1A; color:#fff; font-size:0.62rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; text-align:center; box-sizing:border-box; transition:background 0.2s; margin-bottom:0.6rem;"
          onmouseover="this.style.background='#2a2a2a'" onmouseout="this.style.background='#1A1A1A'">
          Ir a cotización →
        </a>
        <button id="cotizar-close-success"
          style="background:none; border:none; cursor:pointer; font-size:0.65rem; color:rgba(255,255,255,0.2); font-family:var(--font-body); text-decoration:underline; text-underline-offset:3px; padding:0.4rem 0; transition:color 0.2s;"
          onmouseover="this.style.color='rgba(255,255,255,0.5)'" onmouseout="this.style.color='rgba(255,255,255,0.2)'">
          Cerrar
        </button>
      </div>

    </div>
  </div>
</div>

<style>
  @keyframes modal-spin { to { transform: rotate(360deg); } }
</style>

<script is:inline>
(function() {
  var $ = function(id) { return document.getElementById(id); };

  var modal = $('cotizar-modal');
  if (!modal) return;

  var overlay = $('cotizar-overlay');
  var close = $('cotizar-close');
  var closeSuccess = $('cotizar-close-success');
  var step1 = $('cotizar-step-1');
  var step2 = $('cotizar-step-2');
  var step3 = $('cotizar-step-3');
  var emailInput = $('cotizar-email');
  var emailError = $('cotizar-email-error');
  var emailDisplay = $('cotizar-email-display');
  var emailConfirm = $('cotizar-email-confirm');
  var sendBtn = $('cotizar-send-btn');
  var sendText = $('cotizar-send-text');
  var sendSpinner = $('cotizar-send-spinner');
  var verifyBtn = $('cotizar-verify-btn');
  var verifyText = $('cotizar-verify-text');
  var verifySpinner = $('cotizar-verify-spinner');
  var codeError = $('cotizar-code-error');
  var resendBtn = $('cotizar-resend-btn');
  var codeInputs = [
    $('cotizar-code-0'), $('cotizar-code-1'), $('cotizar-code-2'),
    $('cotizar-code-3'), $('cotizar-code-4'), $('cotizar-code-5'),
  ];

  var currentEmail = '';

  function openModal() {
    modal.classList.remove('opacity-0', 'pointer-events-none');
    modal.classList.add('opacity-100', 'pointer-events-auto');
    document.body.style.overflow = 'hidden';
    step1.classList.remove('hidden');
    step2.classList.add('hidden');
    step3.classList.add('hidden');
    emailInput.value = '';
    emailError.classList.add('hidden');
    codeError.classList.add('hidden');
    codeInputs.forEach(function(inp) { if (inp) inp.value = ''; });
    setTimeout(function() { if (emailInput) emailInput.focus(); }, 200);
  }

  function closeModal() {
    modal.classList.remove('opacity-100', 'pointer-events-auto');
    modal.classList.add('opacity-0', 'pointer-events-none');
    document.body.style.overflow = '';
  }

  function showError(el, msg) {
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function setLoading(btn, spinner, text, loading) {
    if (!btn || !spinner || !text) return;
    if (loading) {
      btn.disabled = true;
      spinner.classList.remove('hidden');
      text.textContent = '...';
    } else {
      btn.disabled = false;
      spinner.classList.add('hidden');
      text.textContent = text.getAttribute('data-restore') || text.textContent;
    }
  }

  if (overlay) overlay.addEventListener('click', closeModal);
  if (close) close.addEventListener('click', closeModal);
  if (closeSuccess) closeSuccess.addEventListener('click', closeModal);

  if (emailInput) {
    emailInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && sendBtn) sendBtn.click();
    });
  }

  if (sendBtn) {
    sendBtn.addEventListener('click', async function() {
      if (!emailInput || !emailError || !sendText || !sendSpinner) return;
      var email = emailInput.value.trim().toLowerCase();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError(emailError, 'Ingresa un correo electrónico válido');
        return;
      }
      emailError.classList.add('hidden');

      sendText.setAttribute('data-restore', 'Enviar código');
      setLoading(sendBtn, sendSpinner, sendText, true);

      try {
        var res = await fetch('/api/send-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(emailError, data.error || 'Error al enviar el código');
          setLoading(sendBtn, sendSpinner, sendText, false);
          return;
        }
        currentEmail = email;
        if (emailDisplay) emailDisplay.textContent = email;
        step1.classList.add('hidden');
        step2.classList.remove('hidden');
        if (codeInputs[0]) codeInputs[0].focus();
      } catch(e) {
        showError(emailError, 'Error de conexión. Intenta de nuevo.');
      }
      setLoading(sendBtn, sendSpinner, sendText, false);
    });
  }

  if (codeInputs[0]) {
    codeInputs.forEach(function(inp, i) {
      if (!inp) return;
      inp.addEventListener('input', function() {
        if (this.value.length >= 1 && i < codeInputs.length - 1 && codeInputs[i + 1]) {
          codeInputs[i + 1].focus();
        }
        if (codeError) codeError.classList.add('hidden');
      });
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !this.value && i > 0 && codeInputs[i - 1]) {
          codeInputs[i - 1].focus();
        }
        if (e.key === 'Enter' && verifyBtn) {
          verifyBtn.click();
        }
      });
      inp.addEventListener('paste', function(e) {
        e.preventDefault();
        var paste = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
        for (var j = 0; j < paste.length; j++) {
          if (codeInputs[j]) codeInputs[j].value = paste[j];
        }
        var next = Math.min(paste.length, 5);
        if (codeInputs[next]) codeInputs[next].focus();
      });
    });
  }

  if (verifyBtn) {
    verifyBtn.addEventListener('click', async function() {
      if (!codeInputs || !codeError || !verifyText || !verifySpinner) return;
      var code = codeInputs.map(function(inp) { return inp ? inp.value : ''; }).join('');
      if (code.length !== 6) {
        showError(codeError, 'Ingresa el código completo de 6 dígitos');
        return;
      }

      verifyText.setAttribute('data-restore', 'Verificar código');
      setLoading(verifyBtn, verifySpinner, verifyText, true);

      try {
        var res = await fetch('/api/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail, code: code }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(codeError, data.error || 'Código incorrecto');
          setLoading(verifyBtn, verifySpinner, verifyText, false);
          return;
        }
        window.location.href = '/cotizar';
      } catch(e) {
        showError(codeError, 'Error de conexión. Intenta de nuevo.');
      }
      setLoading(verifyBtn, verifySpinner, verifyText, false);
    });
  }

  if (resendBtn) {
    resendBtn.addEventListener('click', function() {
      if (!currentEmail) return;
      resendBtn.disabled = true;
      resendBtn.textContent = 'Enviando...';
      fetch('/api/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: currentEmail }),
      }).then(function() {
        resendBtn.textContent = '¡Reenviado!';
        setTimeout(function() {
          resendBtn.disabled = false;
          resendBtn.textContent = 'Reenviar código';
        }, 3000);
      }).catch(function() {
        resendBtn.disabled = false;
        resendBtn.textContent = 'Reenviar código';
      });
    });
  }

  window.openCotizarModal = openModal;
  window.closeCotizarModal = closeModal;
})();
</script>
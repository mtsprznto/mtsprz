---
export interface Props {
  items: { name: string; path: string }[];
  class?: string;
}

const { items, class: className = "" } = Astro.props;
const home = { name: "Inicio", path: "/" };
const crumbs = [home, ...items];
---

<nav aria-label="Breadcrumb" class={`text-[11px] font-body tracking-wide ${className}`}>
  <ol class="flex flex-wrap items-center gap-1.5 text-white/30">
    {crumbs.map((crumb, i) => {
      const isLast = i === crumbs.length - 1;
      return (
        <li class="flex items-center gap-1.5">
          {i > 0 && (
            <svg class="w-3 h-3 text-white/20 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 18l6-6-6-6" />
            </svg>
          )}
          {isLast ? (
            <span class="text-white/50" aria-current="page">{crumb.name}</span>
          ) : (
            <a href={crumb.path} class="hover:text-white/60 transition-colors">{crumb.name}</a>
          )}
        </li>
      );
    })}
  </ol>
</nav>

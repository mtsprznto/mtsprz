---
export interface Props {
  icon: string;
  title: string;
  description: string;
  tags: string[];
  number: number;
  accent: string;
}

const { icon, title, description, tags, number, accent } = Astro.props;

const icons: Record<string, string> = {
  Code: "M7.5 3.75L2.25 12l5.25 8.25m9-16.5L21.75 12l-5.25 8.25",
  Search: "M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z",
  Bot: "M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z",
  Palette: "M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072",
  TrendingUp: "M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941",
  Globe: "M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418",
};
const pathData = icons[icon] || icons.Code;
---

<div
  class="service-card group relative rounded-[1.375rem]"
  style="perspective:1200px"
  data-accent={accent}
>
  <!-- Hover border glow -->
  <div
    data-border
    class="absolute -inset-[1px] rounded-[1.375rem] opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none z-10"
    style={`background: conic-gradient(from var(--angle,0deg) at 50% 50%, ${accent} 0%, transparent 30%, transparent 70%, ${accent} 100%); mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0); mask-composite: exclude; -webkit-mask-composite: xor; padding: 1px;box-shadow: inset 0 0 0 1px ${accent}44;`}
  />

  <div
    class="card-inner relative rounded-[1.375rem] overflow-hidden bg-[#0a0a0b] transition-all duration-500 ease-out"
    style="transform-style:preserve-3d; box-shadow: 0 2px 24px -10px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.06);"
  >
    <!-- Accent top bar -->
    <div class="absolute top-0 left-0 right-0 h-[2px] rounded-t-[1.375rem] overflow-hidden">
      <div class="w-full h-full" style={`background: linear-gradient(90deg, ${accent}99, ${accent}33, transparent);`} />
    </div>

    <!-- Hover glow -->
    <div
      class="absolute -top-32 -right-32 w-64 h-64 rounded-full opacity-0 group-hover:opacity-20 transition-all duration-700 blur-[80px] pointer-events-none"
      style={`background: radial-gradient(circle, ${accent}, transparent 70%);`}
    />

    <!-- Bottom gradient -->
    <div class="absolute bottom-0 left-0 right-0 h-32 pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-500"
      style={`background: linear-gradient(to top, ${accent}0a, transparent);`}
    />

    <div class="relative p-6 sm:p-7 flex flex-col min-h-[310px]">
      <!-- Header: number + tags -->
      <div class="flex items-start justify-between gap-3">
        <span
          class="text-xs font-mono font-bold tracking-[0.15em] select-none"
          style={`color: ${accent}; text-shadow: 0 0 20px ${accent}44;`}
        >{String(number).padStart(2, "0")}</span>
        <div class="flex flex-wrap justify-end gap-1.5 max-w-[65%]">
          {tags.map((tag) => (
            <span class="px-2.5 py-0.5 text-[10px] leading-none tracking-wide text-white/50 bg-white/[0.03] rounded-full border border-white/[0.05] font-body">{tag}</span>
          ))}
        </div>
      </div>

      <div class="flex-1 min-h-[8px]" />

      <!-- Icon -->
      <div class="relative mb-3 sm:mb-4">
        <div
          class="absolute -inset-3 rounded-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-xl"
          style={`background: ${accent}33;`}
        />
        <div class="relative w-10 h-10 sm:w-11 sm:h-11 rounded-xl flex items-center justify-center bg-white/[0.04] border border-white/[0.04] group-hover:border-white/10 transition-all duration-300">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white">
            <path d={pathData} />
          </svg>
        </div>
      </div>

      <!-- Title -->
      <h3 class="text-xl sm:text-2xl font-heading font-bold text-white tracking-[-0.5px] leading-tight group-hover:text-white transition-colors duration-300">{title}</h3>

      <!-- Description -->
      <p class="mt-2 text-sm text-white/50 font-body font-light leading-relaxed max-w-[34ch]">{description}</p>

      <!-- CTA -->
      <div class="mt-auto pt-5">
        <div
          class="inline-flex items-center gap-2 text-[11px] font-medium tracking-[0.12em] uppercase transition-all duration-300 group-hover:gap-3"
          style={`color: ${accent}BB;`}
        >
          <span>Saber más</span>
          <svg
            class="w-3.5 h-3.5 transition-all duration-300 group-hover:translate-x-1"
            style={`color: ${accent}`}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M5 12h14" />
            <path d="M12 5l7 7-7 7" />
          </svg>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
  (function(){
    var el = document.currentScript.parentElement;
    var inner = el.querySelector('.card-inner');
    var accent = el.getAttribute('data-accent') || '#6366f1';

    el.addEventListener('mousemove', function(e){
      var r = el.getBoundingClientRect();
      var x = (e.clientX - r.left - r.width / 2) / 18;
      var y = (e.clientY - r.top - r.height / 2) / 18;
      inner.style.transform = 'rotateY(' + x + 'deg) rotateX(' + (-y) + 'deg) translateZ(4px)';
    });

    el.addEventListener('mouseleave', function(){
      inner.style.transform = 'rotateY(0deg) rotateX(0deg) translateZ(0px)';
    });

    var borderEl = el.querySelector('[data-border]');
    if (borderEl) {
      var angle = 0;
      var spinning = false;
      el.addEventListener('mouseenter', function(){
        spinning = true;
        (function spin(){
          if (!spinning) return;
          angle = (angle + 1) % 360;
          borderEl.style.setProperty('--angle', angle + 'deg');
          requestAnimationFrame(spin);
        })();
      });
      el.addEventListener('mouseleave', function(){
        spinning = false;
      });
    }
  })();
  </script>
</div>

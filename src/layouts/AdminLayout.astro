---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/admin") return path === "/admin";
  return path.startsWith(href);
}

const navItems = [
  { href: "/admin", label: "Dashboard", icon: "M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z M9 22V12h6v10" },
  { href: "/admin/contratos", label: "Contratos", icon: "M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8" },
  { href: "/admin/contratos/nuevo", label: "Nuevo Contrato", icon: "M12 5v14 M5 12h14" },
  { href: "/admin/servicios", label: "Servicios", icon: "M22 12h-4l-3 9L9 3l-3 9H2" },
  { href: "/admin/plantillas", label: "Plantillas", icon: "M4 6h16 M4 10h16 M4 14h16 M4 18h16" },
];
---

<!doctype html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Mtsprz Admin</title>
    <meta name="description" content={description || "Panel de administración Mtsprz"} />
  </head>
  <body>
    <!-- Mobile top bar -->
    <header class="md:hidden flex items-center justify-between px-4 h-14 bg-[#0a0a0b] border-b border-white/[0.06] sticky top-0 z-40">
      <a href="/admin" class="flex items-center gap-2.5">
        <picture>
          <source srcset="/logo.webp" type="image/webp" />
          <img src="/logo.jpg" alt="Mtsprz" width="28" height="28" class="w-7 h-7 rounded-lg object-cover shrink-0" />
        </picture>
        <span class="font-heading text-sm font-bold text-white tracking-tight">Mtsprz <span class="text-accent">Admin</span></span>
      </a>
      <button id="mobile-menu-btn" aria-label="Abrir menú" class="p-2 rounded-lg text-white/50 hover:text-white hover:bg-white/[0.06] transition-colors">
        <svg id="icon-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><line x1="3" y1="6" x2="21" y2="6" /><line x1="3" y1="12" x2="21" y2="12" /><line x1="3" y1="18" x2="21" y2="18" /></svg>
        <svg id="icon-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 hidden"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
      </button>
    </header>

    <!-- Mobile drawer overlay -->
    <div id="mobile-overlay" class="md:hidden fixed inset-0 z-30 bg-black/60 backdrop-blur-sm hidden"></div>

    <!-- Mobile drawer -->
    <div id="mobile-drawer" class="md:hidden fixed top-14 left-0 bottom-0 w-64 z-40 bg-[#0a0a0b] border-r border-white/[0.06] flex flex-col translate-x-[-100%] transition-transform duration-300 ease-in-out">
      <nav class="flex-1 flex flex-col gap-0.5 p-3 overflow-y-auto">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-sm font-body font-normal transition-all duration-200 no-underline ${isActive(item.href) ? "bg-accent-subtle text-accent font-medium" : "text-white/45 hover:bg-accent-subtle hover:text-white/80"}`}
          >
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] shrink-0"><path d={item.icon} /></svg>
            {item.label}
          </a>
        ))}
      </nav>
      <div class="p-3 border-t border-white/[0.06] flex flex-col gap-1">
        <a href="/" class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-xs text-white/30 no-underline transition-all duration-200 hover:text-white/60 hover:bg-white/[0.04]">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] shrink-0"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
          Volver al Sitio
        </a>
        <button id="logout-btn-mobile" class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-xs text-red-400/60 hover:text-red-400 hover:bg-red-500/[0.08] transition-all duration-200 w-full text-left">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] shrink-0"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
          Cerrar Sesión
        </button>
      </div>
    </div>

    <div class="flex min-h-screen">
      <!-- Desktop sidebar -->
      <aside class="hidden md:flex md:flex-col w-64 bg-[#0a0a0b] border-r border-white/[0.06] sticky top-0 h-screen shrink-0">
        <a href="/admin" class="flex items-center gap-3 px-6 pt-5 pb-6 border-b border-white/[0.06]">
          <picture>
            <source srcset="/logo.webp" type="image/webp" />
            <img src="/logo.jpg" alt="Mtsprz" width="32" height="32" class="w-8 h-8 rounded-lg object-cover shrink-0" />
          </picture>
          <span class="font-heading text-base font-bold text-white tracking-tight">Mtsprz <span class="text-accent">Admin</span></span>
        </a>

        <nav class="flex-1 flex flex-col gap-0.5 p-3 overflow-y-auto">
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-sm font-body font-normal transition-all duration-200 no-underline ${isActive(item.href) ? "bg-accent-subtle text-accent font-medium" : "text-white/45 hover:bg-accent-subtle hover:text-white/80"}`}
            >
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] shrink-0"><path d={item.icon} /></svg>
              {item.label}
            </a>
          ))}
        </nav>

        <div class="p-3 border-t border-white/[0.06] flex flex-col gap-1">
          <a href="/" class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-xs text-white/30 no-underline transition-all duration-200 hover:text-white/60 hover:bg-white/[0.04]">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] shrink-0"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
            Volver al Sitio
          </a>
          <button id="logout-btn-desktop" class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-xs text-red-400/60 hover:text-red-400 hover:bg-red-500/[0.08] transition-all duration-200 w-full text-left">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-[18px] h-[18px] shrink-0"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
            Cerrar Sesión
          </button>
        </div>
      </aside>

      <main class="flex-1 w-full p-4 sm:p-6 lg:p-8 xl:p-10 min-w-0">
        <slot />
      </main>
    </div>

    <script>
      // Mobile menu toggle
      const btn = document.getElementById("mobile-menu-btn");
      const drawer = document.getElementById("mobile-drawer");
      const overlay = document.getElementById("mobile-overlay");
      const iconOpen = document.getElementById("icon-open");
      const iconClose = document.getElementById("icon-close");

      function openMenu() {
        drawer?.classList.remove("translate-x-[-100%]");
        overlay?.classList.remove("hidden");
        iconOpen?.classList.add("hidden");
        iconClose?.classList.remove("hidden");
      }

      function closeMenu() {
        drawer?.classList.add("translate-x-[-100%]");
        overlay?.classList.add("hidden");
        iconOpen?.classList.remove("hidden");
        iconClose?.classList.add("hidden");
      }

      btn?.addEventListener("click", () => {
        drawer?.classList.contains("translate-x-[-100%]") ? openMenu() : closeMenu();
      });
      overlay?.addEventListener("click", closeMenu);

      // Logout handler
      async function logout() {
        await fetch("/api/auth/logout", { method: "POST" });
        window.location.href = "/login";
      }

      document.getElementById("logout-btn-desktop")?.addEventListener("click", logout);
      document.getElementById("logout-btn-mobile")?.addEventListener("click", logout);
    </script>
  </body>
</html>

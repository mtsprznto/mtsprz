---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  article?: {
    title?: string;
    publishedTime?: string;
    author?: string;
    tags?: string[];
  };
  breadcrumbs?: { name: string; path: string }[];
}

const {
  title,
  description,
  canonical,
  image,
  article,
  breadcrumbs,
} = Astro.props;
const site = "https://mtsprz.org";
const brand = "Mtsprz";
const defaultTitle = `${brand} | Soluciones Digitales`;
const fullTitle = title ? `${title} | ${brand}` : defaultTitle;
const ogImage = image || `${site}/logo.jpg`;
const currentUrl = canonical || site;
---

<!doctype html>
<html lang="es-CL" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    <link rel="icon" type="image/jpeg" href="/logo.jpg" />
    <link rel="apple-touch-icon" href="/logo.jpg" />
    <link rel="alternate" hreflang="es-CL" href={currentUrl} />
    <link rel="alternate" hreflang="x-default" href={currentUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Inter:wght@300;400;500;600;700&family=Montserrat:wght@400;500;600&family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:site_name" content={brand} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#010101" />
    <meta name="author" content={brand} />
    <meta name="geo.region" content="CL-LL" />
    <meta name="geo.placename" content="Puerto Varas" />

    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        ...(article
          ? [
              {
                "@type": "Article",
                "@id": `${currentUrl}#article`,
                headline: article.title || title,
                description: description,
                image: ogImage,
                datePublished: article.publishedTime,
                author: {
                  "@type": "Person",
                  name: article.author || brand,
                },
                publisher: {
                  "@type": "Organization",
                  "@id": `${site}/#organization`,
                  name: brand,
                  logo: {
                    "@type": "ImageObject",
                    url: `${site}/logo.jpg`,
                  },
                },
                ...(article.tags && article.tags.length > 0
                  ? { keywords: article.tags.join(", ") }
                  : {}),
                mainEntityOfPage: {
                  "@type": "WebPage",
                  "@id": currentUrl,
                },
              },
            ]
          : []),
        {
          "@type": "Organization",
          "@id": `${site}/#organization`,
          name: "Mtsprz",
          url: site,
          logo: `${site}/logo.jpg`,
          description: "Soluciones Digitales en la Región de Los Lagos",
          address: {
            "@type": "PostalAddress",
            addressLocality: "Puerto Varas",
            addressRegion: "Los Lagos",
            addressCountry: "CL",
          },
          geo: {
            "@type": "GeoCoordinates",
            latitude: -41.319,
            longitude: -72.985,
          },
          contactPoint: {
            "@type": "ContactPoint",
            contactType: "customer service",
            telephone: "+56975475781",
            availableLanguage: ["Spanish"],
            areaServed: "CL-LL",
          },
        },
        {
          "@type": "WebSite",
          "@id": `${site}/#website`,
          url: site,
          name: defaultTitle,
          description: "Soluciones digitales para pymes en la Región de Los Lagos",
          potentialAction: {
            "@type": "SearchAction",
            target: {
              "@type": "EntryPoint",
              urlTemplate: `${site}/buscar?q={search_term_string}`,
            },
            "query-input": "required name=search_term_string",
          },
        },
        ...(breadcrumbs && breadcrumbs.length > 0
          ? [
              {
                "@type": "BreadcrumbList",
                "@id": `${canonical || site}/#breadcrumb`,
                itemListElement: breadcrumbs.map((cr, i) => ({
                  "@type": "ListItem",
                  position: i + 1,
                  name: cr.name,
                  item: `${site}${cr.path}`,
                })),
              },
            ]
          : []),
      ],
    })} />
  </head>
  <body class="min-h-screen bg-[#010101] text-text-primary antialiased">
    <slot />
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
            }
          });
        },
        { threshold: 0.08, rootMargin: "0px 0px -40px 0px" }
      );

      document.querySelectorAll(".reveal, .reveal-group").forEach((el) => observer.observe(el));
    </script>
  </body>
</html>

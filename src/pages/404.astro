---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import StaggerText from "../components/StaggerText.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Página no encontrada — Mtsprz Soluciones Digitales"
  description="La página que buscas no existe o fue movida. Encuentra lo que necesitas en Mtsprz, tu agencia digital en Puerto Varas, Región de Los Lagos."
  canonical="https://mtsprz.org/404"
  noindex={true}
>
  <Header />

  <main class="min-h-screen bg-[#010101] flex flex-col items-center justify-center px-6 pt-28 pb-20">
    <div class="max-w-lg mx-auto text-center">
      <!-- Código 404 con estilo -->
      <div class="relative mb-8">
        <div class="absolute inset-0 flex items-center justify-center opacity-[0.03] pointer-events-none">
          <svg class="w-64 h-64" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="0.3" class="text-white">
            <circle cx="50" cy="50" r="40"/>
            <circle cx="50" cy="50" r="30"/>
            <circle cx="50" cy="50" r="20"/>
            <circle cx="50" cy="50" r="10"/>
          </svg>
        </div>
        <p class="text-[120px] sm:text-[160px] font-heading font-bold text-white/10 leading-none select-none tracking-[-6px]">
          404
        </p>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center">
            <div class="w-16 h-16 sm:w-20 sm:h-20 mx-auto rounded-2xl bg-white/[0.03] border border-white/[0.06] flex items-center justify-center mb-4">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4"/>
                <path d="M12 16h.01"/>
              </svg>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal-group">
        <h1 class="reveal-item text-2xl sm:text-3xl font-heading font-bold text-white tracking-[-0.5px]">
          Página no encontrada
        </h1>
        <p class="reveal-item mt-3 text-sm sm:text-base text-white/50 font-body font-light leading-relaxed max-w-sm mx-auto">
          La página que buscas no existe, fue movida o el enlace es incorrecto. 
          No te preocupes, tenemos varias formas de ayudarte.
        </p>
      </div>

      <!-- Navegación rápida -->
      <div class="mt-10 grid gap-3 sm:grid-cols-2 text-left max-w-sm mx-auto">
        <a
          href="/"
          class="group flex items-center gap-3 rounded-xl border border-white/10 p-4 hover:border-[#6366f1]/40 transition-all duration-300"
        >
          <div class="w-9 h-9 rounded-lg bg-[#6366f1]/10 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          </div>
          <div>
            <p class="text-sm text-white font-heading font-semibold">Inicio</p>
            <p class="text-[11px] text-white/40 font-body">Volver al sitio</p>
          </div>
        </a>
        <a
          href="/servicios"
          class="group flex items-center gap-3 rounded-xl border border-white/10 p-4 hover:border-[#10b981]/40 transition-all duration-300"
        >
          <div class="w-9 h-9 rounded-lg bg-[#10b981]/10 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 3.75L2.25 12l5.25 8.25m9-16.5L21.75 12l-5.25 8.25"/></svg>
          </div>
          <div>
            <p class="text-sm text-white font-heading font-semibold">Servicios</p>
            <p class="text-[11px] text-white/40 font-body">Lo que ofrecemos</p>
          </div>
        </a>
        <a
          href="/blog"
          class="group flex items-center gap-3 rounded-xl border border-white/10 p-4 hover:border-[#06b6d4]/40 transition-all duration-300"
        >
          <div class="w-9 h-9 rounded-lg bg-[#06b6d4]/10 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#06b6d4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <div>
            <p class="text-sm text-white font-heading font-semibold">Blog</p>
            <p class="text-[11px] text-white/40 font-body">Artículos útiles</p>
          </div>
        </a>
        <a
          href="/contacto"
          class="group flex items-center gap-3 rounded-xl border border-white/10 p-4 hover:border-[#ec4899]/40 transition-all duration-300"
        >
          <div class="w-9 h-9 rounded-lg bg-[#ec4899]/10 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ec4899" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <p class="text-sm text-white font-heading font-semibold">Contacto</p>
            <p class="text-[11px] text-white/40 font-body">Háblanos</p>
          </div>
        </a>
      </div>

      <!-- CTA directa -->
      <div class="mt-8">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-medium text-black transition-all hover:scale-105"
        >
          Volver al inicio
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </a>
      </div>

      <!-- Error info oculto para debugging -->
      <p class="mt-12 text-[10px] text-white/10 font-mono">Error 404 — Recurso no encontrado</p>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  (function() {
    // Track 404s in console for debugging
    var path = window.location.pathname + window.location.search;
    console.log("[Mtsprz 404] Ruta no encontrada:", path);
  })();
</script>

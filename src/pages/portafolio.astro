---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ExternalLink, ArrowUpRight } from "@lucide/astro";
import projects from "../data/projects.json";
---

<BaseLayout
  title="Portafolio de Desarrollo Web"
  description="Proyectos de desarrollo web y aplicaciones realizados por Mtsprz en la Región de Los Lagos. Sitios web modernos con Astro, React y Next.js para pymes en Chile."
  canonical="https://mtsprz.org/portafolio"
>
  <Header />
  <main class="min-h-screen bg-[#010101]">
    <div class="mx-auto max-w-6xl px-6 pt-28">
      <div class="reveal-group">
        <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Portafolio</p>
        <h1 class="reveal-item text-4xl sm:text-5xl md:text-6xl font-heading font-bold text-white leading-[0.9] tracking-[-2px]">Proyectos Realizados</h1>
        <p class="reveal-item mt-3 text-white/60 font-body font-light max-w-xl">
          Cada proyecto refleja nuestro compromiso con la calidad, el rendimiento y el diseño.
        </p>
      </div>
    </div>

    <div class="mt-12 md:mt-16 space-y-0 reveal-group">
      {projects.map((p, idx) => (
        <article class="reveal-item group/project relative overflow-hidden w-full bg-[#010101]">
          <div class="project-carousel relative w-full overflow-hidden" style="height:clamp(300px,50vh,600px)">
              <div class="carousel-track relative h-full flex transition-transform duration-500 ease-out" style="width:100%">
                  {p.images.map((img, iIdx) => {
                    const avifSrc = img.replace(/\.(png|jpg|jpeg)$/i, '.avif');
                    const webpSrc = img.replace(/\.(png|jpg|jpeg)$/i, '.webp');
                    return (
                    <div class="carousel-slide shrink-0 h-full relative" style="width:100%">
                      <picture>
                        <source srcset={avifSrc} type="image/avif" />
                        <source srcset={webpSrc} type="image/webp" />
                        <img src={img} alt={iIdx === 0 ? `Captura principal del proyecto ${p.title}` : `Vista adicional del proyecto ${p.title} - ${iIdx + 1}`} loading={iIdx === 0 ? "eager" : "lazy"} decoding="async" width="1200" height="675" class="w-full h-full object-cover" />
                      </picture>
                    </div>
                    );
                  })}
              </div>
            </div>

            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-[#010101]/80 pointer-events-none" />

            {p.images.length > 1 && (
              <div class="carousel-dots absolute top-4 left-4 z-30 flex gap-1.5 opacity-0 group-hover/project:opacity-100 transition-opacity">
                {p.images.map((_, i) => (
                  <button class="w-1.5 h-1.5 rounded-full bg-white/40 transition-all hover:bg-white/80" data-index={i} aria-label={`Imagen ${i + 1}`} />
                ))}
              </div>
            )}

            <button class="carousel-prev absolute left-3 top-1/2 -translate-y-1/2 z-30 w-9 h-9 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover/project:opacity-100 transition-all text-white/70 hover:bg-black/70 hover:text-white" aria-label="Anterior">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
            </button>
            <button class="carousel-next absolute right-3 top-1/2 -translate-y-1/2 z-30 w-9 h-9 rounded-full bg-black/50 flex items-center justify-center opacity-0 group-hover/project:opacity-100 transition-all text-white/70 hover:bg-black/70 hover:text-white" aria-label="Siguiente">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </button>

            <div class="absolute inset-0 flex items-end sm:items-center justify-start sm:justify-end p-4 sm:p-6 lg:p-8 z-10 pointer-events-none">
              <div class="pointer-events-auto w-full sm:w-[300px] lg:w-[360px] liquid-glass rounded-[1.25rem] p-5 lg:p-6">
                <span class="text-[10px] uppercase tracking-[0.15em] text-white/40 font-body">
                  Proyecto {String(idx + 1).padStart(2, '0')}
                </span>
                <h2 class="text-xl lg:text-2xl font-heading font-bold text-white mt-1 tracking-[-0.5px]">{p.title}</h2>
                <p class="mt-2 text-sm text-white/60 font-body font-light leading-snug">{p.description}</p>
                <div class="mt-4 flex items-center justify-between gap-3">
                  <div class="flex flex-wrap gap-1.5">
                    {p.tags.map((tag) => (
                      <span class="rounded-full bg-white/5 px-2.5 py-0.5 text-[10px] text-white/50">{tag}</span>
                    ))}
                  </div>
                  <a href={p.url} target="_blank" rel="noopener noreferrer" class="shrink-0 liquid-glass-strong rounded-full px-3.5 py-1.5 text-[11px] font-medium text-white inline-flex items-center gap-1.5 transition-all hover:scale-105">
                    Visitar
                    <ExternalLink size={11} stroke-width="1.5" />
                  </a>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

    <div class="mx-auto max-w-6xl px-6 pb-20">
      <div class="reveal-group mt-16 md:mt-20 text-center">
        <div class="reveal-item liquid-glass rounded-[1.25rem] p-8 md:p-12 max-w-2xl mx-auto">
          <h2 class="text-xl md:text-2xl font-heading font-bold text-white tracking-[-0.5px]">Tienes un proyecto en mente?</h2>
          <p class="mt-3 text-sm text-white/50 font-body font-light max-w-md mx-auto">
            Cada proyecto inicia con una conversacion. Trabajemos juntos para llevar tu idea al siguiente nivel.
          </p>
          <div class="mt-6 flex flex-wrap items-center justify-center gap-4">
            <a href="/contacto" class="liquid-glass-strong rounded-full px-6 py-2.5 text-sm font-medium text-white inline-flex items-center gap-2 transition-all hover:scale-105">
              Contactar
              <ArrowUpRight size={16} stroke-width="2" />
            </a>
            <a href="https://portafolio.mtsprz.org/" target="_blank" rel="noopener noreferrer" class="rounded-full px-6 py-2.5 text-sm font-medium text-white/50 border border-white/10 inline-flex items-center gap-2 transition-all hover:text-white hover:border-white/30">
              Portafolio completo
              <ExternalLink size={14} stroke-width="1.5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />

  <script is:inline>
  (function() {
    document.querySelectorAll('.project-carousel').forEach(function(carousel) {
      var track = carousel.querySelector('.carousel-track');
      var slides = carousel.querySelectorAll('.carousel-slide');
      var dots = carousel.querySelectorAll('.carousel-dots button');
      var prev = carousel.querySelector('.carousel-prev');
      var next = carousel.querySelector('.carousel-next');
      var article = carousel.closest('article');
      var autoTimer;
      var total = slides.length;
      var current = 0;

      if (total < 2) {
        if (dots.length) dots.forEach(function(d) { d.style.display = 'none'; });
        return;
      }

      function goTo(i) {
        current = Math.max(0, Math.min(total - 1, i));
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d, j) {
          d.className = 'rounded-full transition-all ' + (j === current ? 'bg-white/80 w-2.5 h-1.5' : 'bg-white/40 w-1.5 h-1.5 hover:bg-white/70');
        });
      }

      function startAuto() { stopAuto(); autoTimer = setInterval(function() { goTo(current + 1); if (current >= total - 1) goTo(0); }, 4000); }
      function stopAuto() { clearInterval(autoTimer); }

      if (prev) prev.addEventListener('click', function(e) { e.stopPropagation(); goTo(current - 1); stopAuto(); startAuto(); });
      if (next) next.addEventListener('click', function(e) { e.stopPropagation(); goTo(current + 1); stopAuto(); startAuto(); });

      dots.forEach(function(d) {
        d.addEventListener('click', function() { goTo(parseInt(d.getAttribute('data-index'))); stopAuto(); startAuto(); });
      });

      if (article) {
        article.addEventListener('mouseenter', stopAuto);
        article.addEventListener('mouseleave', startAuto);
      }

      goTo(0);
      startAuto();
    });
  })();
  </script>
</BaseLayout>

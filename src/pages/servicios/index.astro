---
export const prerender = false;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import CinematicColumn from "../../components/CinematicColumn.astro";
import BlurText from "../../components/BlurText.astro";
import Footer from "../../components/Footer.astro";
import { query, initDb } from "../../lib/db";
import { toServiceDisplay } from "../../lib/service-display";

await initDb();
const dbRows = await query(
  `SELECT DISTINCT ON (LOWER(TRIM(category))) slug, name, description, category
   FROM services WHERE is_active = true AND category IS NOT NULL
   ORDER BY LOWER(TRIM(category)), is_popular DESC, id`
);
const services = dbRows.rows.map((row: any) => toServiceDisplay(row as any));

---

<BaseLayout
  title="Servicios Digitales Profesionales — Mtsprz"
  description="Transformamos procesos manuales en software automatizado. Desarrollo web, automatizaci\u00f3n de procesos, dashboards de datos, bots WhatsApp, SEO local y m\u00e1s. Soluciones digitales para pymes en la Regi\u00f3n de Los Lagos."
  canonical="https://mtsprz.org/servicios"
  breadcrumbs={[{ name: "Servicios", path: "/servicios" }]}
  video={{
    url: "https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4",
    name: "Mtsprz Servicios Digitales",
    description: "Soluciones digitales profesionales: desarrollo web, automatizaci\u00f3n de procesos, dashboards de datos, SEO local, marketing digital, diseño gr\u00e1fico y consultor\u00eda para pymes en la Regi\u00f3n de Los Lagos.",
    thumbnailUrl: "https://mtsprz.org/logo.jpg",
    uploadDate: "2026-06-19",
  }}
>
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
          "@type": "FAQPage",
          "@id": "https://mtsprz.org/servicios#faq",
          "mainEntity": [
          {
            "@type": "Question",
            "name": "\u00bfCu\u00e1nto cuesta una p\u00e1gina web profesional?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Depende de la complejidad. Landing pages desde $290.000, sitios corporativos de 5-10 p\u00e1ginas desde $690.000, y tiendas online completas desde $1.500.000. Incluyen hosting, SSL y SEO b\u00e1sico. Cont\u00e1ctanos para una cotizaci\u00f3n personalizada sin compromiso."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfQu\u00e9 es el SEO local y por qu\u00e9 es importante para mi negocio?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "El SEO local optimiza tu presencia en Google para b\u00fasquedas geogr\u00e1ficas como 'taller mec\u00e1nico en Puerto Varas' o 'abogado en Osorno'. Atrae clientes que buscan activamente tus servicios en tu misma zona. En la Regi\u00f3n de Los Lagos, la competencia digital es menor que en Santiago, lo que permite resultados visibles en 2 a 4 meses."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfC\u00f3mo puedo automatizar procesos en mi pyme?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Automatizamos Excel (reportes que se generan solos), WhatsApp (bots que atienden 24/7), email marketing (secuencias que nutren clientes), integraci\u00f3n de CRM (datos que fluyen entre sistemas) y workflows completos con n8n. Una corredora de propiedades t\u00edpica ahorra 10+ horas semanales."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfQu\u00e9 es un dashboard de datos y para qu\u00e9 sirve?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Un dashboard muestra tus indicadores clave en tiempo real: ventas, clientes, inventario, lo que sea relevante para tu negocio. Conectamos tus datos (Excel, base de datos, APIs) y creamos visualizaciones interactivas accesibles desde cualquier dispositivo. Decisiones basadas en datos, no en corazonadas."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfHacen scraping o extracci\u00f3n de datos de sitios web?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "S\u00ed. Extraemos datos de cualquier sitio web o sistema sin API: precios de competencia, directorios de empresas, portales inmobiliarios, redes sociales. Te entregamos los datos limpios en Excel o base de datos, actualizados peri\u00f3dicamente."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfOfrecen servicios de dise\u00f1o gr\u00e1fico y branding?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "S\u00ed. Creamos identidad corporativa completa: logo principal con variantes, tipograf\u00eda, paleta de colores, papeler\u00eda b\u00e1sica y manual de marca. Todo en formatos vectoriales listos para imprimir y usar en digital."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfEn qu\u00e9 se diferencia una p\u00e1gina web con Astro de una en WordPress?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Los sitios con Astro cargan en menos de 1.5 segundos vs 3-6 segundos de WordPress, obtienen puntaje superior a 95 en PageSpeed Insights, son inherentemente m\u00e1s seguros al no depender de plugins de terceros, y tienen mejor posicionamiento SEO desde el d\u00eda uno."
            }
          }
        ]
      },
      {
        "@type": "ItemList",
        "itemListElement": [
          {
            "@type": "Service",
            "name": "Desarrollo Web",
            "description": "Landing pages, sitios corporativos, e-commerce y aplicaciones web a medida.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Automatizacion de Procesos",
            "description": "Bots WhatsApp, automatizacion Excel, flujos de email, CRM y workflows.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Datos e Inteligencia",
            "description": "Dashboards interactivos, scraping web, APIs a medida y procesamiento de documentos.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "SEO Local",
            "description": "Posicionamiento en Google Maps y busquedas locales para la Region de Los Lagos.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Marketing Digital",
            "description": "Google Ads, redes sociales y estrategia de contenido con resultados medibles.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Diseno Grafico",
            "description": "Identidad corporativa, logotipos, manual de marca y papelería profesional.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Consultoria Digital",
            "description": "Diagnostico gratuito y hoja de ruta digital para pymes en el sur de Chile.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          }
        ]
      }
    ]
  })} />
  <Header />

  <main>
    <!-- Hero -->
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent sm:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent sm:h-48"></div>
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <div class="text-center px-6" style="pointer-events: auto;">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Servicios</p>
          <h1 class="text-5xl sm:text-7xl md:text-8xl font-heading font-bold text-white leading-[0.9] tracking-[-2px]">SERVICIOS</h1>
          <p class="mt-4 text-white/60 font-body font-light max-w-md mx-auto">Todo lo que tu negocio necesita para crecer en el entorno digital</p>
        </div>
      </div>

      <!-- Breadcrumb — integrado en hero, esquina inferior izquierda -->
      <div class="absolute bottom-8 md:bottom-10 left-0 right-0 z-20 px-6">
        <div class="mx-auto max-w-6xl">
          <Breadcrumbs items={[{ name: "Servicios", path: "/servicios" }]} />
        </div>
      </div>
    </section>

    <!-- Services: editorial cinematic columns -->
    <section class="relative bg-[#0A0A0A] w-full">
      <!-- Section header — compacto, como intro de revista -->
      <div class="mx-auto max-w-6xl px-6 pt-28 md:pt-36 pb-16 md:pb-20">
        <div class="reveal-group text-center">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Nuestros Servicios</p>
          <BlurText
            text="Todo lo que tu negocio necesita"
            as="h2"
            className="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white leading-[1.1] tracking-[-1px]"
            wordMs={60}
          />
          <p class="reveal-item mt-4 text-white/50 font-body font-light max-w-lg mx-auto text-sm">
            Soluciones digitales diseñadas para pymes y empresas del sur de Chile
          </p>
        </div>
      </div>

      <!-- Columnas editoriales — full-bleed, asimétricas, sin contenedores -->
      <div class="w-full overflow-hidden">
        <div class="reveal-group grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12">
          {services.map((s, i) => {
            // Ritmo asimétrico: ancho variable por índice
            // Patrón: wide(6) + narrow(3) + narrow(3) → wide(6) + narrow(3) + narrow(3) → wide(6)
            const span = i % 3 === 0 ? "lg:col-span-6" : "lg:col-span-3";
            return (
              <div class={`${span} md:col-span-1 reveal-item`}>
                <CinematicColumn
                  title={s.title}
                  description={s.description}
                  accent={s.accent}
                  slug={s.slug}
                  index={i}
                />
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- FAQ — editorial accordion -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <!-- Background cinematográfico -->
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 30% 0%, #6366f112 0%, transparent 50%), radial-gradient(ellipse at 70% 100%, #8b5cf606 0%, transparent 50%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <!-- Líneas decorativas -->
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />

      <div class="relative mx-auto max-w-4xl px-6 py-28 md:py-36 lg:py-44">
        <div class="reveal-group text-center">
          <!-- Label editorial -->
          <p class="reveal-item text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-6 md:mb-8" style="color: #6366f1aa;">Preguntas Frecuentes</p>

          <!-- Título -->
          <h2 class="reveal-item text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-[0.95] tracking-[-1.5px] md:tracking-[-2px]">
            Resolvemos <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #6366f1, #8b5cf6);">tus dudas</span>
          </h2>

          <!-- Separador editorial -->
          <div class="reveal-item mx-auto my-10 md:my-12 w-12 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f166, transparent);" />
        </div>

        <!-- FAQ items — estilo columna editorial, clean, borders minimal -->
        <div class="reveal-group mx-auto max-w-2xl">
          <div class="divide-y divide-white/[0.06]">
            {[
              { q: "¿Cuánto cuesta una página web profesional?", a: "Landing pages desde $290.000, sitios corporativos (5-10 páginas) desde $690.000, tiendas online desde $1.500.000. Todos incluyen hosting, SSL, SEO básico y Analytics. Cotización personalizada sin compromiso." },
              { q: "¿Qué procesos puedo automatizar en mi pyme?", a: "Automatizamos Excel (reportes que se generan solos), WhatsApp (bots 24/7 que atienden clientes), email marketing (secuencias que nutren y venden), integración CRM (datos que fluyen solos) y workflows completos. Una corredora típica ahorra 10+ horas semanales." },
              { q: "¿Qué es un dashboard de datos y para qué sirve?", a: "Un dashboard muestra tus indicadores clave en tiempo real: ventas, clientes, inventario. Conectamos tus datos (Excel, base de datos, APIs) y creamos visualizaciones interactivas accesibles desde cualquier dispositivo. Decisiones basadas en datos." },
              { q: "¿En qué se diferencia Astro de WordPress?", a: "Los sitios con Astro cargan en menos de 1.5 segundos vs 3-6 segundos de WordPress, obtienen puntaje superior a 95 en PageSpeed Insights, son más seguros al no depender de plugins, y tienen mejor SEO desde el día uno." },
            ].map((faq) => (
              <details class="reveal-item group open:pb-6 transition-all duration-300">
                <summary class="flex cursor-pointer items-center justify-between gap-4 py-5 md:py-6 text-sm md:text-base font-heading font-semibold text-white/85 hover:text-white transition-colors list-none [&::-webkit-details-marker]:hidden">
                  <span class="leading-snug">{faq.q}</span>
                  <span class="shrink-0 flex items-center justify-center w-6 h-6 rounded-full border border-white/10 text-white/30 group-open:text-[#6366f1] group-open:border-[#6366f1]/40 transition-all duration-300">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" class="transition-transform duration-300 group-open:rotate-45"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                  </span>
                </summary>
                <div class="pb-2">
                  <p class="text-sm md:text-[15px] text-white/45 font-body font-light leading-[1.8] max-w-xl">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>

        <!-- Bottom CTA — más preguntas -->
        <div class="reveal-item mt-16 md:mt-20 text-center">
          <p class="text-sm text-white/40 font-body">¿Tienes más preguntas?</p>
          <a
            href="/contacto"
            class="group inline-flex items-center gap-2.5 mt-3 text-sm font-medium tracking-[0.15em] uppercase transition-all duration-300 hover:gap-4"
            style="color: #6366f1;"
          >
            <span>Hablemos</span>
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA — editorial call to action -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-50" style="background: radial-gradient(ellipse at 50% 0%, #6366f128 0%, transparent 50%), radial-gradient(ellipse at 30% 100%, #8b5cf610 0%, transparent 50%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />

      <div class="relative mx-auto max-w-4xl px-6 py-28 md:py-36 lg:py-44 text-center">
        <div class="reveal-group">
          <p class="reveal-item text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-6 md:mb-8" style="color: #6366f1aa;">Contacto</p>

          <h2 class="reveal-item text-3xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-heading font-bold text-white leading-[0.95] tracking-[-1.5px] md:tracking-[-2px] lg:tracking-[-3px]">
            Listo para impulsar<br />
            <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #6366f1, #8b5cf6);">tu negocio?</span>
          </h2>

          <div class="reveal-item mx-auto my-8 md:my-10 w-12 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f166, transparent);" />

          <p class="reveal-item mx-auto max-w-xl text-sm md:text-base lg:text-lg text-white/50 font-body font-light leading-relaxed">
            Conversemos sin compromiso. Te ayudamos a definir la mejor estrategia digital para tu empresa en el sur de Chile.
          </p>

          <div class="reveal-item mt-10 md:mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
            <a
              href="/contacto"
              class="group inline-flex items-center gap-3 px-7 md:px-8 py-3.5 md:py-4 text-xs md:text-sm font-medium tracking-[0.15em] uppercase transition-all duration-300"
              style="color: #fff; background: linear-gradient(135deg, #6366f1, #8b5cf6);"
            >
              <span>Contáctanos</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
            <span class="text-[11px] md:text-xs text-white/30 font-body tracking-wide">o llama al <span class="text-white/50">+56975475781</span></span>
          </div>

          <div class="reveal-item mt-12 md:mt-14 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
            {[
              { label: "Sin compromiso", accent: "#6366f1" },
              { label: "Respuesta en 24 hrs", accent: "#10b981" },
              { label: "Atención personalizada", accent: "#6366f1" },
            ].map((t) => (
              <span class="inline-flex items-center gap-2 text-[10px] md:text-xs font-medium tracking-[0.1em] uppercase" style="color: rgba(255,255,255,0.35);">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke={t.accent} stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                {t.label}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import ServiceCard from "../../components/ServiceCard.astro";
import BlurText from "../../components/BlurText.astro";
import Footer from "../../components/Footer.astro";

interface Service {
  icon: string;
  title: string;
  description: string;
  descriptionLong: string;
  tags: string[];
  accent: string;
  slug?: string;
}

const services: Service[] = [
  {
    icon: "Code",
    title: "Desarrollo Web",
    description: "Landing pages, sitios corporativos, e-commerce y aplicaciones web a medida. Modernos, veloces y hechos para convertir.",
    descriptionLong: "Creamos experiencias digitales que impulsan tu negocio. Cada proyecto est\u00e1 optimizado para velocidad 90+ Lighthouse, SEO desde el d\u00eda uno y m\u00e1xima seguridad. Stack moderno (Astro, Next.js, FastAPI).",
    tags: ["Landing Pages", "Sitios Corporativos", "E-commerce", "Apps Web"],
    accent: "#6366f1",
    slug: "desarrollo-web",
  },
  {
    icon: "Bot",
    title: "Automatizaci\u00f3n de Procesos",
    description: "Bots WhatsApp, automatizaci\u00f3n Excel, flujos de email, integraci\u00f3n CRM y workflows. Tu negocio funcionando solo.",
    descriptionLong: "Recupera horas de trabajo cada semana. Automatizamos procesos manuales, conectamos tus herramientas y eliminamos tareas repetitivas. Desde Excel hasta APIs complejas.",
    tags: ["WhatsApp Bots", "Excel Automation", "CRM", "Workflows n8n"],
    accent: "#06b6d4",
    slug: "automatizaciones",
  },
  {
    icon: "BarChart3",
    title: "Datos e Inteligencia",
    description: "Dashboards interactivos, scraping web, APIs a medida, OCR y procesamiento de documentos. Tus datos al servicio de tus decisiones.",
    descriptionLong: "Transformamos datos crudos en decisiones inteligentes. Dashboards en tiempo real, extracci\u00f3n automatizada de datos web, APIs que conectan tus sistemas y digitalizaci\u00f3n de documentos con OCR.",
    tags: ["Dashboards", "Scraping", "APIs", "OCR"],
    accent: "#f97316",
    slug: "datos",
  },
  {
    icon: "Search",
    title: "SEO",
    description: "Posicionamiento en Google. SEO local, t\u00e9cnico y de contenido para la Regi\u00f3n de Los Lagos.",
    descriptionLong: "Lleva tu negocio a los primeros resultados de b\u00fasqueda. Estrategia SEO completa con enfoque local: Google Maps, b\u00fasquedas por ciudad y contenido optimizado para tu zona.",
    tags: ["SEO Local", "Google Maps", "Auditor\u00eda", "Contenido"],
    accent: "#10b981",
    slug: "seo",
  },
  {
    icon: "TrendingUp",
    title: "Marketing Digital",
    description: "Google Ads, redes sociales y estrategia de contenido. Resultados medibles desde la primera semana.",
    descriptionLong: "Clientes busc\u00e1ndote hoy. Campa\u00f1as segmentadas geogr\u00e1ficamente, gesti\u00f3n profesional de redes sociales y contenido que conecta con tu audiencia local.",
    tags: ["Google Ads", "Redes Sociales", "Contenido", "Anal\u00edtica"],
    accent: "#f59e0b",
  },
  {
    icon: "Palette",
    title: "Dise\u00f1o Gr\u00e1fico",
    description: "Identidad corporativa, logotipos y manual de marca. Tu marca profesional lista para el mercado.",
    descriptionLong: "Construye una marca que conecte con tu audiencia. Dise\u00f1amos tu identidad visual desde cero: logo, paleta, tipograf\u00eda y papeler\u00eda. Todo en formatos vectoriales listos para usar.",
    tags: ["Logos", "Identidad Visual", "Manual de Marca", "UX/UI"],
    accent: "#ec4899",
  },
  {
    icon: "Globe",
    title: "Consultor\u00eda Digital",
    description: "Diagn\u00f3stico gratuito de tu negocio. Hoja de ruta clara con prioridades, presupuestos y plazos.",
    descriptionLong: "Evaluamos tu situaci\u00f3n actual sin compromiso. Identificamos oportunidades digitales reales y te entregamos un plan accionable con prioridades a 30, 60 y 90 d\u00edas.",
    tags: ["Diagn\u00f3stico", "Plan Digital", "Pymes", "Estrategia"],
    accent: "#8b5cf6",
  },
];

---

<BaseLayout
  title="Servicios Digitales Profesionales — Mtsprz"
  description="Transformamos procesos manuales en software automatizado. Desarrollo web, automatizaci\u00f3n de procesos, dashboards de datos, bots WhatsApp, SEO local y m\u00e1s. Soluciones digitales para pymes en la Regi\u00f3n de Los Lagos."
  canonical="https://mtsprz.org/servicios"
  breadcrumbs={[{ name: "Servicios", path: "/servicios" }]}
  video={{
    url: "https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4",
    name: "Mtsprz Servicios Digitales",
    description: "Soluciones digitales profesionales: desarrollo web, automatizaci\u00f3n de procesos, dashboards de datos, SEO local, marketing digital, diseño gr\u00e1fico y consultor\u00eda para pymes en la Regi\u00f3n de Los Lagos.",
    thumbnailUrl: "https://mtsprz.org/logo.jpg",
    uploadDate: "2026-06-19",
  }}
>
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
          "@type": "FAQPage",
          "@id": "https://mtsprz.org/servicios#faq",
          "mainEntity": [
          {
            "@type": "Question",
            "name": "\u00bfCu\u00e1nto cuesta una p\u00e1gina web profesional?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Depende de la complejidad. Landing pages desde $290.000, sitios corporativos de 5-10 p\u00e1ginas desde $690.000, y tiendas online completas desde $1.500.000. Incluyen hosting, SSL y SEO b\u00e1sico. Cont\u00e1ctanos para una cotizaci\u00f3n personalizada sin compromiso."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfQu\u00e9 es el SEO local y por qu\u00e9 es importante para mi negocio?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "El SEO local optimiza tu presencia en Google para b\u00fasquedas geogr\u00e1ficas como 'taller mec\u00e1nico en Puerto Varas' o 'abogado en Osorno'. Atrae clientes que buscan activamente tus servicios en tu misma zona. En la Regi\u00f3n de Los Lagos, la competencia digital es menor que en Santiago, lo que permite resultados visibles en 2 a 4 meses."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfC\u00f3mo puedo automatizar procesos en mi pyme?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Automatizamos Excel (reportes que se generan solos), WhatsApp (bots que atienden 24/7), email marketing (secuencias que nutren clientes), integraci\u00f3n de CRM (datos que fluyen entre sistemas) y workflows completos con n8n. Una corredora de propiedades t\u00edpica ahorra 10+ horas semanales."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfQu\u00e9 es un dashboard de datos y para qu\u00e9 sirve?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Un dashboard muestra tus indicadores clave en tiempo real: ventas, clientes, inventario, lo que sea relevante para tu negocio. Conectamos tus datos (Excel, base de datos, APIs) y creamos visualizaciones interactivas accesibles desde cualquier dispositivo. Decisiones basadas en datos, no en corazonadas."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfHacen scraping o extracci\u00f3n de datos de sitios web?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "S\u00ed. Extraemos datos de cualquier sitio web o sistema sin API: precios de competencia, directorios de empresas, portales inmobiliarios, redes sociales. Te entregamos los datos limpios en Excel o base de datos, actualizados peri\u00f3dicamente."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfOfrecen servicios de dise\u00f1o gr\u00e1fico y branding?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "S\u00ed. Creamos identidad corporativa completa: logo principal con variantes, tipograf\u00eda, paleta de colores, papeler\u00eda b\u00e1sica y manual de marca. Todo en formatos vectoriales listos para imprimir y usar en digital."
            }
          },
          {
            "@type": "Question",
            "name": "\u00bfEn qu\u00e9 se diferencia una p\u00e1gina web con Astro de una en WordPress?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Los sitios con Astro cargan en menos de 1.5 segundos vs 3-6 segundos de WordPress, obtienen puntaje superior a 95 en PageSpeed Insights, son inherentemente m\u00e1s seguros al no depender de plugins de terceros, y tienen mejor posicionamiento SEO desde el d\u00eda uno."
            }
          }
        ]
      },
      {
        "@type": "ItemList",
        "itemListElement": [
          {
            "@type": "Service",
            "name": "Desarrollo Web",
            "description": "Landing pages, sitios corporativos, e-commerce y aplicaciones web a medida.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Automatizacion de Procesos",
            "description": "Bots WhatsApp, automatizacion Excel, flujos de email, CRM y workflows.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Datos e Inteligencia",
            "description": "Dashboards interactivos, scraping web, APIs a medida y procesamiento de documentos.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "SEO Local",
            "description": "Posicionamiento en Google Maps y busquedas locales para la Region de Los Lagos.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Marketing Digital",
            "description": "Google Ads, redes sociales y estrategia de contenido con resultados medibles.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Diseno Grafico",
            "description": "Identidad corporativa, logotipos, manual de marca y papelería profesional.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          },
          {
            "@type": "Service",
            "name": "Consultoria Digital",
            "description": "Diagnostico gratuito y hoja de ruta digital para pymes en el sur de Chile.",
            "provider": { "@id": "https://mtsprz.org/#organization" },
            "areaServed": "CL-LL",
            "audience": { "@type": "Audience", "audienceType": "pymes" }
          }
        ]
      }
    ]
  })} />
  <Header />

  <main>
    <!-- Hero -->
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent sm:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent sm:h-48"></div>
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <div class="text-center px-6" style="pointer-events: auto;">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Servicios</p>
          <h1 class="text-5xl sm:text-7xl md:text-8xl font-heading font-bold text-white leading-[0.9] tracking-[-2px]">SERVICIOS</h1>
          <p class="mt-4 text-white/60 font-body font-light max-w-md mx-auto">Todo lo que tu negocio necesita para crecer en el entorno digital</p>
        </div>
      </div>
    </section>

    <div class="mx-auto max-w-6xl px-6 pt-16">
      <Breadcrumbs items={[{ name: "Servicios", path: "/servicios" }]} />
    </div>

    <!-- Services -->
    <section class="relative bg-[#010101] py-28 md:py-36">
      <div class="mx-auto max-w-6xl px-6">
        <div class="reveal-group mb-12 md:mb-16 text-center">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Nuestros Servicios</p>
          <BlurText
            text="Todo lo que tu negocio necesita"
            as="h2"
            className="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white leading-[1.1] tracking-[-1px]"
            wordMs={60}
          />
          <p class="mt-4 text-white/50 font-body font-light max-w-lg mx-auto text-sm">
            Soluciones digitales diseñadas para pymes y empresas del sur de Chile
          </p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((s, i) => (
            <ServiceCard
              icon={s.icon}
              title={s.title}
              description={s.description}
              tags={s.tags}
              number={i + 1}
              accent={s.accent}
              id={s.slug}
            />
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="bg-[#010101] py-28 md:py-36 border-t border-white/[0.03]">
      <div class="mx-auto max-w-3xl px-6">
        <div class="reveal-group mb-12 md:mb-16 text-center">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Preguntas Frecuentes</p>
          <h2 class="reveal-item text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white leading-[1.1] tracking-[-1px]">Resolvemos tus dudas</h2>
        </div>
        <div class="reveal-group space-y-4">
          {[
            { q: "¿Cuánto cuesta una página web profesional?", a: "Landing pages desde $290.000, sitios corporativos (5-10 páginas) desde $690.000, tiendas online desde $1.500.000. Todos incluyen hosting, SSL, SEO básico y Analytics. Cotización personalizada sin compromiso." },
            { q: "¿Qué procesos puedo automatizar en mi pyme?", a: "Automatizamos Excel (reportes que se generan solos), WhatsApp (bots 24/7 que atienden clientes), email marketing (secuencias que nutren y venden), integración CRM (datos que fluyen solos) y workflows completos. Una corredora típica ahorra 10+ horas semanales." },
            { q: "¿Qué es un dashboard de datos y para qué sirve?", a: "Un dashboard muestra tus indicadores clave en tiempo real: ventas, clientes, inventario. Conectamos tus datos (Excel, base de datos, APIs) y creamos visualizaciones interactivas accesibles desde cualquier dispositivo. Decisiones basadas en datos." },
            { q: "¿En qué se diferencia Astro de WordPress?", a: "Los sitios con Astro cargan en menos de 1.5 segundos vs 3-6 segundos de WordPress, obtienen puntaje superior a 95 en PageSpeed Insights, son más seguros al no depender de plugins, y tienen mejor SEO desde el día uno." },
          ].map((faq) => (
            <details class="reveal-item group liquid-glass rounded-[1.25rem] overflow-hidden transition-all duration-300 open:border-[#6366f1]/30">
              <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 sm:px-6 py-4 sm:py-5 text-sm sm:text-base font-heading font-semibold text-white/90 hover:text-white transition-colors list-none [&::-webkit-details-marker]:hidden">
                <span>{faq.q}</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-white/30 group-open:rotate-180 transition-transform duration-300"><path d="M6 9l6 6 6-6"/></svg>
              </summary>
              <div class="px-5 sm:px-6 pb-4 sm:pb-5">
                <p class="text-sm text-white/50 font-body font-light leading-relaxed">{faq.a}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-[#010101] py-28 md:py-36">
      <div class="mx-auto max-w-6xl px-6">
        <div class="cta-card reveal-group relative rounded-[1.375rem] p-10 md:p-14 text-center max-w-3xl mx-auto overflow-hidden bg-[#0a0a0b] border border-white/[0.06]">
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 50% 0%, #6366f133, transparent 60%);" />
            <div class="absolute -top-1/2 -left-1/2 w-full h-full animate-gradient-slow opacity-20" style="background: conic-gradient(from 0deg at 50% 50%, #6366f1, #8b5cf6, #ec4899, #6366f1); filter: blur(80px);" />
          </div>
          <div class="absolute top-6 left-8 flex gap-2 opacity-20 pointer-events-none">
            <div class="w-1.5 h-1.5 rounded-full bg-white/40" />
            <div class="w-1.5 h-1.5 rounded-full bg-white/20" />
            <div class="w-1.5 h-1.5 rounded-full bg-white/10" />
          </div>
          <div class="relative">
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading font-bold text-white tracking-[-1px] leading-[1.1]">¿Listo para impulsar tu negocio?</h2>
            <p class="mx-auto mt-4 max-w-lg text-sm text-white/50 font-body font-light leading-relaxed">
              Conversemos sin compromiso. Te ayudamos a definir la mejor estrategia digital para tu empresa en el sur de Chile.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
              <a
                href="/contacto"
                class="group relative inline-flex items-center gap-2.5 rounded-full px-7 py-3.5 text-sm font-medium text-white transition-all duration-300"
                style="background: linear-gradient(135deg, #6366f1, #8b5cf6);"
              >
                <span class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" style="background: #6366f166;" />
                <span class="relative">Contáctanos</span>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="relative transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
              </a>
              <span class="text-[11px] text-white/30 font-body tracking-wide">o llama al <span class="text-white/50">+56975475781</span></span>
            </div>
            <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[11px] text-white/30 font-body">
              <span class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-[#6366f1]/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                Sin compromiso
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-[#6366f1]/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                Respuesta en 24 hrs
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-[#6366f1]/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                Atención personalizada
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

      display: flex;
      flex-direction: column;
      width: 100%;
    }
    .sol-col {
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      min-height: 85vw;
    }

    @media (min-width: 768px) {
      .sol-row { flex-direction: row; }
      .sol-col { min-height: 72vh; }
      .sol-dominant      { width: 55%; }
      .sol-secondary     { width: 45%; border-left: 1px solid rgba(255,255,255,0.04); }
      .sol-secondary-alt { width: 45%; }
      .sol-dominant-alt  { width: 55%; border-left: 1px solid rgba(255,255,255,0.04); }
      .sol-row + .sol-row { border-top: 1px solid rgba(255,255,255,0.04); }
    }

    .sol-col:hover .sol-hover { opacity: 1 !important; }

    @media (max-width: 640px) {
      .sol-col { min-height: 100vw; }
    }

    /* Planes */
    .plan-row:hover { background: rgba(255,255,255,0.01); }

    /* FAQ */
    .faq-item summary:hover { color: #fff !important; }
    .faq-item[open] summary { color: #fff !important; }
    .faq-item[open] .faq-icon { border-color: rgba(255,255,255,0.3) !important; transform: rotate(45deg); }

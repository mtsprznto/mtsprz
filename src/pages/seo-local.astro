---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";

const waPhone = "56966929818";
const waMsg = encodeURIComponent("Hola! Vi la página de SEO Local y quiero posicionar mi negocio en Google Maps.");
const waUrl = `https://wa.me/${waPhone}?text=${waMsg}`;
const site = "https://mtsprz.org";
---

<BaseLayout
  title="SEO Local — Posiciona tu Negocio en Google Maps | Mtsprz"
  description="Posicionamiento SEO local para pymes en Puerto Varas, Osorno, Valdivia y toda la Región de Los Lagos. Aparece primero en Google Maps, atrae más clientes locales. Desde $190.000."
  canonical="https://mtsprz.org/seo-local"
  breadcrumbs={[{ name: "SEO Local", path: "/seo-local" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "@id": `${site}/seo-local#service`,
        "name": "SEO Local — Mtsprz",
        "description": "Posicionamiento SEO local en Google Maps y búsquedas locales para pymes en la Región de Los Lagos y Los Ríos.",
        "provider": { "@id": `${site}/#organization` },
        "areaServed": [
          { "@type": "City", "name": "Puerto Varas" },
          { "@type": "City", "name": "Osorno" },
          { "@type": "City", "name": "Valdivia" },
          { "@type": "City", "name": "Puerto Montt" }
        ],
        "serviceType": "SEO Local",
        "offers": { "@type": "AggregateOffer", "priceCurrency": "CLP", "lowPrice": 190000, "highPrice": 490000, "offerCount": 3 }
      },
      {
        "@type": "FAQPage",
        "@id": `${site}/seo-local#faq`,
        "mainEntity": [
          { "@type": "Question", "name": "¿Cuánto cuesta el SEO local en Puerto Varas y Osorno?", "acceptedAnswer": { "@type": "Answer", "text": "Desde $190.000 para optimización Google Business Profile + SEO básico. Plan completo con gestión mensual desde $290.000/mes." } },
          { "@type": "Question", "name": "¿En cuánto tiempo aparezco en Google Maps?", "acceptedAnswer": { "@type": "Answer", "text": "Mejoras en Google Maps se ven en 2-4 semanas. Posicionamiento orgánico toma 2-3 meses. Reportes mensuales con evidencia." } },
          { "@type": "Question", "name": "¿Funciona el SEO local para cualquier tipo de negocio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Restaurantes, hospedajes, corredoras, clínicas, talleres, ferreterías — cualquier negocio con clientes locales." } }
        ]
      }
    ]
  })} />

  <Header />
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />

  <main style="overflow-x:hidden;">

    <!-- ═══════════════════════════════════════════
         HERO — Video full-bleed, texto al pie izquierdo
    ═══════════════════════════════════════════ -->
    <section style="position:relative; width:100vw; height:100dvh; min-height:100vh; overflow:hidden; background:#010101;">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline preload="auto"
        style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; z-index:1;"
      />
      <div style="position:absolute; inset:0; z-index:2; background:linear-gradient(to top, #010101 0%, #010101 18%, rgba(1,1,1,0.55) 50%, rgba(1,1,1,0.3) 100%);"></div>
      <div style="position:absolute; inset:0; z-index:2; background:linear-gradient(to right, rgba(1,1,1,0.5) 0%, transparent 60%);"></div>
      <div style="position:absolute; inset:0; z-index:3; opacity:0.025; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>

      <div style="position:absolute; bottom:0; left:0; right:0; z-index:10; padding:0 2.5rem 3.5rem;">
        <p style="font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.25); font-family:var(--font-body); margin-bottom:1rem;">SEO Local</p>
        <h1 style="font-size:clamp(4rem, 13vw, 15rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.85; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
          APARECE<br /><span style="color:rgba(255,255,255,0.18);">EN GOOGLE</span>
        </h1>
        <p style="margin-top:1.25rem; font-size:0.75rem; color:rgba(255,255,255,0.35); font-family:var(--font-body); font-weight:300; max-width:380px; line-height:1.65;">
          Posicionamiento local para pymes del sur de Chile. Más clientes desde Google Maps, sin pagar publicidad.
        </p>
        <div style="margin-top:1.75rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
          <a href={waUrl} target="_blank" rel="noopener noreferrer"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.5rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s;"
            onmouseover="this.style.background='#25D366'" onmouseout="this.style.background='#1A1A1A'">
            CONSULTAR AHORA
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/cotizar"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.5rem; background:transparent; color:rgba(255,255,255,0.45); font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:1px solid rgba(255,255,255,0.12); text-decoration:none; transition:all 0.2s;"
            onmouseover="this.style.color='#fff'; this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'; this.style.borderColor='rgba(255,255,255,0.12)'">
            COTIZAR GRATIS
          </a>
        </div>
      </div>

      <div style="position:absolute; bottom:2rem; right:2.5rem; z-index:20;">
        <Breadcrumbs items={[{ name: "SEO Local", path: "/seo-local" }]} />
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         EL PROBLEMA — full-width, 2 cols 35/65
    ═══════════════════════════════════════════ -->
    <section style="width:100vw; background:#0A0A0A; position:relative; overflow:hidden;">
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
      <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 15% 60%, rgba(16,185,129,0.05) 0%, transparent 55%);"></div>

      <div class="problem-row">

        <!-- Col izquierda — etiqueta y título grande -->
        <div class="problem-col-left" style="position:relative; display:flex; flex-direction:column; justify-content:center; padding:5rem 2.5rem; background:#010101;">
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 80% 50%, rgba(16,185,129,0.06) 0%, transparent 60%);"></div>
          <div style="position:relative; z-index:2;">
            <p class="reveal-item" style="font-size:0.58rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.5rem;">El problema</p>
            <h2 class="reveal-item" style="font-size:clamp(2.5rem,6vw,6rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
              TUS<br />CLIENTES<br />TE BUSCAN<br /><span style="color:rgba(255,255,255,0.18);">EN GOOGLE</span>
            </h2>
          </div>
        </div>

        <!-- Col derecha — stats + texto -->
        <div class="problem-col-right" style="position:relative; display:flex; flex-direction:column; justify-content:center; padding:5rem 2.5rem; background:#0A0A0A; border-left:1px solid rgba(255,255,255,0.04);">
          <div class="reveal-group" style="max-width:540px;">
            <p class="reveal-item" style="font-size:0.9rem; color:rgba(255,255,255,0.45); font-family:var(--font-body); font-weight:300; line-height:1.8; margin-bottom:2rem;">
              El 97% de los consumidores buscan negocios locales en Google antes de comprar. Si no apareces en los primeros resultados cuando buscan en Puerto Varas, Osorno o Valdivia, esos clientes van a tu competencia.
            </p>
            <p class="reveal-item" style="font-size:0.78rem; color:rgba(255,255,255,0.25); font-family:var(--font-body); font-weight:300; line-height:1.8; margin-bottom:3rem;">
              El SEO local no es publicidad pagada — es optimización permanente. Una vez posicionado, los clientes llegan solos, todos los días, sin costo por clic.
            </p>
            <!-- Stats: sin cards, solo números editoriales -->
            <div class="reveal-group" style="display:grid; grid-template-columns:repeat(3,1fr); border-top:1px solid rgba(255,255,255,0.06);">
              {[
                { n: "97%", label: "busca local antes de comprar" },
                { n: "76%", label: "visita el negocio tras la búsqueda" },
                { n: "28%", label: "compra el mismo día" },
              ].map((s, i) => (
                <div class="reveal-item" style={`padding:1.5rem 0; padding-right:1.5rem; border-right:${i < 2 ? "1px solid rgba(255,255,255,0.06)" : "none"}; padding-left:${i > 0 ? "1.5rem" : "0"};`}>
                  <p style="font-size:clamp(1.5rem,3.5vw,2.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; line-height:1; margin:0;">{s.n}</p>
                  <p style="font-size:0.62rem; color:rgba(255,255,255,0.25); text-transform:uppercase; letter-spacing:0.1em; font-family:var(--font-body); margin-top:0.4rem; line-height:1.4;">{s.label}</p>
                </div>
              ))}
            </div>
          </div>
        </div>

      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         QUÉ OPTIMIZAMOS — 4 columnas cinematográficas
         Fila 1: 60/40 | Fila 2: 40/60
    ═══════════════════════════════════════════ -->
    <div class="opt-wrapper">

      <!-- Fila 1 -->
      <div class="opt-row">

        <!-- GOOGLE BUSINESS PROFILE — 60% -->
        <div class="opt-col opt-dominant">
          <div style="position:absolute; inset:0; background:linear-gradient(145deg, #041208 0%, #071a10 45%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 25% 30%, rgba(16,185,129,0.14) 0%, transparent 55%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 80% 80%, rgba(16,185,129,0.05) 0%, transparent 50%);"></div>
          <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="opt-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.018); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">01 — Google Business Profile</p>
            <h2 style="font-size:clamp(2.25rem, 5vw, 5rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              FICHA<br />GOOGLE MAPS
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:340px; line-height:1.65;">
              Categorías correctas, fotos de calidad, horarios, servicios, zona de atención y respuestas a reseñas. La base del SEO local.
            </p>
            <div style="margin-top:1.25rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em;">RESULTADOS 2-4 SEMANAS</span>
            </div>
          </div>
        </div>

        <!-- SEO ON-PAGE — 40% -->
        <div class="opt-col opt-secondary">
          <div style="position:absolute; inset:0; background:linear-gradient(155deg, #060810 0%, #0a0e1a 45%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 70% 25%, rgba(6,182,212,0.14) 0%, transparent 55%);"></div>
          <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="opt-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.018); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">02 — SEO On-Page</p>
            <h2 style="font-size:clamp(2rem, 4vw, 3.75rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              SITIO WEB<br />OPTIMIZADO
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:300px; line-height:1.65;">
              Metadatos, keywords locales, schema markup LocalBusiness. Tu sitio web listo para Google.
            </p>
            <div style="margin-top:1.25rem;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em;">RESULTADOS 1-3 MESES</span>
            </div>
          </div>
        </div>

      </div><!-- /fila 1 -->

      <!-- Fila 2 -->
      <div class="opt-row">

        <!-- DIRECTORIOS — 40% -->
        <div class="opt-col opt-secondary-alt">
          <div style="position:absolute; inset:0; background:linear-gradient(160deg, #07060f 0%, #0c0a18 45%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 30% 35%, rgba(99,102,241,0.14) 0%, transparent 55%);"></div>
          <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="opt-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.018); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">03 — Citas & Directorios</p>
            <h2 style="font-size:clamp(2rem, 4vw, 3.75rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              PRESENCIA<br />DIGITAL
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:300px; line-height:1.65;">
              15+ directorios locales de Chile: Páginas Amarillas, Yelp, TripAdvisor. Consistencia NAP total.
            </p>
            <div style="margin-top:1.25rem;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em;">MÁS AUTORIDAD</span>
            </div>
          </div>
        </div>

        <!-- RESEÑAS — 60% -->
        <div class="opt-col opt-dominant-alt">
          <div style="position:absolute; inset:0; background:linear-gradient(140deg, #0d0a04 0%, #140e02 45%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 75% 30%, rgba(245,158,11,0.12) 0%, transparent 55%);"></div>
          <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="opt-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.018); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">04 — Reseñas & Reputación</p>
            <h2 style="font-size:clamp(2.25rem, 5vw, 5rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              5 ESTRELLAS<br />EN GOOGLE
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:340px; line-height:1.65;">
              Las reseñas son el factor #1 de conversión local. Estrategia para conseguir más reseñas de 5 estrellas sin spam.
            </p>
            <div style="margin-top:1.25rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <a href={waUrl} target="_blank" rel="noopener noreferrer"
                style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s;"
                onmouseover="this.style.background='#333'" onmouseout="this.style.background='#1A1A1A'">
                CONSULTAR →
              </a>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.2); font-family:var(--font-body);">+40% conversiones</span>
            </div>
          </div>
        </div>

      </div><!-- /fila 2 -->

    </div><!-- /qué optimizamos -->


    <!-- ═══════════════════════════════════════════
         PLANES — editorial list, sin cards
    ═══════════════════════════════════════════ -->
    <section style="width:100vw; background:#0A0A0A; position:relative; overflow:hidden;">
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
      <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 50% 0%, rgba(16,185,129,0.04) 0%, transparent 55%);"></div>

      <div style="padding:6rem 2.5rem;">
        <div class="reveal-group" style="margin-bottom:4rem;">
          <p class="reveal-item" style="font-size:0.6rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Precios</p>
          <h2 class="reveal-item" style="font-size:clamp(2.5rem,8vw,8rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.04em; text-transform:uppercase; line-height:0.88; margin:0;">
            PLANES DE<br /><span style="color:rgba(255,255,255,0.18);">SEO LOCAL</span>
          </h2>
        </div>


      .dw-secondary { width: 45%; border-left: 1px solid rgba(255,255,255,0.04); }
      .dw-full { min-height: 45vh; border-top: 1px solid rgba(255,255,255,0.04); }
    }

    @media (max-width: 640px) {
      .dw-col  { min-height: 100vw; }
      .dw-full { min-height: 90vw; }
    }

    .dw-col:hover .dw-hover,

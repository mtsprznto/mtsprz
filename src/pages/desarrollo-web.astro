---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";

const waPhone = "56966929818";
const waMsg = encodeURIComponent("Hola! Vi la página de desarrollo web y quiero cotizar mi sitio.");
const waUrl = `https://wa.me/${waPhone}?text=${waMsg}`;
const site = "https://mtsprz.org";
---

<BaseLayout
  title="Desarrollo Web Profesional — Páginas Web en Puerto Varas y Los Lagos"
  description="Creamos páginas web profesionales ultrarrápidas con Astro para pymes en Puerto Varas, Osorno, Valdivia y toda la Región de Los Lagos. SEO local incluido, diseño responsive, carga en 1.5s."
  canonical="https://mtsprz.org/desarrollo-web"
  breadcrumbs={[{ name: "Desarrollo Web", path: "/desarrollo-web" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "Service",
        "@id": `${site}/desarrollo-web#service`,
        "name": "Desarrollo Web Profesional — Mtsprz",
        "description": "Páginas web ultrarrápidas con Astro para pymes en la Región de Los Lagos. Diseño responsive, SEO local incluido y optimización Core Web Vitals.",
        "provider": { "@id": `${site}/#organization` },
        "areaServed": [
          { "@type": "City", "name": "Puerto Varas" },
          { "@type": "City", "name": "Osorno" },
          { "@type": "City", "name": "Valdivia" },
          { "@type": "City", "name": "Puerto Montt" }
        ],
        "serviceType": "Desarrollo Web",
        "offers": { "@type": "AggregateOffer", "priceCurrency": "CLP", "lowPrice": 290000, "highPrice": 1500000, "offerCount": 3 }
      },
      {
        "@type": "FAQPage",
        "@id": `${site}/desarrollo-web#faq`,
        "mainEntity": [
          { "@type": "Question", "name": "¿Cuánto cuesta una página web profesional en Puerto Varas?", "acceptedAnswer": { "@type": "Answer", "text": "Landing pages desde $290.000, sitios corporativos desde $690.000, tiendas online desde $1.500.000. Todos incluyen hosting, SSL, SEO básico y Analytics." } },
          { "@type": "Question", "name": "¿En qué se diferencia Astro de WordPress?", "acceptedAnswer": { "@type": "Answer", "text": "Astro carga en menos de 1.5s vs 3-6s de WordPress, puntaje 95+ en PageSpeed, más seguro sin plugins vulnerables, mejor SEO desde el día uno." } },
          { "@type": "Question", "name": "¿Cuánto tiempo toma crear una página web?", "acceptedAnswer": { "@type": "Answer", "text": "Landing page en 5-7 días hábiles. Sitio corporativo completo 2-3 semanas. Tienda online 4-8 semanas." } },
          { "@type": "Question", "name": "¿Incluye hosting y dominio?", "acceptedAnswer": { "@type": "Answer", "text": "Sí. Hosting en Vercel con CDN global, certificado SSL y configuración de dominio personalizado. Sin costos ocultos." } }
        ]
      }
    ]
  })} />

  <Header />
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />

  <main style="overflow-x:hidden;">

    <!-- ═══════════════════════════════════════════
         HERO — Video full-bleed, texto al pie izquierdo
    ═══════════════════════════════════════════ -->
    <section style="position:relative; width:100vw; height:100dvh; min-height:100vh; overflow:hidden; background:#010101;">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline preload="auto"
        style="position:absolute; top:0; left:0; width:100%; height:100%; object-fit:cover; z-index:1;"
      />
      <div style="position:absolute; inset:0; z-index:2; background:linear-gradient(to top, #010101 0%, #010101 18%, rgba(1,1,1,0.55) 50%, rgba(1,1,1,0.3) 100%);"></div>
      <div style="position:absolute; inset:0; z-index:2; background:linear-gradient(to right, rgba(1,1,1,0.5) 0%, transparent 60%);"></div>
      <div style="position:absolute; inset:0; z-index:3; opacity:0.025; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>

      <div style="position:absolute; bottom:0; left:0; right:0; z-index:10; padding:0 2.5rem 3.5rem;">
        <p style="font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.25); font-family:var(--font-body); margin-bottom:1rem;">Desarrollo Web</p>
        <h1 style="font-size:clamp(3.5rem, 12vw, 14rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.85; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
          PÁGINAS WEB<br /><span style="color:rgba(255,255,255,0.18);">PROFESIONALES</span>
        </h1>
        <p style="margin-top:1.25rem; font-size:0.75rem; color:rgba(255,255,255,0.35); font-family:var(--font-body); font-weight:300; max-width:380px; line-height:1.65;">
          Sitios ultrarrápidos con Astro. Diseño responsive, SEO incluido, carga en 1.5s.
        </p>
        <div style="margin-top:1.75rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
          <a href={waUrl} target="_blank" rel="noopener noreferrer"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.5rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s;"
            onmouseover="this.style.background='#25D366'" onmouseout="this.style.background='#1A1A1A'">
            COTIZAR AHORA
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/cotizar"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.5rem; background:transparent; color:rgba(255,255,255,0.45); font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:1px solid rgba(255,255,255,0.12); text-decoration:none; transition:all 0.2s;"
            onmouseover="this.style.color='#fff'; this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'; this.style.borderColor='rgba(255,255,255,0.12)'">
            COTIZAR ONLINE
          </a>
        </div>
      </div>

      <div style="position:absolute; bottom:2rem; right:2.5rem; z-index:20;">
        <Breadcrumbs items={[{ name: "Desarrollo Web", path: "/desarrollo-web" }]} />
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         TIPOS DE SITIO — 3 columnas cinematográficas
         Fila 1: 55/45 | Fila 2: full-width
    ═══════════════════════════════════════════ -->
    <div class="dw-wrapper">

      <!-- Fila 1: LANDING / CORPORATIVO -->
      <div class="dw-row">

        <!-- LANDING PAGE — 55% -->
        <div class="dw-col dw-dominant">
          <div style="position:absolute; inset:0; background:linear-gradient(145deg, #060810 0%, #0a0e1a 40%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 25% 30%, rgba(99,102,241,0.16) 0%, transparent 55%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 80% 80%, rgba(99,102,241,0.05) 0%, transparent 50%);"></div>
          <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="dw-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.018); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">01 — Landing Page</p>
            <h2 style="font-size:clamp(2.25rem, 5vw, 5rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              LANDING<br />PÁGINA
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:340px; line-height:1.65;">
              1 página de alto impacto. Ideal para capturar leads, presentar un servicio o lanzar una campaña. Lista en 5-7 días.
            </p>
            <div style="margin-top:1.25rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <a href={waUrl} target="_blank" rel="noopener noreferrer"
                style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s;"
                onmouseover="this.style.background='#333'" onmouseout="this.style.background='#1A1A1A'">
                COTIZAR →
              </a>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.2); font-family:var(--font-body);">Desde $290.000</span>
            </div>
          </div>
        </div>

        <!-- SITIO CORPORATIVO — 45% -->
        <div class="dw-col dw-secondary">
          <div style="position:absolute; inset:0; background:linear-gradient(155deg, #07060f 0%, #0c0918 45%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 70% 25%, rgba(139,92,246,0.14) 0%, transparent 55%);"></div>
          <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="dw-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.018); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">02 — Sitio Corporativo</p>
            <h2 style="font-size:clamp(2rem, 4vw, 3.75rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              SITIO<br />CORPORATIVO
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:300px; line-height:1.65;">
              5-10 páginas. Blog, galería, formularios. Posiciona tu empresa en Google con SEO completo. 2-3 semanas.
            </p>
            <div style="margin-top:1.25rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em;">MÁS POPULAR</span>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.2); font-family:var(--font-body);">Desde $690.000</span>
            </div>
          </div>
        </div>

      </div><!-- /fila 1 -->

      <!-- Fila 2: E-COMMERCE — full width -->
      <div class="dw-full">
        <div style="position:absolute; inset:0; background:linear-gradient(135deg, #080608 0%, #0e0810 50%, #010101 100%);"></div>
        <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 30% 50%, rgba(99,102,241,0.1) 0%, transparent 50%);"></div>
        <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 75% 30%, rgba(139,92,246,0.08) 0%, transparent 45%);"></div>
        <div style="position:absolute; inset:0; opacity:0.022; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
        <div class="dw-hover" style="position:absolute; inset:0; background:rgba(255,255,255,0.015); opacity:0; transition:opacity 0.4s;"></div>
        <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
        <div style="position:relative; z-index:10; padding:2.5rem;">
          <p style="font-size:0.58rem; letter-spacing:0.22em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.7rem;">03 — E-commerce & App Web</p>
          <div style="display:flex; flex-wrap:wrap; align-items:flex-end; gap:2.5rem; width:100%;">
            <div>
              <h2 style="font-size:clamp(1.75rem, 4vw, 3.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.9; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
                TIENDA ONLINE · CATÁLOGO · CHECKOUT · PAGOS
              </h2>
              <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; max-width:520px; line-height:1.65;">
                E-commerce completo con Transbank/Mercado Pago, panel de administración, sistema de usuarios y SEO avanzado. 4-8 semanas.
              </p>
            </div>
            <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap; margin-left:auto;">
              <a href={waUrl} target="_blank" rel="noopener noreferrer"
                style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s; white-space:nowrap;"
                onmouseover="this.style.background='#333'" onmouseout="this.style.background='#1A1A1A'">
                COTIZAR →
              </a>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.2); font-family:var(--font-body); white-space:nowrap;">Desde $1.500.000</span>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /dw-wrapper -->


    <!-- ═══════════════════════════════════════════
         POR QUÉ ASTRO — 35/65 split
    ═══════════════════════════════════════════ -->
    <section style="width:100vw; background:#0A0A0A; position:relative; overflow:hidden;">
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
      <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 80% 50%, rgba(99,102,241,0.04) 0%, transparent 55%);"></div>

      <div class="astro-row">
        <!-- Col izquierda: título grande -->
        <div class="astro-left" style="position:relative; display:flex; flex-direction:column; justify-content:center; padding:5rem 2.5rem; background:#010101;">
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 70% 50%, rgba(99,102,241,0.07) 0%, transparent 60%);"></div>
          <div style="position:relative; z-index:2;">
            <p class="reveal-item" style="font-size:0.58rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.5rem;">Por qué Astro</p>
            <h2 class="reveal-item" style="font-size:clamp(2.5rem,6vw,6rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
              NO ES<br />WORDPRESS<br /><span style="color:rgba(255,255,255,0.18);">ES MEJOR</span>
            </h2>
          </div>
        </div>

        <!-- Col derecha: stats + diferenciadores -->
        <div class="astro-right" style="position:relative; display:flex; flex-direction:column; justify-content:center; padding:5rem 2.5rem; background:#0A0A0A; border-left:1px solid rgba(255,255,255,0.04);">
          <div class="reveal-group" style="max-width:560px;">
            <p class="reveal-item" style="font-size:0.88rem; color:rgba(255,255,255,0.45); font-family:var(--font-body); font-weight:300; line-height:1.8; margin-bottom:2.5rem;">
              Mientras WordPress carga plugins y scripts pesados, Astro envía HTML estático puro. El resultado: velocidad imposible de igualar, seguridad sin parches constantes y posicionamiento SEO desde el día uno.
            </p>

            <!-- Comparación editorial: números en línea -->
            <div class="reveal-group" style="border-top:1px solid rgba(255,255,255,0.06);">
              {[
                { stat: "1.5s", label: "Tiempo de carga Astro", versus: "3-6s WordPress" },
                { stat: "95+", label: "PageSpeed Insights", versus: "60-75 WordPress típico" },
                { stat: "0", label: "Plugins vulnerables", versus: "Promedio 25 plugins WP" },
              ].map((item, i) => (
                <div class="reveal-item" style={`display:flex; align-items:baseline; gap:1.5rem; padding:1.25rem 0; border-bottom:1px solid rgba(255,255,255,0.05);`}>
                  <p style="font-size:clamp(2rem,4vw,3rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; line-height:1; margin:0; flex-shrink:0; min-width:5rem;">{item.stat}</p>
                  <div>
                    <p style="font-size:0.75rem; color:rgba(255,255,255,0.6); font-family:var(--font-body); font-weight:500; margin:0;">{item.label}</p>
                    <p style="font-size:0.65rem; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-top:0.15rem;">vs {item.versus}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══════════════════════════════════════════
         PLANES — editorial list, sin cards
    ═══════════════════════════════════════════ -->
    <section style="width:100vw; background:#0A0A0A; position:relative; overflow:hidden;">
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
      <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 50% 0%, rgba(99,102,241,0.04) 0%, transparent 55%);"></div>

      <div style="padding:6rem 2.5rem;">
        <div class="reveal-group" style="margin-bottom:4rem;">
          <p class="reveal-item" style="font-size:0.6rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Precios</p>
          <h2 class="reveal-item" style="font-size:clamp(2.5rem,8vw,8rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.04em; text-transform:uppercase; line-height:0.88; margin:0;">
            PLANES<br /><span style="color:rgba(255,255,255,0.18);">WEB</span>
          </h2>
        </div>

        <div class="reveal-group" style="border-top:1px solid rgba(255,255,255,0.06);">

          <!-- Plan 1: Landing -->
          <div class="reveal-item plan-row" style="border-bottom:1px solid rgba(255,255,255,0.06); padding:2.5rem 0; display:flex; flex-wrap:wrap; align-items:flex-start; gap:2rem;">
            <div style="min-width:130px;">
              <p style="font-size:0.58rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.5rem;">01</p>
              <p style="font-size:clamp(2rem,5vw,3.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; line-height:1; margin:0;">$290k</p>
              <p style="font-size:0.65rem; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-top:0.25rem;">Pago único</p>
            </div>
            <div style="flex:1; min-width:200px;">
              <h3 style="font-size:1.1rem; font-family:var(--font-heading); font-weight:700; color:#fff; letter-spacing:-0.02em; text-transform:uppercase; margin:0 0 0.75rem;">Landing Page</h3>
              <div style="display:flex; flex-wrap:wrap; gap:1.5rem;">
                {["1 página", "Diseño responsive", "SEO local básico", "Hosting + SSL", "Formulario contacto", "Google Analytics", "5-7 días hábiles"].map(item => (
                  <span style="font-size:0.72rem; color:rgba(255,255,255,0.38); font-family:var(--font-body);">{item}</span>
                ))}
              </div>

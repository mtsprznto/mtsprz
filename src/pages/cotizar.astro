---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
import { query, initDb } from "../lib/db";

await initDb();
const result = await query("SELECT * FROM services WHERE is_active = true ORDER BY category, name");
interface Service {
  id: number;
  slug: string;
  name: string;
  description: string | null;
  price: number;
  promo_price: number | null;
  category: string | null;
  deliverables: string[] | null;
  includes_maintenance: boolean;
  maintenance_price: number;
  maintenance_description: string | null;
  is_active: boolean;
  is_popular: boolean;
  is_monthly: boolean;
}
const services = result.rows as Service[];

const cookieEmail = (Astro.cookies.get("mtsprz_verified")?.value || "").trim().toLowerCase();
const urlEmail = (Astro.url.searchParams.get("email") || "").trim().toLowerCase();
const candidateEmail = cookieEmail || urlEmail || "";
let verifiedEmail = "";
if (candidateEmail) {
  const verResult = await query("SELECT 1 FROM verified_emails WHERE email = $1", [candidateEmail]);
  if (verResult.rows.length > 0) {
    verifiedEmail = candidateEmail;
  }
}
const categories = [...new Set(services.map((s) => s.category).filter(Boolean))] as string[];
const effectivePrice = (s: Service) => (s.promo_price && s.promo_price > 0 ? s.promo_price : s.price);
---

<BaseLayout
  title={verifiedEmail ? "Cotización — Mtsprz Soluciones Digitales" : "Cotizar — Mtsprz"}
  description={verifiedEmail ? "Simula tu cotización personalizada. Selecciona los servicios digitales que necesita tu negocio." : "Verifica tu correo para solicitar una cotización personalizada."}
  canonical="https://mtsprz.org/cotizar"
>
  <Header />
  <main style="overflow-x:hidden; background:#010101; min-height:100vh;">

    {!verifiedEmail ? (
      <>
        <section style="position:relative; width:100vw; height:60vh; min-height:420px; overflow:hidden; background:#010101; display:flex; flex-direction:column; justify-content:flex-end;">
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 60% 0%, rgba(99,102,241,0.1) 0%, transparent 55%), linear-gradient(160deg, #010101 0%, #06060e 60%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; opacity:0.025; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:50%; background:linear-gradient(to top, #010101, transparent);"></div>

          <div style="position:relative; z-index:10; padding:0 2.5rem 3rem;">
            <p style="font-size:0.58rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.75rem;">Cotización</p>
            <h1 style="font-size:clamp(3rem,9vw,9rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
              COTIZA<br /><span style="color:rgba(255,255,255,0.18);">GRATIS</span>
            </h1>
          </div>

          <div style="position:absolute; bottom:1.75rem; right:2.5rem; z-index:20;">
            <Breadcrumbs items={[{ name: "Cotización", path: "/cotizar" }]} />
          </div>
        </section>

        <section style="width:100vw; background:#010101; position:relative;">
          <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
          <div style="max-width:480px; margin:0 auto; padding:5rem 2rem;">

            <div id="verify-step-1">
              <p style="font-size:0.58rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.5rem;">Paso 1 de 2</p>
              <h2 style="font-size:clamp(1.5rem,4vw,2.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; line-height:0.92; margin:0 0 0.75rem;">INGRESA TU CORREO</h2>
              <p style="font-size:0.78rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); font-weight:300; line-height:1.7; margin-bottom:2.5rem;">
                Te enviamos un código de verificación para comenzar la cotización.
              </p>
              <div style="display:flex; flex-direction:column; gap:0.75rem;">
                <input
                  type="email"
                  id="verify-email"
                  placeholder="tu@correo.com"
                  autocomplete="email"
                  style="width:100%; padding:1rem 1.25rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); color:#fff; font-size:0.85rem; font-family:var(--font-body); outline:none; box-sizing:border-box; transition:border-color 0.2s;"
                  onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'"
                />
                <p id="verify-email-error" class="hidden" style="font-size:0.72rem; color:#f87171; font-family:var(--font-body);"></p>
                <button id="verify-send-btn"
                  style="width:100%; padding:1rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 0.2s;"
                  onmouseover="this.style.background='#2a2a2a'" onmouseout="this.style.background='#1A1A1A'">
                  <span id="verify-send-text">ENVIAR CÓDIGO</span>
                  <svg id="verify-send-spinner" class="hidden" style="width:14px;height:14px;animation:spin 1s linear infinite;" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
                </button>
              </div>
            </div>

            <div id="verify-step-2" class="hidden">
              <p style="font-size:0.58rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.5rem;">Paso 2 de 2</p>
              <h2 style="font-size:clamp(1.5rem,4vw,2.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; line-height:0.92; margin:0 0 0.75rem;">CÓDIGO DE 6 DÍGITOS</h2>
              <p style="font-size:0.78rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); font-weight:300; line-height:1.7; margin-bottom:2.5rem;">
                Enviamos el código a <strong id="verify-email-display" style="color:rgba(255,255,255,0.6); font-weight:500;"></strong>
              </p>
              <div style="display:flex; flex-direction:column; gap:0.75rem;">
                <div style="display:flex; justify-content:center; gap:0.5rem;">
                  <input type="text" id="verify-code-0" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code"
                    style="width:3rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:700;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
                    onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
                  <input type="text" id="verify-code-1" maxlength="1" inputmode="numeric" pattern="[0-9]"
                    style="width:3rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:700;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
                    onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
                  <input type="text" id="verify-code-2" maxlength="1" inputmode="numeric" pattern="[0-9]"
                    style="width:3rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:700;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
                    onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
                  <span style="display:flex;align-items:center;color:rgba(255,255,255,0.15);font-size:1.25rem;font-weight:700;">—</span>
                  <input type="text" id="verify-code-3" maxlength="1" inputmode="numeric" pattern="[0-9]"
                    style="width:3rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:700;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
                    onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
                  <input type="text" id="verify-code-4" maxlength="1" inputmode="numeric" pattern="[0-9]"
                    style="width:3rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:700;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
                    onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
                  <input type="text" id="verify-code-5" maxlength="1" inputmode="numeric" pattern="[0-9]"
                    style="width:3rem;height:3.5rem;text-align:center;font-size:1.25rem;font-family:var(--font-heading);font-weight:700;color:#fff;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);outline:none;transition:border-color 0.2s;"
                    onfocus="this.style.borderColor='rgba(99,102,241,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.08)'" />
                </div>
                <p id="verify-code-error" class="hidden" style="font-size:0.72rem; color:#f87171; font-family:var(--font-body); text-align:center;"></p>
                <button id="verify-verify-btn"
                  style="width:100%; padding:1rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 0.2s;"
                  onmouseover="this.style.background='#2a2a2a'" onmouseout="this.style.background='#1A1A1A'">
                  <span id="verify-verify-text">VERIFICAR CÓDIGO</span>
                  <svg id="verify-verify-spinner" class="hidden" style="width:14px;height:14px;animation:spin 1s linear infinite;" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
                </button>
                <button id="verify-resend-btn"
                  style="background:none; border:none; cursor:pointer; font-size:0.68rem; color:rgba(255,255,255,0.25); font-family:var(--font-body); text-decoration:underline; text-underline-offset:3px; transition:color 0.2s; padding:0.5rem 0;"
                  onmouseover="this.style.color='rgba(255,255,255,0.55)'" onmouseout="this.style.color='rgba(255,255,255,0.25)'">
                  Reenviar código
                </button>
              </div>
            </div>

          </div>
        </section>
      </>

    ) : (

      <>
        <section style="position:relative; width:100vw; height:50vh; min-height:360px; overflow:hidden; background:#010101; display:flex; flex-direction:column; justify-content:flex-end;">
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 40% 0%, rgba(99,102,241,0.1) 0%, transparent 55%), linear-gradient(160deg, #010101 0%, #06060e 60%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; opacity:0.025; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:50%; background:linear-gradient(to top, #010101, transparent);"></div>

          <div style="position:relative; z-index:10; padding:0 2.5rem 2.5rem;">
            <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.75rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.4)" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
              <p style="font-size:0.62rem; color:rgba(255,255,255,0.3); font-family:var(--font-body);">{verifiedEmail}</p>
            </div>
            <h1 style="font-size:clamp(3rem,9vw,9rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.88; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
              TU COTIZACIÓN<br /><span style="color:rgba(255,255,255,0.18);">PERSONALIZADA</span>
            </h1>
          </div>

          <div style="position:absolute; bottom:1.75rem; right:2.5rem; z-index:20;">
            <Breadcrumbs items={[{ name: "Cotización", path: "/cotizar" }]} />
          </div>
        </section>

        <section style="width:100vw; background:#010101; position:relative;">
          <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>

          <div class="cotizar-layout" style="padding:4rem 2.5rem;">

            <div class="cotizar-services">
              {categories.map((cat) => (
                <div style="margin-bottom:3rem;">
                  <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:1.25rem; padding-bottom:0.75rem; border-bottom:1px solid rgba(255,255,255,0.05);">
                    <span style="display:block; width:2px; height:1.1rem; background:rgba(99,102,241,0.6); flex-shrink:0;"></span>
                    <h2 style="font-size:0.7rem; font-family:var(--font-heading); font-weight:700; color:rgba(255,255,255,0.5); text-transform:uppercase; letter-spacing:0.15em; margin:0;">{cat}</h2>
                  </div>
                  <div style="display:flex; flex-direction:column; gap:0.5rem;">
                    {services.filter((s) => s.category === cat).map((s) => (
                      <label
                        class="cotizar-option"
                        data-price={effectivePrice(s)}
                        data-monthly={s.is_monthly ? "true" : "false"}
                        data-slug={s.slug}
                        style="display:flex; align-items:flex-start; gap:1rem; padding:1.25rem 1.5rem; border:1px solid rgba(255,255,255,0.06); cursor:pointer; transition:all 0.2s; background:rgba(255,255,255,0.01);"
                        onmouseover="if(!this.querySelector('input').checked){this.style.borderColor='rgba(255,255,255,0.12)';this.style.background='rgba(255,255,255,0.03)';}"
                        onmouseout="if(!this.querySelector('input').checked){this.style.borderColor='rgba(255,255,255,0.06)';this.style.background='rgba(255,255,255,0.01)';}"
                      >
                        <input type="checkbox" class="cotizar-checkbox"
                          style="margin-top:2px; width:14px; height:14px; flex-shrink:0; accent-color:#6366f1; cursor:pointer;" />
                        <div style="flex:1; min-width:0;">
                          <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem;">
                            <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                              <span class="font-heading font-semibold" style="font-size:0.85rem; font-family:var(--font-heading); font-weight:600; color:#fff;">{s.name}</span>
                              {s.is_popular && (
                                <span style="font-size:0.58rem; font-family:var(--font-body); color:rgba(99,102,241,0.8); text-transform:uppercase; letter-spacing:0.1em; border:1px solid rgba(99,102,241,0.25); padding:0.15rem 0.4rem;">Popular</span>
                              )}
                            </div>
                            <div style="text-align:right; flex-shrink:0;">
                              {s.promo_price && s.promo_price > 0 ? (
                                <div>
                                  <span style="font-size:0.88rem; font-family:var(--font-heading); font-weight:700; color:#fff;">${(effectivePrice(s) / 1000).toFixed(0)}k</span>
                                  <span style="margin-left:0.4rem; font-size:0.72rem; color:rgba(255,255,255,0.25); text-decoration:line-through;">${(s.price / 1000).toFixed(0)}k</span>
                                </div>
                              ) : (
                                <span style="font-size:0.88rem; font-family:var(--font-heading); font-weight:700; color:#fff;">${(s.price / 1000).toFixed(0)}k</span>
                              )}
                              {s.is_monthly && <span style="display:block; font-size:0.6rem; color:rgba(255,255,255,0.3); font-family:var(--font-body);">/mes</span>}
                            </div>
                          </div>
                          <p style="margin-top:0.3rem; font-size:0.72rem; color:rgba(255,255,255,0.35); font-family:var(--font-body); font-weight:300; line-height:1.5;">{s.description}</p>
                        </div>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <div class="cotizar-sidebar">
              <div style="position:sticky; top:6rem; border:1px solid rgba(255,255,255,0.07); padding:2rem; background:#0A0A0A;">
                <p style="font-size:0.58rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Resumen</p>
                <h3 style="font-size:1.5rem; font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; margin:0 0 1.5rem; line-height:0.95;">TU<br />COTIZACIÓN</h3>

                <div id="cotizar-summary" style="margin-bottom:1.5rem; min-height:3rem;">
                  <p style="font-size:0.75rem; color:rgba(255,255,255,0.25); font-family:var(--font-body);">Selecciona servicios para ver el total.</p>
                </div>

                <div style="border-top:1px solid rgba(255,255,255,0.06); padding-top:1.25rem;">
                  <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.5rem;">
                    <span style="font-size:0.72rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.1em;">Subtotal</span>
                    <span id="cotizar-subtotal" style="font-size:0.88rem; font-family:var(--font-heading); font-weight:700; color:rgba(255,255,255,0.7);">$0</span>
                  </div>
                  <div id="cotizar-discount-row" class="hidden" style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.5rem;">
                    <span style="font-size:0.72rem; color:#34d399; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.1em;">Descuento pack</span>
                    <span id="cotizar-discount" style="font-size:0.88rem; font-family:var(--font-heading); font-weight:700; color:#34d399;">-$0</span>
                  </div>
                  <div style="display:flex; justify-content:space-between; align-items:baseline; padding-top:0.75rem; border-top:1px solid rgba(255,255,255,0.06); margin-top:0.25rem;">
                    <span style="font-size:0.72rem; color:#fff; font-family:var(--font-heading); font-weight:700; text-transform:uppercase; letter-spacing:0.1em;">Total</span>
                    <span id="cotizar-total" style="font-size:1.5rem; font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.02em;">$0</span>
                  </div>
                </div>

                <button id="cotizar-submit-btn"
                  data-verified-email={verifiedEmail}
                  style="width:100%; margin-top:1.5rem; padding:0.9rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:none; cursor:pointer; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:background 0.2s; opacity:0.4; pointer-events:none;"
                  onmouseover="if(!this.disabled)this.style.background='#2a2a2a'" onmouseout="if(!this.disabled)this.style.background='#1A1A1A'">
                  <span id="cotizar-submit-text">ENVIAR COTIZACIÓN</span>
                  <svg id="cotizar-submit-spinner" class="hidden" style="width:14px;height:14px;animation:spin 1s linear infinite;" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
                </button>

                <p style="margin-top:1rem; font-size:0.62rem; color:rgba(255,255,255,0.2); font-family:var(--font-body); line-height:1.6; text-align:center;">
                  Sin compromiso. Te contactamos en menos de 24 hrs.
                </p>
              </div>
            </div>

          </div>
        </section>
      </>
    )}

  </main>

  <Footer />

  <style>
    @keyframes spin { to { transform: rotate(360deg); } }

    /* cotizar-option checked state */
    .cotizar-option:has(input:checked) {
      border-color: rgba(99,102,241,0.35) !important;
      background: rgba(99,102,241,0.05) !important;
    }

    /* Layout cotizador */
    .cotizar-layout {
      display: flex;
      flex-direction: column;
      gap: 3rem;
      max-width: 1200px;
      margin: 0 auto;
    }
    .cotizar-services { width: 100%; }
    .cotizar-sidebar  { width: 100%; }

    @media (min-width: 1024px) {
      .cotizar-layout {
        flex-direction: row;
        align-items: flex-start;
        gap: 4rem;
        padding-left: 3rem;
        padding-right: 3rem;
      }
      .cotizar-services { flex: 1; }

---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
import { query, initDb } from "../lib/db";

await initDb();
const result = await query("SELECT * FROM services WHERE is_active = true ORDER BY category, name");
interface Service {
  id: number;
  slug: string;
  name: string;
  description: string | null;
  price: number;
  promo_price: number | null;
  category: string | null;
  deliverables: string[] | null;
  includes_maintenance: boolean;
  maintenance_price: number;
  maintenance_description: string | null;
  is_active: boolean;
  is_popular: boolean;
  is_monthly: boolean;
}
const services = result.rows as Service[];

const cookieEmail = (Astro.cookies.get("mtsprz_verified")?.value || "").trim().toLowerCase();
const urlEmail = (Astro.url.searchParams.get("email") || "").trim().toLowerCase();
const candidateEmail = cookieEmail || urlEmail || "";
let verifiedEmail = "";
if (candidateEmail) {
  const verResult = await query("SELECT 1 FROM verified_emails WHERE email = $1", [candidateEmail]);
  if (verResult.rows.length > 0) {
    verifiedEmail = candidateEmail;
  }
}
const categories = [...new Set(services.map((s) => s.category).filter(Boolean))] as string[];
const effectivePrice = (s: Service) => (s.promo_price && s.promo_price > 0 ? s.promo_price : s.price);
---

<BaseLayout
  title={verifiedEmail ? "Cotización — Mtsprz Soluciones Digitales" : "Verifica tu Correo — Mtsprz"}
  description={verifiedEmail ? "Simula tu cotización personalizada. Selecciona los servicios digitales que necesita tu negocio." : "Verifica tu correo electrónico para solicitar una cotización personalizada."}
  canonical="https://mtsprz.org/cotizar"
>
  <Header />
  <Breadcrumbs items={[
    { name: "Cotización", path: "/cotizar" },
  ]} class="mx-auto max-w-6xl px-6 pt-6 pb-2" />

  <main class="bg-[#010101] pb-28">
    {!verifiedEmail ? (
      <section class="py-16 md:py-24">
        <div class="mx-auto max-w-md px-6">
          <div id="verify-step-1">
            <div class="text-center mb-8">
              <div class="w-14 h-14 mx-auto rounded-2xl bg-[#6366f1]/10 border border-[#6366f1]/20 flex items-center justify-center mb-5">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-[#6366f1]"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <h1 class="text-3xl sm:text-4xl font-heading font-bold text-white tracking-[-1px]">
                Solicita tu Cotización
              </h1>
              <p class="mt-3 text-sm text-white/40 font-body max-w-sm mx-auto leading-relaxed">
                Déjanos tu correo y te enviaremos un código de verificación para comenzar.
              </p>
            </div>
            <div class="space-y-3">
              <input
                type="email"
                id="verify-email"
                placeholder="tu@correo.com"
                autocomplete="email"
                class="w-full px-4 py-3.5 rounded-xl bg-white/[0.04] border border-white/[0.08] text-sm text-white placeholder-white/30 font-body outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all"
              />
              <p id="verify-email-error" class="text-xs text-red-400 font-body hidden"></p>
              <button id="verify-send-btn"
                class="w-full py-3.5 rounded-xl bg-[#6366f1] text-sm font-medium text-white hover:bg-[#5558e6] transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
              >
                <span id="verify-send-text">Enviar código</span>
                <svg id="verify-send-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
              </button>
            </div>
          </div>

          <div id="verify-step-2" class="hidden">
            <div class="text-center mb-8">
              <div class="w-14 h-14 mx-auto rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
                <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-emerald-400"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
              </div>
              <h1 class="text-3xl sm:text-4xl font-heading font-bold text-white tracking-[-1px]">
                Verifica tu Correo
              </h1>
              <p class="mt-3 text-sm text-white/40 font-body leading-relaxed">
                Ingresa el código de 6 dígitos que enviamos a <strong id="verify-email-display" class="text-white/70 font-medium"></strong>
              </p>
            </div>
            <div class="space-y-4">
              <div class="flex justify-center gap-2">
                <input type="text" id="verify-code-0" maxlength="1" inputmode="numeric" pattern="[0-9]" autocomplete="one-time-code" class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all" />
                <input type="text" id="verify-code-1" maxlength="1" inputmode="numeric" pattern="[0-9]" class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all" />
                <input type="text" id="verify-code-2" maxlength="1" inputmode="numeric" pattern="[0-9]" class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all" />
                <span class="flex items-center text-white/20 text-lg font-heading font-bold">—</span>
                <input type="text" id="verify-code-3" maxlength="1" inputmode="numeric" pattern="[0-9]" class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all" />
                <input type="text" id="verify-code-4" maxlength="1" inputmode="numeric" pattern="[0-9]" class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all" />
                <input type="text" id="verify-code-5" maxlength="1" inputmode="numeric" pattern="[0-9]" class="w-11 h-14 text-center text-xl font-heading font-bold text-white bg-white/[0.04] border border-white/[0.08] rounded-xl outline-none focus:border-[#6366f1]/50 focus:bg-white/[0.06] transition-all" />
              </div>
              <p id="verify-code-error" class="text-xs text-red-400 font-body text-center hidden"></p>
              <button id="verify-verify-btn"
                class="w-full py-3.5 rounded-xl bg-[#6366f1] text-sm font-medium text-white hover:bg-[#5558e6] transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
              >
                <span id="verify-verify-text">Verificar código</span>
                <svg id="verify-verify-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
              </button>
              <button id="verify-resend-btn" class="block mx-auto text-xs text-white/30 hover:text-[#6366f1] transition-colors font-body">Reenviar código</button>
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class="py-12 md:py-16">
        <div class="mx-auto max-w-6xl px-6">
          <div class="text-center mb-12">
            <div class="w-14 h-14 mx-auto rounded-2xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-5">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h1 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white tracking-[-1px]">
              Tu Cotización Personalizada
            </h1>
            <p class="mt-3 text-sm text-white/50 font-body">
              Correo verificado: <strong class="text-white/70 font-medium">{verifiedEmail}</strong>
            </p>
            <p class="mt-2 text-sm text-white/40 font-body max-w-lg mx-auto">
              Selecciona los servicios que te interesan y ajusta el total según tu presupuesto.
            </p>
          </div>

          <div class="grid lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-10">
              {categories.map((cat) => (
                <div>
                  <h2 class="text-lg font-heading font-semibold text-white/80 tracking-[-0.5px] mb-4 flex items-center gap-2">
                    <span class="w-1 h-5 rounded-full bg-[#6366f1]" />
                    {cat}
                  </h2>
                  <div class="space-y-3">
                    {services.filter((s) => s.category === cat).map((s) => (
                      <label
                        class="cotizar-option group flex items-start gap-4 p-4 rounded-xl border border-white/[0.06] bg-white/[0.02] hover:bg-white/[0.04] hover:border-[#6366f1]/30 transition-all cursor-pointer has-[:checked]:border-[#6366f1]/50 has-[:checked]:bg-[#6366f1]/5"
                        data-price={effectivePrice(s)}
                        data-monthly={s.is_monthly ? "true" : "false"}
                        data-slug={s.slug}
                      >
                        <input type="checkbox" class="cotizar-checkbox mt-1 shrink-0 w-4 h-4 rounded border-white/20 bg-transparent text-[#6366f1] focus:ring-[#6366f1]/30 cursor-pointer" />
                        <div class="flex-1 min-w-0">
                          <div class="flex items-start justify-between gap-2">
                            <div>
                              <span class="text-sm font-heading font-semibold text-white">{s.name}</span>
                              {s.is_popular && (
                                <span class="ml-2 inline-block px-2 py-0.5 rounded-full bg-[#6366f1]/10 border border-[#6366f1]/20 text-[10px] font-medium text-[#6366f1]">Popular</span>
                              )}
                            </div>
                            <div class="text-right shrink-0">
                              {s.promo_price && s.promo_price > 0 ? (
                                <>
                                  <span class="text-sm font-heading font-bold text-white">${(effectivePrice(s) / 1000).toFixed(0)}k</span>
                                  <span class="ml-1.5 text-xs text-white/30 line-through">${(s.price / 1000).toFixed(0)}k</span>
                                </>
                              ) : (
                                <span class="text-sm font-heading font-bold text-white">${(s.price / 1000).toFixed(0)}k</span>
                              )}
                              {s.is_monthly && <span class="block text-[10px] text-white/40">/mes</span>}
                            </div>
                          </div>
                          <p class="mt-0.5 text-xs text-white/40 font-body leading-relaxed">{s.description}</p>
                        </div>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>

            <div class="lg:col-span-1">
              <div class="sticky top-28 liquid-glass rounded-2xl p-6 space-y-5">
                <h3 class="text-base font-heading font-semibold text-white tracking-[-0.3px]">Resumen</h3>
                <div id="cotizar-summary" class="space-y-3">
                  <p class="text-sm text-white/40 font-body">Selecciona servicios para ver el total.</p>
                </div>
                <div class="pt-4 border-t border-white/[0.06] space-y-2">
                  <div class="flex justify-between text-sm">
                    <span class="text-white/50 font-body">Subtotal</span>
                    <span id="cotizar-subtotal" class="text-white font-heading font-semibold">$0</span>
                  </div>
                  <div id="cotizar-discount-row" class="hidden flex justify-between text-sm">
                    <span class="text-emerald-400 font-body">Descuento pack</span>
                    <span id="cotizar-discount" class="text-emerald-400 font-heading font-semibold">-$0</span>
                  </div>
                  <div class="flex justify-between text-base pt-2 border-t border-white/[0.06]">
                    <span class="text-white font-heading font-semibold">Total</span>
                    <span id="cotizar-total" class="text-white font-heading font-bold text-lg">$0</span>
                  </div>
                </div>
                <button id="cotizar-submit-btn"
                  class="w-full py-3 rounded-xl bg-[#6366f1] text-sm font-medium text-white hover:bg-[#5558e6] transition-all disabled:opacity-40 disabled:cursor-not-allowed flex items-center justify-center gap-2"
                  data-verified-email={verifiedEmail}
                >
                  <span id="cotizar-submit-text">Enviar Cotización</span>
                  <svg id="cotizar-submit-spinner" class="hidden w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/></svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      </section>
    )}
  </main>

  <Footer />
</BaseLayout>

{!verifiedEmail ? (
<script is:inline>
(function() {
  var $ = function(id) { return document.getElementById(id); };
  var step1 = $('verify-step-1');
  var step2 = $('verify-step-2');
  var emailInput = $('verify-email');
  var emailError = $('verify-email-error');
  var emailDisplay = $('verify-email-display');
  var sendBtn = $('verify-send-btn');
  var sendText = $('verify-send-text');
  var sendSpinner = $('verify-send-spinner');
  var verifyBtn = $('verify-verify-btn');
  var verifyText = $('verify-verify-text');
  var verifySpinner = $('verify-verify-spinner');
  var codeError = $('verify-code-error');
  var resendBtn = $('verify-resend-btn');
  var codeInputs = [
    $('verify-code-0'), $('verify-code-1'), $('verify-code-2'),
    $('verify-code-3'), $('verify-code-4'), $('verify-code-5'),
  ];
  var currentEmail = '';

  function showError(el, msg) {
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function setLoading(btn, spinner, text, loading) {
    if (!btn || !spinner || !text) return;
    if (loading) {
      btn.disabled = true;
      spinner.classList.remove('hidden');
      text.textContent = '...';
    } else {
      btn.disabled = false;
      spinner.classList.add('hidden');
      text.textContent = text.getAttribute('data-restore') || text.textContent;
    }
  }

  if (emailInput) {
    emailInput.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' && sendBtn) sendBtn.click();
    });
  }

  if (sendBtn) {
    sendBtn.addEventListener('click', async function() {
      if (!emailInput || !emailError || !sendText || !sendSpinner) return;
      var email = emailInput.value.trim().toLowerCase();
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        showError(emailError, 'Ingresa un correo electrónico válido');
        return;
      }
      emailError.classList.add('hidden');
      sendText.setAttribute('data-restore', 'Enviar código');
      setLoading(sendBtn, sendSpinner, sendText, true);
      try {
        var res = await fetch('/api/send-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(emailError, data.error || 'Error al enviar el código');
          setLoading(sendBtn, sendSpinner, sendText, false);
          return;
        }
        currentEmail = email;
        if (emailDisplay) emailDisplay.textContent = email;
        step1.classList.add('hidden');
        step2.classList.remove('hidden');
        if (codeInputs[0]) codeInputs[0].focus();
      } catch(e) {
        showError(emailError, 'Error de conexión. Intenta de nuevo.');
      }
      setLoading(sendBtn, sendSpinner, sendText, false);
    });
  }

  if (codeInputs[0]) {
    codeInputs.forEach(function(inp, i) {
      if (!inp) return;
      inp.addEventListener('input', function() {
        if (this.value.length >= 1 && i < codeInputs.length - 1 && codeInputs[i + 1]) {
          codeInputs[i + 1].focus();
        }
        if (codeError) codeError.classList.add('hidden');
      });
      inp.addEventListener('keydown', function(e) {
        if (e.key === 'Backspace' && !this.value && i > 0 && codeInputs[i - 1]) {
          codeInputs[i - 1].focus();
        }
        if (e.key === 'Enter' && verifyBtn) verifyBtn.click();
      });
      inp.addEventListener('paste', function(e) {
        e.preventDefault();
        var paste = (e.clipboardData || window.clipboardData).getData('text').replace(/\D/g, '').slice(0, 6);
        for (var j = 0; j < paste.length; j++) {
          if (codeInputs[j]) codeInputs[j].value = paste[j];
        }
        var next = Math.min(paste.length, 5);
        if (codeInputs[next]) codeInputs[next].focus();
      });
    });
  }

  if (verifyBtn) {
    verifyBtn.addEventListener('click', async function() {
      if (!codeInputs || !codeError || !verifyText || !verifySpinner) return;
      var code = codeInputs.map(function(inp) { return inp ? inp.value : ''; }).join('');
      if (code.length !== 6) {
        showError(codeError, 'Ingresa el código completo de 6 dígitos');
        return;
      }
      verifyText.setAttribute('data-restore', 'Verificar código');
      setLoading(verifyBtn, verifySpinner, verifyText, true);
      try {
        var res = await fetch('/api/verify-code', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail, code: code }),
        });
        var data = await res.json();
        if (!res.ok) {
          showError(codeError, data.error || 'Código incorrecto');
          setLoading(verifyBtn, verifySpinner, verifyText, false);
          return;
        }
        window.location.href = '/cotizar';
      } catch(e) {
        showError(codeError, 'Error de conexión. Intenta de nuevo.');
      }
      setLoading(verifyBtn, verifySpinner, verifyText, false);
    });
  }

  if (resendBtn) {
    resendBtn.addEventListener('click', function() {
      if (!currentEmail) return;
      resendBtn.disabled = true;
      resendBtn.textContent = 'Enviando...';
      fetch('/api/send-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email: currentEmail }),
      }).then(function() {
        resendBtn.textContent = '\u00a1Reenviado!';
        setTimeout(function() {
          resendBtn.disabled = false;
          resendBtn.textContent = 'Reenviar c\u00f3digo';
        }, 3000);
      }).catch(function() {
        resendBtn.disabled = false;
        resendBtn.textContent = 'Reenviar c\u00f3digo';
      });
    });
  }
})();
</script>
) : (
<script is:inline>
(function() {
  var submitBtn = document.getElementById('cotizar-submit-btn');
  var email = submitBtn ? submitBtn.getAttribute('data-verified-email') || '' : '';
  var checkboxes = document.querySelectorAll('.cotizar-checkbox');
  var summary = document.getElementById('cotizar-summary');
  var subtotalEl = document.getElementById('cotizar-subtotal');
  var totalEl = document.getElementById('cotizar-total');
  var discountRow = document.getElementById('cotizar-discount-row');
  var discountEl = document.getElementById('cotizar-discount');
  var submitText = document.getElementById('cotizar-submit-text');
  var submitSpinner = document.getElementById('cotizar-submit-spinner');

  var packs = [
    { ids: ['web-profesional', 'seo-local', 'bot-whatsapp'], discount: 200000, label: 'Pack Digital Completo' },
    { ids: ['landing', 'logo-brand', 'social-media'], discount: 150000, label: 'Pack Emprendedor' },
    { ids: ['seo-audit', 'seo-local', 'seo-mensual'], discount: 100000, label: 'Pack SEO Completo' },
  ];

  function formatPrice(price) {
    return '$' + price.toLocaleString('es-CL');
  }

  function updateSummary() {
    var selected = [];
    var total = 0;
    checkboxes.forEach(function(cb) {
      var opt = cb.closest('.cotizar-option');
      if (cb.checked) {
        var price = parseInt(opt.getAttribute('data-price'));
        total += price;
        selected.push({
          name: opt.querySelector('.font-heading.font-semibold').textContent.trim(),
          price: price,
        });
      }
    });
    if (selected.length === 0) {
      summary.innerHTML = '<p class="text-sm text-white/40 font-body">Selecciona servicios para ver el total.</p>';
      subtotalEl.textContent = '$0';
      discountRow.classList.add('hidden');
      totalEl.textContent = '$0';
      if (submitBtn) submitBtn.disabled = true;
      return;
    }
    var discount = 0;
    var discountLabel = '';
    var selectedIds = [];
    checkboxes.forEach(function(cb) {
      if (cb.checked) {
        var opt = cb.closest('.cotizar-option');
        var id = opt.getAttribute('data-slug') || opt.querySelector('.font-heading.font-semibold').textContent.trim().toLowerCase().replace(/\s+/g, '-');
        selectedIds.push(id);
      }
    });
    for (var p = 0; p < packs.length; p++) {
      var pack = packs[p];
      if (pack.ids.every(function(id) { return selectedIds.indexOf(id) !== -1; })) {
        discount = pack.discount;
        discountLabel = pack.label;
        break;
      }
    }
    var html = '';
    selected.forEach(function(s) {
      html += '<div class="flex justify-between text-sm"><span class="text-white/70 font-body">' + s.name + '</span><span class="text-white font-heading">' + formatPrice(s.price) + '</span></div>';
    });
    summary.innerHTML = html;
    subtotalEl.textContent = formatPrice(total);
    if (discount > 0) {
      discountRow.classList.remove('hidden');
      discountEl.textContent = '-' + formatPrice(discount);
    } else {
      discountRow.classList.add('hidden');
    }
    totalEl.textContent = formatPrice(total - discount);
    if (submitBtn) submitBtn.disabled = selected.length === 0 || !email;
  }

  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', updateSummary);
  });

  if (submitBtn) {
    submitBtn.addEventListener('click', async function() {
      if (!email) return;
      submitText.setAttribute('data-restore', 'Enviar Cotización');
      submitBtn.disabled = true;
      submitText.textContent = 'Enviando...';
      if (submitSpinner) submitSpinner.classList.remove('hidden');
      var selected = [];
      var total = 0;
      checkboxes.forEach(function(cb) {
        if (cb.checked) {
          var opt = cb.closest('.cotizar-option');
          var name = opt.querySelector('.font-heading.font-semibold').textContent.trim();
          var slug = opt.getAttribute('data-slug') || name.toLowerCase().replace(/\s+/g, '-');
          var price = parseInt(opt.getAttribute('data-price'));
          total += price;
          selected.push({ id: slug, name: name, price: price });
        }
      });
      try {
        var finalTotal = total;
        var finalDiscount = discountRow.classList.contains('hidden') ? 0 : parseInt(discountEl.textContent.replace(/[^0-9]/g, ''));
        var res = await fetch('/api/submit-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, services: selected, total: total }),
        });
        if (res.ok) {
          summary.innerHTML = '<div class="text-center py-4"><div class="w-12 h-12 mx-auto rounded-full bg-emerald-500/10 flex items-center justify-center mb-3"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-emerald-400"><polyline points="20 6 9 17 4 12"/></svg></div><p class="text-sm text-white/70 font-body">\u00a1Cotizaci\u00f3n enviada con \u00e9xito!</p><p class="text-xs text-white/40 font-body mt-1">Te contactaremos pronto a <strong class="text-white/60">' + email + '</strong></p><p class="text-xs text-white/50 font-body mt-3 border-t border-white/[0.06] pt-3">Monto cotizado: <strong class="text-white/80">' + formatPrice(finalTotal - finalDiscount) + '</strong></p></div>';
          checkboxes.forEach(function(cb) { cb.checked = false; });
          if (submitBtn) submitBtn.style.display = 'none';
        } else {
          submitText.textContent = 'Error al enviar. Intenta de nuevo.';
          setTimeout(function() { submitBtn.disabled = false; submitText.textContent = 'Enviar Cotización'; if (submitSpinner) submitSpinner.classList.add('hidden'); }, 3000);
        }
      } catch(e) {
        submitText.textContent = 'Error de conexión.';
        setTimeout(function() { submitBtn.disabled = false; submitText.textContent = 'Enviar Cotización'; if (submitSpinner) submitSpinner.classList.add('hidden'); }, 3000);
      }
    });
  }

  updateSummary();
})();
</script>
)}
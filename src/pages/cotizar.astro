<script is:inline>
(function() {
  var submitBtn = document.getElementById('cotizar-submit-btn');
  var email = submitBtn ? submitBtn.getAttribute('data-verified-email') || '' : '';
  var checkboxes = document.querySelectorAll('.cotizar-checkbox');
  var summary = document.getElementById('cotizar-summary');
  var subtotalEl = document.getElementById('cotizar-subtotal');
  var totalEl = document.getElementById('cotizar-total');
  var discountRow = document.getElementById('cotizar-discount-row');
  var discountEl = document.getElementById('cotizar-discount');
  var submitText = document.getElementById('cotizar-submit-text');
  var submitSpinner = document.getElementById('cotizar-submit-spinner');

  var packs = [
    { ids: ['web-profesional', 'seo-local', 'bot-whatsapp'], discount: 200000, label: 'Pack Digital Completo' },
    { ids: ['landing', 'logo-brand', 'social-media'], discount: 150000, label: 'Pack Emprendedor' },
    { ids: ['seo-audit', 'seo-local', 'seo-mensual'], discount: 100000, label: 'Pack SEO Completo' },
  ];

  function formatPrice(price) {
    return '$' + price.toLocaleString('es-CL');
  }

  function updateSummary() {
    var selected = [];
    var total = 0;
    checkboxes.forEach(function(cb) {
      var opt = cb.closest('.cotizar-option');
      if (cb.checked) {
        var price = parseInt(opt.getAttribute('data-price'));
        total += price;
        selected.push({
          name: opt.querySelector('.font-heading.font-semibold').textContent.trim(),
          price: price,
        });
      }
    });
    if (selected.length === 0) {
      summary.innerHTML = '<p style="font-size:0.75rem; color:rgba(255,255,255,0.25); font-family:var(--font-body);">Selecciona servicios para ver el total.</p>';
      subtotalEl.textContent = '$0';
      discountRow.classList.add('hidden');
      totalEl.textContent = '$0';
      if (submitBtn) { submitBtn.style.opacity='0.4'; submitBtn.style.pointerEvents='none'; submitBtn.classList.remove('enabled'); }
      return;
    }
    var discount = 0;
    var discountLabel = '';
    var selectedIds = [];
    checkboxes.forEach(function(cb) {
      if (cb.checked) {
        var opt = cb.closest('.cotizar-option');
        var id = opt.getAttribute('data-slug') || opt.querySelector('.font-heading.font-semibold').textContent.trim().toLowerCase().replace(/\s+/g, '-');
        selectedIds.push(id);
      }
    });
    for (var p = 0; p < packs.length; p++) {
      var pack = packs[p];
      if (pack.ids.every(function(id) { return selectedIds.indexOf(id) !== -1; })) {
        discount = pack.discount;
        discountLabel = pack.label;
        break;
      }
    }
    var html = '';
    selected.forEach(function(s) {
      html += '<div style="display:flex;justify-content:space-between;margin-bottom:0.5rem;padding-bottom:0.5rem;border-bottom:1px solid rgba(255,255,255,0.05);"><span style="font-size:0.72rem;color:rgba(255,255,255,0.55);font-family:var(--font-body);flex:1;padding-right:0.5rem;">' + s.name + '</span><span style="font-size:0.78rem;font-family:var(--font-heading);font-weight:700;color:#fff;flex-shrink:0;">' + formatPrice(s.price) + '</span></div>';
    });
    summary.innerHTML = html;
    subtotalEl.textContent = formatPrice(total);
    if (discount > 0) {
      discountRow.classList.remove('hidden');
      discountRow.style.display = 'flex';
      discountEl.textContent = '-' + formatPrice(discount);
    } else {
      discountRow.classList.add('hidden');
    }
    totalEl.textContent = formatPrice(total - discount);
    if (submitBtn) { submitBtn.style.opacity='1'; submitBtn.style.pointerEvents='auto'; submitBtn.classList.add('enabled'); }
  }

  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', function() {
      var opt = cb.closest('.cotizar-option');
      if (cb.checked) {
        opt.style.borderColor = 'rgba(99,102,241,0.35)';
        opt.style.background = 'rgba(99,102,241,0.05)';
      } else {
        opt.style.borderColor = 'rgba(255,255,255,0.06)';
        opt.style.background = 'rgba(255,255,255,0.01)';
      }
      updateSummary();
    });
  });

  if (submitBtn) {
    submitBtn.addEventListener('click', async function() {
      if (!email || !submitBtn.classList.contains('enabled')) return;
      submitText.setAttribute('data-restore', 'ENVIAR COTIZACIÓN');
      submitBtn.style.opacity = '0.5';
      submitBtn.style.pointerEvents = 'none';
      submitText.textContent = 'Enviando...';
      if (submitSpinner) submitSpinner.classList.remove('hidden');
      var selected = [];
      var total = 0;
      checkboxes.forEach(function(cb) {
        if (cb.checked) {
          var opt = cb.closest('.cotizar-option');
          var name = opt.querySelector('.font-heading.font-semibold').textContent.trim();
          var slug = opt.getAttribute('data-slug') || name.toLowerCase().replace(/\s+/g, '-');
          var price = parseInt(opt.getAttribute('data-price'));
          total += price;
          selected.push({ id: slug, name: name, price: price });
        }
      });
      try {
        var finalDiscount = discountRow.classList.contains('hidden') ? 0 : parseInt(discountEl.textContent.replace(/[^0-9]/g, ''));
        var res = await fetch('/api/submit-quote', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, services: selected, total: total }),
        });
        if (res.ok) {
          summary.innerHTML = '<div style="text-align:center;padding:1.5rem 0;"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2" stroke-linecap="round" style="display:block;margin:0 auto 0.75rem;"><polyline points="20 6 9 17 4 12"/></svg><p style="font-size:0.8rem;color:rgba(255,255,255,0.6);font-family:var(--font-body);margin-bottom:0.4rem;">¡Cotización enviada!</p><p style="font-size:0.68rem;color:rgba(255,255,255,0.3);font-family:var(--font-body);">Te contactamos pronto a<br><strong style="color:rgba(255,255,255,0.55);">' + email + '</strong></p><p style="font-size:0.72rem;color:rgba(255,255,255,0.4);font-family:var(--font-heading);font-weight:700;margin-top:0.75rem;padding-top:0.75rem;border-top:1px solid rgba(255,255,255,0.06);">' + formatPrice(total - finalDiscount) + '</p></div>';
          checkboxes.forEach(function(cb) { cb.checked = false; });
          if (submitBtn) submitBtn.style.display = 'none';
          subtotalEl.textContent = '$0';
          totalEl.textContent = '$0';
          discountRow.classList.add('hidden');
        } else {
          submitText.textContent = 'Error al enviar.';
          setTimeout(function() { submitBtn.style.opacity='1'; submitBtn.style.pointerEvents='auto'; submitText.textContent = 'ENVIAR COTIZACIÓN'; if (submitSpinner) submitSpinner.classList.add('hidden'); }, 3000);
        }
      } catch(e) {
        submitText.textContent = 'Error de conexión.';
        setTimeout(function() { submitBtn.style.opacity='1'; submitBtn.style.pointerEvents='auto'; submitText.textContent = 'ENVIAR COTIZACIÓN'; if (submitSpinner) submitSpinner.classList.add('hidden'); }, 3000);
      }
    });
  }

  updateSummary();
})();
</script>

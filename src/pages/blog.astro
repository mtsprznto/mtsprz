---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

function isRecent(d: Date): boolean {
  const weekAgo = new Date();
  weekAgo.setDate(weekAgo.getDate() - 7);
  return d >= weekAgo;
}
---

<BaseLayout
  title="Blog de Marketing Digital y SEO — Mtsprz"
  description="Artículos sobre SEO local, marketing digital, desarrollo web y automatizaciones para pymes en la Región de Los Lagos y el sur de Chile."
  canonical="https://mtsprz.org/blog"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Blog",
    "@id": "https://mtsprz.org/blog#blog",
    "name": "Blog de Marketing Digital y SEO | Mtsprz",
    "description": "Artículos sobre SEO local, marketing digital, desarrollo web y automatizaciones para pymes en la Región de Los Lagos y el sur de Chile.",
    "url": "https://mtsprz.org/blog",
    "publisher": { "@id": "https://mtsprz.org/#organization" },
    "blogPost": [
      ...posts.map((p) => ({
        "@type": "BlogPosting",
        "@id": `https://mtsprz.org/blog/${p.id.replace(/\.(md|mdx)$/, "")}#article`,
        "headline": p.data.title,
        "description": p.data.description,
        "datePublished": p.data.pubDate.toISOString(),
        "author": { "@type": "Person", "name": p.data.author || "Mtsprz", "url": "https://mtsprz.org/#person" },
      })),
    ],
  })} />
  <Header />
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  <main>
    <!-- Hero — video background full-bleed -->
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent sm:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent sm:h-48"></div>

      <!-- Contenido central -->
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <div class="text-center px-6" style="pointer-events: auto;">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Blog</p>
          <h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-heading font-bold text-white leading-[0.9] tracking-[-3px] md:tracking-[-4px]">BLOG</h1>
          <p class="mt-4 text-white/50 font-body font-light max-w-md mx-auto text-sm md:text-base">
            Consejos y guías sobre soluciones digitales para pymes del sur de Chile
          </p>
        </div>
      </div>

      <!-- Breadcrumb — integrado en hero, esquina inferior -->
      <div class="absolute bottom-8 md:bottom-10 left-0 right-0 z-20 px-6">
        <div class="mx-auto max-w-6xl">
          <Breadcrumbs items={[{ name: "Blog", path: "/blog" }]} />
        </div>
      </div>
    </section>

    <!-- Editorial blog listing -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 30% 0%, #6366f110 0%, transparent 50%), radial-gradient(ellipse at 70% 100%, #8b5cf606 0%, transparent 50%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />

      <div class="relative mx-auto max-w-4xl px-6 py-28 md:py-36">
        <div class="reveal-group divide-y divide-white/[0.06]">
          {
            posts.map((post, i) => {
              const postSlug = post.id.replace(/\.(md|mdx)$/, "");
              return (
                <article class="reveal-item group py-8 md:py-10 first:pt-0">
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
                    <div class="min-w-0 flex-1">
                      <!-- Meta editorial -->
                      <div class="flex flex-wrap items-center gap-2.5 text-[11px] text-white/30 font-body tracking-wide mb-3">
                        <time datetime={post.data.pubDate.toISOString()}>
                          {post.data.pubDate.toLocaleDateString("es-CL", {
                            year: "numeric",
                            month: "long",
                            day: "numeric",
                          })}
                        </time>
                        {post.data.modifiedTime && (
                          <>
                            <span class="text-white/15">&middot;</span>
                            <span class="text-emerald-400/70">Actualizado</span>
                          </>
                        )}
                      </div>

                      <!-- Título -->
                      <h2 class="text-xl md:text-2xl lg:text-3xl font-heading font-bold text-white leading-snug tracking-[-0.5px] md:tracking-[-1px]">
                        <a
                          href={`/blog/${postSlug}`}
                          class="transition-colors duration-300 hover:text-white/60"
                        >
                          {post.data.title}
                        </a>
                      </h2>

                      <!-- Descripción -->
                      <p class="mt-2.5 text-sm md:text-[15px] text-white/45 font-body font-light leading-relaxed max-w-2xl">
                        {post.data.description}
                      </p>

                      <!-- Tags -->
                      <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1">
                        {post.data.tags.map((tag) => (
                          <span class="text-[10px] text-white/25 font-body tracking-[0.05em] uppercase">
                            {tag}
                          </span>
                        ))}
                      </div>
                    </div>

                    <!-- CTA flecha -->
                    <div class="shrink-0 pt-1 hidden sm:block">
                      <a
                        href={`/blog/${postSlug}`}
                        class="flex items-center justify-center w-10 h-10 rounded-full border border-white/10 text-white/30 group-hover:text-white group-hover:border-white/30 transition-all duration-300"
                        aria-label="Leer artículo"
                      >
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                      </a>
                    </div>
                  </div>
                </article>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

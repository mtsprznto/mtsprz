---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import StaggerText from "../components/StaggerText.astro";
import BlurText from "../components/BlurText.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Footer from "../components/Footer.astro";
import { ArrowUpRight } from "@lucide/astro";
import Testimonials from "../components/Testimonials.astro";
import testimonialsData from "../data/testimonials.json";

interface Service {
  icon: string;
  title: string;
  description: string;
  tags: string[];
  accent: string;
}

const services: Service[] = [
  {
    icon: "Code",
    title: "Desarrollo Web",
    description: "Landing pages, sitios corporativos, e-commerce y aplicaciones web a medida. Modernos, veloces y hechos para convertir.",
    tags: ["Landing Pages", "Sitios Web", "E-commerce", "Apps Web"],
    accent: "#6366f1",
  },
  {
    icon: "Bot",
    title: "Automatización",
    description: "Bots WhatsApp, automatización Excel, flujos de email, CRM y workflows. Tu negocio funcionando solo.",
    tags: ["WhatsApp Bots", "Excel", "CRM", "Workflows"],
    accent: "#06b6d4",
  },
  {
    icon: "BarChart3",
    title: "Datos e Inteligencia",
    description: "Dashboards interactivos, scraping web, APIs a medida y OCR. Tus datos al servicio de tus decisiones.",
    tags: ["Dashboards", "Scraping", "APIs", "OCR"],
    accent: "#f97316",
  },
  {
    icon: "Search",
    title: "SEO",
    description: "Posicionamiento en Google Maps y búsquedas locales. Tu negocio apareciendo cuando te buscan en tu ciudad.",
    tags: ["SEO Local", "Google Maps", "Auditoría", "Contenido"],
    accent: "#10b981",
  },
  {
    icon: "TrendingUp",
    title: "Marketing Digital",
    description: "Google Ads, redes sociales y estrategia de contenido. Resultados medibles desde la primera semana.",
    tags: ["Google Ads", "Redes Sociales", "Contenido", "Analítica"],
    accent: "#f59e0b",
  },
  {
    icon: "Palette",
    title: "Diseño Gráfico",
    description: "Identidad corporativa, logotipos y manual de marca. Tu marca profesional lista para el mercado.",
    tags: ["Logos", "Identidad", "Marca", "UX/UI"],
    accent: "#ec4899",
  },
  {
    icon: "Globe",
    title: "Consultoría Digital",
    description: "Diagnóstico gratuito de tu negocio. Hoja de ruta clara con prioridades, presupuestos y plazos.",
    tags: ["Diagnóstico", "Plan", "Pymes", "Estrategia"],
    accent: "#8b5cf6",
  },
];
---

<BaseLayout
  title="Mtsprz — Soluciones Digitales Profesionales en la Región de Los Lagos"
  description="Mtsprz transforma procesos manuales en software automatizado. Desarrollo web, automatizaci\u00f3n de procesos, dashboards de datos, bots WhatsApp, SEO local y m\u00e1s. Soluciones digitales para pymes en Puerto Varas, Osorno, Puerto Montt y toda la Regi\u00f3n de Los Lagos."
  video={{
    url: "https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4",
    name: "Mtsprz Soluciones Digitales - Hero",
    description: "Agencia de soluciones digitales en la Región de Los Lagos, Chile. Desarrollo web, SEO local, automatizaciones y marketing digital.",
    thumbnailUrl: "https://mtsprz.org/logo.jpg",
    uploadDate: "2026-06-19",
  }}
>
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": "https://mtsprz.org/#aboutpage",
    url: "https://mtsprz.org",
    description: "Mtsprz es una agencia de soluciones digitales en Puerto Varas, Región de Los Lagos, Chile. Ayudamos a pymes del sur de Chile a crecer con páginas web, SEO local, automatizaciones y diseño gráfico.",
    mainEntity: { "@id": "https://mtsprz.org/#organization" },
    significantLink: ["https://mtsprz.org/servicios", "https://mtsprz.org/portafolio", "https://mtsprz.org/blog"]
  })} />
  <Header />

  <main>
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent md:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent md:h-48"></div>
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none;">
        <div class="w-full max-w-7xl mx-auto px-6 flex flex-col items-center justify-center" style="pointer-events: auto;">
        <h1 aria-label="EXPERTOS EN SOLUCIONES DIGITALES" class="text-[clamp(1rem,5.5vw,6rem)] sm:text-6xl md:text-7xl lg:text-[6rem] font-heading font-bold text-white leading-[1.05] tracking-tight text-center">
          <span aria-hidden="true">
            <StaggerText
              text="EXPERTOS EN"
              as="span"
              className="block"
              staggerMs={0.05}
            />
            <StaggerText
              text="SOLUCIONES DIGITALES"
              as="span"
              className="block text-white/70 -mt-1 sm:-mt-2"
              staggerMs={0.045}
            />
          </span>
        </h1>
        <p class="mt-6 sm:mt-8 text-sm sm:text-base md:text-lg text-white/60 font-body font-light leading-relaxed max-w-xl text-center">
          Creamos sitios web profesionales, posicionamos tu negocio en Google y automatizamos tus procesos.
          <span class="block mt-1.5 text-white/60 text-xs sm:text-sm leading-relaxed">Tu agencia digital de confianza en Puerto Varas y la Región de Los Lagos.</span>
        </p>
        <div class="mt-8 flex items-center gap-4">
          <button onclick="window.openCotizarModal()" class="liquid-glass-strong rounded-full px-7 sm:px-10 py-3.5 sm:py-4 text-sm font-medium text-white/90 tracking-[0.18em] uppercase flex items-center gap-2 transition-all hover:scale-[1.03] hover:text-white cursor-pointer">
            Cotizar
            <ArrowUpRight size={16} stroke-width="2" />
          </button>
        </div>
        <div class="mt-10 inline-flex flex-wrap items-center gap-x-5 gap-y-2 justify-center rounded-full border border-white/[0.08] bg-white/[0.04] px-5 py-2 text-[11px] text-white/80 font-body tracking-wide backdrop-blur-sm">
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Sin compromiso
          </span>
          <span class="text-white/20">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Atención personalizada
          </span>
          <span class="text-white/20">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Puerto Varas — Los Lagos
          </span>
          </div>
        </div>
      </div>

      <div class="absolute bottom-6 left-0 w-full flex justify-center z-10" style="pointer-events: none;">
        <div class="w-5 h-8 rounded-full border border-white/15 flex items-start justify-center pt-1.5" style="pointer-events: auto;">
          <div class="w-1 h-2 rounded-full bg-white/30" />
        </div>
      </div>
    </section>

    <!-- Service Discovery — 2026 SEO: indexable, linked, GEO-optimized -->
    <section class="relative bg-[#010101] py-16 md:py-20" id="diagnostico">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <div class="liquid-glass rounded-[1.5rem] p-8 md:p-10">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-3">Diagnóstico Rápido</p>
          <h2 class="text-xl sm:text-2xl md:text-3xl font-heading font-bold text-white tracking-[-0.5px]">
            ¿Qué necesita tu negocio en <span class="text-[#6366f1]">Puerto Varas</span>, <span class="text-[#10b981]">Osorno</span> o <span class="text-[#06b6d4]">Valdivia</span>?
          </h2>
          <p class="mt-2 text-sm text-white/50 font-body font-light max-w-lg mx-auto">
            Cada pyme es diferente. Encuentra el servicio digital ideal para tu empresa en la Región de Los Lagos.
          </p>

          <!-- Service cards — fully crawlable anchor links -->
          <div class="mt-8 grid gap-4 sm:grid-cols-3 text-left">
            <a href="/servicios/#desarrollo-web" class="group block rounded-xl border border-white/10 p-5 hover:border-[#6366f1]/50 transition-all duration-300">
              <svg class="w-6 h-6 text-[#6366f1] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7.5 3.75L2.25 12l5.25 8.25m9-16.5L21.75 12l-5.25 8.25"/></svg>
              <h3 class="text-white font-heading font-semibold text-base">Sitio Web Profesional</h3>
              <p class="mt-1 text-sm text-white/50 font-body leading-relaxed">Páginas ultrarrápidas con Astro, diseño responsive y SEO local incluido para tu negocio en el sur de Chile.</p>
              <span class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-[#6366f1] group-hover:gap-2 transition-all">Saber más →</span>
            </a>
            <a href="/servicios/#seo" class="group block rounded-xl border border-white/10 p-5 hover:border-[#10b981]/50 transition-all duration-300">
              <svg class="w-6 h-6 text-[#10b981] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/></svg>
              <h3 class="text-white font-heading font-semibold text-base">Posicionamiento SEO Local</h3>
              <p class="mt-1 text-sm text-white/50 font-body leading-relaxed">Aparece en Google Maps y búsquedas locales en Puerto Varas, Osorno, Valdivia y toda la Región de Los Lagos.</p>
              <span class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-[#10b981] group-hover:gap-2 transition-all">Saber más →</span>
            </a>
            <a href="/servicios/#automatizaciones" class="group block rounded-xl border border-white/10 p-5 hover:border-[#06b6d4]/50 transition-all duration-300">
              <svg class="w-6 h-6 text-[#06b6d4] mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>
              <h3 class="text-white font-heading font-semibold text-base">Automatización de Procesos</h3>
              <p class="mt-1 text-sm text-white/50 font-body leading-relaxed">Bots para WhatsApp, flujos de email marketing, integraciones CRM y workflows que ahorran horas a tu pyme.</p>
              <span class="mt-2 inline-flex items-center gap-1 text-xs font-medium text-[#06b6d4] group-hover:gap-2 transition-all">Saber más →</span>
            </a>
          </div>

          <!-- Full-width CTA for undecided visitors -->
          <a href="/contacto" class="mt-4 group block rounded-xl border border-[#6366f1]/20 p-4 bg-[#6366f1]/5 hover:bg-[#6366f1]/10 hover:border-[#6366f1]/40 transition-all duration-300">
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 sm:gap-4">
              <div class="text-left">
                <h3 class="text-white font-heading font-semibold text-sm">¿No sabes por dónde empezar?</h3>
                <p class="mt-0.5 sm:mt-0 text-sm text-white/50 font-body">Cuéntanos tu situación y te recomendamos la solución ideal sin compromiso.</p>
              </div>
              <span class="self-start sm:self-auto shrink-0 inline-flex items-center gap-1 text-xs font-medium text-[#6366f1] group-hover:gap-2 transition-all whitespace-nowrap">Diagnóstico gratuito →</span>
            </div>
          </a>

          <!-- GEO Quick Answer Block — optimized for AI Overviews extraction -->
          <div class="mt-6 pt-4 border-t border-white/5 text-left">
            <p class="text-xs text-white/40 font-body leading-relaxed">
              <strong class="text-white/60">Respuesta rápida: </strong>
              La mayoría de las pymes en la Región de Los Lagos comienzan con un sitio web profesional optimizado para SEO local.
              Si ya tienes página, el siguiente paso es el posicionamiento en Google Maps y búsquedas locales.
              Las automatizaciones son ideales cuando tu negocio empieza a recibir más clientes de los que puedes atender manualmente.
              <a href="/contacto" class="text-[#6366f1] hover:underline ml-1">Solicita un diagnóstico →</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Structured Data: Service + FAQPage (2026 SEO / GEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://mtsprz.org/#service-web",
          "name": "Desarrollo Web Profesional",
          "description": "Páginas web ultrarrápidas con Astro para pymes en la Región de Los Lagos. Diseño responsive, SEO local incluido y optimización Core Web Vitals.",
          "provider": { "@id": "https://mtsprz.org/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Puerto Varas" },
            { "@type": "City", "name": "Osorno" },
            { "@type": "City", "name": "Valdivia" }
          ],
          "serviceType": "Desarrollo Web"
        },
        {
          "@type": "Service",
          "@id": "https://mtsprz.org/#service-seo",
          "name": "Posicionamiento SEO Local",
          "description": "Optimización para Google Maps y búsquedas locales en Puerto Varas, Osorno, Valdivia y toda la Región de Los Lagos.",
          "provider": { "@id": "https://mtsprz.org/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Puerto Varas" },
            { "@type": "City", "name": "Osorno" },
            { "@type": "City", "name": "Valdivia" }
          ],
          "serviceType": "SEO Local"
        },
        {
          "@type": "Service",
          "@id": "https://mtsprz.org/#service-automation",
          "name": "Automatización de Procesos",
          "description": "Bots para WhatsApp, flujos de email marketing, integraciones CRM y workflows que ahorran horas de trabajo a pymes del sur de Chile.",
          "provider": { "@id": "https://mtsprz.org/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Puerto Varas" },
            { "@type": "City", "name": "Osorno" },
            { "@type": "City", "name": "Valdivia" }
          ],
          "serviceType": "Automatización"
        },
        {
          "@type": "FAQPage",
          "@id": "https://mtsprz.org/#faq-home",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "¿Qué servicio digital necesita mi pyme en la Región de Los Lagos?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "La mayoría de las pymes en la Región de Los Lagos comienzan con un sitio web profesional optimizado para SEO local. Si ya tienes página, el siguiente paso es el posicionamiento en Google Maps y búsquedas locales. Las automatizaciones son ideales cuando tu negocio empieza a recibir más clientes de los que puedes atender manualmente."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cuánto cuesta una página web en Puerto Varas?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Los precios varían según la complejidad del proyecto. En Mtsprz ofrecemos sitios web profesionales con Astro desde presupuestos accesibles para pymes del sur de Chile, incluyendo SEO local y diseño responsive. Solicita un diagnóstico gratuito sin compromiso."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cómo funciona el SEO local en Osorno y Valdivia?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El SEO local optimiza tu presencia en Google Maps y búsquedas geográficas. Trabajamos con tu Google Business Profile, generamos citaciones en directorios chilenos y creamos contenido con keywords locales de la Región de Los Lagos para que tu negocio aparezca cuando los clientes buscan cerca."
              }
            }
          ]
        }
      ]
    })} />

    <section class="relative bg-[#010101] py-28 md:py-36 overflow-hidden">
      <div class="mx-auto max-w-6xl px-6">
        <div class="reveal-group text-center sm:text-left">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Servicios</p>
          <BlurText
            text="Todo lo que tu negocio necesita para crecer en el entorno digital"
            as="h2"
            className="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white leading-[1.05] tracking-[-1px] max-w-3xl"
          />
        </div>

        <div class="mt-16 md:mt-20 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((s, i) => (
            <div id={s.title.toLowerCase().replace(/\s+/g, '-')} class="service-card" data-tags={(s.title + " " + s.tags.join(" ")).toLowerCase()} style="transition: opacity 0.3s ease, transform 0.3s ease">
              <ServiceCard
                icon={s.icon}
                title={s.title}
                description={s.description}
                tags={s.tags}
                number={i + 1}
                accent={s.accent}
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#010101] py-28 md:py-36 border-t border-white/[0.03]">
      <div class="mx-auto max-w-6xl px-6">
        <div class="reveal-group max-w-3xl mx-auto text-center">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Nosotros</p>
          <h2 class="reveal-item text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white leading-[1.05] tracking-[-1px]">
            Agencia Digital en la Región de Los Lagos
          </h2>
          <p class="reveal-item mt-6 text-white/60 font-body font-light leading-relaxed max-w-2xl mx-auto text-sm sm:text-base">
            Mtsprz nació en Puerto Varas con la misión de llevar soluciones digitales profesionales a las pymes del sur de Chile. Sabemos que las empresas de la Región de Los Lagos necesitan presencia digital de calidad sin pagar precios de Santiago. Por eso creamos sitios web ultrarrápidos con Astro, estrategias SEO locales que realmente posicionan en Google, automatizaciones que ahorran horas de trabajo y diseño gráfico que construye marcas memorables.
          </p>
          <p class="reveal-item mt-4 text-white/50 font-body font-light leading-relaxed max-w-2xl mx-auto text-sm">
            Trabajamos con negocios de <a href="/regiones/puerto-varas" class="text-white/70 underline underline-offset-2 decoration-white/20 hover:decoration-white/60 transition-all">Puerto Varas</a>, <a href="/regiones/osorno" class="text-white/70 underline underline-offset-2 decoration-white/20 hover:decoration-white/60 transition-all">Osorno</a>, <a href="/regiones/valdivia" class="text-white/70 underline underline-offset-2 decoration-white/20 hover:decoration-white/60 transition-all">Valdivia</a>, Ancud, Castro y toda la Región de Los Lagos. Cada proyecto incluye optimización SEO desde el día uno, diseño responsive y atención personalizada sin importar el tamaño de tu empresa.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-[#010101] py-28 md:py-36">
      <div class="mx-auto max-w-6xl px-6">
        <div class="cta-card reveal-group relative rounded-[1.375rem] p-10 md:p-14 text-center max-w-3xl mx-auto overflow-hidden bg-[#0a0a0b] border border-white/[0.06]">
          <!-- Animated gradient background -->
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 50% 0%, #6366f133, transparent 60%);" />
            <div class="absolute -top-1/2 -left-1/2 w-full h-full animate-gradient-slow opacity-20" style="background: conic-gradient(from 0deg at 50% 50%, #6366f1, #8b5cf6, #ec4899, #6366f1); filter: blur(80px);" />
          </div>
          <!-- Decorative dots -->
          <div class="absolute top-6 left-8 flex gap-2 opacity-20 pointer-events-none">
            <div class="w-1.5 h-1.5 rounded-full bg-white/40" />
            <div class="w-1.5 h-1.5 rounded-full bg-white/20" />
            <div class="w-1.5 h-1.5 rounded-full bg-white/10" />
          </div>
          <div class="relative">
            <BlurText
              text="Listo para impulsar tu negocio?"
              as="h2"
              className="text-2xl sm:text-3xl md:text-4xl font-heading font-bold text-white tracking-[-1px] leading-[1.1]"
            />
            <p class="mx-auto mt-4 max-w-lg text-sm text-white/50 font-body font-light leading-relaxed">
              Conversemos sin compromiso. Te ayudamos a definir la mejor estrategia digital para tu empresa en el sur de Chile.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
              <a
                href="/contacto"
                class="group relative inline-flex items-center gap-2.5 rounded-full px-7 py-3.5 text-sm font-medium text-white transition-all duration-300"
                style="background: linear-gradient(135deg, #6366f1, #8b5cf6);"
              >

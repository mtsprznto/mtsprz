---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import StaggerText from "../components/StaggerText.astro";
import BlurText from "../components/BlurText.astro";
import CinematicColumn from "../components/CinematicColumn.astro";
import Footer from "../components/Footer.astro";
import Testimonials from "../components/Testimonials.astro";
import testimonialsData from "../data/testimonials.json";
import { query, initDb } from "../lib/db";
import { toServiceDisplay } from "../lib/service-display";

await initDb();
const dbRows = await query(
  `SELECT DISTINCT ON (LOWER(TRIM(category))) slug, name, description, category
   FROM services WHERE is_active = true AND category IS NOT NULL
   ORDER BY LOWER(TRIM(category)), is_popular DESC, id`
);
const services = dbRows.rows.map((row: any) => toServiceDisplay(row as any));

// Feature-d sections for homepage diagnosis
const diagnosisSlugs = ["desarrollo-web", "seo", "automatizaciones"];
const diagnosisServices = services.filter((s: any) => diagnosisSlugs.includes(s.slug));
// Hardcoded fallbacks if DB doesn't have these categories yet
const diagnosisFallbacks = [
  { title: "Sitio Web Profesional", description: "Páginas ultrarrápidas con Astro, diseño responsive y SEO local incluido para tu negocio en el sur de Chile.", accent: "#6366f1", slug: "desarrollo-web", icon: "Code", tags: [], landingUrl: "/desarrollo-web" },
  { title: "Posicionamiento SEO Local", description: "Aparece en Google Maps y búsquedas locales en Puerto Varas, Osorno, Valdivia y toda la Región de Los Lagos.", accent: "#10b981", slug: "seo", icon: "Search", tags: [], landingUrl: "/seo-local" },
  { title: "Automatización de Procesos", description: "Bots para WhatsApp, flujos de email marketing, integraciones CRM y workflows que ahorran horas a tu pyme.", accent: "#06b6d4", slug: "automatizaciones", icon: "Bot", tags: [], landingUrl: "/automatizacion" },
];
const featured = diagnosisServices.length >= 3 ? diagnosisServices : diagnosisFallbacks;
---

<BaseLayout
  title="Mtsprz — Soluciones Digitales Profesionales en la Región de Los Lagos"
  description="Mtsprz transforma procesos manuales en software automatizado. Desarrollo web, automatizaci\u00f3n de procesos, dashboards de datos, bots WhatsApp, SEO local y m\u00e1s. Soluciones digitales para pymes en Puerto Varas, Osorno, Puerto Montt y toda la Regi\u00f3n de Los Lagos."
  video={{
    url: "https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4",
    name: "Mtsprz Soluciones Digitales - Hero",
    description: "Agencia de soluciones digitales en la Región de Los Lagos, Chile. Desarrollo web, SEO local, automatizaciones y marketing digital.",
    thumbnailUrl: "https://mtsprz.org/logo.jpg",
    uploadDate: "2026-06-19",
  }}
>
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": "https://mtsprz.org/#aboutpage",
    url: "https://mtsprz.org",
    description: "Mtsprz es una agencia de soluciones digitales en Puerto Varas, Región de Los Lagos, Chile. Ayudamos a pymes del sur de Chile a crecer con páginas web, SEO local, automatizaciones y diseño gráfico.",
    mainEntity: { "@id": "https://mtsprz.org/#organization" },
    significantLink: ["https://mtsprz.org/servicios", "https://mtsprz.org/portafolio", "https://mtsprz.org/blog"]
  })} />
  <Header />

  <main>
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent md:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent md:h-48"></div>
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; flex-direction: column; align-items: center; justify-content: center; pointer-events: none;">
        <div class="w-full max-w-7xl mx-auto px-6 flex flex-col items-center justify-center" style="pointer-events: auto;">
        <h1 aria-label="EXPERTOS EN SOLUCIONES DIGITALES" class="text-[clamp(1rem,5.5vw,6rem)] sm:text-6xl md:text-7xl lg:text-[6rem] font-heading font-bold text-white leading-[1.05] tracking-tight text-center">
          <span aria-hidden="true">
            <StaggerText
              text="EXPERTOS EN"
              as="span"
              className="block"
              staggerMs={0.05}
            />
            <StaggerText
              text="SOLUCIONES DIGITALES"
              as="span"
              className="block text-white/70 -mt-1 sm:-mt-2"
              staggerMs={0.045}
            />
          </span>
        </h1>
        <p class="mt-6 sm:mt-8 text-sm sm:text-base md:text-lg text-white/60 font-body font-light leading-relaxed max-w-xl text-center">
          Creamos sitios web profesionales, posicionamos tu negocio en Google y automatizamos tus procesos.
          <span class="block mt-1.5 text-white/60 text-xs sm:text-sm leading-relaxed">Tu agencia digital de confianza en Puerto Varas y la Región de Los Lagos.</span>
        </p>
        <div class="mt-8 flex items-center gap-4">
          <button onclick="window.openCotizarModal()" class="liquid-glass-strong rounded-full px-7 sm:px-10 py-3.5 sm:py-4 text-sm font-medium text-white/90 tracking-[0.18em] uppercase flex items-center gap-2 transition-all hover:scale-[1.03] hover:text-white cursor-pointer">
            Cotizar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
          </button>
        </div>
        <div class="mt-10 inline-flex flex-wrap items-center gap-x-5 gap-y-2 justify-center rounded-full border border-white/[0.08] bg-white/[0.04] px-5 py-2 text-[11px] text-white/80 font-body tracking-wide backdrop-blur-sm">
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Sin compromiso
          </span>
          <span class="text-white/20">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Atención personalizada
          </span>
          <span class="text-white/20">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Puerto Varas — Los Lagos
          </span>
          </div>
        </div>
      </div>

      <div class="absolute bottom-6 left-0 w-full flex justify-center z-10" style="pointer-events: none;">
        <div class="w-5 h-8 rounded-full border border-white/15 flex items-start justify-center pt-1.5" style="pointer-events: auto;">
          <div class="w-1 h-2 rounded-full bg-white/30" />
        </div>
      </div>
    </section>

    <!-- Diagnóstico — editorial cinematic columns -->
    <section class="relative bg-[#0A0A0A] w-full" id="diagnostico">
      <!-- Header -->
      <div class="mx-auto max-w-5xl px-6 pt-20 md:pt-28 pb-14 md:pb-18 text-center">
        <div class="reveal-group">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-3">Diagnóstico Rápido</p>
          <h2 class="reveal-item text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-heading font-bold text-white leading-[1.05] tracking-[-1px]">
            ¿Qué necesita tu negocio en <span style="color: #6366f1">Puerto Varas</span>, <span style="color: #10b981">Osorno</span> o <span style="color: #06b6d4">Valdivia</span>?
          </h2>
          <p class="reveal-item mt-3 text-sm md:text-base text-white/50 font-body font-light max-w-lg mx-auto">
            Cada pyme es diferente. Encuentra el servicio digital ideal para tu empresa en la Región de Los Lagos.
          </p>
        </div>
      </div>

      <!-- 3 editorial columns — full-bleed, cada una link a su landing si existe -->
      <div class="w-full overflow-hidden reveal-group">
        <div class="grid grid-cols-1 md:grid-cols-3">
          {featured.map((s, i) => (
            <div class="reveal-item">
              <CinematicColumn
                title={s.title}
                description={s.description}
                accent={s.accent}
                slug={s.slug}
                index={i}
                href={s.landingUrl || `/servicios/#${s.slug}`}
                ctaText="Explorar"
                compact
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Full-width CTA + GEO Quick Answer — sutil, debajo de columnas -->
      <div class="mx-auto max-w-5xl px-6 py-16 md:py-20">
        <div class="reveal-group">
          <a href="/contacto" class="reveal-item group flex flex-col sm:flex-row sm:items-center justify-between gap-4 rounded-xl px-6 md:px-8 py-5 md:py-6 transition-all duration-300"
            style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05);"
          >
            <div>
              <h3 class="text-sm md:text-base font-heading font-semibold text-white/80">¿No sabes por dónde empezar?</h3>
              <p class="mt-0.5 text-xs md:text-sm text-white/40 font-body">Cuéntanos tu situación y te recomendamos la solución ideal sin compromiso.</p>
            </div>
            <span class="shrink-0 inline-flex items-center gap-1.5 text-xs font-medium tracking-[0.1em] uppercase transition-all duration-300 group-hover:gap-3"
              style="color: #6366f1cc;"
            >
              Diagnóstico gratuito
              <svg class="w-3.5 h-3.5 transition-transform duration-300 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </span>
          </a>

          <!-- GEO Quick Answer -->
          <div class="reveal-item mt-6 pt-5 border-t border-white/5 text-left">
            <p class="text-xs text-white/35 font-body leading-relaxed">
              <strong class="text-white/50">Respuesta rápida: </strong>
              La mayoría de las pymes en la Región de Los Lagos comienzan con un sitio web profesional optimizado para SEO local.
              Si ya tienes página, el siguiente paso es el posicionamiento en Google Maps y búsquedas locales.
              Las automatizaciones son ideales cuando tu negocio empieza a recibir más clientes de los que puedes atender manualmente.
              <a href="/contacto" class="hover:underline ml-1" style="color: #6366f1bb;">Solicita un diagnóstico →</a>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Structured Data: Service + FAQPage (2026 SEO / GEO) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Service",
          "@id": "https://mtsprz.org/#service-web",
          "name": "Desarrollo Web Profesional",
          "description": "Páginas web ultrarrápidas con Astro para pymes en la Región de Los Lagos. Diseño responsive, SEO local incluido y optimización Core Web Vitals.",
          "provider": { "@id": "https://mtsprz.org/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Puerto Varas" },
            { "@type": "City", "name": "Osorno" },
            { "@type": "City", "name": "Valdivia" }
          ],
          "serviceType": "Desarrollo Web"
        },
        {
          "@type": "Service",
          "@id": "https://mtsprz.org/#service-seo",
          "name": "Posicionamiento SEO Local",
          "description": "Optimización para Google Maps y búsquedas locales en Puerto Varas, Osorno, Valdivia y toda la Región de Los Lagos.",
          "provider": { "@id": "https://mtsprz.org/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Puerto Varas" },
            { "@type": "City", "name": "Osorno" },
            { "@type": "City", "name": "Valdivia" }
          ],
          "serviceType": "SEO Local"
        },
        {
          "@type": "Service",
          "@id": "https://mtsprz.org/#service-automation",
          "name": "Automatización de Procesos",
          "description": "Bots para WhatsApp, flujos de email marketing, integraciones CRM y workflows que ahorran horas de trabajo a pymes del sur de Chile.",
          "provider": { "@id": "https://mtsprz.org/#organization" },
          "areaServed": [
            { "@type": "City", "name": "Puerto Varas" },
            { "@type": "City", "name": "Osorno" },
            { "@type": "City", "name": "Valdivia" }
          ],
          "serviceType": "Automatización"
        },
        {
          "@type": "FAQPage",
          "@id": "https://mtsprz.org/#faq-home",
          "mainEntity": [
            {
              "@type": "Question",
              "name": "¿Qué servicio digital necesita mi pyme en la Región de Los Lagos?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "La mayoría de las pymes en la Región de Los Lagos comienzan con un sitio web profesional optimizado para SEO local. Si ya tienes página, el siguiente paso es el posicionamiento en Google Maps y búsquedas locales. Las automatizaciones son ideales cuando tu negocio empieza a recibir más clientes de los que puedes atender manualmente."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cuánto cuesta una página web en Puerto Varas?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Los precios varían según la complejidad del proyecto. En Mtsprz ofrecemos sitios web profesionales con Astro desde presupuestos accesibles para pymes del sur de Chile, incluyendo SEO local y diseño responsive. Solicita un diagnóstico gratuito sin compromiso."
              }
            },
            {
              "@type": "Question",
              "name": "¿Cómo funciona el SEO local en Osorno y Valdivia?",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "El SEO local optimiza tu presencia en Google Maps y búsquedas geográficas. Trabajamos con tu Google Business Profile, generamos citaciones en directorios chilenos y creamos contenido con keywords locales de la Región de Los Lagos para que tu negocio aparezca cuando los clientes buscan cerca."
              }
            }
          ]
        }
      ]
    })} />

    <!-- Services — editorial cinematic columns -->
    <section class="relative bg-[#0A0A0A] w-full">
      <!-- Header -->
      <div class="mx-auto max-w-5xl px-6 pt-20 md:pt-28 pb-14 md:pb-18 text-center">
        <div class="reveal-group">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Servicios</p>
          <BlurText
            text="Todo lo que tu negocio necesita para crecer en el entorno digital"
            as="h2"
            className="reveal-item text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white leading-[1.05] tracking-[-1px] max-w-3xl mx-auto"
            wordMs={60}
          />
        </div>
      </div>

      <!-- Columnas editoriales — full-bleed, asimétricas -->
      <div class="w-full overflow-hidden reveal-group">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12">
          {services.map((s, i) => {
            const span = i % 3 === 0 ? "lg:col-span-6" : "lg:col-span-3";
            return (
              <div class={`${span} md:col-span-1 reveal-item`}>
                <CinematicColumn
                  title={s.title}
                  description={s.description}
                  accent={s.accent}
                  slug={s.slug}
                  index={i}
                  href={s.landingUrl || "/cotizar"}
                  ctaText={s.landingUrl ? "Explorar" : "Cotizar"}
                  compact
                />
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Nosotros — editorial brand spread -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <!-- Background cinematográfico — iluminación de estudio dramática -->
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-60" style="background: radial-gradient(ellipse at 30% 20%, #6366f122 0%, transparent 50%), radial-gradient(ellipse at 70% 80%, #8b5cf615 0%, transparent 50%), radial-gradient(ellipse at 50% 50%, #0A0A0A 0%, transparent 70%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <!-- Línea decorativa superior -->
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />

      <div class="relative mx-auto max-w-5xl px-6 py-28 md:py-36 lg:py-44">
        <div class="reveal-group text-center max-w-4xl mx-auto">
          <!-- Label editorial -->
          <p class="reveal-item text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-6 md:mb-8" style="color: #6366f1aa;">Sobre Nosotros</p>

          <!-- Título principal — enorme, editorial -->
          <h2 class="reveal-item text-4xl sm:text-5xl md:text-7xl lg:text-8xl xl:text-9xl font-heading font-bold text-white leading-[0.92] tracking-[-2px] md:tracking-[-3px] lg:tracking-[-4px] uppercase">
            Agencia Digital<br />
            <span class="block mt-1 md:mt-0" style="color: #6366f1cc;">Región de Los Lagos</span>
          </h2>

          <!-- Separador editorial -->
          <div class="reveal-item mx-auto my-8 md:my-10 w-12 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f166, transparent);" />

          <!-- Cuerpo — texto editorial con tracking amplio -->
          <div class="reveal-item max-w-3xl mx-auto space-y-5 md:space-y-6">
            <p class="text-sm md:text-base lg:text-lg text-white/55 font-body font-light leading-[1.8] md:leading-[1.9] tracking-[0.01em]">
              Mtsprz nació en <span class="text-white/80">Puerto Varas</span> con la misión de llevar soluciones digitales profesionales a las pymes del sur de Chile. Sabemos que las empresas de la Región de Los Lagos necesitan presencia digital de calidad sin pagar precios de Santiago. Por eso creamos sitios web ultrarrápidos con Astro, estrategias SEO locales que realmente posicionan en Google, automatizaciones que ahorran horas de trabajo y diseño gráfico que construye marcas memorables.
            </p>
            <p class="text-sm md:text-base text-white/45 font-body font-light leading-[1.8] md:leading-[1.9]">
              Trabajamos con negocios de toda la región.
            </p>
          </div>

          <!-- Regiones — chips editoriales -->
          <div class="reveal-item mt-10 md:mt-12 flex flex-wrap justify-center gap-3">
            {[
              { name: "Puerto Varas", slug: "puerto-varas" },
              { name: "Osorno", slug: "osorno" },
              { name: "Valdivia", slug: "valdivia" },
              { name: "Ancud", slug: "ancud" },
              { name: "Castro", slug: "castro" },
            ].map((r) => (
              <a
                href={`/regiones/${r.slug}`}
                class="group inline-flex items-center gap-2 px-4 md:px-5 py-2 md:py-2.5 text-[11px] md:text-xs font-medium tracking-[0.1em] uppercase transition-all duration-300"
                style="color: rgba(255,255,255,0.5); background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);"
                onmouseover="this.style.background='rgba(99,102,241,0.12)'; this.style.borderColor='rgba(99,102,241,0.3)'; this.style.color='rgba(255,255,255,0.85)'"
                onmouseout="this.style.background='rgba(255,255,255,0.03)'; this.style.borderColor='rgba(255,255,255,0.06)'; this.style.color='rgba(255,255,255,0.5)'"
              >
                <span>{r.name}</span>
                <svg class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity duration-300 -ml-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Línea decorativa inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />
    </section>

    <!-- CTA — editorial call to action -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <!-- Background cinematográfico -->
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-50" style="background: radial-gradient(ellipse at 50% 0%, #6366f128 0%, transparent 50%), radial-gradient(ellipse at 30% 100%, #8b5cf610 0%, transparent 50%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <!-- Líneas decorativas -->
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />

      <div class="relative mx-auto max-w-4xl px-6 py-28 md:py-36 lg:py-44 text-center">
        <div class="reveal-group">
          <!-- Label editorial -->
          <p class="reveal-item text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-6 md:mb-8" style="color: #6366f1aa;">Contacto</p>

          <!-- Título -->
          <h2 class="reveal-item text-3xl sm:text-4xl md:text-6xl lg:text-7xl xl:text-8xl font-heading font-bold text-white leading-[0.95] tracking-[-1.5px] md:tracking-[-2px] lg:tracking-[-3px]">
            Listo para impulsar<br />
            <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #6366f1, #8b5cf6);">tu negocio?</span>
          </h2>

          <!-- Separador -->
          <div class="reveal-item mx-auto my-8 md:my-10 w-12 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f166, transparent);" />

          <!-- Descripción -->
          <p class="reveal-item mx-auto max-w-xl text-sm md:text-base lg:text-lg text-white/50 font-body font-light leading-relaxed">
            Conversemos sin compromiso. Te ayudamos a definir la mejor estrategia digital para tu empresa en el sur de Chile.
          </p>

          <!-- CTA + teléfono -->
          <div class="reveal-item mt-10 md:mt-12 flex flex-col sm:flex-row items-center justify-center gap-5">
            <a
              href="/contacto"
              class="group inline-flex items-center gap-3 px-7 md:px-8 py-3.5 md:py-4 text-xs md:text-sm font-medium tracking-[0.15em] uppercase transition-all duration-300"
              style="color: #fff; background: linear-gradient(135deg, #6366f1, #8b5cf6);"
            >
              <span>Contáctanos</span>
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
            <span class="text-[11px] md:text-xs text-white/30 font-body tracking-wide">o llama al <span class="text-white/50">+56975475781</span></span>
          </div>

          <!-- Trust signals — chips editoriales -->
          <div class="reveal-item mt-12 md:mt-14 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
            {[
              { label: "Sin compromiso", accent: "#6366f1" },
              { label: "Respuesta en 24 hrs", accent: "#10b981" },
              { label: "Atención personalizada", accent: "#6366f1" },
            ].map((t) => (
              <span class="inline-flex items-center gap-2 text-[10px] md:text-xs font-medium tracking-[0.1em] uppercase" style="color: rgba(255,255,255,0.35);">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke={t.accent} stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                {t.label}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Testimonials testimonials={testimonialsData} />
  </main>

  <Footer />
</BaseLayout>

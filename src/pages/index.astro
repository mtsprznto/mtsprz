---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import StaggerText from "../components/StaggerText.astro";
import BlurText from "../components/BlurText.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Footer from "../components/Footer.astro";
import { ArrowUpRight } from "@lucide/astro";

interface Service {
  icon: string;
  title: string;
  description: string;
  tags: string[];
  accent: string;
}

const services: Service[] = [
  {
    icon: "Code",
    title: "Desarrollo Web",
    description: "Sitios web modernos con Astro. Rápidos, seguros y optimizados para SEO.",
    tags: ["Astro", "SEO", "Responsive", "Rendimiento"],
    accent: "#6366f1",
  },
  {
    icon: "Search",
    title: "SEO",
    description: "Posicionamiento en Google. SEO local, técnico y de contenido.",
    tags: ["Local", "Google", "Contenido", "Analítica"],
    accent: "#10b981",
  },
  {
    icon: "Bot",
    title: "Automatizaciones",
    description: "Bots, flujos de email, CRM y procesos automatizados.",
    tags: ["WhatsApp", "CRM", "Email", "Workflows"],
    accent: "#06b6d4",
  },
  {
    icon: "Palette",
    title: "Diseño Gráfico",
    description: "Identidad corporativa, logotipos y material publicitario.",
    tags: ["Identidad", "Logos", "UX/UI", "Marca"],
    accent: "#ec4899",
  },
  {
    icon: "TrendingUp",
    title: "Marketing Digital",
    description: "Redes sociales, Google Ads y estrategia de contenido.",
    tags: ["Redes", "Ads", "Contenido", "Analítica"],
    accent: "#f59e0b",
  },
  {
    icon: "Globe",
    title: "Consultoría Digital",
    description: "Diagnóstico y plan de transformación digital para pymes.",
    tags: ["Diagnóstico", "Plan", "Pymes", "Estrategia"],
    accent: "#8b5cf6",
  },
];
---

<BaseLayout
  title="Soluciones Digitales para el Sur de Chile"
  description="Mtsprz - Agencia de soluciones digitales en la Región de Los Lagos. Creamos páginas web, automatizaciones, SEO y marketing digital para pymes y empresas del sur de Chile."
>
  <Header />

  <main>
    <section class="relative min-h-screen w-full flex flex-col items-center overflow-hidden bg-[#010101]">
      <div class="absolute top-[15vh] left-0 w-full h-[100vh] z-0 pointer-events-none">
        <video
          src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
          autoplay
          loop
          muted
          playsinline
          class="w-full h-full object-cover opacity-100"
        />
        <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-[#010101] to-transparent" />
        <div class="absolute bottom-0 left-0 w-full h-48 bg-gradient-to-t from-[#010101] to-transparent" />
      </div>

      <div class="relative z-10 flex flex-1 flex-col items-center justify-center w-full max-w-7xl mx-auto px-6 pt-20 md:pt-32">
        <StaggerText
          text="EXPERTOS EN"
          as="h1"
          className="text-[clamp(1rem,5.5vw,6rem)] sm:text-6xl md:text-7xl lg:text-[6rem] font-heading font-bold text-white leading-[1.05] tracking-tight text-center"
          staggerMs={0.05}
        />
        <StaggerText
          text="SOLUCIONES DIGITALES"
          as="p"
          className="text-[clamp(1rem,5.5vw,6rem)] sm:text-6xl md:text-7xl lg:text-[6rem] font-heading font-bold text-white/70 leading-[1.05] tracking-tight text-center -mt-1 sm:-mt-2"
          staggerMs={0.045}
        />
        <p class="mt-6 sm:mt-8 text-sm sm:text-base md:text-lg text-white/60 font-body font-light leading-relaxed max-w-xl text-center">
          Creamos sitios web profesionales, posicionamos tu negocio en Google y automatizamos tus procesos.
          <span class="block mt-1.5 text-white/60 text-xs sm:text-sm leading-relaxed">Tu agencia digital de confianza en Puerto Varas y la Región de Los Lagos.</span>
        </p>
        <div class="mt-8 flex items-center gap-4">
          <a href="/contacto" class="liquid-glass-strong rounded-full px-7 sm:px-10 py-3.5 sm:py-4 text-sm font-medium text-white/90 tracking-[0.18em] uppercase flex items-center gap-2 transition-all hover:scale-[1.03] hover:text-white">
            Cotizar
            <ArrowUpRight size={16} stroke-width="2" />
          </a>
        </div>
        <div class="mt-10 inline-flex flex-wrap items-center gap-x-5 gap-y-2 justify-center rounded-full border border-white/[0.08] bg-white/[0.04] px-5 py-2 text-[11px] text-white/80 font-body tracking-wide backdrop-blur-sm">
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Sin compromiso
          </span>
          <span class="text-white/20">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Atención personalizada
          </span>
          <span class="text-white/20">|</span>
          <span class="flex items-center gap-1.5">
            <svg class="w-3 h-3 text-[#6366f1] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
            Puerto Varas — Los Lagos
          </span>
        </div>
      </div>

      <div class="absolute bottom-6 left-0 w-full flex justify-center z-10">
        <div class="w-5 h-8 rounded-full border border-white/15 flex items-start justify-center pt-1.5">
          <div class="w-1 h-2 rounded-full bg-white/30" />
        </div>
      </div>
    </section>

    <section class="relative bg-[#010101] py-28 md:py-36 overflow-hidden">
      <div class="mx-auto max-w-6xl px-6">
        <div class="reveal-group text-center sm:text-left">
          <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Servicios</p>
          <BlurText
            text="Todo lo que tu negocio necesita para crecer en el entorno digital"
            as="h2"
            className="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-heading font-bold text-white leading-[1.05] tracking-[-1px] max-w-3xl"
          />
        </div>

        <div class="mt-16 md:mt-20 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {services.map((s, i) => (
            <ServiceCard
              icon={s.icon}
              title={s.title}
              description={s.description}
              tags={s.tags}
              number={i + 1}
              accent={s.accent}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="bg-[#010101] py-28 md:py-36">
      <div class="mx-auto max-w-6xl px-6">
        <div class="cta-card reveal-group relative rounded-[1.375rem] p-10 md:p-14 text-center max-w-3xl mx-auto overflow-hidden bg-[#0a0a0b] border border-white/[0.06]">
          <!-- Animated gradient background -->
          <div class="absolute inset-0 pointer-events-none">
            <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 50% 0%, #6366f133, transparent 60%);" />
            <div class="absolute -top-1/2 -left-1/2 w-full h-full animate-gradient-slow opacity-20" style="background: conic-gradient(from 0deg at 50% 50%, #6366f1, #8b5cf6, #ec4899, #6366f1); filter: blur(80px);" />
          </div>
          <!-- Decorative dots -->
          <div class="absolute top-6 left-8 flex gap-2 opacity-20 pointer-events-none">
            <div class="w-1.5 h-1.5 rounded-full bg-white/40" />
            <div class="w-1.5 h-1.5 rounded-full bg-white/20" />
            <div class="w-1.5 h-1.5 rounded-full bg-white/10" />
          </div>
          <div class="relative">
            <BlurText
              text="Listo para impulsar tu negocio?"
              as="h2"
              className="text-2xl sm:text-3xl md:text-4xl font-heading font-bold text-white tracking-[-1px] leading-[1.1]"
            />
            <p class="mx-auto mt-4 max-w-lg text-sm text-white/50 font-body font-light leading-relaxed">
              Conversemos sin compromiso. Te ayudamos a definir la mejor estrategia digital para tu empresa en el sur de Chile.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
              <a
                href="/contacto"
                class="group relative inline-flex items-center gap-2.5 rounded-full px-7 py-3.5 text-sm font-medium text-white transition-all duration-300"
                style="background: linear-gradient(135deg, #6366f1, #8b5cf6);"
              >
                <span class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" style="background: #6366f166;" />
                <span class="relative">Contáctanos</span>
                <ArrowUpRight size={16} class="relative transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" stroke-width="2" />
              </a>
              <span class="text-[11px] text-white/30 font-body tracking-wide">o llama al <span class="text-white/50">+56975475781</span></span>
            </div>
            <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-[11px] text-white/30 font-body">
              <span class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-[#6366f1]/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                Sin compromiso
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-[#6366f1]/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                Respuesta en 24 hrs
              </span>
              <span class="flex items-center gap-1.5">
                <svg class="w-3 h-3 text-[#6366f1]/60 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                Atención personalizada
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

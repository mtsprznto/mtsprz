---
import BaseLayout from "../../layouts/BaseLayout.astro";
import pricing from "../../data/pricing.json";
export const prerender = false;
const { token } = Astro.params;
---

<BaseLayout title="Firmar Contrato — Mtsprz">
  <main class="min-h-screen bg-[#010101] px-4 py-12">
    <div class="mx-auto max-w-3xl">
      <div id="loadingState" class="text-center py-24">
        <div class="animate-spin w-8 h-8 border-2 border-accent/30 border-t-accent rounded-full mx-auto mb-4"></div>
        <p class="text-sm text-white/30">Cargando contrato...</p>
      </div>

      <div id="errorState" class="hidden text-center py-24">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-red-400/10 flex items-center justify-center">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        </div>
        <h2 class="text-lg font-semibold text-white/80 mb-2">Enlace inv&aacute;lido o expirado</h2>
        <p id="errorMsg" class="text-sm text-white/30">Este enlace de firma no es v&aacute;lido o ha expirado.</p>
        <p class="text-sm text-white/20 mt-4">Si crees que es un error, contacta a <span class="text-accent">contacto@mtsprz.org</span></p>
      </div>

      <div id="doneState" class="hidden text-center py-24">
        <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-emerald-400/10 flex items-center justify-center">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        <h2 class="text-lg font-semibold text-white/80 mb-2">&iexcl;Contrato Firmado Exitosamente!</h2>
        <p id="doneMsg" class="text-sm text-white/30">Gracias por firmar. Recibir&aacute;s una copia del contrato por correo.</p>
      </div>

      <div id="signForm" class="hidden space-y-6">
        <div class="text-center mb-6">
          <div class="text-2xl font-bold text-white/90 font-heading tracking-tight mb-1">
            <span class="text-accent">MTSPRZ</span> — Firma tu Contrato
          </div>
          <p id="contractNumber" class="text-sm text-white/30">Cargando...</p>
        </div>

        <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-5">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-400/10 text-emerald-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            </span>
            <span class="font-heading text-sm font-semibold text-white tracking-tight">Resumen del Contrato</span>
          </div>
          <div id="contractSummary" class="text-sm text-white/60 space-y-1"></div>
        </div>

        <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-5">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-amber-400/10 text-amber-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </span>
            <span class="font-heading text-sm font-semibold text-white tracking-tight">Tus Datos</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Nombre Completo *</label>
              <input id="fieldName" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body" maxlength="255" required />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">RUT</label>
              <input id="fieldRut" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-mono" placeholder="12.345.678-9" maxlength="20" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Tel&eacute;fono</label>
              <input id="fieldPhone" type="tel" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-mono" placeholder="+56 9 1234 5678" maxlength="50" />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Direcci&oacute;n</label>
              <input id="fieldAddress" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body" maxlength="500" />
            </div>
          </div>
        </div>

        <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-5">
          <div class="flex items-center gap-2.5 mb-4">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-400/10 text-violet-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            </span>
            <span class="font-heading text-sm font-semibold text-white tracking-tight">Tu Firma</span>
          </div>
          <p class="text-xs text-white/30 mb-3">Dibuja tu firma en el recuadro usando el mouse o tu dedo</p>
          <canvas id="sigCanvas" width="600" height="180" class="w-full h-auto border border-white/[0.06] rounded-xl bg-white cursor-crosshair" style="touch-action:none;"></canvas>
          <div class="flex gap-2 mt-3">
            <button type="button" onclick="clearCanvas()" class="inline-flex items-center px-3.5 py-2 rounded-full text-xs font-medium text-white/50 border border-white/[0.08] transition-all duration-200 hover:border-white/20 hover:text-white">Limpiar</button>
          </div>
        </div>

        <!-- Verificación Biométrica — Steps -->
        <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-5 space-y-5">
          <div class="flex items-center gap-2.5">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-sky-400/10 text-sky-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
            </span>
            <span class="font-heading text-sm font-semibold text-white tracking-tight">Verificaci&oacute;n de Identidad</span>
            <span id="bioStatus" class="ml-auto text-[10px] font-medium text-white/20 cursor-pointer">Pendiente</span>
          </div>

          <!-- Step 1: Cédula Frontal -->
          <div class="rounded-xl border border-white/[0.06] p-4 space-y-3">
            <div class="flex items-center gap-2">
              <span id="step1Dot" class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-[10px] font-bold text-white/40 shrink-0">1</span>
              <span class="text-xs font-medium text-white/70">Foto de c&eacute;dula frontal</span>
              <span id="step1Status" class="ml-auto text-[10px] text-white/30">Pendiente</span>
            </div>
            <p class="text-[11px] text-white/30 pl-8">Sube una foto clara de la parte <strong class="text-white/50">frontal</strong> de tu c&eacute;dula de identidad.</p>
            <div class="pl-8">
              <label id="step1Upload" class="flex items-center gap-2 px-3 py-2 rounded-lg border border-dashed border-white/[0.10] bg-white/[0.02] cursor-pointer hover:bg-white/[0.04] transition-colors w-fit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-white/40"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span class="text-[11px] text-white/40">Subir imagen</span>
                <input type="file" accept="image/*" class="hidden" onchange="handleIdUpload(this, 'front')" />
              </label>
              <div id="idFrontPreview" class="hidden mt-2 relative w-48">
                <img class="w-full rounded-lg border border-white/[0.06] object-cover" style="aspect-ratio:85/54" />
                <button type="button" onclick="removeIdUpload('front')" class="absolute top-1 right-1 w-5 h-5 rounded-full bg-black/70 text-white/80 text-[10px] flex items-center justify-center">✕</button>
              </div>
              <div id="frontFaceStatus" class="hidden mt-1 text-[10px]"></div>
            </div>
          </div>

          <!-- Step 2: Cédula Trasera + MRZ -->
          <div class="rounded-xl border border-white/[0.06] p-4 space-y-3">
            <div class="flex items-center gap-2">
              <span id="step2Dot" class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-[10px] font-bold text-white/40 shrink-0">2</span>
              <span class="text-xs font-medium text-white/70">Foto de c&eacute;dula trasera + c&oacute;digo MRZ</span>
              <span id="step2Status" class="ml-auto text-[10px] text-white/30">Pendiente</span>
            </div>
            <p class="text-[11px] text-white/30 pl-8">Sube la parte <strong class="text-white/50">trasera</strong> de tu c&eacute;dula y copia las 3 l&iacute;neas del c&oacute;digo MRZ (zona inferior con letras y signos <code class="text-accent/70">&lt;</code>).</p>
            <div class="pl-8 space-y-3">
              <label id="step2Upload" class="flex items-center gap-2 px-3 py-2 rounded-lg border border-dashed border-white/[0.10] bg-white/[0.02] cursor-pointer hover:bg-white/[0.04] transition-colors w-fit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-white/40"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <span class="text-[11px] text-white/40">Subir imagen dorso</span>
                <input type="file" accept="image/*" class="hidden" onchange="handleIdUpload(this, 'back')" />
              </label>
              <div id="idBackPreview" class="hidden mt-2 relative w-48">
                <img class="w-full rounded-lg border border-white/[0.06] object-cover" style="aspect-ratio:85/54" />
                <button type="button" onclick="removeIdUpload('back')" class="absolute top-1 right-1 w-5 h-5 rounded-full bg-black/70 text-white/80 text-[10px] flex items-center justify-center">✕</button>
              </div>
              <!-- MRZ siempre visible -->
              <div>
                <label class="block text-[10px] text-white/35 uppercase tracking-wider mb-1.5">
                  C&oacute;digo MRZ <span class="text-white/20 normal-case">(3 l&iacute;neas, parte trasera)</span>
                </label>
                <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-3 mb-2">
                  <p class="text-[10px] text-white/30 mb-1">Ejemplo (zona inferior de la c&eacute;dula):</p>
                  <code class="text-[10px] text-emerald-400/70 font-mono block leading-5">
                    IDCHL12345678901&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;<br/>
                    8001011M3512319CHL&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;4<br/>
                    APELLIDO&lt;&lt;NOMBRE&lt;SEGUNDO&lt;&lt;&lt;&lt;&lt;
                  </code>
                </div>
                <textarea
                  id="mrzInput"
                  rows="3"
                  class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl px-3 py-2.5 text-[11px] text-white font-mono outline-none focus:border-accent/40 transition-colors resize-none"
                  placeholder="Se llena automáticamente al subir la foto — o pégalo manualmente"
                  oninput="onMrzInput(this)"
                ></textarea>
                <div id="mrzStatus" class="mt-1 text-[10px]"></div>
              </div>
            </div>
          </div>

          <!-- Step 3: Selfie + Liveness -->
          <div class="rounded-xl border border-white/[0.06] p-4 space-y-3">
            <div class="flex items-center gap-2">
              <span id="step3Dot" class="w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-[10px] font-bold text-white/40 shrink-0">3</span>
              <span class="text-xs font-medium text-white/70">Selfie con prueba de vida</span>
              <span id="step3Status" class="ml-auto text-[10px] text-white/30">Pendiente</span>
            </div>
            <p class="text-[11px] text-white/30 pl-8">Activa la c&aacute;mara y <strong class="text-white/50">parpadea 2 veces</strong> para confirmar que eres una persona real. La foto se toma autom&aacute;ticamente.</p>
            <div class="pl-8">
              <!-- Contenedor cámara 9:16 centrado -->
              <div id="cameraContainer" class="relative mx-auto overflow-hidden rounded-xl border border-white/[0.08] bg-black" style="width:180px;aspect-ratio:9/16">
                <video id="cameraPreview" autoplay playsinline muted class="absolute inset-0 w-full h-full object-cover"></video>
                <canvas id="faceOverlay" class="hidden absolute inset-0 w-full h-full pointer-events-none"></canvas>
                <div id="cameraOverlay" class="absolute inset-0 flex flex-col items-center justify-center gap-2 bg-black/60">
                  <button type="button" id="startCameraBtn" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-xs font-medium text-white bg-gradient-to-r from-accent to-violet-500 transition-all duration-200 hover:opacity-90">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                    Activar
                  </button>
                </div>
                <!-- Guía oval para rostro -->
                <div id="faceGuide" class="hidden absolute inset-0 flex items-center justify-center pointer-events-none">
                  <div class="border-2 border-white/30 rounded-full" style="width:100px;height:130px"></div>
                </div>
              </div>
              <div id="selfieStatus" class="mt-2 text-[10px] text-center"></div>
              <!-- Botón fallback: captura manual cuando EAR no detecta el parpadeo -->
              <div id="manualLivenessDiv" class="hidden mt-2 text-center">
                <p class="text-[10px] text-amber-400/70 mb-1">¿El detector no reconoce tus parpadeos?</p>
                <button type="button" id="manualLivenessBtn"
                  class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-[11px] font-medium text-white border border-white/20 hover:bg-white/[0.06] transition-colors">
                  📸 Capturar selfie manualmente
                </button>
              </div>
              <div id="selfieTaken" class="hidden mt-2 relative mx-auto" style="width:180px">
                <img id="selfieCaptureImg" class="w-full rounded-xl border border-white/[0.06] object-cover" style="aspect-ratio:9/16" />
                <button type="button" onclick="retakeSelfie()" class="absolute top-1 right-1 w-6 h-6 rounded-full bg-black/60 text-white/80 text-xs flex items-center justify-center">✕</button>
              </div>
            </div>
          </div>

          <!-- Resumen verificación -->
          <div id="bioDetails" class="pt-1 space-y-1.5">
            <div class="flex justify-between text-xs"><span class="text-white/40">Rostro en c&eacute;dula:</span><span id="bioFaceId" class="text-white/60">—</span></div>
            <div class="flex justify-between text-xs"><span class="text-white/40">Coincidencia facial:</span><span id="bioMatch" class="text-white/60">—</span></div>
            <div class="flex justify-between text-xs"><span class="text-white/40">Prueba de vida (parpadeos):</span><span id="bioLiveness" class="text-white/60">—</span></div>
            <div class="flex justify-between text-xs"><span class="text-white/40">RUT v&aacute;lido:</span><span id="bioRut" class="text-white/60">—</span></div>
            <div class="flex justify-between text-xs"><span class="text-white/40">MRZ v&aacute;lido:</span><span id="bioMrz" class="text-white/60">—</span></div>
            <div class="flex justify-between text-xs"><span class="text-white/40">Rostro en selfie:</span><span id="bioFaceSelfie" class="text-white/60">—</span></div>
          </div>
        </div>

        <div id="signError" class="hidden text-sm text-red-400 text-center"></div>

        <button type="button" id="submitSignBtn" class="w-full inline-flex items-center justify-center gap-2 px-6 py-3.5 rounded-full text-sm font-medium text-white bg-gradient-to-r from-accent to-violet-500 transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5 disabled:opacity-40 disabled:cursor-not-allowed">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Firmar Contrato
        </button>
      </div>
    </div>
  </main>
</BaseLayout>

<script src="https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js"></script>
<script type="module" id="mpLoader">
  import { FilesetResolver, FaceLandmarker } from "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/vision_bundle.mjs";
  window._mpInit = async function() {
    const vision = await FilesetResolver.forVisionTasks("https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.14/wasm");
    window._faceLandmarker = await FaceLandmarker.createFromOptions(vision, {
      baseOptions: { modelAssetPath: "https://storage.googleapis.com/mediapipe-models/face_landmarker/face_landmarker/float16/latest/face_landmarker.task", delegate: "GPU" },
      runningMode: "VIDEO",
      numFaces: 1,
      minFaceDetectionConfidence: 0.4,
      minFacePresenceConfidence: 0.4,
      minTrackingConfidence: 0.4,
      outputFaceBlendshapes: true
    });
    window._mpReady = true;
    console.log("[MediaPipe] FaceLandmarker ready");
  };
  window._mpInit().catch(function(e) { console.error("[MediaPipe] init failed:", e); window._mpInitError = e.message; });
</script>
<script is:inline>
  var signingToken = window.location.pathname.replace("/firmar/", "").split("/")[0].split("?")[0];
  var contractData = null;
  var sigCanvas, ctx, isDrawing = false;
  var idUploads = { front: null, back: null, selfie: null };
  var cameraStream = null;
  var bioResult = { faceMatchScore: null, livenessPassed: false, rutValid: false, mrzValid: false, mrzOcrOnly: false, verificationStatus: "pending", faceDetectedOnId: false, faceDetectedOnSelfie: false };
  var blinkCount = 0;
  // MediaPipe via window._faceLandmarker / window._mpReady

  function formatCurrency(n) { return "$" + Number(n).toLocaleString("es-CL"); }

  function formatDate(d) {
    if (!d) return "\u2014";
    return new Date(d).toLocaleDateString("es-CL", { year: "numeric", month: "long", day: "numeric" });
  }

  // ── RUT validation (client-side copy) ──
  function validarRut(rut) {
    var clean = rut.replace(/[^0-9kK]/g, "");
    if (clean.length < 2 || clean.length > 10) return false;
    var body = clean.slice(0, -1);
    var dv = clean.slice(-1).toUpperCase();
    if (!/^\d+$/.test(body)) return false;
    var sum = 0, mul = 2;
    for (var i = body.length - 1; i >= 0; i--) {
      sum += parseInt(body[i], 10) * mul;
      mul = mul === 7 ? 2 : mul + 1;
    }
    var rem = sum % 11;
    var expected = rem === 0 ? "0" : rem === 1 ? "K" : String(11 - rem);
    return dv === expected;
  }

  function formatRut(rut) {
    var c = rut.replace(/[^0-9kK]/g, "");
    if (c.length < 2) return c;
    var body = c.slice(0, -1);
    var dv = c.slice(-1).toUpperCase();
    return body.replace(/\B(?=(\d{3})+(?!\d))/g, ".") + "-" + dv;
  }

  // ── MRZ validation (client-side copy) ──
  function mrzChecksum(field) {
    var chars = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    function cv(c) { return c === "<" ? 0 : chars.indexOf(c) >= 0 ? chars.indexOf(c) : 0; }
    var w = [7, 3, 9], sum = 0;
    for (var i = 0; i < field.length; i++) sum += cv(field[i]) * w[i % 3];
    return sum % 10;
  }

  function validarMrz(mrz) {
    var lines = mrz.replace(/\r/g, "").split("\n").filter(function(l) { return l.length > 0; });
    if (lines.length < 3) return { valid: false, errors: ["Debe tener 3 l\u00edneas"] };
    var l1 = lines[0].padEnd(30, "<").slice(0, 30);
    var l2 = lines[1].padEnd(30, "<").slice(0, 30);
    var errs = [];
    if (l1.substring(0, 2) !== "ID") errs.push("Tipo doc debe ser ID");
    if (l1.substring(2, 5) !== "CHL") errs.push("Pa\u00eds debe ser CHL");
    var dn = l1.substring(5, 14).replace(/</g, "");
    if (dn.length === 0) errs.push("N\u00famero documento vac\u00edo");
    if (l1[14] !== "<" && mrzChecksum(l1.substring(5, 14)) !== parseInt(l1[14], 10)) errs.push("Checksum doc inv\u00e1lido");
    var dob = l2.substring(0, 6);
    if (l2[6] !== "<" && mrzChecksum(dob) !== parseInt(l2[6], 10)) errs.push("Checksum fecha nac. inv\u00e1lido");
    var exp = l2.substring(8, 14);
    if (l2[14] !== "<" && mrzChecksum(exp) !== parseInt(l2[14], 10)) errs.push("Checksum venc. inv\u00e1lido");
    return { valid: errs.length === 0, errors: errs, docNumber: dn, dateOfBirth: dob, expiryDate: exp, sex: l2[7], names: lines[2].replace(/</g, " ").replace(/\s+/g, " ").trim() };
  }

  // ── MediaPipe ready check ──
  async function waitForMP() {
    if (window._mpInitError) throw new Error("MediaPipe: " + window._mpInitError);
    if (window._mpReady) return true;
    document.getElementById("bioStatus").textContent = "⏳ Cargando detector...";
    for (var i = 0; i < 60; i++) {
      await new Promise(function(r){ setTimeout(r, 500); });
      if (window._mpReady) { document.getElementById("bioStatus").textContent = ""; return true; }
      if (window._mpInitError) throw new Error(window._mpInitError);
    }
    throw new Error("Timeout cargando MediaPipe");
  }

  // ── Camera ──
  async function startCamera() {
    try {
      cameraStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: "user", width: { ideal: 480 }, height: { ideal: 854 } }
      });
      var video = document.getElementById("cameraPreview");
      video.srcObject = cameraStream;
      await video.play();
      document.getElementById("cameraOverlay").classList.add("hidden");
      document.getElementById("faceOverlay").classList.remove("hidden");
      document.getElementById("faceGuide").classList.remove("hidden");
      document.getElementById("selfieStatus").textContent = "Parpadeos: 0/2 — Mira a la cámara";
      document.getElementById("selfieStatus").classList.remove("hidden");
      try {
        await waitForMP();
        startLivenessDetection();
      } catch(mpErr) {
        document.getElementById("selfieStatus").textContent = "⚠️ " + mpErr.message;
      }
    } catch (e) {
      document.getElementById("selfieStatus").textContent = "Error al acceder a la c\u00e1mara: " + e.message;
      document.getElementById("selfieStatus").classList.remove("hidden");
    }
  }

  function stopCamera() {
    if (cameraStream) {
      cameraStream.getTracks().forEach(function(t) { t.stop(); });
      cameraStream = null;
    }
    var cont = document.getElementById("cameraContainer");
    if (cont) cont.style.display = "none";
    var fov = document.getElementById("faceOverlay");
    if (fov) fov.getContext("2d").clearRect(0, 0, fov.width, fov.height);
    var guide = document.getElementById("faceGuide");
    if (guide) guide.classList.add("hidden");
    var manDiv = document.getElementById("manualLivenessDiv");
    if (manDiv) manDiv.classList.add("hidden");
  }

  // ── Liveness con MediaPipe blendshapes ──
  var livenessActive = false;
  function dist(a,b){ return Math.hypot(a.x-b.x, a.y-b.y); }

  async function startLivenessDetection() {
    if (livenessActive) return;
    livenessActive = true;
    blinkCount = 0;
    var video   = document.getElementById("cameraPreview");
    var overlay = document.getElementById("faceOverlay");
    var oc      = overlay.getContext("2d");
    var status  = document.getElementById("selfieStatus");
    var lm_obj  = window._faceLandmarker;
    var wasBlinking = false;
    var noFaceFrames = 0;

    function drawDebug(msg, color) {
      oc.fillStyle = "rgba(0,0,0,0.65)";
      oc.fillRect(4, 4, overlay.width - 8, 28);
      oc.font = "13px monospace";
      oc.fillStyle = color || "#86efac";
      oc.fillText(msg, 8, 22);
    }

    function loop() {
      if (!livenessActive) return;
      if (video.readyState < 2) { requestAnimationFrame(loop); return; }

      if (overlay.width  !== video.videoWidth)  overlay.width  = video.videoWidth  || 480;
      if (overlay.height !== video.videoHeight) overlay.height = video.videoHeight || 854;
      oc.clearRect(0, 0, overlay.width, overlay.height);

      var result;
      try {
        result = lm_obj.detectForVideo(video, performance.now());
      } catch(e) {
        drawDebug("Error: " + (e.message||e), "#f87171");
        requestAnimationFrame(loop);
        return;
      }

      if (!result || !result.faceLandmarks || result.faceLandmarks.length === 0) {
        noFaceFrames++;
        if (noFaceFrames > 10) {
          drawDebug("👤 Acerca tu rostro", "#fbbf24");
          status.textContent = "👤 Acerca tu rostro a la cámara";
        }
        requestAnimationFrame(loop);
        return;
      }
      noFaceFrames = 0;
      bioResult.faceDetectedOnSelfie = true;

      // Bounding box
      var lms = result.faceLandmarks[0];
      var xs = lms.map(function(p){ return p.x * overlay.width; });
      var ys = lms.map(function(p){ return p.y * overlay.height; });
      var x1=Math.min.apply(null,xs), x2=Math.max.apply(null,xs);
      var y1=Math.min.apply(null,ys), y2=Math.max.apply(null,ys);
      oc.strokeStyle = "#22c55e"; oc.lineWidth = 2;
      oc.strokeRect(x1, y1, x2 - x1, y2 - y1);

      // Blendshapes eyeBlink
      var blinkL = 0, blinkR = 0;
      if (result.faceBlendshapes && result.faceBlendshapes.length > 0) {
        var cats = result.faceBlendshapes[0].categories;
        for (var i = 0; i < cats.length; i++) {
          if (cats[i].categoryName === "eyeBlinkLeft")  blinkL = cats[i].score;
          if (cats[i].categoryName === "eyeBlinkRight") blinkR = cats[i].score;
        }
      }
      var blinkAvg = (blinkL + blinkR) / 2;

      drawDebug(
        "L:" + blinkL.toFixed(2) + " R:" + blinkR.toFixed(2) + " | blinks:" + blinkCount + "/2",
        blinkAvg > 0.4 ? "#f87171" : "#86efac"
      );

      if (blinkAvg > 0.4) {
        if (!wasBlinking) {
          wasBlinking = true;
          blinkCount++;
          status.textContent = blinkCount < 2
            ? "💚 Parpadeo 1/2 — un parpadeo más"
            : "💚 Parpadeo 2/2 — capturando...";
        }
      } else {
        wasBlinking = false;
        if (blinkCount === 0) {
          status.textContent = "👁 Parpadea lento (score: " + blinkAvg.toFixed(2) + ")";
        }
      }

      if (blinkCount >= 2) {
        livenessActive = false;
        bioResult.livenessPassed = true;
        document.getElementById("bioLiveness").textContent = "✅ Liveness OK";
        status.textContent = "✅ Capturando selfie...";
        updateSteps();
        var cap = document.createElement("canvas");
        cap.width = video.videoWidth; cap.height = video.videoHeight;
        cap.getContext("2d").drawImage(video, 0, 0);
        idUploads.selfie = cap.toDataURL("image/jpeg", 0.9);
        selfieDescriptor = null;
        document.getElementById("selfieTaken").classList.remove("hidden");
        document.getElementById("selfieCaptureImg").src = idUploads.selfie;
        document.getElementById("selfieStatus").textContent = "✅ Selfie capturada";
        document.getElementById("bioFaceSelfie").textContent = "⏳ Extrayendo descriptor...";
        stopCamera();
        extractSelfieDescriptor(idUploads.selfie);
        return;
      }

      requestAnimationFrame(loop);
    }

    loop();
  }

  // ── face-api lazy load (solo para descriptores estáticos) ──
  var faceApiLoaded = false;
  var MODEL_URL = "https://justadudewhohacks.github.io/face-api.js/models";

  async function initFaceApi_legacy() {
    if (faceApiLoaded) return;
    if (typeof faceapi === "undefined") {
      await new Promise(function(resolve) {
        var s = document.createElement("script");
        s.src = "https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js";
        s.onload = resolve;
        s.onerror = function() { console.warn("[face-api] load failed"); resolve(); };
        document.head.appendChild(s);
      });
    }
    if (typeof faceapi === "undefined") return;
    try {
      await faceapi.nets.ssdMobilenetv1.loadFromUri(MODEL_URL);
      await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
      await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
      faceApiLoaded = true;
    } catch(e) { console.warn("[face-api] model load failed:", e); }
  }

  async function extractSelfieDescriptor(dataUrl) {
    document.getElementById("bioFaceSelfie").textContent = "⏳ Cargando detector...";
    for (var attempt = 1; attempt <= 3; attempt++) {
      try {
        await initFaceApi_legacy();
        if (!faceApiLoaded) {
          await new Promise(function(r){ setTimeout(r, 1500); });
          continue;
        }
        var img = new Image();
        img.src = dataUrl;
        await new Promise(function(r){ img.onload = r; img.onerror = r; });
        await new Promise(function(r){ setTimeout(r, 50); });
        var det = await faceapi
          .detectSingleFace(img, new faceapi.SsdMobilenetv1Options({ minConfidence: 0.15 }))
          .withFaceLandmarks().withFaceDescriptor();
        if (det && det.descriptor) {
          selfieDescriptor = det.descriptor;
          document.getElementById("bioFaceSelfie").textContent = "✅ Detectado";
          document.getElementById("selfieStatus").textContent = "✅ Selfie + rostro OK";
        } else {
          document.getElementById("bioFaceSelfie").textContent = "⚠️ Sin descriptor (liveness OK)";
        }
        break;
      } catch(e) {
        if (attempt === 3) {
          document.getElementById("bioFaceSelfie").textContent = "⚠️ " + (e.message || "Error");
        } else {
          await new Promise(function(r){ setTimeout(r, 1000); });
        }
      }
    }
    runFaceMatching();
    updateSteps();
  }

  var selfieDescriptor = null;

  function autoCaptureNoDescriptor(video) {
    livenessActive = false;
    var canvas = document.createElement("canvas");
    canvas.width = video.videoWidth || 480;
    canvas.height = video.videoHeight || 854;
    canvas.getContext("2d").drawImage(video, 0, 0);
    var dataUrl = canvas.toDataURL("image/jpeg", 0.85);
    idUploads.selfie = dataUrl;
    selfieDescriptor = null;
    document.getElementById("selfieTaken").classList.remove("hidden");
    document.getElementById("selfieCaptureImg").src = dataUrl;
    document.getElementById("selfieStatus").textContent = "✅ Selfie capturada (sin descriptor)";
    document.getElementById("selfieStatus").classList.remove("hidden");
    stopCamera();
    updateSteps();
  }

  function autoCaptureSelfie(detection) {
    livenessActive = false;
    var video = document.getElementById("cameraPreview");
    var canvas = document.createElement("canvas");
    canvas.width = video.videoWidth || 480;
    canvas.height = video.videoHeight || 854;
    canvas.getContext("2d").drawImage(video, 0, 0);
    var dataUrl = canvas.toDataURL("image/jpeg", 0.85);
    idUploads.selfie = dataUrl;
    selfieDescriptor = detection && detection.descriptor ? detection.descriptor : null;
    document.getElementById("selfieTaken").classList.remove("hidden");
    document.getElementById("selfieCaptureImg").src = dataUrl;
    document.getElementById("selfieStatus").textContent = "✅ Selfie capturada";
    document.getElementById("selfieStatus").classList.remove("hidden");
    document.getElementById("bioFaceSelfie").textContent = selfieDescriptor ? "✅ Detectado" : "⏳ Extrayendo...";
    stopCamera();
    if (!selfieDescriptor) {
      var img2 = new Image();
      img2.src = dataUrl;
      img2.onload = async function() {
        try {
          if (!faceApiLoaded) await initFaceApi_legacy();
          var d2 = await faceapi
            .detectSingleFace(img2, new faceapi.SsdMobilenetv1Options({ minConfidence: 0.2 }))
            .withFaceLandmarks().withFaceDescriptor();
          if (d2 && d2.descriptor) {
            selfieDescriptor = d2.descriptor;
            document.getElementById("bioFaceSelfie").textContent = "✅ Detectado";
            document.getElementById("selfieStatus").textContent = "✅ Selfie + rostro OK";
          } else {
            document.getElementById("bioFaceSelfie").textContent = "⚠️ Sin descriptor";
          }
        } catch(e) { document.getElementById("bioFaceSelfie").textContent = "⚠️ Error: " + (e.message||e); }
        runFaceMatching();
        updateSteps();
      };
    } else {
      runFaceMatching();
    }
  }

  function retakeSelfie() {
    selfieDescriptor = null;
    bioResult.livenessPassed = false;
    bioResult.faceDetectedOnSelfie = false;
    blinkCount = 0;
    idUploads.selfie = null;
    document.getElementById("selfieTaken").classList.add("hidden");
    document.getElementById("selfieStatus").textContent = "";
    document.getElementById("bioMatch").textContent = "\u2014";
    document.getElementById("bioLiveness").textContent = "\u2014";
    document.getElementById("bioFaceSelfie").textContent = "\u2014";
    var cont2 = document.getElementById("cameraContainer");
    if (cont2) cont2.style.display = "";
    document.getElementById("cameraOverlay").classList.remove("hidden");
    document.getElementById("startCameraBtn").textContent = "Reintentar";
    livenessActive = false;
    updateBioStatus();
  }

  // ── Face matching ──
  var idFaceDescriptor = null;

  async function runFaceMatching() {
    if (!idUploads.front) return;

    var img = new Image();
    img.src = idUploads.front; // base64 local — sin crossOrigin
    await new Promise(function(r) { img.onload = r; img.onerror = r; });

    try {
      if (!faceApiLoaded) await initFaceApi_legacy();
      if (!faceApiLoaded) { document.getElementById("frontFaceStatus").textContent = "⚠️ Face-api no cargado"; return; }

      document.getElementById("frontFaceStatus").textContent = "🔍 Detectando rostro...";
      document.getElementById("frontFaceStatus").classList.remove("hidden");

      var idDet = await faceapi
        .detectSingleFace(img, new faceapi.SsdMobilenetv1Options({ minConfidence: 0.2 }))
        .withFaceLandmarks().withFaceDescriptor();

      if (idDet) {
        bioResult.faceDetectedOnId = true;
        idFaceDescriptor = idDet.descriptor;
        document.getElementById("frontFaceStatus").textContent = "✅ Rostro detectado en cédula";
        document.getElementById("frontFaceStatus").className = "mt-1 text-[10px] text-emerald-400";
        document.getElementById("bioFaceId").textContent = "✅ Detectado";
      } else {
        document.getElementById("frontFaceStatus").textContent = "⚠️ No se detectó rostro (sube foto más clara y nítida)";
        document.getElementById("frontFaceStatus").className = "mt-1 text-[10px] text-amber-400";
        document.getElementById("bioFaceId").textContent = "❌ No detectado";
      }

      // Face match solo si tenemos ambos descriptores
      if (idDet && selfieDescriptor) {
        var distance = faceapi.euclideanDistance(idDet.descriptor, selfieDescriptor);
        var score = Math.max(0, Math.min(1, 1 - distance / 1.2));
        bioResult.faceMatchScore = Math.round(score * 1000) / 1000;
        document.getElementById("bioFaceSelfie").textContent = "✅ Detectado";
        document.getElementById("bioMatch").textContent = (score >= 0.5 ? "✅ " : "⚠️ ") + Math.round(score * 100) + "% coincidencia";
        if (score >= 0.5) bioResult.verificationStatus = "passed";
        else bioResult.verificationStatus = "failed";
      } else if (!selfieDescriptor) {
        // selfieDescriptor aún no disponible — puede estar siendo extraído
      if (idUploads.selfie) {
        document.getElementById("bioMatch").textContent = "⏳ Procesando selfie...";
        // Reintentar en 2s por si extractSelfieDescriptor aún no terminó
        setTimeout(function() {
          if (selfieDescriptor) runFaceMatching();
        }, 2000);
      } else {
        document.getElementById("bioMatch").textContent = idDet ? "⏳ Toma la selfie" : "—";
      }
      }
    } catch (e) {
      document.getElementById("frontFaceStatus").textContent = "❌ Error: " + (e.message || e);
      document.getElementById("frontFaceStatus").classList.remove("hidden");
    }

    updateBioStatus();
  }

  // ── RUT validation UI ──
  document.getElementById("fieldRut").addEventListener("input", function() {
    var val = this.value.trim();
    if (val.length < 2) { bioResult.rutValid = false; document.getElementById("bioRut").textContent = "\u2014"; updateBioStatus(); return; }
    var formatted = formatRut(val);
    if (formatted !== val) this.value = formatted;
    var valid = validarRut(val);
    bioResult.rutValid = valid;
    document.getElementById("bioRut").textContent = valid ? "\u2705 V\u00e1lido" : "\u274c Inv\u00e1lido";
    updateBioStatus();
    updateSteps();
  });

  // ── Bio status update ──
  function updateBioStatus() {
    updateSteps();
    var passed = bioResult.livenessPassed && bioResult.rutValid;
    var statusEl = document.getElementById("bioStatus");
    if (passed) {
      bioResult.verificationStatus = "passed";
      statusEl.textContent = "\u2705 Verificado";
      statusEl.className = "ml-auto text-[10px] font-medium text-emerald-400";
    } else if (bioResult.faceDetectedOnId || bioResult.livenessPassed || bioResult.rutValid) {
      statusEl.textContent = "En progreso...";
      statusEl.className = "ml-auto text-[10px] font-medium text-amber-400";
    }
  }

  // ── Load contract ──
  async function loadContract() {
    try {
      var res = await fetch("/api/contracts/find-by-token/" + signingToken);
      var data = await res.json();
      if (!data.contract) {
        showError(data.error || "Enlace inv\u00e1lido");
        return;
      }
      contractData = data.contract;
      var c = contractData;

      document.getElementById("loadingState").classList.add("hidden");
      document.getElementById("signForm").classList.remove("hidden");

      document.getElementById("contractNumber").textContent = c.contract_number + " \u2022 " + formatDate(c.created_at);

      var svcs = c.services || [];
      var summaryHtml = '<div class="font-medium text-white/80 mb-1">Servicios contratados:</div><ul class="list-disc list-inside space-y-0.5">';
      for (var i = 0; i < svcs.length; i++) {
        summaryHtml += "<li>" + (svcs[i].name || "Servicio") + " \u2014 <span class='text-accent font-mono'>" + formatCurrency(svcs[i].price) + "</span></li>";
      }
      summaryHtml += '</ul><div class="mt-2 pt-2 border-t border-white/[0.06] flex justify-between text-sm"><span>Total:</span><span class="font-bold text-accent font-mono">' + formatCurrency(c.total_amount) + "</span></div>";
      if (c.duration_months) {
        summaryHtml += '<div class="text-xs text-white/30 mt-1">Duraci\u00f3n: ' + c.duration_months + " meses</div>";
      }
      document.getElementById("contractSummary").innerHTML = summaryHtml;

      document.getElementById("fieldName").value = c.client_name || "";
      document.getElementById("fieldRut").value = c.client_rut || "";
      document.getElementById("fieldPhone").value = c.client_phone || "";
      document.getElementById("fieldAddress").value = c.client_address || "";
      if (c.client_rut) {
        bioResult.rutValid = validarRut(c.client_rut);
        document.getElementById("bioRut").textContent = bioResult.rutValid ? "✅ Válido" : "❌ Inválido";
      }

      initCanvas(); // MediaPipe carga en background via mpLoader
    } catch (e) {
      showError("Error al cargar el contrato. Verifica tu conexi\u00f3n.");
    }
  }

  function showError(msg) {
    document.getElementById("loadingState").classList.add("hidden");
    document.getElementById("errorState").classList.remove("hidden");
    document.getElementById("errorMsg").textContent = msg;
  }

  // ── Signature canvas ──
  function initCanvas() {
    sigCanvas = document.getElementById("sigCanvas");
    ctx = sigCanvas.getContext("2d");
    ctx.strokeStyle = "#000";
    ctx.lineWidth = 2.5;
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.fillStyle = "#fff";
    ctx.fillRect(0, 0, sigCanvas.width, sigCanvas.height);

    sigCanvas.onpointerdown = function(e) {
      isDrawing = true;
      ctx.beginPath();
      ctx.moveTo(e.offsetX, e.offsetY);
    };
    sigCanvas.onpointermove = function(e) {
      if (!isDrawing) return;
      ctx.lineTo(e.offsetX, e.offsetY);
      ctx.stroke();
    };
    sigCanvas.onpointerup = function() { isDrawing = false; };
    sigCanvas.onpointerleave = function() { isDrawing = false; };
  }

  function clearCanvas() {
    if (!ctx) return;
    ctx.fillStyle = "#fff";
    ctx.fillRect(0, 0, sigCanvas.width, sigCanvas.height);
  }

  // ── ID upload handlers ──
  async function runMrzFromImage(dataUrl) {
    var mrzStatus = document.getElementById("mrzStatus");
    mrzStatus.textContent = "🔍 Leyendo MRZ con OCR...";
    mrzStatus.className = "mt-1 text-[10px] text-white/40";
    mrzStatus.classList.remove("hidden");
    try {
      if (typeof Tesseract === "undefined") {
        mrzStatus.textContent = "⚠️ OCR no disponible — ingresa el MRZ manualmente";
        mrzStatus.className = "mt-1 text-[10px] text-amber-400";
        return;
      }
      // OCR con perfil MRZ: fuente OCR-B, solo mayúsculas y símbolos MRZ
      var result = await Tesseract.recognize(dataUrl, "eng", {
        tessedit_char_whitelist: "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789<",
        tessedit_pageseg_mode: "6",   // bloque de texto uniforme
        logger: function() {}
      });
      var rawText = result.data.text || "";
      // Filtrar solo líneas que parecen MRZ (≥25 chars, mayúsculas + números + <)
      var lines = rawText.split("\n").map(function(l) {
        return l.replace(/[^A-Z0-9<]/g, "").trim();
      }).filter(function(l) { return l.length >= 25; });

      // Corregir errores OCR solo en línea 1 (IDCHL...)
      if (lines.length > 0 && lines[0].length >= 5) {
        var arr = lines[0].split('');
        arr[0] = 'I';
        if (arr[1] === 'N' || arr[1] === '0' || arr[1] === 'O' || arr[1] === 'I') arr[1] = 'D';
        arr[2] = 'C'; arr[3] = 'H'; arr[4] = 'L';
        lines[0] = arr.join('');
      }

      if (lines.length >= 2) {
        var mrzText = lines.slice(0, 3).join("\n");
        var mrzInput = document.getElementById("mrzInput");
        if (mrzInput) {
          mrzInput.value = mrzText;
          onMrzInput(mrzInput);
          mrzStatus.textContent = "✅ MRZ extraído automáticamente";
          mrzStatus.className = "mt-1 text-[10px] text-emerald-400";
        }
      } else {
        mrzStatus.textContent = "⚠️ No se detectó MRZ — ingresa manualmente las 3 líneas";
        mrzStatus.className = "mt-1 text-[10px] text-amber-400";
      }
    } catch(e) {
      mrzStatus.textContent = "⚠️ Error OCR: " + (e.message || e) + " — ingresa manualmente";
      mrzStatus.className = "mt-1 text-[10px] text-amber-400";
    }
  }

  function handleIdUpload(input, type) {
    var file = input.files && input.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
      idUploads[type] = e.target.result;
      var previewId = type === "front" ? "idFrontPreview" : "idBackPreview";
      var preview = document.getElementById(previewId);
      var label = preview.previousElementSibling;
      if (label) label.style.display = "none";
      preview.classList.remove("hidden");
      preview.querySelector("img").src = e.target.result;

      if (type === "front") runFaceMatching();
      if (type === "back") runMrzFromImage(e.target.result);
    };
    reader.readAsDataURL(file);
  }

  function removeIdUpload(type) {
    idUploads[type] = null;
    if (type === "selfie") { retakeSelfie(); return; }
    var previewId = type === "front" ? "idFrontPreview" : "idBackPreview";
    var preview = document.getElementById(previewId);
    preview.classList.add("hidden");
    var label = preview.previousElementSibling;
    if (label) label.style.display = "";
    var input = label && label.querySelector("input[type='file']");
    if (input) input.value = "";
    if (type === "front") {
      idFaceDescriptor = null;
      bioResult.faceDetectedOnId = false;
      document.getElementById("frontFaceStatus").classList.add("hidden");
      document.getElementById("bioFaceId").textContent = "\u2014";
      document.getElementById("bioMatch").textContent = "\u2014";
      updateBioStatus();
    }
  }



  // ── Camera init ──
  
  // ── MRZ live input
  function onMrzInput(el) {
    var val = el.value.trim();
    if (val.length < 30) {
      bioResult.mrzValid = false;
      document.getElementById('mrzStatus').textContent = '';
      document.getElementById('bioMrz').textContent = '—';
      updateSteps();
      return;
    }
    var result = validarMrz(val);
    // Aceptar MRZ si tiene formato correcto aunque checksums fallen por OCR
    var hasFormat = result.errors.every(function(e) {
      return e.indexOf('Checksum') !== -1; // Solo errores de checksum, no de formato
    });
    bioResult.mrzValid = result.valid || (result.errors.length > 0 && hasFormat && result.docNumber && result.docNumber.length >= 5);
    if (!result.valid && hasFormat) {
      document.getElementById('bioMrz').textContent = '⚠️ MRZ leído (checksums imprecisos por OCR)';
    }
    var el2 = document.getElementById('mrzStatus');
    var hasOnlyChecksumErrors = result.errors.length > 0 && result.errors.every(function(e){ return e.indexOf('Checksum') !== -1; });
    var hasFormatError = result.errors.some(function(e){ return e.indexOf('Checksum') === -1; });
    if (result.valid) {
      el2.textContent = '✅ MRZ válido';
      el2.className = 'mt-1 text-[10px] text-emerald-400';
      bioResult.mrzOcrOnly = false;
      document.getElementById('bioMrz').textContent = '✅ Válido';
    } else if (hasOnlyChecksumErrors && result.docNumber && result.docNumber.length >= 5) {
      bioResult.mrzOcrOnly = true;
      // Solo errores de checksum — el OCR leyó el texto pero con ruido
      el2.textContent = '⚠️ MRZ leído con imprecisiones OCR (se guardará como evidencia)';
      el2.className = 'mt-1 text-[10px] text-amber-400';
      document.getElementById('bioMrz').textContent = '⚠️ Leído (OCR impreciso)';
    } else {
      el2.textContent = '❌ ' + (result.errors[0] || 'Inválido');
      el2.className = 'mt-1 text-[10px] text-red-400';
      document.getElementById('bioMrz').textContent = '❌ ' + (result.errors[0] || 'Inválido');
    }
    updateSteps();
    updateBioStatus();
  }

  // ── Step dots visual update
  function updateSteps() {
    // Step 1: cedula frontal
    var s1HasImg = !!idUploads.front;
    var s1Pass = bioResult.faceDetectedOnId;
    setStepDot('step1Dot', 'step1Status', s1Pass ? 'passed' : (s1HasImg ? 'partial' : 'pending'),
      s1Pass ? '✅ Rostro detectado' : (s1HasImg ? '📷 Procesando...' : 'Pendiente'));
    // Step 2: dorso + MRZ
    var s2hasImg = !!idUploads.back;
    var s2 = s2hasImg && bioResult.mrzValid;
    var s2Label = s2
      ? (bioResult.mrzOcrOnly ? '⚠️ MRZ capturado (OCR)' : '✅ MRZ verificado')
      : (s2hasImg ? '⏳ Ingresa el MRZ' : 'Pendiente');
    setStepDot('step2Dot', 'step2Status', s2 ? 'passed' : (s2hasImg ? 'partial' : 'pending'), s2Label);
    // Step 3: selfie + liveness
    var s3 = bioResult.livenessPassed && !!idUploads.selfie;
    setStepDot('step3Dot', 'step3Status', s3 ? 'passed' : (bioResult.faceDetectedOnSelfie ? 'partial' : 'pending'),
      s3 ? '✅ Selfie con liveness' : (bioResult.faceDetectedOnSelfie ? '👁 Parpadea 2 veces' : 'Pendiente'));
  }

  function setStepDot(dotId, statusId, state, label) {
    var dot = document.getElementById(dotId);
    var sta = document.getElementById(statusId);
    if (!dot || !sta) return;
    if (state === 'passed') {
      dot.className = 'w-6 h-6 rounded-full bg-emerald-500 flex items-center justify-center text-[10px] font-bold text-white shrink-0';
      dot.textContent = '✓';
      sta.className = 'ml-auto text-[10px] text-emerald-400';
    } else if (state === 'partial') {
      dot.className = 'w-6 h-6 rounded-full bg-amber-500/30 flex items-center justify-center text-[10px] font-bold text-amber-400 shrink-0';
      sta.className = 'ml-auto text-[10px] text-amber-400';
    } else {
      dot.className = 'w-6 h-6 rounded-full bg-white/10 flex items-center justify-center text-[10px] font-bold text-white/40 shrink-0';
      sta.className = 'ml-auto text-[10px] text-white/30';
    }
    sta.textContent = label;
  }

  document.getElementById("startCameraBtn").addEventListener("click", startCamera);

  document.getElementById("manualLivenessBtn").addEventListener("click", function() {
    var video = document.getElementById("cameraPreview");
    if (!video.srcObject) { alert("Activa la cámara primero"); return; }
    livenessActive = false;
    bioResult.livenessPassed = true;
    blinkCount = 2;
    document.getElementById("bioLiveness").textContent = "✅ Manual";
    document.getElementById("manualLivenessDiv").classList.add("hidden");
    // Capturar frame actual
    var canvas = document.createElement("canvas");
    canvas.width = video.videoWidth || 480;
    canvas.height = video.videoHeight || 854;
    canvas.getContext("2d").drawImage(video, 0, 0);
    var dataUrl = canvas.toDataURL("image/jpeg", 0.9);
    idUploads.selfie = dataUrl;
    selfieDescriptor = null;
    document.getElementById("selfieTaken").classList.remove("hidden");
    document.getElementById("selfieCaptureImg").src = dataUrl;
    document.getElementById("selfieStatus").textContent = "✅ Selfie capturada";
    stopCamera();
    // Extraer descriptor de la imagen capturada para face match
    var img = new Image();
    img.onload = async function() {
      try {
        if (!faceApiLoaded) await initFaceApi_legacy();
        var det = await faceapi
          .detectSingleFace(img, new faceapi.SsdMobilenetv1Options({ minConfidence: 0.2 }))
          .withFaceLandmarks().withFaceDescriptor();
        if (det && det.descriptor) {
          selfieDescriptor = det.descriptor;
          document.getElementById("selfieStatus").textContent = "✅ Selfie + rostro OK";
          document.getElementById("bioFaceSelfie").textContent = "✅ Detectado";
        } else {
          document.getElementById("bioFaceSelfie").textContent = "⚠️ Sin rostro detectado";
        }
      } catch(e) {
        document.getElementById("bioFaceSelfie").textContent = "⚠️ Error: " + (e.message||e);
      }
      updateSteps();
      if (idUploads.front) runFaceMatching();
    };
    img.src = dataUrl;
    updateSteps();
  });

  // ── Submit ──
  document.getElementById("submitSignBtn").addEventListener("click", async function() {
    var name = document.getElementById("fieldName").value.trim();
    if (!name) { alert("El nombre es obligatorio"); return; }

    var imageData = ctx && ctx.getImageData(0, 0, sigCanvas.width, sigCanvas.height).data;
    if (imageData) {
      var empty = true;
      for (var i = 0; i < imageData.length; i += 4) {
        if (imageData[i] !== 255) { empty = false; break; }
      }
      if (empty) { alert("Dibuja tu firma primero"); return; }
    }

    var btn = this;
    btn.disabled = true;
    document.getElementById("signError").classList.add("hidden");

    var SVG_SPIN = '<svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>';
    var SVG_PEN = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>';

    function resetBtn() {
      btn.disabled = false;
      btn.innerHTML = SVG_PEN + ' Firmar Contrato';
    }

    function showSignError(msg) {
      document.getElementById("signError").textContent = msg;
      document.getElementById("signError").classList.remove("hidden");
      resetBtn();
    }

    // \u2500\u2500 Paso 1: Verificaci\u00f3n biom\u00e9trica server-side \u2500\u2500
    btn.innerHTML = SVG_SPIN + ' Verificando identidad...';

    var mrzText = null;
    var mrzInput = document.getElementById("mrzInput");
    if (mrzInput) mrzText = mrzInput.value.trim() || null;

    try {
      var bioRes = await fetch("/api/biometric/verify", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          signing_token: signingToken,
          rut: document.getElementById("fieldRut").value.trim() || null,
          mrz_text: mrzText,
          id_front_data: idUploads.front,
          id_back_data: idUploads.back,
          selfie_data: idUploads.selfie,
          face_match_score: bioResult.faceMatchScore,
          liveness_passed: bioResult.livenessPassed,
        }),
      });
      var bioData = await bioRes.json();
      if (!bioRes.ok) { showSignError(bioData.error || "Error en verificaci\u00f3n biom\u00e9trica"); return; }

      // Actualizar UI con resultados del servidor
      if (bioData.rut_valid !== undefined) document.getElementById("bioRut").textContent = bioData.rut_valid ? "\u2705 V\u00e1lido (servidor)" : "\u274c Inv\u00e1lido";
      if (bioData.mrz_valid !== undefined) document.getElementById("bioMrz").textContent = bioData.mrz_valid ? "\u2705 V\u00e1lido (servidor)" : ("\u274c " + (bioData.mrz_errors && bioData.mrz_errors[0] ? bioData.mrz_errors[0] : "Inv\u00e1lido"));

      // \u2500\u2500 Paso 2: Firmar con el token del servidor \u2500\u2500
      btn.innerHTML = SVG_SPIN + ' Firmando contrato...';

      var res = await fetch("/api/contracts/sign-by-token", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          signing_token: signingToken,
          signature_data: sigCanvas.toDataURL("image/png"),
          client_name: name,
          client_rut: document.getElementById("fieldRut").value.trim() || null,
          client_phone: document.getElementById("fieldPhone").value.trim() || null,
          client_address: document.getElementById("fieldAddress").value.trim() || null,
          id_front_data: idUploads.front,
          id_back_data: idUploads.back,
          selfie_data: idUploads.selfie,
          verification_token: bioData.verification_token,
        }),
      });
      var data = await res.json();
      if (!res.ok) { showSignError(data.error || "Error al firmar"); return; }

      document.getElementById("signForm").classList.add("hidden");
      document.getElementById("doneState").classList.remove("hidden");
      document.getElementById("doneMsg").textContent = "Gracias por firmar el contrato " + (data.contract?.contract_number || "") + ". Recibir\u00e1s una copia por correo.";
      stopCamera();
    } catch (e) {
      showSignError("Error de conexi\u00f3n. Intenta nuevamente.");
    }
  });

  // ── Bio details toggle ──
  document.getElementById("bioStatus").addEventListener("click", function() {
    var d = document.getElementById("bioDetails");
    d.classList.toggle("hidden");
  });

  loadContract();
</script>

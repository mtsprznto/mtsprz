---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Plantillas" description="Gestionar plantillas de contratos">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
    <div>
      <p class="text-[11px] font-medium text-accent tracking-[0.15em] uppercase mb-2">Configuración</p>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white tracking-tight">Plantillas</h1>
      <p class="mt-2 text-sm text-white/30 font-body">Gestiona las plantillas prediseñadas para crear contratos</p>
    </div>
    <button id="seedBtn" class="group inline-flex items-center gap-2.5 px-4 py-2.5 bg-white/[0.04] hover:bg-white/[0.07] transition-all duration-300">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-accent"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>
      <span class="text-[11px] font-medium text-white/40 tracking-wider uppercase group-hover:text-white/60 transition-colors">Inicializar</span>
      <span id="seedResult" class="text-[10px] text-white/20"></span>
    </button>
  </div>

  <!-- Stats: visual summary -->
  <div class="flex flex-wrap gap-px bg-white/[0.04] mb-8">
    <div class="bg-[#010101] px-5 py-3.5 flex-1 min-w-[100px]">
      <div class="font-heading text-xl font-bold text-white" id="statTotal">—</div>
      <div class="text-[9px] text-white/20 uppercase tracking-[0.15em] mt-0.5">Total</div>
    </div>
    <div class="bg-[#010101] px-5 py-3.5 flex-1 min-w-[100px]">
      <div class="font-heading text-xl font-bold text-indigo-300" id="statProyecto">—</div>
      <div class="text-[9px] text-white/20 uppercase tracking-[0.15em] mt-0.5">Proyecto</div>
    </div>
    <div class="bg-[#010101] px-5 py-3.5 flex-1 min-w-[100px]">
      <div class="font-heading text-xl font-bold text-emerald-400" id="statRecurrente">—</div>
      <div class="text-[9px] text-white/20 uppercase tracking-[0.15em] mt-0.5">Recurrente</div>
    </div>
    <div class="bg-[#010101] px-5 py-3.5 flex-1 min-w-[100px]">
      <div class="font-heading text-xl font-bold text-amber-400" id="statDedicada">—</div>
      <div class="text-[9px] text-white/20 uppercase tracking-[0.15em] mt-0.5">Dedicada</div>
    </div>
  </div>

  <!-- Loading skeleton -->
  <div id="templatesLoading">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/[0.04]">
      <div class="bg-[#010101] p-6 min-h-[200px] animate-pulse">
        <div class="h-3 w-16 bg-white/[0.06] mb-3"></div>
        <div class="h-5 w-3/4 bg-white/[0.06] mb-2"></div>
        <div class="h-3 w-full bg-white/[0.04] mb-1"></div>
        <div class="h-3 w-2/3 bg-white/[0.04] mb-4"></div>
        <div class="flex gap-2 mt-auto">
          <div class="h-3 w-14 bg-white/[0.06]"></div>
          <div class="h-3 w-14 bg-white/[0.06]"></div>
        </div>
      </div>
      <div class="bg-[#010101] p-6 min-h-[200px] animate-pulse hidden sm:block">
        <div class="h-3 w-16 bg-white/[0.06] mb-3"></div>
        <div class="h-5 w-2/3 bg-white/[0.06] mb-2"></div>
        <div class="h-3 w-full bg-white/[0.04] mb-1"></div>
        <div class="h-3 w-1/2 bg-white/[0.04] mb-4"></div>
        <div class="flex gap-2">
          <div class="h-3 w-14 bg-white/[0.06]"></div>
          <div class="h-3 w-14 bg-white/[0.06]"></div>
        </div>
      </div>
      <div class="bg-[#010101] p-6 min-h-[200px] animate-pulse hidden lg:block">
        <div class="h-3 w-16 bg-white/[0.06] mb-3"></div>
        <div class="h-5 w-4/5 bg-white/[0.06] mb-2"></div>
        <div class="h-3 w-full bg-white/[0.04] mb-1"></div>
        <div class="h-3 w-3/4 bg-white/[0.04] mb-4"></div>
        <div class="flex gap-2">
          <div class="h-3 w-14 bg-white/[0.06]"></div>
          <div class="h-3 w-14 bg-white/[0.06]"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Card grid -->
  <div id="templatesGrid" class="hidden"></div>

  <!-- Empty state (hidden by default, shown via JS) -->
  <div id="emptyState" class="hidden">
    <div class="border border-white/[0.04] py-16 px-6 text-center">
      <svg class="w-12 h-12 text-white/[0.06] mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
        <line x1="16" y1="13" x2="8" y2="13"/>
        <line x1="16" y1="17" x2="8" y2="17"/>
      </svg>
      <p class="text-sm text-white/25 font-body mb-1">No hay plantillas disponibles</p>
      <p class="text-xs text-white/15 font-body">Inicializa las plantillas por defecto para comenzar</p>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  var typeMeta = {
    proyecto_unico: {
      label: "Proyecto Único",
      color: "text-indigo-300",
      border: "border-indigo-400/20",
      icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>',
    },
    recurrente: {
      label: "Recurrente",
      color: "text-emerald-400",
      border: "border-emerald-400/20",
      icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>',
    },
    jornada_dedicada: {
      label: "Jornada Dedicada",
      color: "text-amber-400",
      border: "border-amber-400/20",
      icon: '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>',
    },
  };

  function getMeta(type) {
    return typeMeta[type] || { label: type || "—", color: "text-white/30", border: "border-white/[0.06]", icon: "" };
  }

  function safeJson(raw) {
    if (!raw) return {};
    if (typeof raw === "object") return raw;
    try { return JSON.parse(raw); } catch(e) { return {}; }
  }

  async function loadTemplates() {
    try {
      var res = await fetch("/api/templates");
      var data = await res.json();
      var loading = document.getElementById("templatesLoading");
      var grid = document.getElementById("templatesGrid");
      var empty = document.getElementById("emptyState");

      loading.classList.add("hidden");

      if (!data.templates || data.templates.length === 0) {
        grid.classList.add("hidden");
        empty.classList.remove("hidden");
        updateStats([]);
        return;
      }

      empty.classList.add("hidden");
      grid.classList.remove("hidden");

      // Stats
      updateStats(data.templates);

      // Render cards
      var html = [];
      html.push('<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/[0.04]">');

      for (var i = 0; i < data.templates.length; i++) {
        var t = data.templates[i];
        var meta = getMeta(t.type);
        var content = safeJson(t.content_json);
        var cat = content.category || "";
        var dur = content.defaultDurationMonths;
        var renewable = content.renewable;

        html.push('<a href="/admin/plantillas/' + t.id + '" class="block bg-[#010101] p-6 flex flex-col group transition-all duration-300 hover:bg-white/[0.015] no-underline cursor-pointer">');

        // Type badge + icon row
        html.push('<div class="flex items-center gap-2 mb-3">');
        html.push('<span class="flex items-center justify-center w-8 h-8 border border-white/[0.06] text-white/40 group-hover:' + meta.color + ' transition-colors duration-300">' + meta.icon + '</span>');
        html.push('<span class="text-[10px] font-medium ' + meta.color + ' uppercase tracking-[0.12em]">' + meta.label + '</span>');
        html.push('</div>');

        // Name
        html.push('<h3 class="font-heading text-base font-bold text-white/80 group-hover:text-white transition-colors duration-300 leading-snug mb-1.5">' + escapeHtml(t.name) + '</h3>');

        // Description
        if (t.description) {
          html.push('<p class="text-xs text-white/25 font-body leading-relaxed mb-4 line-clamp-2">' + escapeHtml(t.description) + '</p>');
        } else {
          html.push('<div class="mb-4"></div>');
        }

        // Divider
        html.push('<div class="border-t border-white/[0.03] mb-3"></div>');

        // Metadata chips
        html.push('<div class="flex flex-wrap gap-x-3 gap-y-1.5 text-[10px] text-white/20 font-body mt-auto">');
        if (cat) {
          html.push('<span class="inline-flex items-center gap-1"><span class="w-1 h-1 rounded-full bg-white/20"></span>' + escapeHtml(cat) + '</span>');
        }
        if (dur) {
          html.push('<span class="inline-flex items-center gap-1"><span class="w-1 h-1 rounded-full bg-white/20"></span>' + dur + ' mes' + (dur > 1 ? "es" : "") + '</span>');
        }
        if (renewable) {
          html.push('<span class="inline-flex items-center gap-1 text-emerald-400/50"><span class="w-1 h-1 rounded-full bg-emerald-400/40"></span>Renovable</span>');
        }
        html.push('</div>');

        // Footer: usage indicator + visual cue
        html.push('<div class="mt-4 pt-3 border-t border-white/[0.03] flex items-center justify-between">');
        var count = parseInt(t.contract_count) || 0;
        if (count > 0) {
          html.push('<span class="inline-flex items-center gap-1.5 text-[10px] font-medium text-accent/70">');
          html.push('<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>');
          html.push(count + ' contrato' + (count > 1 ? "s" : ""));
          html.push('</span>');
        } else {
          html.push('<span class="text-[10px] text-white/15">Sin uso</span>');
        }
        html.push('<span class="inline-flex items-center gap-1.5 text-[10px] font-medium text-white/15 group-hover:text-accent tracking-wider uppercase transition-colors duration-200">');
        html.push('Ver');
        html.push('<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>');
        html.push('</span>');
        html.push('</div>');

        html.push('</a>');
      }

      html.push('</div>');
      grid.innerHTML = html.join("");

    } catch(e) {
      document.getElementById("templatesLoading").innerHTML =
        '<div class="text-center py-12"><p class="text-sm text-red-400/60 font-body">Error al cargar plantillas</p></div>';
    }
  }

  function updateStats(templates) {
    var total = templates.length;
    var p = templates.filter(function(t) { return t.type === "proyecto_unico"; }).length;
    var r = templates.filter(function(t) { return t.type === "recurrente"; }).length;
    var d = templates.filter(function(t) { return t.type === "jornada_dedicada"; }).length;
    document.getElementById("statTotal").textContent = total;
    document.getElementById("statProyecto").textContent = p;
    document.getElementById("statRecurrente").textContent = r;
    document.getElementById("statDedicada").textContent = d;
  }

  function escapeHtml(str) {
    var div = document.createElement("div");
    div.appendChild(document.createTextNode(str));
    return div.innerHTML;
  }

  // Seed button
  document.getElementById("seedBtn").addEventListener("click", async function() {
    var btn = document.getElementById("seedBtn");
    var result = document.getElementById("seedResult");
    btn.disabled = true;
    btn.classList.add("opacity-50", "cursor-not-allowed");
    result.textContent = "Cargando...";

    try {
      var res = await fetch("/api/seed-templates", { method: "POST" });
      var data = await res.json();
      result.textContent = "\u2713 " + data.created + " creadas";
      loadTemplates();
    } catch(e) {
      result.textContent = "Error";
    }
    btn.disabled = false;
    btn.classList.remove("opacity-50", "cursor-not-allowed");
  });

  loadTemplates();
</script>

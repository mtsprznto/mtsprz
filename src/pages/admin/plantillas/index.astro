---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Plantillas" description="Gestionar plantillas de contratos">
  <div class="mb-6">
    <h1 class="font-heading text-2xl font-bold text-white tracking-tight">Plantillas</h1>
    <p class="mt-1 text-sm text-white/35 font-body">Gestiona las plantillas para crear contratos</p>
  </div>

  <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] overflow-x-auto">
    <div id="templatesLoading" class="text-center py-8 text-sm text-white/30">Cargando plantillas...</div>
    <div id="templatesList" class="hidden">
      <table class="w-full border-collapse">
        <thead>
          <tr>
            <th class="text-left text-[11px] font-medium text-white/25 uppercase tracking-wider px-4 py-3 border-b border-white/[0.06]">Nombre</th>
            <th class="text-left text-[11px] font-medium text-white/25 uppercase tracking-wider px-4 py-3 border-b border-white/[0.06]">Tipo</th>
            <th class="text-left text-[11px] font-medium text-white/25 uppercase tracking-wider px-4 py-3 border-b border-white/[0.06]">Descripción</th>
            <th class="text-left text-[11px] font-medium text-white/25 uppercase tracking-wider px-4 py-3 border-b border-white/[0.06]"></th>
          </tr>
        </thead>
        <tbody id="templatesBody"></tbody>
      </table>
    </div>
  </div>

  <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-5 mt-4">
    <div class="flex items-center mb-4"><span class="font-heading text-sm font-semibold text-white tracking-tight">Inicializar Plantillas</span></div>
    <p class="text-xs text-white/40 mb-3">Si es la primera vez, puedes cargar las plantillas por defecto.</p>
    <div class="flex items-center gap-3">
      <button id="seedBtn" class="inline-flex items-center px-4 py-2 rounded-full text-sm font-medium text-white/60 border border-white/[0.08] transition-all duration-200 hover:border-white/20 hover:text-white">Cargar Plantillas por Defecto</button>
      <span id="seedResult" class="text-xs text-white/35"></span>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  var typeLabels = {
    proyecto_unico: "Proyecto \u00danico", recurrente: "Recurrente", jornada_dedicada: "Jornada Dedicada",
  };

  async function loadTemplates() {
    try {
      var res = await fetch("/api/templates");
      var data = await res.json();
      document.getElementById("templatesLoading").classList.add("hidden");
      document.getElementById("templatesList").classList.remove("hidden");

      if (!data.templates || data.templates.length === 0) {
        document.getElementById("templatesBody").innerHTML =
          '<tr><td colspan="4" class="text-center py-8 text-sm text-white/30">Sin plantillas. Carga las plantillas por defecto.</td></tr>';
        return;
      }

      var html = [];
      for (var i = 0; i < data.templates.length; i++) {
        var t = data.templates[i];
        html.push("<tr class='border-b border-white/[0.04]'>");
        html.push("<td class='px-4 py-3.5 text-sm text-white/70 font-medium'>" + t.name + "</td>");
        html.push("<td class='px-4 py-3.5'><span class='inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[11px] font-medium bg-indigo-500/15 text-indigo-400'><span class='w-1.5 h-1.5 rounded-full bg-current shrink-0'></span>" + (typeLabels[t.type] || t.type) + "</span></td>");
        html.push("<td class='px-4 py-3.5 text-xs text-white/40'>" + (t.description || "\u2014") + "</td>");
        html.push("<td class='px-4 py-3.5 text-xs text-white/20 font-mono'>ID: " + t.id + "</td>");
        html.push("</tr>");
      }
      document.getElementById("templatesBody").innerHTML = html.join("");
    } catch(e) {}
  }

  document.getElementById("seedBtn").addEventListener("click", async function() {
    var btn = document.getElementById("seedBtn");
    var result = document.getElementById("seedResult");
    btn.disabled = true;
    btn.classList.add("opacity-50", "cursor-not-allowed");
    result.textContent = "Cargando...";

    try {
      var res = await fetch("/api/seed-templates", { method: "POST" });
      var data = await res.json();
      result.textContent = "\u2713 " + data.created + " plantillas creadas";
      await loadTemplates();
    } catch(e) {
      result.textContent = "Error al cargar";
    }
    btn.disabled = false;
    btn.classList.remove("opacity-50", "cursor-not-allowed");
  });

  loadTemplates();
</script>
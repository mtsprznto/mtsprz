---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard" description="Panel de administración">
  <div class="mb-10">
    <p class="text-[11px] font-medium text-accent tracking-[0.15em] uppercase mb-2">Panel de Control</p>
    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white tracking-tight">Dashboard</h1>
    <p class="mt-2 text-sm text-white/30 font-body max-w-md">Resumen de contratos y actividad del sistema</p>
  </div>

  <!-- Stats: editorial typographic treatment -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-px bg-white/[0.04] mb-10">
    <div class="bg-[#010101] p-6 sm:p-8">
      <div class="font-heading text-4xl sm:text-5xl font-bold text-white tracking-tight" id="statTotal">—</div>
      <div class="mt-2 text-[10px] text-white/25 uppercase tracking-[0.15em] font-medium">Total Contratos</div>
    </div>
    <div class="bg-[#010101] p-6 sm:p-8">
      <div class="font-heading text-4xl sm:text-5xl font-bold text-amber-300 tracking-tight" id="statPending">—</div>
      <div class="mt-2 text-[10px] text-white/25 uppercase tracking-[0.15em] font-medium">Pendientes</div>
    </div>
    <div class="bg-[#010101] p-6 sm:p-8">
      <div class="font-heading text-4xl sm:text-5xl font-bold text-emerald-400 tracking-tight" id="statCompleted">—</div>
      <div class="mt-2 text-[10px] text-white/25 uppercase tracking-[0.15em] font-medium">Completados</div>
    </div>
    <div class="bg-[#010101] p-6 sm:p-8">
      <div class="font-heading text-4xl sm:text-5xl font-bold text-red-400/70 tracking-tight" id="statCancelled">—</div>
      <div class="mt-2 text-[10px] text-white/25 uppercase tracking-[0.15em] font-medium">Cancelados</div>
    </div>
  </div>

  <!-- Quick Actions: editorial CTA -->
  <div class="border-t border-white/[0.06] pt-8">
    <p class="text-[10px] font-medium text-white/20 tracking-[0.15em] uppercase mb-5">Acciones Rápidas</p>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/admin/contratos/nuevo" class="group inline-flex items-center gap-3 px-5 py-3 bg-white/[0.04] hover:bg-white/[0.07] transition-all duration-300 no-underline">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-accent/10">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-accent"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </span>
        <span class="text-xs font-medium text-white/60 tracking-wider uppercase group-hover:text-white/80 transition-colors">Nuevo Contrato</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/20 ml-auto group-hover:text-white/40 transition-colors"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/admin/contratos" class="group inline-flex items-center gap-3 px-5 py-3 bg-white/[0.04] hover:bg-white/[0.07] transition-all duration-300 no-underline">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-white/[0.04]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        </span>
        <span class="text-xs font-medium text-white/50 tracking-wider uppercase group-hover:text-white/70 transition-colors">Ver Todos los Contratos</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/20 ml-auto group-hover:text-white/40 transition-colors"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
      <a href="/admin/plantillas" class="group inline-flex items-center gap-3 px-5 py-3 bg-white/[0.04] hover:bg-white/[0.07] transition-all duration-300 no-underline">
        <span class="flex items-center justify-center w-8 h-8 rounded-full bg-white/[0.04]">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        </span>
        <span class="text-xs font-medium text-white/50 tracking-wider uppercase group-hover:text-white/70 transition-colors">Gestionar Plantillas</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/20 ml-auto group-hover:text-white/40 transition-colors"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  (function() {
    async function loadStats() {
      try {
        var res = await fetch("/api/contracts");
        var data = await res.json();
        if (data.contracts) {
          var total = data.contracts.length;
          var pending = data.contracts.filter(function(c) { return c.status === "pending"; }).length;
          var completed = data.contracts.filter(function(c) { return c.status === "completed"; }).length;
          var cancelled = data.contracts.filter(function(c) { return c.status === "cancelled"; }).length;

          document.getElementById("statTotal").textContent = total;
          document.getElementById("statPending").textContent = pending;
          document.getElementById("statCompleted").textContent = completed;
          document.getElementById("statCancelled").textContent = cancelled;
        }
      } catch(e) {}
    }
    loadStats();
  })();
</script>

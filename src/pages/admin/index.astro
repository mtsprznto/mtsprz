---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Dashboard" description="Panel de administración">
  <div class="mb-6">
    <h1 class="font-heading text-2xl font-bold text-white tracking-tight">Dashboard</h1>
    <p class="mt-1 text-sm text-white/35 font-body">Resumen de contratos y actividad</p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 mb-8">
    <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-4 sm:p-5 text-center">
      <div class="font-heading text-2xl sm:text-3xl font-bold text-accent" id="statTotal">—</div>
      <div class="mt-1 text-[11px] text-white/35 uppercase tracking-wider font-medium">Total Contratos</div>
    </div>
    <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-4 sm:p-5 text-center">
      <div class="font-heading text-2xl sm:text-3xl font-bold text-amber-400" id="statPending">—</div>
      <div class="mt-1 text-[11px] text-white/35 uppercase tracking-wider font-medium">Pendientes</div>
    </div>
    <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-4 sm:p-5 text-center">
      <div class="font-heading text-2xl sm:text-3xl font-bold text-emerald-400" id="statCompleted">—</div>
      <div class="mt-1 text-[11px] text-white/35 uppercase tracking-wider font-medium">Completados</div>
    </div>
    <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-4 sm:p-5 text-center">
      <div class="font-heading text-2xl sm:text-3xl font-bold text-red-400" id="statCancelled">—</div>
      <div class="mt-1 text-[11px] text-white/35 uppercase tracking-wider font-medium">Cancelados</div>
    </div>
  </div>

  <div class="liquid-glass rounded-xl p-5 sm:p-6">
    <h2 class="font-heading text-sm font-semibold text-white tracking-tight mb-4">Acciones Rápidas</h2>
    <div class="flex flex-col sm:flex-row gap-3">
      <a href="/admin/contratos/nuevo" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium text-white bg-gradient-to-r from-accent to-violet-500 no-underline transition-all duration-200 hover:opacity-90 hover:-translate-y-0.5">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuevo Contrato
      </a>
      <a href="/admin/contratos" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium text-white/60 border border-white/[0.08] no-underline transition-all duration-200 hover:border-white/20 hover:text-white">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        Ver Todos los Contratos
      </a>
      <a href="/admin/plantillas" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full text-sm font-medium text-white/60 border border-white/[0.08] no-underline transition-all duration-200 hover:border-white/20 hover:text-white">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
        Gestionar Plantillas
      </a>
    </div>
  </div>
</AdminLayout>

<script is:inline>
  (function() {
    async function loadStats() {
      try {
        var res = await fetch("/api/contracts");
        var data = await res.json();
        if (data.contracts) {
          var total = data.contracts.length;
          var pending = data.contracts.filter(function(c) { return c.status === "pending"; }).length;
          var completed = data.contracts.filter(function(c) { return c.status === "completed"; }).length;
          var cancelled = data.contracts.filter(function(c) { return c.status === "cancelled"; }).length;

          document.getElementById("statTotal").textContent = total;
          document.getElementById("statPending").textContent = pending;
          document.getElementById("statCompleted").textContent = completed;
          document.getElementById("statCancelled").textContent = cancelled;
        }
      } catch(e) {}
    }
    loadStats();
  })();
</script>

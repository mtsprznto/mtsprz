---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { query, initDb } from "../../../lib/db";
export const prerender = false;

const { slug } = Astro.params;
await initDb();
const result = await query("SELECT * FROM services WHERE slug = $1", [slug]);
const service = result.rows[0] as Record<string, unknown> | undefined;
if (!service) {
  return Astro.redirect("/admin/servicios", 302);
}
---

<AdminLayout title={`Editar ${service.name as string} — Admin Mtsprz`}>
  <div class="mb-8">
    <a href="/admin/servicios" class="inline-flex items-center gap-1.5 text-xs text-white/30 hover:text-white/60 transition-colors mb-3 no-underline">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M19 12H5 M12 19l-7-7 7-7"/></svg>
      <span class="text-[10px] font-medium tracking-wider uppercase">Volver a Servicios</span>
    </a>
    <p class="text-[11px] font-medium text-accent tracking-[0.15em] uppercase mb-2">Editar</p>
    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white tracking-tight">Editar Servicio</h1>
    <p class="mt-2 text-sm text-white/30 font-body">{service.name as string}</p>
  </div>

  <form id="serviceForm" class="max-w-3xl" data-slug={service.slug as string}>
    <!-- Basic info -->
    <div class="border-b border-white/[0.04] pb-6 mb-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
        <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Información General</span>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="sm:col-span-2">
          <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Nombre <span class="text-red-400/60">*</span></label>
          <input name="name" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" value={service.name as string} maxlength="255" required />
        </div>
        <div>
          <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Categoría</label>
          <input name="category" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" value={service.category as string || ""} maxlength="100" />
        </div>
        <div>
          <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Precio CLP <span class="text-red-400/60">*</span></label>
          <input name="price" type="number" min="0" max="2147483647" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-mono" value={service.price as number} required />
        </div>
        <div>
          <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Precio Promocional</label>
          <input name="promo_price" type="number" min="0" max="2147483647" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-mono" value={service.promo_price as number || ""} />
        </div>
      </div>

      <div class="mt-5">
        <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Descripción Detallada</label>
        <textarea name="description" rows="4" class="w-full bg-transparent border border-white/[0.08] py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body resize-y">{service.description as string || ""}</textarea>
      </div>

      <div class="mt-5">
        <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Entregables (uno por línea)</label>
        <textarea name="deliverables" rows="4" class="w-full bg-transparent border border-white/[0.08] py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body resize-y">{(service.deliverables as string[] || []).join("\n")}</textarea>
      </div>
    </div>

    <!-- Maintenance -->
    <div class="border-b border-white/[0.04] pb-6 mb-6">
      <div class="flex items-center gap-3 mb-5">
        <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
        <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Mantenimiento</span>
      </div>
      <div class="flex items-center gap-3 mb-4">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" name="includes_maintenance" class="sr-only peer" checked={service.includes_maintenance as boolean} />
          <div class="w-9 h-5 bg-white/[0.08] rounded-full peer peer-checked:bg-accent/40 transition-colors after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"></div>
        </label>
        <span class="text-sm text-white/50">Incluye plan de mantenimiento recomendado</span>
      </div>
      <div id="maintenanceFields" class={`grid grid-cols-1 sm:grid-cols-2 gap-5 ${service.includes_maintenance ? "" : "hidden"}`}>
        <div>
          <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Precio Mantenimiento (CLP/mes)</label>
          <input name="maintenance_price" type="number" min="0" max="2147483647" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-mono" value={service.maintenance_price as number || ""} />
        </div>
        <div class="sm:col-span-2">
          <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Descripción Mantenimiento</label>
          <textarea name="maintenance_description" rows="3" class="w-full bg-transparent border border-white/[0.08] py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body resize-y">{service.maintenance_description as string || ""}</textarea>
        </div>
      </div>
    </div>

    <!-- Status toggle -->
    <div class="border-b border-white/[0.04] pb-6 mb-6">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
        <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Estado</span>
      </div>
      <div class="flex items-center gap-3">
        <label class="relative inline-flex items-center cursor-pointer">
          <input type="checkbox" name="is_active" class="sr-only peer" checked={service.is_active as boolean} />
          <div class="w-9 h-5 bg-white/[0.08] rounded-full peer peer-checked:bg-emerald-400/40 transition-colors after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"></div>
        </label>
        <span class="text-sm text-white/50">Servicio activo (disponible en contratos)</span>
      </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-between">
      <button type="button" id="deleteBtn" class="text-[10px] font-medium text-red-400/30 hover:text-red-400/60 tracking-wider uppercase transition-colors">Eliminar</button>
      <div class="flex items-center gap-3">
        <a href="/admin/servicios" class="inline-flex items-center px-3.5 py-2 bg-white/[0.04] hover:bg-white/[0.07] text-[10px] font-medium text-white/40 tracking-wider uppercase transition-all duration-300 no-underline">Cancelar</a>
        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-accent/10 hover:bg-accent/20 text-[10px] font-medium text-accent tracking-wider uppercase transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg>
          Guardar Cambios
        </button>
      </div>
    </div>
  </form>
</AdminLayout>

<script is:inline>
  document.querySelector("[name='includes_maintenance']").addEventListener("change", function() {
    document.getElementById("maintenanceFields").classList.toggle("hidden", !this.checked);
  });

  document.getElementById("serviceForm").addEventListener("submit", async function(e) {
    e.preventDefault();
    var form = this;
    var data = new FormData(form);
    var deliverables = (data.get("deliverables") || "").split("\n").map(function(s) { return s.trim(); }).filter(Boolean);
    var slug = form.getAttribute("data-slug");

    var body = {
      name: data.get("name"),
      description: data.get("description"),
      price: parseInt(data.get("price")) || 0,
      promo_price: data.get("promo_price") ? parseInt(data.get("promo_price")) : null,
      category: data.get("category"),
      deliverable: deliverables,
      includes_maintenance: data.has("includes_maintenance"),
      maintenance_price: data.has("includes_maintenance") ? (parseInt(data.get("maintenance_price")) || 0) : 0,
      maintenance_description: data.has("includes_maintenance") ? data.get("maintenance_description") : null,
      is_active: data.has("is_active"),
    };

    var btn = form.querySelector("button[type='submit']");
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Guardando...';

    try {
      var res = await fetch("/api/services/" + slug, { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) });
      var json = await res.json();
      if (res.ok) {
        window.location.reload();
      } else {
        alert("Error: " + (json.error || "Desconocido"));
        btn.disabled = false;
        btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg> Guardar Cambios';
      }
    } catch (err) {
      alert("Error de red: " + err.message);
      btn.disabled = false;
      btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20 6L9 17l-5-5"/></svg> Guardar Cambios';
    }
  });

  document.getElementById("deleteBtn").addEventListener("click", async function() {
    if (!confirm("¿Eliminar este servicio? Esta acción no se puede deshacer.")) return;
    var slug = document.getElementById("serviceForm").getAttribute("data-slug");
    var res = await fetch("/api/services/" + slug, { method: "DELETE" });
    if (res.ok) {
      window.location.href = "/admin/servicios";
    } else {
      var json = await res.json();
      alert("Error: " + (json.error || "Desconocido"));
    }
  });
</script>

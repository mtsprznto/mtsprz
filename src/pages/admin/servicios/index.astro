---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { query, initDb } from "../../../lib/db";
export const prerender = false;

await initDb();
const result = await query("SELECT * FROM services ORDER BY category, name");
const services = result.rows as Record<string, unknown>[];
---

<AdminLayout title="Servicios — Admin Mtsprz">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="font-heading text-2xl font-bold text-white tracking-tight">Servicios</h1>
      <p class="text-sm text-white/30 mt-0.5">Gestiona los servicios disponibles para contratos</p>
    </div>
    <div class="flex items-center gap-3">
      <form method="POST" action="/api/services/seed">
        <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-medium text-white/50 border border-white/[0.08] transition-all duration-200 hover:border-white/20 hover:text-white/70">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12a9 9 0 1 1 9 9"/><path d="M21 12h-4l-2 3-3-6-1 2h-3"/></svg>
          Cargar por Defecto
        </button>
      </form>
      <a href="/admin/servicios/nuevo" class="inline-flex items-center gap-2 px-4 py-2 rounded-xl text-xs font-medium text-white bg-gradient-to-r from-accent to-violet-500 transition-all duration-200 hover:opacity-90">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14 M5 12h14"/></svg>
        Nuevo Servicio
      </a>
    </div>
  </div>

  <div class="rounded-xl border border-white/[0.06] overflow-hidden">
    <table class="w-full">
      <thead>
        <tr class="border-b border-white/[0.06]">
          <th class="text-left text-[10px] font-medium text-white/30 uppercase tracking-wider px-4 py-3">Nombre</th>
          <th class="text-left text-[10px] font-medium text-white/30 uppercase tracking-wider px-4 py-3">Categoría</th>
          <th class="text-right text-[10px] font-medium text-white/30 uppercase tracking-wider px-4 py-3">Precio</th>
          <th class="text-right text-[10px] font-medium text-white/30 uppercase tracking-wider px-4 py-3">Mantención</th>
          <th class="text-center text-[10px] font-medium text-white/30 uppercase tracking-wider px-4 py-3">Estado</th>
          <th class="text-right text-[10px] font-medium text-white/30 uppercase tracking-wider px-4 py-3">Acción</th>
        </tr>
      </thead>
      <tbody>
        {services.length === 0 ? (
          <tr><td colspan="6" class="px-4 py-12 text-center text-sm text-white/20">No hay servicios. Carga los servicios por defecto o crea uno nuevo.</td></tr>
        ) : services.map((s) => (
          <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
            <td class="px-4 py-3">
              <div class="text-sm text-white/90 font-medium">{s.name as string}</div>
              <div class="text-[11px] text-white/30 mt-0.5 line-clamp-1">{(s.description as string || "").slice(0, 80)}</div>
            </td>
            <td class="px-4 py-3 text-sm text-white/50">{s.category as string || "—"}</td>
            <td class="px-4 py-3 text-right">
              <div class="text-sm text-accent font-mono">
                ${Number(s.price).toLocaleString("es-CL")}
              </div>
              {(s.promo_price as number) ? (
                <div class="text-[10px] text-white/30 line-through font-mono">${Number(s.promo_price).toLocaleString("es-CL")}</div>
              ) : ""}
            </td>
            <td class="px-4 py-3 text-right text-sm text-white/50 font-mono">
              {s.includes_maintenance ? `$${Number(s.maintenance_price).toLocaleString("es-CL")}/mes` : "—"}
            </td>
            <td class="px-4 py-3 text-center">
              <span class={`inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium ${s.is_active ? "bg-emerald-400/10 text-emerald-400" : "bg-white/5 text-white/30"}`}>
                <span class={`w-1.5 h-1.5 rounded-full ${s.is_active ? "bg-emerald-400" : "bg-white/20"}`}></span>
                {s.is_active ? "Activo" : "Inactivo"}
              </span>
            </td>
            <td class="px-4 py-3 text-right">
              <a href={`/admin/servicios/${s.slug as string}`} class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-[11px] font-medium text-white/50 border border-white/[0.08] transition-all duration-200 hover:border-white/20 hover:text-white/80">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Editar
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>

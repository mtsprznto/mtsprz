---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { query, initDb } from "../../../lib/db";
export const prerender = false;

await initDb();
const result = await query("SELECT * FROM services ORDER BY category, name");
const services = result.rows as Record<string, unknown>[];
---

<AdminLayout title="Servicios — Admin Mtsprz">
  <div class="flex items-end justify-between flex-wrap gap-4 mb-8">
    <div>
      <p class="text-[11px] font-medium text-accent tracking-[0.15em] uppercase mb-2">Catálogo</p>
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white tracking-tight">Servicios</h1>
      <p class="mt-2 text-sm text-white/30 font-body">Gestiona los servicios disponibles para contratos</p>
    </div>
    <div class="flex items-center gap-2">
      <form method="POST" action="/api/services/seed">
        <button type="submit" class="inline-flex items-center gap-2 px-3 py-2 bg-white/[0.04] hover:bg-white/[0.07] text-[10px] font-medium text-white/40 tracking-wider uppercase transition-all duration-300">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M3 12a9 9 0 1 1 9 9"/><path d="M21 12h-4l-2 3-3-6-1 2h-3"/></svg>
          Cargar por Defecto
        </button>
      </form>
      <a href="/admin/servicios/nuevo" class="inline-flex items-center gap-2 px-3 py-2 bg-accent/10 hover:bg-accent/20 text-[10px] font-medium text-accent tracking-wider uppercase transition-all duration-300">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nuevo Servicio
      </a>
    </div>
  </div>

  <div class="overflow-x-auto border border-white/[0.04]">
    <table class="w-full">
      <thead>
        <tr class="border-b border-white/[0.04]">
          <th class="text-left text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] px-4 py-3.5">Nombre</th>
          <th class="text-left text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] px-4 py-3.5">Categoría</th>
          <th class="text-right text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] px-4 py-3.5">Precio</th>
          <th class="text-right text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] px-4 py-3.5">Mantención</th>
          <th class="text-center text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] px-4 py-3.5">Estado</th>
          <th class="text-right text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] px-4 py-3.5">Acción</th>
        </tr>
      </thead>
      <tbody>
        {services.length === 0 ? (
          <tr><td colspan="6" class="px-4 py-16 text-center text-sm text-white/20 font-body">No hay servicios. Carga los servicios por defecto o crea uno nuevo.</td></tr>
        ) : services.map((s) => (
          <tr class="border-b border-white/[0.03] hover:bg-white/[0.015] transition-colors">
            <td class="px-4 py-3.5">
              <div class="text-sm text-white/80 font-medium">{(s.name as string)}</div>
              <div class="text-[11px] text-white/25 mt-0.5 line-clamp-1 font-body">{(s.description as string || "").slice(0, 80)}</div>
            </td>
            <td class="px-4 py-3.5 text-sm text-white/40">{(s.category as string || "—")}</td>
            <td class="px-4 py-3.5 text-right">
              <div class="text-sm text-accent font-mono">
                ${Number(s.price).toLocaleString("es-CL")}
              </div>
              {(s.promo_price as number) ? (
                <div class="text-[10px] text-white/20 line-through font-mono">${Number(s.promo_price).toLocaleString("es-CL")}</div>
              ) : ""}
            </td>
            <td class="px-4 py-3.5 text-right text-sm text-white/40 font-mono">
              {s.includes_maintenance ? `$${Number(s.maintenance_price).toLocaleString("es-CL")}/mes` : "—"}
            </td>
            <td class="px-4 py-3.5 text-center">
              <span class={`inline-flex items-center gap-1.5 ${s.is_active ? "text-emerald-400" : "text-white/25"} text-[11px] font-medium`}>
                <span class={`w-1.5 h-1.5 rounded-full ${s.is_active ? "bg-emerald-400" : "bg-white/20"}`}></span>
                {s.is_active ? "Activo" : "Inactivo"}
              </span>
            </td>
            <td class="px-4 py-3.5 text-right">
              <a href={`/admin/servicios/${s.slug as string}`} class="inline-flex items-center gap-1.5 px-2.5 py-1.5 text-[10px] font-medium text-white/30 hover:text-white/60 transition-colors uppercase tracking-wider">
                Editar →
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</AdminLayout>

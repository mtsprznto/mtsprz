<script id="pricing-data" type="application/json">{JSON.stringify({ rut: prestadorRut, services })}</script>

<script is:inline>
  var pricingServices = {};
  var allServices = [];
  var prestadorRut = "Pendiente";
  try {
    var configData = JSON.parse(document.getElementById("pricing-data").textContent);
    prestadorRut = configData.rut || "Pendiente";
    // Override from form field if filled
    var rutField = document.querySelector("[name='prestador_rut']");
    if (rutField && rutField.value) prestadorRut = rutField.value;
    allServices = configData.services || [];
    allServices.forEach(function(s) {
      pricingServices[s.slug] = {
        name: s.name,
        price: s.promo_price && s.promo_price > 0 ? s.promo_price : s.price,
        description: s.description || "",
        deliverables: s.deliverables || [],
        includes_maintenance: !!s.includes_maintenance,
        maintenance_price: s.maintenance_price || 0,
        maintenance_description: s.maintenance_description || "",
      };
    });
  } catch(e) { console.warn("Error loading pricing data:", e); }

  async function loadServiceDescriptions() {
    try {
      var res = await fetch("/api/services?active=true");
      var json = await res.json();
      if (json.services) {
        allServices = json.services;
        pricingServices = {};
        var opts = '<option value="">Personalizado...</option>';
        json.services.forEach(function(s) {
          var promoP = s.promo_price && s.promo_price > 0 ? s.promo_price : null;
          var fullP = s.price;
          var displayPrice = promoP || fullP;
          pricingServices[s.slug] = {
            name: s.name,
            price: displayPrice,
            price_full: fullP,
            description: s.description || "",
            deliverables: s.deliverables || [],
            includes_maintenance: s.includes_maintenance || false,
            maintenance_price: s.maintenance_price || 0,
            maintenance_description: s.maintenance_description || "",
            is_monthly: !!s.is_monthly,
          };
          var label = s.name + ' — $' + fullP.toLocaleString('es-CL');
          if (promoP && promoP !== fullP) label += ' (promo $' + promoP.toLocaleString('es-CL') + ')';
          opts += '<option value="' + s.slug + '" data-price="' + displayPrice + '" data-price-full="' + fullP + '">' + label + "</option>";
        });
        document.querySelectorAll(".service-select").forEach(function(sel) {
          var currentVal = sel.value;
          sel.innerHTML = opts;
          sel.value = currentVal;
        });
      }
    } catch(e) { console.warn("No se pudieron cargar servicios desde DB:", e); }
  }

  function getServiceRows() {
    return document.querySelectorAll(".service-row");
  }

  function updateServicePrice(select) {
    var row = select.closest(".service-row");
    var priceInput = row.querySelector(".service-price");
    var nameInput = row.querySelector(".service-name");
    var selected = select.options[select.selectedIndex];
    var dataPrice = selected.getAttribute("data-price");
    var dataPriceFull = selected.getAttribute("data-price-full");
    var delivTextarea = row.querySelector(".service-deliverables");
    if (dataPrice) {
      priceInput.value = dataPrice;
      var svc = pricingServices[select.value];
      // Name from service data (not selected.text, which may contain price info)
      nameInput.value = svc ? svc.name : selected.text;
      nameInput.readOnly = true;
      // Auto-fill deliverables from service data
      if (svc && svc.deliverables && svc.deliverables.length > 0) {
        delivTextarea.value = svc.deliverables.join("\n");
      } else {
        delivTextarea.value = "";
      }
    } else {
      nameInput.readOnly = false;
      delivTextarea.value = "";
    }
    updateTotal();
    updatePreview();
  }

  // Strip price info from service names (prevents " — $400.000 (promo $350.000)" leaking into doc)
  function sanitizeServiceName(raw) {
    // Strip trailing price info: " — $400.000 (promo $350.000)" or "— $250.000" or " (promo $290.000)"
    return (raw || "").replace(/\s*[-–—].*\(promo\s*\$[\d\.]+.*\)/g, "").replace(/\s*[-–—]\s*\$[\d\.]+[\s\S]*$/g, "").trim();
  }

  function getServices() {
    var rows = getServiceRows();
    return Array.from(rows).map(function(row) {
      var select = row.querySelector(".service-select");
      var nameInput = row.querySelector(".service-name");
      var priceInput = row.querySelector(".service-price");
      var delivTextarea = row.querySelector(".service-deliverables");
      var id = select.value || "custom";
      var svc = pricingServices[id] || {};
      // Read deliverables from textarea first (user can edit), fallback to service data
      var deliverables = [];
      if (delivTextarea && delivTextarea.value.trim()) {
        deliverables = delivTextarea.value.split("\n").map(function(s) { return s.trim(); }).filter(Boolean);
      } else if (svc.deliverables) {
        deliverables = svc.deliverables;
      }
      return {
        id: id,
        name: sanitizeServiceName(nameInput.value) || "Servicio personalizado",
        price: parseInt(priceInput.value) || 0,
        description: svc.description || "",
        deliverables: deliverables,
        includes_maintenance: svc.includes_maintenance || false,
        maintenance_price: svc.maintenance_price || 0,
        maintenance_description: svc.maintenance_description || "",
        is_monthly: !!svc.is_monthly,
      };
    });
  }

  // Keywords que implican servicio continuo/recurrente aunque is_monthly sea false
  var RECURRING_PATTERNS = [
    "mensual", "monthly", "gestión de redes", "gestion de redes",
    "mantenimiento seo", "community", "social media", "seguimiento",
    "soporte continuo", "monitoreo continuo",
  ];

  function checkRecurringMismatch(svcs) {
    var mismatched = svcs.filter(function(s) {
      if (s.is_monthly) return false; // ya marcado correcto
      var name = (s.name || "").toLowerCase();
      return RECURRING_PATTERNS.some(function(p) { return name.includes(p); });
    });
    var banner = document.getElementById("recurringWarning");
    var detail = document.getElementById("recurringWarningDetail");
    if (mismatched.length > 0) {
      var names = mismatched.map(function(s) { return '"' + s.name + '"'; }).join(", ");
      detail.textContent = names + " — nombre implica servicio continuo pero el precio está contabilizado una sola vez. " +
        "Si es cobro mensual, el texto firmado solo respalda el monto total indicado (perjudica al prestador).";
      banner.classList.remove("hidden");
    } else {
      banner.classList.add("hidden");
    }
  }

  // Slugs/keywords de servicios que pueden clasificar como 1ª categoría → posible IVA/factura
  var IVA_RISK_PATTERNS = [
    "ecommerce", "e-commerce", "tienda", "web-app", "aplicacion", "aplicación",
    "crm", "bot", "sistema", "backend", "api", "plataforma",
    "whatsapp", "automatizacion", "automatización",
  ];

  function checkIvaRisk(svcs) {
    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    var risky = svcs.filter(function(s) {
      var slug = (s.id || "").toLowerCase();
      var name = (s.name || "").toLowerCase();
      return IVA_RISK_PATTERNS.some(function(p) { return slug.includes(p) || name.includes(p); });
    });
    var riskyTotal = risky.reduce(function(sum, s) { return sum + s.price; }, 0);
    var pct = total > 0 ? Math.round((riskyTotal / total) * 100) : 0;

    var banner = document.getElementById("ivaWarning");
    var detail = document.getElementById("ivaWarningDetail");
    if (risky.length > 0) {
      var names = risky.map(function(s) { return s.name + " ($" + s.price.toLocaleString("es-CL") + ")"; }).join(", ");
      detail.textContent = "Servicios de posible 1ª categoría: " + names + " — " + pct + "% del total. " +
        "El SII puede clasificar desarrollo transaccional (e-commerce, apps, bots, CRM) como actividad afecta a IVA (Art. 20 N°3 LIR). " +
        "Si corresponde factura en vez de boleta de honorarios, el IVA no declarado (19%) quedaría a cargo del prestador.";
      banner.classList.remove("hidden");
    } else {
      banner.classList.add("hidden");
    }
  }

  function updateTotal() {
    var svcs = getServices();
    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    var formatted = "$" + total.toLocaleString("es-CL");
    document.getElementById("totalDisplay").textContent = formatted;
    document.getElementById("stickyTotal").textContent = formatted;
    document.getElementById("serviceCount").textContent = svcs.length + (svcs.length === 1 ? "" : "");
    var totalInput = document.querySelector("[name='total_amount']");
    if (!totalInput.value) totalInput.value = String(total);
    checkRecurringMismatch(svcs);
    checkIvaRisk(svcs);
    updatePreview();
  }

  function updatePreview() {
    var templateLabels = { proyecto_unico: "Proyecto \u00danico", recurrente: "Servicio Recurrente", jornada_dedicada: "Jornada Dedicada" };
    var selected = document.querySelector("input[name='templateType']:checked");
    var typeEl = document.getElementById("previewType");
    if (selected && selected.value) {
      typeEl.textContent = templateLabels[selected.value] || selected.value;
    } else {
      typeEl.textContent = "—";
    }

    var clientName = document.querySelector("[name='client_name']").value || "—";
    document.getElementById("previewClient").textContent = clientName;

    var svcs = getServices();
    var svcCount = svcs.filter(function(s) { return s.name; }).length;
    document.getElementById("previewServices").textContent = svcCount > 0 ? svcCount + " servicio(s)" : "—";

    var duration = document.querySelector("[name='duration_months']").value;

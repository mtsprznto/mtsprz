      <div class="flex items-center justify-end gap-3 px-5 sm:px-7 py-4 border-t border-white/[0.04] shrink-0">
        <button onclick="closePreview()" class="px-3.5 py-2 bg-white/[0.04] hover:bg-white/[0.07] text-[10px] font-medium text-white/40 tracking-wider uppercase transition-all duration-300">Cerrar</button>
        <button id="previewSubmitBtn" class="px-4 py-2 bg-accent/10 hover:bg-accent/20 text-[10px] font-medium text-accent tracking-wider uppercase transition-all duration-300">
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="inline mr-1 -mt-0.5"><polyline points="20 6 9 17 4 12"/></svg>

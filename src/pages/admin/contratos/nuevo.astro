    html += clauseTitle(2, 'OBJETO DEL CONTRATO');
    html += clauseText('El Prestador se obliga a prestar al Cliente los servicios digitales detallados en la cláusula siguiente, conforme a las especificaciones acordadas.');
    html += clauseBold('Alcance incluido: ', 'Los servicios contratados se detallan en la cláusula CUARTA. Los entregables, plazos y especificaciones de cada servicio se describen en el Anexo A adjunto, que forma parte integrante de este contrato.');
    html += clauseBold('Alcance excluido: ', 'Quedan excluidos: (a) servicios no listados; (b) modificaciones no acordadas por escrito; (c) licencias de software de terceros, costos de suscripción o infraestructura tecnológica, salvo que se incluyan expresamente como entregable en el Anexo A del presente contrato.');

    // ── 4. SERVICIOS CONTRATADOS ──

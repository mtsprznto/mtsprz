    var endDate = document.querySelector("[name='end_date']").value || "";
    var specialClauses = document.querySelector("[name='special_clauses']")?.value || "";

    var dateStr = new Date().toLocaleDateString("es-CL", { year: "numeric", month: "long", day: "numeric" });
    function fmt(n) { return "$" + n.toLocaleString("es-CL"); }

    // Helper: clause header
    var ordinals = ["PRIMERA","SEGUNDA","TERCERA","CUARTA","QUINTA","SEXTA","SÉPTIMA","OCTAVA","NOVENA","DÉCIMA","DÉCIMA PRIMERA","DÉCIMA SEGUNDA","DÉCIMA TERCERA","DÉCIMA CUARTA","DÉCIMA QUINTA","DÉCIMA SEXTA","DÉCIMA SÉPTIMA","DÉCIMA OCTAVA","DÉCIMA NOVENA"];
    function clauseTitle(idx, title) {
      return '<h3 style="font-size:13px;font-weight:700;color:#4f46e5;margin:16px 0 6px;padding-top:10px;border-top:1px solid #e5e7eb;">' + ordinals[idx] + '. — ' + title + '</h3>';
    }
    function clauseText(t) {
      return '<p style="font-size:11px;color:#374151;margin:0 0 6px;line-height:1.55;">' + t + '</p>';
    }
    function clauseBold(label, text) {
      return '<p style="font-size:11px;color:#374151;margin:0 0 4px;line-height:1.55;"><strong style="color:#111827;">' + label + '</strong>' + text + '</p>';
    }
    function clauseItem(letter, text) {
      return '<p style="font-size:11px;color:#374151;margin:0 0 3px 16px;line-height:1.5;text-indent:-12px;padding-left:12px;"><strong>' + letter + ')</strong> ' + text + '</p>';
    }

    var html = "";

    // ── HEADER ──
    html += '<div style="text-align:center;margin-bottom:20px;padding-bottom:16px;border-bottom:2px solid #4f46e5;">';
    html += '<h1 style="font-size:18px;font-weight:700;color:#111827;margin:0 0 2px;">CONTRATO DE PRESTACIÓN DE SERVICIOS</h1>';
    html += '<p style="font-size:11px;color:#6b7280;margin:0;">Mtsprz — Soluciones Digitales</p>';
    html += '<p style="font-size:10px;color:#9ca3af;margin:6px 0 0;">Fecha: ' + dateStr + ' | N° Contrato: (se generará al crear)</p>';
    html += '</div>';

    // ── 1. IDENTIFICACIÓN DE LAS PARTES ──
    html += clauseTitle(0, 'IDENTIFICACIÓN DE LAS PARTES');
    html += '<table style="width:100%;font-size:11px;border-collapse:collapse;margin-bottom:8px;">';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;width:130px;">PRESTADOR:</td><td style="padding:2px 0;color:#111827;">Mtsprz — Soluciones Digitales</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">RUT PRESTADOR:</td><td style="padding:2px 0;color:#111827;">' + prestadorRut + '</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">DOMICILIO:</td><td style="padding:2px 0;color:#111827;">Puerto Varas, Región de Los Lagos, Chile</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">CORREO:</td><td style="padding:2px 0;color:#111827;">contacto@mtsprz.org</td></tr>';
    html += '<tr><td colspan="2" style="padding:4px 0;"></td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">CLIENTE:</td><td style="padding:2px 0;color:#111827;">' + clientName + '</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">RUT:</td><td style="padding:2px 0;color:#111827;">' + clientRut + '</td></tr>';
    var isCompanyRut = /^[5-9]\d{7,}/.test((clientRut || '').replace(/[.\-]/g, ''));
    if (!isCompanyRut && clientNationality) html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">NACIONALIDAD:</td><td style="padding:2px 0;color:#111827;">' + clientNationality + '</td></tr>';
    if (clientProfession) html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">' + (isCompanyRut ? 'GIRO:' : 'PROFESIÓN / GIRO:') + '</td><td style="padding:2px 0;color:#111827;">' + clientProfession + '</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">DOMICILIO:</td><td style="padding:2px 0;color:#111827;">' + clientAddress + '</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">CORREO:</td><td style="padding:2px 0;color:#111827;">' + clientEmail + '</td></tr>';
    html += '<tr><td style="padding:2px 6px 2px 0;color:#6b7280;">TELÉFONO:</td><td style="padding:2px 0;color:#111827;">' + clientPhone + '</td></tr>';
    html += '</table>';

    // ── 2. DECLARACIONES ──
    html += clauseTitle(1, 'DECLARACIONES');
    html += clauseText('El PRESTADOR declara: (a) Ser persona natural, con capacidad para contratar y obligarse (Art. 1445 CC). (b) Dedicarse profesionalmente a servicios digitales. (c) Contar con experiencia técnica necesaria.');

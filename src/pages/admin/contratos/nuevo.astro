---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { query, initDb } from "../../../lib/db";

await initDb();
const result = await query("SELECT * FROM services WHERE is_active = true ORDER BY category, name");
interface Service {
  id: number;
  slug: string;
  name: string;
  description: string | null;
  price: number;
  promo_price: number | null;
  category: string | null;
  includes_maintenance: boolean;
  maintenance_price: number;
  is_monthly: boolean;
}
const services = result.rows as Service[];
const prestadorRut = import.meta.env.MTSPRZ_RUT || "Pendiente";
---

<AdminLayout title="Nuevo Contrato" description="Crear nuevo contrato">
  <div class="mb-6">
    <div class="flex items-center justify-between flex-wrap gap-3">
      <div>
        <h1 class="font-heading text-2xl font-bold text-white tracking-tight">Nuevo Contrato</h1>
        <p class="mt-1 text-sm text-white/35 font-body">Completa los datos para generar el contrato</p>
      </div>
      <div class="flex items-center gap-1.5 text-xs text-white/25 font-medium">
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-accent"></span> paso 1</span>
        <span class="text-white/10">—</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-white/20"></span> paso 2</span>
        <span class="text-white/10">—</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-white/20"></span> paso 3</span>
        <span class="text-white/10">—</span>
        <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-white/20"></span> paso 4</span>
      </div>
    </div>
  </div>

  <form id="contractForm">
    <div class="lg:grid lg:grid-cols-5 lg:gap-6">
      <div class="lg:col-span-3">

        <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-5 mb-4 transition-all duration-300" data-section="1">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-accent/10 text-accent">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </span>
            <div>
              <span class="font-heading text-sm font-semibold text-white tracking-tight">Tipo de Contrato</span>
              <p class="text-[11px] text-white/30">Selecciona la modalidad del servicio</p>
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
            <label class="template-card relative cursor-pointer rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 transition-all duration-200 has-checked:border-accent/40 has-checked:bg-accent/[0.04] hover:border-white/15" onclick="selectTemplate('proyecto_unico')" data-template="proyecto_unico">
              <input type="radio" name="templateType" value="proyecto_unico" class="sr-only" checked required />
              <div class="flex flex-col items-center text-center gap-2">
                <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/[0.04]">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/50"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                </span>
                <span class="text-sm font-medium text-white/80">Proyecto Único</span>
                <span class="text-[10px] text-white/30 leading-relaxed">Alcance definido, entrega pactada</span>
                <span class="inline-flex px-2 py-0.5 rounded-full text-[9px] font-semibold uppercase tracking-wider bg-accent/10 text-accent">Recomendado</span>
              </div>
            </label>
            <label class="template-card relative cursor-pointer rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 transition-all duration-200 has-checked:border-accent/40 has-checked:bg-accent/[0.04] hover:border-white/15" onclick="selectTemplate('recurrente')" data-template="recurrente">
              <input type="radio" name="templateType" value="recurrente" class="sr-only" />
              <div class="flex flex-col items-center text-center gap-2">
                <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/[0.04]">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/50"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </span>
                <span class="text-sm font-medium text-white/80">Servicio Recurrente</span>
                <span class="text-[10px] text-white/30 leading-relaxed">Mensual, facturación periódica</span>
              </div>
            </label>
            <label class="template-card relative cursor-pointer rounded-xl border border-white/[0.06] bg-white/[0.02] p-4 transition-all duration-200 has-checked:border-accent/40 has-checked:bg-accent/[0.04] hover:border-white/15" onclick="selectTemplate('jornada_dedicada')" data-template="jornada_dedicada">
              <input type="radio" name="templateType" value="jornada_dedicada" class="sr-only" />
              <div class="flex flex-col items-center text-center gap-2">
                <span class="flex items-center justify-center w-10 h-10 rounded-xl bg-white/[0.04]">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/50"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </span>
                <span class="text-sm font-medium text-white/80">Jornada Dedicada</span>
                <span class="text-[10px] text-white/30 leading-relaxed">Horario fijo, disponibilidad</span>
              </div>
            </label>
          </div>
        </div>

        <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-5 mb-4 transition-all duration-300" data-section="2">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-amber-400/10 text-amber-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </span>
            <div>
              <span class="font-heading text-sm font-semibold text-white tracking-tight">Datos del Cliente</span>
              <p class="text-[11px] text-white/30">Información del contratante</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Nombre / Empresa <span class="text-red-400/60">*</span></label>
              <input name="client_name" maxlength="255" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" required placeholder="Blast-up Consulting Spa" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">RUT</label>
              <input name="client_rut" maxlength="20" pattern="\d{1,2}\.?\d{3}\.?\d{3}[-]?[\dkK]" title="Formato: 77.670.736-8" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="77.670.736-8" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Nacionalidad</label>
              <input name="client_nationality" maxlength="100" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="Chilena" value="Chilena" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Profesión / Giro</label>
              <input name="client_profession" maxlength="255" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="Ingeniero Comercial / Consultoría" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Email <span class="text-red-400/60">*</span></label>
              <input name="client_email" type="email" maxlength="255" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" required placeholder="contacto@blast-up.cl" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Teléfono</label>
              <input name="client_phone" maxlength="50" pattern="[\+\d\s\-\(\)]{8,20}" title="Formato: +56 9 7547 5781" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="+56 9 7547 5781" />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Dirección <span class="text-white/20 font-normal normal-case">(incluir comuna)</span></label>
              <input name="client_address" autocomplete="off" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="Av. Bosques de Montemar 30, Of. 316, Concón, Región de Valparaíso" />
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-5 mb-4 transition-all duration-300" data-section="2b">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-violet-400/10 text-violet-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </span>
            <div>
              <span class="font-heading text-sm font-semibold text-white tracking-tight">Datos del Prestador</span>
              <p class="text-[11px] text-white/30">Mtsprz — Soluciones Digitales</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">RUT Prestador</label>
              <input name="prestador_rut" maxlength="20" pattern="\d{1,2}\.?\d{3}\.?\d{3}[-]?[\dkK]" title="Formato: 12.345.678-9" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="12.345.678-9" />
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-5 mb-4 transition-all duration-300" data-section="3">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-2.5">
              <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-400/10 text-emerald-400">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              </span>
              <div>
                <span class="font-heading text-sm font-semibold text-white tracking-tight">Servicios</span>
                <p class="text-[11px] text-white/30">Ítems y valores del contrato</p>
              </div>
            </div>
            <button type="button" id="addServiceBtn" class="inline-flex items-center gap-1.5 px-3.5 py-2 rounded-full text-xs font-medium text-accent border border-accent/20 transition-all duration-200 hover:bg-accent/10 hover:border-accent/30">+ Agregar Servicio</button>
          </div>
          <div id="servicesContainer" class="space-y-3">
            <div class="service-row rounded-xl border border-white/[0.06] bg-white/[0.02] p-3 sm:p-4 transition-all duration-200">
              <div class="flex flex-col sm:flex-row gap-3">
                <div class="w-full sm:flex-[3]">
                  <label class="block text-[10px] font-medium text-white/35 uppercase tracking-wider mb-1">Servicio</label>
                    <select class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body service-select" onchange="updateServicePrice(this)">
                      <option value="">Personalizado...</option>
                      {services.map(s => (
                        <option value={s.slug} data-price={s.promo_price && s.promo_price > 0 ? s.promo_price : s.price} data-price-full={s.price}>{s.name}</option>
                      ))}
                  </select>
                </div>
                <div class="w-full sm:flex-[2]">
                  <label class="block text-[10px] font-medium text-white/35 uppercase tracking-wider mb-1">Nombre</label>
                  <input class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body service-name" maxlength="255" placeholder="Desarrollo Web" />
                </div>
                <div class="w-full sm:flex-[2]">
                  <label class="block text-[10px] font-medium text-white/35 uppercase tracking-wider mb-1">Valor CLP</label>
                  <input type="number" min="0" max="2147483647" step="1" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-mono service-price" placeholder="290000" oninput="updateTotal()" />
                </div>
                <div class="flex sm:items-end gap-2 pt-1 sm:pt-0 sm:pb-[1px]">
                  <div class="hidden sm:block w-px h-8 bg-white/[0.06] self-center"></div>
                  <button type="button" class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-white/30 border border-white/[0.06] transition-all duration-200 hover:border-red-400/30 hover:text-red-400 remove-service" onclick="this.closest('.service-row').remove(); updateTotal();">✕</button>
              </div>
              <div class="mt-2">
                <details class="service-deliverables-details" open>
                  <summary class="text-[10px] font-medium text-white/30 uppercase tracking-wider cursor-pointer hover:text-white/50 transition-colors">Entregables</summary>
                  <textarea class="service-deliverables w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2 px-3.5 text-xs text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body resize-y mt-1" rows="3" placeholder="Entregable 1&#10;Entregable 2&#10;Entregable 3"></textarea>
                </details>
              </div>
            </div>
          </div>
          </div>
          <div class="flex items-center justify-between pt-4 mt-4 border-t border-white/[0.06]">
            <span class="text-xs text-white/30"><span id="serviceCount">1</span> servicio(s)</span>
            <div class="flex items-center gap-2">
              <span class="text-xs text-white/40">Total estimado</span>
              <span id="totalDisplay" class="text-xl font-bold text-accent font-mono tracking-tight">$0</span>
            </div>
          </div>

          <div id="recurringWarning" class="hidden mt-4 rounded-xl border border-sky-400/20 bg-sky-400/[0.04] p-4">
            <div class="flex gap-3">
              <span class="shrink-0 mt-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-sky-400/20 text-sky-400">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
              </span>
              <div>
                <p class="text-xs font-semibold text-sky-400 mb-1">Servicios recurrentes en esquema de pago único</p>
                <p class="text-[11px] text-sky-300/70 leading-relaxed" id="recurringWarningDetail"></p>
                <p class="text-[10px] text-sky-300/40 mt-1.5">Si el precio es mensual, marcar "is_monthly" en el catálogo o aclarar en cláusulas especiales "precio de $X.XXX por mes, facturación mensual adelantada".</p>
              </div>
            </div>
          </div>

          <div id="ivaWarning" class="hidden mt-4 rounded-xl border border-amber-400/20 bg-amber-400/[0.04] p-4">
            <div class="flex gap-3">
              <span class="shrink-0 mt-0.5 flex items-center justify-center w-5 h-5 rounded-full bg-amber-400/20 text-amber-400">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </span>
              <div>
                <p class="text-xs font-semibold text-amber-400 mb-1">Validar tratamiento tributario antes de emitir</p>
                <p class="text-[11px] text-amber-300/70 leading-relaxed" id="ivaWarningDetail"></p>
                <p class="text-[10px] text-amber-300/40 mt-1.5">Consultar con contador antes de emitir la primera boleta. Si corresponde IVA, usar factura y ajustar cláusula SÉPTIMA.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="rounded-xl bg-[#0a0a0b] border border-white/[0.06] p-5 mb-4 transition-all duration-300" data-section="4">
          <div class="flex items-center gap-2.5 mb-5">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-sky-400/10 text-sky-400">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </span>
            <div>
              <span class="font-heading text-sm font-semibold text-white tracking-tight">Condiciones</span>
              <p class="text-[11px] text-white/30">Plazos, montos y modalidad de pago</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Duración</label>
              <div class="flex gap-2">
                <input name="duration_months" type="number" min="1" max="1200" class="w-24 bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body" value="3" />
                <span class="inline-flex items-center text-xs text-white/30">meses</span>
              </div>
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Valor Total (CLP)</label>
              <input name="total_amount" type="number" min="0" max="2147483647" step="1" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body font-mono" required placeholder="0" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Fecha de Inicio</label>
              <input name="start_date" type="date" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Fecha de Término</label>
              <input name="end_date" type="date" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Modalidad de Pago</label>
              <select name="payment_method" onchange="togglePaymentTerms()" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body">
                <option value="">Personalizada...</option>
                <option value="contado">Contado</option>
                <option value="50_50">50% Inicio + 50% Entrega</option>
                <option value="hitos">Por Hitos</option>
              </select>
            </div>
            <div id="paymentTermsGroup">
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Términos de Pago</label>
              <input name="payment_terms" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body" placeholder="Transferencia mensual anticipada" />
            </div>
            <div>
              <label class="block text-[11px] font-medium text-white/40 uppercase tracking-wider mb-1.5">Días de Garantía</label>

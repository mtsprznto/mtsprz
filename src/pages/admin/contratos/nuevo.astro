    html += '<table style="width:100%;font-size:11px;border-collapse:collapse;margin-bottom:8px;">';
    html += '<thead><tr style="background:#f9fafb;"><th style="text-align:left;padding:6px 8px;font-weight:600;color:#374151;border-bottom:1px solid #e5e7eb;font-size:10px;">SERVICIO</th><th style="text-align:right;padding:6px 8px;font-weight:600;color:#374151;border-bottom:1px solid #e5e7eb;font-size:10px;">VALOR</th></tr></thead><tbody>';
    for (var si = 0; si < svcs.length; si++) {

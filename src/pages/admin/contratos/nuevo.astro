    </div>

    <div class="sticky bottom-0 z-10 -mx-4 sm:-mx-6 px-4 sm:px-6 py-3 bg-[#010101]/95 border-t border-white/[0.04] mt-2">
      <div class="flex items-center justify-between max-w-full">
        <div class="hidden sm:flex items-center gap-3">
          <span class="text-[10px] text-white/20 tracking-wider uppercase">Total:</span>
          <span class="text-base font-bold text-accent font-mono" id="stickyTotal">$0</span>
        </div>
        <div class="flex gap-3 w-full sm:w-auto">
          <a href="/admin/contratos" class="inline-flex items-center px-3.5 py-2 bg-white/[0.04] hover:bg-white/[0.07] text-[10px] font-medium text-white/40 tracking-wider uppercase transition-all duration-300 no-underline">Cancelar</a>
          <button type="button" id="previewBtn" onclick="openPreview()" class="inline-flex items-center gap-2 px-3.5 py-2 bg-white/[0.04] hover:bg-white/[0.07] text-[10px] font-medium text-white/40 tracking-wider uppercase transition-all duration-300">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            Vista Previa
          </button>
          <button type="submit" id="submitBtn" class="flex-1 sm:flex-none inline-flex items-center justify-center gap-2 px-4 py-2 bg-accent/10 hover:bg-accent/20 text-[10px] font-medium text-accent tracking-wider uppercase transition-all duration-300 disabled:opacity-30 disabled:cursor-not-allowed">

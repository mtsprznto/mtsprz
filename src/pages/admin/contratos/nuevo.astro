<script id="pricing-data" type="application/json">{JSON.stringify({ rut: prestadorRut, services })}</script>

<script is:inline>
  var pricingServices = {};
  var allServices = [];
  var prestadorRut = "Pendiente";
  try {
    var configData = JSON.parse(document.getElementById("pricing-data").textContent);
    prestadorRut = configData.rut || "Pendiente";
    // Override from form field if filled
    var rutField = document.querySelector("[name='prestador_rut']");
    if (rutField && rutField.value) prestadorRut = rutField.value;
    allServices = configData.services || [];
    allServices.forEach(function(s) {
      pricingServices[s.slug] = {
        name: s.name,
        price: s.promo_price && s.promo_price > 0 ? s.promo_price : s.price,
        description: s.description || "",
        deliverables: s.deliverables || [],
        includes_maintenance: !!s.includes_maintenance,
        maintenance_price: s.maintenance_price || 0,
        maintenance_description: s.maintenance_description || "",
      };
    });
  } catch(e) { console.warn("Error loading pricing data:", e); }

  async function loadServiceDescriptions() {
    try {
      var res = await fetch("/api/services?active=true");
      var json = await res.json();
      if (json.services) {
        allServices = json.services;
        pricingServices = {};
        var opts = '<option value="">Personalizado...</option>';
        json.services.forEach(function(s) {
          var promoP = s.promo_price && s.promo_price > 0 ? s.promo_price : null;
          var fullP = s.price;
          var displayPrice = promoP || fullP;
          pricingServices[s.slug] = {
            name: s.name,
            price: displayPrice,
            price_full: fullP,
            description: s.description || "",
            deliverables: s.deliverables || [],
            includes_maintenance: s.includes_maintenance || false,
            maintenance_price: s.maintenance_price || 0,
            maintenance_description: s.maintenance_description || "",
            is_monthly: !!s.is_monthly,
          };
          var label = s.name + ' — $' + fullP.toLocaleString('es-CL');
          if (promoP && promoP !== fullP) label += ' (promo $' + promoP.toLocaleString('es-CL') + ')';
          opts += '<option value="' + s.slug + '" data-price="' + displayPrice + '" data-price-full="' + fullP + '">' + label + "</option>";
        });
        document.querySelectorAll(".service-select").forEach(function(sel) {
          var currentVal = sel.value;
          sel.innerHTML = opts;
          sel.value = currentVal;
        });
      }
    } catch(e) { console.warn("No se pudieron cargar servicios desde DB:", e); }
  }

  function getServiceRows() {
    return document.querySelectorAll(".service-row");
  }

  function updateServicePrice(select) {
    var row = select.closest(".service-row");
    var priceInput = row.querySelector(".service-price");
    var nameInput = row.querySelector(".service-name");
    var selected = select.options[select.selectedIndex];
    var dataPrice = selected.getAttribute("data-price");
    var dataPriceFull = selected.getAttribute("data-price-full");
    var delivTextarea = row.querySelector(".service-deliverables");
    if (dataPrice) {
      priceInput.value = dataPrice;
      var svc = pricingServices[select.value];
      // Name from service data (not selected.text, which may contain price info)
      nameInput.value = svc ? svc.name : selected.text;
      nameInput.readOnly = true;
      // Auto-fill deliverables from service data
      if (svc && svc.deliverables && svc.deliverables.length > 0) {
        delivTextarea.value = svc.deliverables.join("\n");
      } else {
        delivTextarea.value = "";
      }
    } else {
      nameInput.readOnly = false;
      delivTextarea.value = "";
    }
    updateTotal();
    updatePreview();
  }

  // Strip price info from service names (prevents " — $400.000 (promo $350.000)" leaking into doc)
  function sanitizeServiceName(raw) {
    // Strip trailing price info: " — $400.000 (promo $350.000)" or "— $250.000" or " (promo $290.000)"
    return (raw || "").replace(/\s*[-–—].*\(promo\s*\$[\d\.]+.*\)/g, "").replace(/\s*[-–—]\s*\$[\d\.]+[\s\S]*$/g, "").trim();
  }

  function getServices() {
    var rows = getServiceRows();
    return Array.from(rows).map(function(row) {
      var select = row.querySelector(".service-select");
      var nameInput = row.querySelector(".service-name");
      var priceInput = row.querySelector(".service-price");
      var delivTextarea = row.querySelector(".service-deliverables");
      var id = select.value || "custom";
      var svc = pricingServices[id] || {};
      // Read deliverables from textarea first (user can edit), fallback to service data
      var deliverables = [];
      if (delivTextarea && delivTextarea.value.trim()) {
        deliverables = delivTextarea.value.split("\n").map(function(s) { return s.trim(); }).filter(Boolean);
      } else if (svc.deliverables) {
        deliverables = svc.deliverables;
      }
      return {
        id: id,
        name: sanitizeServiceName(nameInput.value) || "Servicio personalizado",
        price: parseInt(priceInput.value) || 0,
        description: svc.description || "",
        deliverables: deliverables,
        includes_maintenance: svc.includes_maintenance || false,
        maintenance_price: svc.maintenance_price || 0,
        maintenance_description: svc.maintenance_description || "",
        is_monthly: !!svc.is_monthly,
      };
    });
  }

  // Keywords que implican servicio continuo/recurrente aunque is_monthly sea false
  var RECURRING_PATTERNS = [
    "mensual", "monthly", "gestión de redes", "gestion de redes",
    "mantenimiento seo", "community", "social media", "seguimiento",
    "soporte continuo", "monitoreo continuo",
  ];

  function checkRecurringMismatch(svcs) {
    var mismatched = svcs.filter(function(s) {
      if (s.is_monthly) return false; // ya marcado correcto
      var name = (s.name || "").toLowerCase();
      return RECURRING_PATTERNS.some(function(p) { return name.includes(p); });
    });
    var banner = document.getElementById("recurringWarning");
    var detail = document.getElementById("recurringWarningDetail");
    if (mismatched.length > 0) {
      var names = mismatched.map(function(s) { return '"' + s.name + '"'; }).join(", ");
      detail.textContent = names + " — nombre implica servicio continuo pero el precio está contabilizado una sola vez. " +
        "Si es cobro mensual, el texto firmado solo respalda el monto total indicado (perjudica al prestador).";
      banner.classList.remove("hidden");
    } else {
      banner.classList.add("hidden");
    }
  }

  // Slugs/keywords de servicios que pueden clasificar como 1ª categoría → posible IVA/factura
  var IVA_RISK_PATTERNS = [
    "ecommerce", "e-commerce", "tienda", "web-app", "aplicacion", "aplicación",
    "crm", "bot", "sistema", "backend", "api", "plataforma",
    "whatsapp", "automatizacion", "automatización",
  ];

  function checkIvaRisk(svcs) {
    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    var risky = svcs.filter(function(s) {
      var slug = (s.id || "").toLowerCase();
      var name = (s.name || "").toLowerCase();
      return IVA_RISK_PATTERNS.some(function(p) { return slug.includes(p) || name.includes(p); });
    });
    var riskyTotal = risky.reduce(function(sum, s) { return sum + s.price; }, 0);
    var pct = total > 0 ? Math.round((riskyTotal / total) * 100) : 0;

    var banner = document.getElementById("ivaWarning");
    var detail = document.getElementById("ivaWarningDetail");
    if (risky.length > 0) {
      var names = risky.map(function(s) { return s.name + " ($" + s.price.toLocaleString("es-CL") + ")"; }).join(", ");
      detail.textContent = "Servicios de posible 1ª categoría: " + names + " — " + pct + "% del total. " +
        "El SII puede clasificar desarrollo transaccional (e-commerce, apps, bots, CRM) como actividad afecta a IVA (Art. 20 N°3 LIR). " +
        "Si corresponde factura en vez de boleta de honorarios, el IVA no declarado (19%) quedaría a cargo del prestador.";
      banner.classList.remove("hidden");
    } else {
      banner.classList.add("hidden");
    }
  }

  function updateTotal() {
    var svcs = getServices();
    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    var formatted = "$" + total.toLocaleString("es-CL");
    document.getElementById("totalDisplay").textContent = formatted;
    document.getElementById("stickyTotal").textContent = formatted;
    document.getElementById("serviceCount").textContent = svcs.length + (svcs.length === 1 ? "" : "");
    var totalInput = document.querySelector("[name='total_amount']");
    if (!totalInput.value) totalInput.value = String(total);
    checkRecurringMismatch(svcs);
    checkIvaRisk(svcs);
    updatePreview();
  }

  function updatePreview() {
    var templateLabels = { proyecto_unico: "Proyecto \u00danico", recurrente: "Servicio Recurrente", jornada_dedicada: "Jornada Dedicada" };
    var selected = document.querySelector("input[name='templateType']:checked");
    var typeEl = document.getElementById("previewType");
    if (selected && selected.value) {
      typeEl.textContent = templateLabels[selected.value] || selected.value;
    } else {
      typeEl.textContent = "—";
    }

    var clientName = document.querySelector("[name='client_name']").value || "—";
    document.getElementById("previewClient").textContent = clientName;

    var svcs = getServices();
    var svcCount = svcs.filter(function(s) { return s.name; }).length;
    document.getElementById("previewServices").textContent = svcCount > 0 ? svcCount + " servicio(s)" : "—";

    var duration = document.querySelector("[name='duration_months']").value;
    document.getElementById("previewDuration").textContent = duration ? duration + " meses" : "—";

    var pmLabels = { contado: "Contado", "50_50": "50/50", hitos: "Por Hitos" };
    var pm = document.querySelector("[name='payment_method']")?.value;
    var pmEl = document.getElementById("previewPayment");
    if (pmEl) pmEl.textContent = pm ? (pmLabels[pm] || pm) : "—";

    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    document.getElementById("previewTotal").textContent = "$" + total.toLocaleString("es-CL");
  }

  function updateClauseCount() {
    var val = document.querySelector("[name='special_clauses']").value;
    document.getElementById("clauseCount").textContent = val.length + " caracteres";
  }

  function createServiceRow() {
    var opts = "";
    for (var si = 0; si < allServices.length; si++) {
      var s = allServices[si];
      var promoP = s.promo_price && s.promo_price > 0 ? s.promo_price : null;
      var fullP = s.price;
      var displayPrice = promoP || fullP;
      var label = s.name + ' — $' + fullP.toLocaleString('es-CL');
      if (promoP && promoP !== fullP) label += ' (promo $' + promoP.toLocaleString('es-CL') + ')';
      opts += '<option value="' + s.slug + '" data-price="' + displayPrice + '" data-price-full="' + fullP + '">' + label + "</option>";
    }
    var div = document.createElement("div");
    div.className = "service-row border border-white/[0.04] p-3 sm:p-4 transition-all duration-200";
    div.innerHTML =
      '<div class="flex flex-col sm:flex-row gap-3">' +
        '<div class="w-full sm:flex-[3]">' +
          '<label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Servicio</label>' +
          '<select class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body service-select" onchange="updateServicePrice(this)">' +
            '<option value="">Personalizado...</option>' + opts +
          "</select>" +
        "</div>" +
        '<div class="w-full sm:flex-[2]">' +
          '<label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Nombre</label>' +
          '<input class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body service-name" maxlength="255" placeholder="Desarrollo Web" />' +
        "</div>" +
        '<div class="w-full sm:flex-[2]">' +
          '<label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Valor CLP</label>' +
          '<input type="number" min="0" max="2147483647" step="1" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-mono service-price" placeholder="290000" oninput="updateTotal()" />' +
        "</div>" +
        '<div class="flex sm:items-end gap-2 pt-1 sm:pt-0 sm:pb-[1px]">' +
          '<div class="hidden sm:block w-px h-8 bg-white/[0.04] self-center"></div>' +
          '<button type="button" class="inline-flex items-center justify-center w-9 h-9 text-sm text-white/20 hover:text-red-400/60 transition-colors remove-service">✕</button>' +
        "</div>" +
      "</div>" +
      '<div class="mt-2">' +
        '<details class="service-deliverables-details" open>' +
          '<summary class="text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] cursor-pointer hover:text-white/50 transition-colors">Entregables</summary>' +
          '<textarea class="service-deliverables w-full bg-transparent border border-white/[0.08] py-2 px-3.5 text-xs text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body resize-y mt-1" rows="3" placeholder="Entregable 1&#10;Entregable 2&#10;Entregable 3"></textarea>' +
        "</details>" +
      "</div>";
    div.querySelector(".remove-service").onclick = function() { div.remove(); updateTotal(); };
    return div;
  }

  function checkDuplicateNames() {
    var names = Array.from(document.querySelectorAll(".service-name")).map(function(inp) { return inp.value.trim().toLowerCase(); });
    var nameCount = {};
    names.forEach(function(n) { if (n) nameCount[n] = (nameCount[n] || 0) + 1; });
    var dupes = Object.keys(nameCount).filter(function(n) { return nameCount[n] > 1; });
    // Highlight duplicates
    document.querySelectorAll(".service-name").forEach(function(inp) {
      var val = inp.value.trim().toLowerCase();
      var isDup = dupes.indexOf(val) !== -1 && val !== "";
      inp.style.borderColor = isDup ? "rgba(239,68,68,0.5)" : "";
      inp.style.backgroundColor = isDup ? "rgba(239,68,68,0.05)" : "";
    });
    return dupes.length > 0;
  }

  document.getElementById("addServiceBtn").addEventListener("click", function() {
    document.getElementById("servicesContainer").appendChild(createServiceRow());
    updateTotal();
    // Attach duplicate checker to new row's name input
    var rows = document.querySelectorAll(".service-row");
    var lastRow = rows[rows.length - 1];
    lastRow.querySelector(".service-name").addEventListener("input", function() {
      checkDuplicateNames();
      updatePreview();
    });
    lastRow.querySelector(".service-select").addEventListener("change", function() {
      checkDuplicateNames();
    });
  });

  // Attach duplicate checker to existing rows on page load
  document.addEventListener("DOMContentLoaded", function() {
    document.querySelectorAll(".service-name").forEach(function(inp) {
      inp.addEventListener("input", function() { checkDuplicateNames(); updatePreview(); });
    });
  });
  // Also run after loadServiceDescriptions populates selects
  var origLoad = loadServiceDescriptions;
  loadServiceDescriptions = function() {
    return origLoad.apply(this, arguments).then(function() {
      document.querySelectorAll(".service-name").forEach(function(inp) {
        inp.addEventListener("input", function() { checkDuplicateNames(); updatePreview(); });
      });
    }).catch(function(e) { console.warn(e); });
  };

  var dayNames = { 0: "Dom", 1: "Lun", 2: "Mar", 3: "Mi\u00e9", 4: "Jue", 5: "Vie", 6: "S\u00e1b" };
  var scheduleDays = [1, 2, 3, 4, 5];

  function updateScheduleDisplay() {
    var from = document.getElementById("scheduleFrom").value;
    var to = document.getElementById("scheduleTo").value;
    if (scheduleDays.length === 0) {
      document.getElementById("schedulePreview").textContent = "Sin d\u00edas seleccionados";
      document.getElementById("scheduleInput").value = "";
      return;
    }
    var sorted = scheduleDays.slice().sort();
    var ranges = [];
    var start = sorted[0], end = sorted[0];
    for (var i = 1; i < sorted.length; i++) {
      if (sorted[i] === end + 1 || (end === 6 && sorted[i] === 0)) { end = sorted[i]; }
      else { ranges.push({ s: start, e: end }); start = sorted[i]; end = sorted[i]; }
    }
    ranges.push({ s: start, e: end });
    var dayStr = ranges.map(function(r) { return r.s === r.e ? dayNames[r.s] : dayNames[r.s] + "-" + dayNames[r.e]; }).join(", ");
    var full = dayStr + " " + from + "\u2013" + to;
    document.getElementById("schedulePreview").textContent = full;
    document.getElementById("scheduleInput").value = full;
    updatePreview();
  }

  function toggleDay(d) {
    var idx = scheduleDays.indexOf(d);
    if (idx !== -1) { if (scheduleDays.length > 1) scheduleDays.splice(idx, 1); }
    else { scheduleDays.push(d); }
    for (var i = 0; i <= 6; i++) {
      var el = document.getElementById("day" + i);
      if (!el) continue;
      var active = scheduleDays.indexOf(i) !== -1;
      el.className = "day-chip px-3 py-1.5 rounded-lg text-xs font-medium border transition-all duration-150 " + (active ? "bg-accent/15 border-accent/30 text-accent" : "text-white/40 border-white/[0.06]");
    }
    var presetMap = { "1,2,3,4,5": "lun-vie", "1,2,3,4,5,6": "lun-sab", "0,1,2,3,4,5,6": "lun-dom", "0,6": "finde" };
    var key = scheduleDays.slice().sort().join(",");
    ["lun-vie", "lun-sab", "lun-dom", "finde"].forEach(function(p) {
      var el = document.getElementById("preset-" + p);
      if (!el) return;
      el.className = "preset-chip px-2.5 py-1 rounded-md text-[10px] font-medium border transition-all duration-150 " + (p === presetMap[key] ? "bg-accent/10 border-accent/20 text-accent" : "text-white/35 border-white/[0.06]");
    });
    updateScheduleDisplay();
  }

  function presetDays(preset) {
    var map = { "lun-vie": [1, 2, 3, 4, 5], "lun-sab": [1, 2, 3, 4, 5, 6], "lun-dom": [1, 2, 3, 4, 5, 6, 0], "finde": [0, 6] };
    scheduleDays = (map[preset] || []).slice();
    for (var i = 0; i <= 6; i++) {
      var el = document.getElementById("day" + i);
      if (!el) continue;
      var active = scheduleDays.indexOf(i) !== -1;
      el.className = "day-chip px-3 py-1.5 rounded-lg text-xs font-medium border transition-all duration-150 " + (active ? "bg-accent/15 border-accent/30 text-accent" : "text-white/40 border-white/[0.06]");
    }
    ["lun-vie", "lun-sab", "lun-dom", "finde"].forEach(function(p) {
      var el = document.getElementById("preset-" + p);
      if (!el) return;
      el.className = "preset-chip px-2.5 py-1 rounded-md text-[10px] font-medium border transition-all duration-150 " + (p === preset ? "bg-accent/10 border-accent/20 text-accent" : "text-white/35 border-white/[0.06]");
    });
    updateScheduleDisplay();
  }

  function selectTemplate(tplId, tplType) {
    var radio = document.querySelector("input[name='templateType'][value='" + tplType + "']");
    if (radio) radio.checked = true;
    // Set the hidden template_id input for the selected template
    document.querySelectorAll("input[name='template_id']").forEach(function(inp) {
      var card = inp.closest(".template-card");
      if (card && card.getAttribute("data-template-id") == tplId) {
        inp.value = tplId;
      } else if (card) {
        inp.value = "";
      }
    });
    var isJornada = tplType === "jornada_dedicada";
    var sg = document.getElementById("scheduleGroup");
    if (sg) {
      sg.style.display = isJornada ? "block" : "none";
    }
    updatePreview();
  }

  // ── Client quick-search ─────────────────────────────────────────────────
  var clientSearchEl = document.getElementById("clientSearch");
  var clientResultsEl = document.getElementById("clientResults");
  var clientSearchTimeout;

  function fillClient(c) {
    document.querySelector("[name='client_name']").value = c.name || "";
    document.querySelector("[name='client_rut']").value = c.rut || "";
    document.querySelector("[name='client_email']").value = c.email || "";
    document.querySelector("[name='client_phone']").value = c.phone || "";
    document.querySelector("[name='client_address']").value = c.address || "";
    document.querySelector("[name='client_nationality']").value = c.nationality || "Chilena";
    document.querySelector("[name='client_profession']").value = c.profession || "";
    clientResultsEl.classList.add("hidden");
    clientSearchEl.value = "";
    updatePreview();
  }

  function renderClientResults(clients) {
    if (clients.length === 0) {
      var q = (clientSearchEl.value || "").trim();
      clientResultsEl.innerHTML =
        '<div class="px-3 py-4 text-center border-b border-white/[0.03]">' +
        '<p class="text-xs text-white/20 font-body">Sin resultados para "<span class="text-white/40">' + escapeHtml(q) + '</span>"</p>' +
        '<p class="text-[10px] text-white/15 font-body mt-1.5">Completa los datos manualmente y marca "Guardar como cliente recurrente" al crear el contrato</p>' +
        '</div>';
      clientResultsEl.classList.remove("hidden");
      return;
    }
    var html = [];
    for (var i = 0; i < clients.length; i++) {
      var c = clients[i];
      html.push('<button type="button" class="w-full text-left px-3 py-2.5 border-b border-white/[0.03] hover:bg-white/[0.03] transition-colors" onclick="fillClient(' + JSON.stringify(c).replace(/"/g, "&quot;") + ')">');
      html.push('<div class="text-xs text-white/70 font-medium">' + escapeHtml(c.name) + (c.company_name ? " — " + escapeHtml(c.company_name) : "") + '</div>');
      html.push('<div class="text-[10px] text-white/25 mt-0.5">' + (c.rut ? escapeHtml(c.rut) + " · " : "") + (c.email ? escapeHtml(c.email) : "") + '</div>');
      html.push('</button>');
    }
    clientResultsEl.innerHTML = html.join("");
    clientResultsEl.classList.remove("hidden");
  }

  if (clientSearchEl) {
    clientSearchEl.addEventListener("input", function() {
      clearTimeout(clientSearchTimeout);
      var q = this.value.trim();
      if (q.length < 2) {
        clientResultsEl.classList.add("hidden");
        return;
      }
      clientSearchTimeout = setTimeout(function() {
        fetch("/api/clients?search=" + encodeURIComponent(q))
          .then(function(r) { return r.json(); })
          .then(function(data) {
            if (data.error) {
              renderClientResults([]);
            } else {
              renderClientResults(data.clients || []);
            }
          })
          .catch(function() {
            clientResultsEl.innerHTML =
              '<div class="px-3 py-3 text-center"><p class="text-xs text-white/20 font-body">Error al buscar. Si es la primera vez, reinicia el servidor para aplicar migraciones.</p></div>';
            clientResultsEl.classList.remove("hidden");
          });
      }, 250);
    });
    clientSearchEl.addEventListener("blur", function() {
      setTimeout(function() { clientResultsEl.classList.add("hidden"); }, 200);
    });
    clientSearchEl.addEventListener("focus", function() {
      if (clientResultsEl.children.length > 0) clientResultsEl.classList.remove("hidden");
    });
  }

  document.querySelector("[name='client_name']").addEventListener("input", updatePreview);
  document.querySelector("[name='duration_months']").addEventListener("input", updatePreview);


<script id="pricing-data" type="application/json">{JSON.stringify(pricing.services)}</script>

<script is:inline>
  var pricingServices = {};
  var allServices = [];
  try {
    allServices = JSON.parse(document.getElementById("pricing-data").textContent);
    allServices.forEach(function(s) {
      pricingServices[s.id] = {
        name: s.name,
        price: s.promoPrice || s.price,
        description: s.description || "",
        deliverables: s.features || [],
        includes_maintenance: false,
        maintenance_price: 0,
        maintenance_description: "",
      };
    });
  } catch(e) { console.warn("Error loading pricing data:", e); }

  async function loadServiceDescriptions() {
    try {
      var res = await fetch("/api/services?active=true");
      var json = await res.json();
      if (json.services) {
        allServices = json.services;
        pricingServices = {};
        var opts = '<option value="">Personalizado...</option>';
        json.services.forEach(function(s) {
          var p = s.promo_price || s.price;
          pricingServices[s.slug] = {
            name: s.name,
            price: p,
            description: s.description || "",
            deliverables: s.deliverables || [],
            includes_maintenance: s.includes_maintenance || false,
            maintenance_price: s.maintenance_price || 0,
            maintenance_description: s.maintenance_description || "",
          };
          opts += '<option value="' + s.slug + '" data-price="' + p + '">' + s.name + "</option>";
        });
        document.querySelectorAll(".service-select").forEach(function(sel) {
          var currentVal = sel.value;
          sel.innerHTML = opts;
          sel.value = currentVal;
        });
      }
    } catch(e) { console.warn("No se pudieron cargar servicios desde DB:", e); }
  }

  function getServiceRows() {
    return document.querySelectorAll(".service-row");
  }

  function updateServicePrice(select) {
    var row = select.closest(".service-row");
    var priceInput = row.querySelector(".service-price");
    var nameInput = row.querySelector(".service-name");
    var selected = select.options[select.selectedIndex];
    var dataPrice = selected.getAttribute("data-price");
    if (dataPrice) {
      priceInput.value = dataPrice;
      nameInput.value = selected.text;
      nameInput.readOnly = true;
    } else {
      nameInput.readOnly = false;
    }
    updateTotal();
    updatePreview();
  }

  function getServices() {
    var rows = getServiceRows();
    return Array.from(rows).map(function(row) {
      var select = row.querySelector(".service-select");
      var nameInput = row.querySelector(".service-name");
      var priceInput = row.querySelector(".service-price");
      var id = select.value || "custom";
      var svc = pricingServices[id] || {};
      return {
        id: id,
        name: nameInput.value || "Servicio personalizado",
        price: parseInt(priceInput.value) || 0,
        description: svc.description || "",
        deliverables: svc.deliverables || [],
        includes_maintenance: svc.includes_maintenance || false,
        maintenance_price: svc.maintenance_price || 0,
        maintenance_description: svc.maintenance_description || "",
      };
    });
  }

  function updateTotal() {
    var svcs = getServices();
    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    var formatted = "$" + total.toLocaleString("es-CL");
    document.getElementById("totalDisplay").textContent = formatted;
    document.getElementById("stickyTotal").textContent = formatted;
    document.getElementById("serviceCount").textContent = svcs.length + (svcs.length === 1 ? "" : "");
    var totalInput = document.querySelector("[name='total_amount']");
    if (!totalInput.value) totalInput.value = String(total);
    updatePreview();
  }

  function updatePreview() {
    var templateLabels = { proyecto_unico: "Proyecto \u00danico", recurrente: "Servicio Recurrente", jornada_dedicada: "Jornada Dedicada" };
    var selected = document.querySelector("input[name='templateType']:checked");
    var typeEl = document.getElementById("previewType");
    if (selected && selected.value) {
      typeEl.textContent = templateLabels[selected.value] || selected.value;
    } else {
      typeEl.textContent = "—";
    }

    var clientName = document.querySelector("[name='client_name']").value || "—";
    document.getElementById("previewClient").textContent = clientName;

    var svcs = getServices();
    var svcCount = svcs.filter(function(s) { return s.name; }).length;
    document.getElementById("previewServices").textContent = svcCount > 0 ? svcCount + " servicio(s)" : "—";

    var duration = document.querySelector("[name='duration_months']").value;
    document.getElementById("previewDuration").textContent = duration ? duration + " meses" : "—";

    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    document.getElementById("previewTotal").textContent = "$" + total.toLocaleString("es-CL");
  }

  function updateClauseCount() {
    var val = document.querySelector("[name='special_clauses']").value;
    document.getElementById("clauseCount").textContent = val.length + " caracteres";
  }

  function createServiceRow() {
    var opts = "";
    for (var si = 0; si < allServices.length; si++) {
      var s = allServices[si];
      opts += '<option value="' + s.id + '" data-price="' + (s.promoPrice || s.price) + '">' + s.name + "</option>";
    }
    var div = document.createElement("div");
    div.className = "service-row rounded-xl border border-white/[0.06] bg-white/[0.02] p-3 sm:p-4 transition-all duration-200";
    div.innerHTML =
      '<div class="flex flex-col sm:flex-row gap-3">' +
        '<div class="w-full sm:flex-[3]">' +
          '<label class="block text-[10px] font-medium text-white/35 uppercase tracking-wider mb-1">Servicio</label>' +
          '<select class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] font-body service-select" onchange="updateServicePrice(this)">' +
            '<option value="">Personalizado...</option>' + opts +
          "</select>" +
        "</div>" +
        '<div class="w-full sm:flex-[2]">' +
          '<label class="block text-[10px] font-medium text-white/35 uppercase tracking-wider mb-1">Nombre</label>' +
          '<input class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-body service-name" maxlength="255" placeholder="Desarrollo Web" />' +
        "</div>" +
        '<div class="w-full sm:flex-[2]">' +
          '<label class="block text-[10px] font-medium text-white/35 uppercase tracking-wider mb-1">Valor CLP</label>' +
          '<input type="number" min="0" max="2147483647" step="1" class="w-full bg-white/[0.04] border border-white/[0.08] rounded-xl py-2.5 px-3.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 focus:bg-accent/[0.04] placeholder:text-white/15 font-mono service-price" placeholder="290000" oninput="updateTotal()" />' +
        "</div>" +
        '<div class="flex sm:items-end gap-2 pt-1 sm:pt-0 sm:pb-[1px]">' +
          '<div class="hidden sm:block w-px h-8 bg-white/[0.06] self-center"></div>' +
          '<button type="button" class="inline-flex items-center justify-center w-9 h-9 rounded-xl text-sm text-white/30 border border-white/[0.06] transition-all duration-200 hover:border-red-400/30 hover:text-red-400 remove-service">✕</button>' +
        "</div>" +
      "</div>";
    div.querySelector(".remove-service").onclick = function() { div.remove(); updateTotal(); };
    return div;
  }

  document.getElementById("addServiceBtn").addEventListener("click", function() {
    document.getElementById("servicesContainer").appendChild(createServiceRow());
    updateTotal();
  });

  var dayNames = { 0: "Dom", 1: "Lun", 2: "Mar", 3: "Mi\u00e9", 4: "Jue", 5: "Vie", 6: "S\u00e1b" };
  var scheduleDays = [1, 2, 3, 4, 5];

  function updateScheduleDisplay() {
    var from = document.getElementById("scheduleFrom").value;
    var to = document.getElementById("scheduleTo").value;
    if (scheduleDays.length === 0) {
      document.getElementById("schedulePreview").textContent = "Sin d\u00edas seleccionados";
      document.getElementById("scheduleInput").value = "";
      return;
    }
    var sorted = scheduleDays.slice().sort();
    var ranges = [];
    var start = sorted[0], end = sorted[0];
    for (var i = 1; i < sorted.length; i++) {
      if (sorted[i] === end + 1 || (end === 6 && sorted[i] === 0)) { end = sorted[i]; }
      else { ranges.push({ s: start, e: end }); start = sorted[i]; end = sorted[i]; }
    }
    ranges.push({ s: start, e: end });
    var dayStr = ranges.map(function(r) { return r.s === r.e ? dayNames[r.s] : dayNames[r.s] + "-" + dayNames[r.e]; }).join(", ");
    var full = dayStr + " " + from + "\u2013" + to;
    document.getElementById("schedulePreview").textContent = full;
    document.getElementById("scheduleInput").value = full;
    updatePreview();
  }

  function toggleDay(d) {
    var idx = scheduleDays.indexOf(d);
    if (idx !== -1) { if (scheduleDays.length > 1) scheduleDays.splice(idx, 1); }
    else { scheduleDays.push(d); }
    for (var i = 0; i <= 6; i++) {
      var el = document.getElementById("day" + i);
      if (!el) continue;
      var active = scheduleDays.indexOf(i) !== -1;
      el.className = "day-chip px-3 py-1.5 rounded-lg text-xs font-medium border transition-all duration-150 " + (active ? "bg-accent/15 border-accent/30 text-accent" : "text-white/40 border-white/[0.06]");
    }
    var presetMap = { "1,2,3,4,5": "lun-vie", "1,2,3,4,5,6": "lun-sab", "0,1,2,3,4,5,6": "lun-dom", "0,6": "finde" };
    var key = scheduleDays.slice().sort().join(",");
    ["lun-vie", "lun-sab", "lun-dom", "finde"].forEach(function(p) {
      var el = document.getElementById("preset-" + p);
      if (!el) return;
      el.className = "preset-chip px-2.5 py-1 rounded-md text-[10px] font-medium border transition-all duration-150 " + (p === presetMap[key] ? "bg-accent/10 border-accent/20 text-accent" : "text-white/35 border-white/[0.06]");
    });
    updateScheduleDisplay();
  }

  function presetDays(preset) {
    var map = { "lun-vie": [1, 2, 3, 4, 5], "lun-sab": [1, 2, 3, 4, 5, 6], "lun-dom": [1, 2, 3, 4, 5, 6, 0], "finde": [0, 6] };
    scheduleDays = (map[preset] || []).slice();
    for (var i = 0; i <= 6; i++) {
      var el = document.getElementById("day" + i);
      if (!el) continue;
      var active = scheduleDays.indexOf(i) !== -1;
      el.className = "day-chip px-3 py-1.5 rounded-lg text-xs font-medium border transition-all duration-150 " + (active ? "bg-accent/15 border-accent/30 text-accent" : "text-white/40 border-white/[0.06]");
    }
    ["lun-vie", "lun-sab", "lun-dom", "finde"].forEach(function(p) {
      var el = document.getElementById("preset-" + p);
      if (!el) return;
      el.className = "preset-chip px-2.5 py-1 rounded-md text-[10px] font-medium border transition-all duration-150 " + (p === preset ? "bg-accent/10 border-accent/20 text-accent" : "text-white/35 border-white/[0.06]");
    });
    updateScheduleDisplay();
  }

  function selectTemplate(type) {
    var radio = document.querySelector("input[name='templateType'][value='" + type + "']");
    if (radio) radio.checked = true;
    var isJornada = type === "jornada_dedicada";
    var sg = document.getElementById("scheduleGroup");
    if (sg) {
      sg.style.display = isJornada ? "block" : "none";
    }
    updatePreview();
  }

  document.querySelector("[name='client_name']").addEventListener("input", updatePreview);
  document.querySelector("[name='duration_months']").addEventListener("input", updatePreview);

  presetDays("lun-vie");
  updateTotal();
  updatePreview();
  loadServiceDescriptions();

  function renderContractPreview() {
    var templateLabels = { proyecto_unico: "Proyecto \u00danico", recurrente: "Servicio Recurrente (Mensual)", jornada_dedicada: "Jornada Dedicada (Horario Fijo)" };
    var selected = document.querySelector("input[name='templateType']:checked");
    var templateType = selected ? (templateLabels[selected.value] || selected.value) : "—";

    var clientName = document.querySelector("[name='client_name']").value || "—";
    var clientRut = document.querySelector("[name='client_rut']").value || "—";
    var clientEmail = document.querySelector("[name='client_email']").value || "—";
    var clientPhone = document.querySelector("[name='client_phone']").value || "—";
    var clientAddress = document.querySelector("[name='client_address']").value || "—";

    var svcs = getServices();
    var total = svcs.reduce(function(sum, s) { return sum + s.price; }, 0);
    var duration = document.querySelector("[name='duration_months']").value || "—";
    var paymentTerms = document.querySelector("[name='payment_terms']").value || "";
    var startDate = document.querySelector("[name='start_date']").value || "";
    var endDate = document.querySelector("[name='end_date']").value || "";
    var schedule = "";
    try {
      var selTpl = document.querySelector("input[name='templateType']:checked");
      if (selTpl && selTpl.value === "jornada_dedicada") {
        var fEl = document.getElementById("scheduleFrom");
        var tEl = document.getElementById("scheduleTo");
        if (fEl && tEl) {
          var active = [];
          for (var d = 0; d <= 6; d++) {
            var chip = document.getElementById("day" + d);
            if (chip && chip.className.indexOf("bg-accent") !== -1) active.push(d);
          }
          if (active.length > 0) {
            active.sort();
            var rngs = [];
            var st = active[0], en = active[0];
            for (var i = 1; i < active.length; i++) {
              if (active[i] === en + 1 || (en === 6 && active[i] === 0)) en = active[i];
              else { rngs.push({ s: st, e: en }); st = active[i]; en = active[i]; }
            }
            rngs.push({ s: st, e: en });
            var dN = {0:"Dom",1:"Lun",2:"Mar",3:"Mi\u00e9",4:"Jue",5:"Vie",6:"S\u00e1b"};
            var ds = rngs.map(function(r) { return r.s === r.e ? dN[r.s] : dN[r.s] + "-" + dN[r.e]; }).join(", ");
            schedule = ds + " " + fEl.value + "\u2013" + tEl.value;
          }
        }
      }
    } catch(e) { schedule = "Error: " + e.message; }
    var clauses = document.querySelector("[name='special_clauses']").value || "";

    var dateStr = new Date().toLocaleDateString("es-CL", { year: "numeric", month: "long", day: "numeric" });

    function fmt(n) { return "$" + n.toLocaleString("es-CL"); }

    var html = "";

    html += '<div style="text-align:center;margin-bottom:24px;padding-bottom:20px;border-bottom:2px solid #e5e7eb;">';
    html += '<h1 style="font-size:20px;font-weight:700;color:#111827;letter-spacing:-0.02em;margin:0 0 4px;">CONTRATO DE PRESTACI\u00d3N DE SERVICIOS</h1>';
    html += '<p style="font-size:12px;color:#6b7280;margin:0;">Mtsprz &mdash; Tecnolog\u00eda y Desarrollo Web</p>';
    html += '<p style="font-size:11px;color:#9ca3af;margin:8px 0 0;">Fecha: ' + dateStr + " | N\u00b0 Contrato: (se generar\u00e1 al crear)</p>";
    html += "</div>";

    html += '<div style="margin-bottom:20px;">';
    html += '<h2 style="font-size:14px;font-weight:600;color:#111827;margin:0 0 8px;padding-bottom:6px;border-bottom:1px solid #e5e7eb;">1. IDENTIFICACI\u00d3N DE LAS PARTES</h2>';
    html += '<table style="width:100%;font-size:12px;border-collapse:collapse;">';
    html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;width:120px;vertical-align:top;">PRESTADOR:</td><td style="padding:4px 0;color:#111827;">Mat\u00edas P\u00e9rez Nauto — Mtsprz</td></tr>';
    html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;width:120px;vertical-align:top;">CLIENTE:</td><td style="padding:4px 0;color:#111827;">' + clientName + "</td></tr>";
    if (clientRut !== "—") html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">RUT:</td><td style="padding:4px 0;color:#111827;">' + clientRut + "</td></tr>";
    html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">EMAIL:</td><td style="padding:4px 0;color:#111827;">' + clientEmail + "</td></tr>";
    if (clientPhone !== "—") html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">TEL\u00c9FONO:</td><td style="padding:4px 0;color:#111827;">' + clientPhone + "</td></tr>";
    if (clientAddress !== "—") html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">DIRECCI\u00d3N:</td><td style="padding:4px 0;color:#111827;">' + clientAddress + "</td></tr>";
    html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">TIPO:</td><td style="padding:4px 0;color:#111827;font-weight:600;">' + templateType + "</td></tr>";
    html += "</table>";
    html += "</div>";

    html += '<div style="margin-bottom:20px;">';
    html += '<h2 style="font-size:14px;font-weight:600;color:#111827;margin:0 0 8px;padding-bottom:6px;border-bottom:1px solid #e5e7eb;">2. SERVICIOS Y VALORES</h2>';
    html += '<table style="width:100%;font-size:12px;border-collapse:collapse;">';
    html += '<thead><tr style="background:#f9fafb;"><th style="text-align:left;padding:8px 10px;font-weight:600;color:#374151;border-bottom:1px solid #e5e7eb;">Servicio</th><th style="text-align:right;padding:8px 10px;font-weight:600;color:#374151;border-bottom:1px solid #e5e7eb;">Valor</th></tr></thead>';
    html += "<tbody>";
    for (var i = 0; i < svcs.length; i++) {
      var s = svcs[i];
      html += '<tr><td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;color:#111827;font-weight:600;">' + (s.name || "Servicio personalizado") + '</td><td style="padding:8px 10px;border-bottom:1px solid #f3f4f6;color:#374151;text-align:right;font-family:monospace;font-weight:600;">' + fmt(s.price) + "</td></tr>";
      if (s.description) {
        html += '<tr><td colspan="2" style="padding:2px 10px 8px 10px;color:#6b7280;font-size:11px;line-height:1.5;border-bottom:1px solid #f3f4f6;">';
        html += s.description;
        if (s.deliverables && s.deliverables.length > 0) {
          html += '<div style="margin-top:6px;font-weight:600;color:#374151;">Entregables:</div><ul style="margin:4px 0 0 14px;padding:0;">';
          for (var d = 0; d < s.deliverables.length; d++) {
            html += '<li style="margin-bottom:2px;">' + s.deliverables[d] + "</li>";
          }
          html += "</ul>";
        }
        if (s.includes_maintenance) {
          html += '<div style="margin-top:6px;padding:4px 8px;background:#f0fdf4;border-radius:4px;color:#166534;font-weight:500;display:inline-block;font-size:10px;">Incluye plan de mantenimiento: $' + Number(s.maintenance_price).toLocaleString("es-CL") + "/mes</div>";
        }
        html += "</td></tr>";
      }
    }
    html += "</tbody>";
    html += '<tfoot><tr><td style="padding:10px;font-weight:700;color:#111827;border-top:2px solid #e5e7eb;">TOTAL</td><td style="padding:10px;font-weight:700;color:#4f46e5;text-align:right;font-family:monospace;border-top:2px solid #e5e7eb;font-size:15px;">' + fmt(total) + "</td></tr></tfoot>";
    html += "</table>";
    html += "</div>";

    html += '<div style="margin-bottom:20px;">';
    html += '<h2 style="font-size:14px;font-weight:600;color:#111827;margin:0 0 8px;padding-bottom:6px;border-bottom:1px solid #e5e7eb;">3. CONDICIONES</h2>';
    html += '<table style="width:100%;font-size:12px;border-collapse:collapse;">';
    html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;width:120px;vertical-align:top;">DURACI\u00d3N:</td><td style="padding:4px 0;color:#111827;">' + duration + " meses</td></tr>";
    if (startDate) html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">INICIO:</td><td style="padding:4px 0;color:#111827;">' + new Date(startDate + "T12:00:00").toLocaleDateString("es-CL", { year: "numeric", month: "long", day: "numeric" }) + "</td></tr>";
    if (endDate) html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">T\u00c9RMINO:</td><td style="padding:4px 0;color:#111827;">' + new Date(endDate + "T12:00:00").toLocaleDateString("es-CL", { year: "numeric", month: "long", day: "numeric" }) + "</td></tr>";
    if (paymentTerms) html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">FORMA DE PAGO:</td><td style="padding:4px 0;color:#111827;">' + paymentTerms + "</td></tr>";
    if (selected && selected.value === "jornada_dedicada") html += '<tr><td style="padding:4px 8px 4px 0;color:#6b7280;">JORNADA:</td><td style="padding:4px 0;color:#111827;">' + (schedule || "Por definir") + "</td></tr>";
    html += "</table>";
    html += "</div>";

    if (clauses) {
      html += '<div style="margin-bottom:20px;">';
      html += '<h2 style="font-size:14px;font-weight:600;color:#111827;margin:0 0 8px;padding-bottom:6px;border-bottom:1px solid #e5e7eb;">4. CL\u00c1USULAS ESPECIALES</h2>';
      html += '<p style="font-size:12px;color:#374151;margin:0;line-height:1.6;white-space:pre-wrap;">' + clauses + "</p>";
      html += "</div>";
    }

    html += '<div style="margin-top:28px;padding-top:20px;border-top:2px solid #e5e7eb;">';
    html += '<h2 style="font-size:14px;font-weight:600;color:#111827;margin:0 0 16px;padding-bottom:6px;border-bottom:1px solid #e5e7eb;">5. FIRMAS</h2>';
    html += '<div style="display:flex;justify-content:space-between;gap:24px;">';
    html += '<div style="flex:1;text-align:center;">';
    html += '<div style="height:60px;border-bottom:1px solid #9ca3af;margin-bottom:6px;"></div>';
    html += '<p style="font-size:11px;color:#6b7280;margin:0;">' + clientName + "</p>";
    html += '<p style="font-size:10px;color:#9ca3af;margin:2px 0 0;">CLIENTE</p>';
    html += "</div>";
    html += '<div style="flex:1;text-align:center;">';
    html += '<div style="height:60px;border-bottom:1px solid #9ca3af;margin-bottom:6px;"></div>';
    html += '<p style="font-size:11px;color:#6b7280;margin:0;">Mat\u00edas P\u00e9rez Nauto</p>';
    html += '<p style="font-size:10px;color:#9ca3af;margin:2px 0 0;">PRESTADOR — Mtsprz</p>';
    html += "</div>";
    html += "</div>";
    html += "</div>";

    document.getElementById("previewDocument").innerHTML = html;
  }

  function openPreview() {
    renderContractPreview();
    document.getElementById("previewModal").classList.remove("hidden");
    document.getElementById("previewModal").classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closePreview() {
    document.getElementById("previewModal").classList.add("hidden");
    document.getElementById("previewModal").classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.getElementById("previewBtn").addEventListener("click", openPreview);
  document.getElementById("previewSubmitBtn").addEventListener("click", function() {
    closePreview();
    document.getElementById("submitBtn").click();
  });

  document.getElementById("contractForm").addEventListener("submit", async function(e) {
    e.preventDefault();
    var form = this;
    var formData = new FormData(form);
    var btn = document.getElementById("submitBtn");
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Creando...';

    var services = getServices();
    var total = services.reduce(function(sum, s) { return sum + s.price; }, 0);

    var body = {
      template_type: formData.get("templateType"),
      client_name: formData.get("client_name"),
      client_rut: formData.get("client_rut"),
      client_email: formData.get("client_email"),
      client_phone: formData.get("client_phone"),
      client_address: formData.get("client_address"),
      services: services,
      total_amount: parseInt(formData.get("total_amount")) || total,
      payment_terms: formData.get("payment_terms"),
      start_date: formData.get("start_date"),
      end_date: formData.get("end_date"),
      duration_months: parseInt(formData.get("duration_months")) || 1,
      schedule: formData.get("schedule"),
      special_clauses: formData.get("special_clauses"),
    };

    try {
      var res = await fetch("/api/contracts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      // Si la respuesta no es 2xx, intentamos leer el error
      if (!res.ok) {
        try {
          var errorData = await res.json();
          alert("Error: " + (errorData.error || "No se pudo crear el contrato"));
        } catch (_jsonErr) {
          alert("Error del servidor (" + res.status + "). Intenta de nuevo.");
        }
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Crear y Enviar Contrato';
        return;
      }

      // Respuesta exitosa: intentamos leer el body JSON
      try {
        var data = await res.json();
        window.location.href = "/admin/contratos/" + data.contract.id;
      } catch (_jsonErr) {
        // Body vacío o inválido pero status 2xx → el contrato se creó igual
        window.location.href = "/admin/contratos";
      }
    } catch (_e) {
      alert("Error de conexión: no se pudo enviar la solicitud. Verifica tu conexión a internet.");
      btn.disabled = false;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Crear y Enviar Contrato';
    }
  });
</script>
---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { query, initDb } from "../../../lib/db";

await initDb();
const svcResult = await query("SELECT * FROM services WHERE is_active = true ORDER BY category, name");
interface Service {
  id: number;
  slug: string;
  name: string;
  description: string | null;
  price: number;
  promo_price: number | null;
  category: string | null;
  includes_maintenance: boolean;
  maintenance_price: number;
  is_monthly: boolean;
}
const services = svcResult.rows as Service[];

const tplResult = await query("SELECT * FROM contract_templates WHERE is_active = true ORDER BY name ASC");
interface Template {
  id: number;
  name: string;
  type: string;
  description: string | null;
  content_json: Record<string, unknown>;
}
const templates = tplResult.rows as Template[];
const prestadorRut = import.meta.env.MTSPRZ_RUT || "Pendiente";
---

<AdminLayout title="Nuevo Contrato" description="Crear nuevo contrato">
  <div class="mb-8">
    <p class="text-[11px] font-medium text-accent tracking-[0.15em] uppercase mb-2">Creación</p>
    <h1 class="font-heading text-3xl sm:text-4xl font-bold text-white tracking-tight">Nuevo Contrato</h1>
    <p class="mt-2 text-sm text-white/30 font-body">Completa los datos para generar el contrato</p>
  </div>

  <form id="contractForm">
    <div class="lg:grid lg:grid-cols-5 lg:gap-6">
      <div class="lg:col-span-3">

        <div class="border-b border-white/[0.04] pb-6 mb-6" data-section="1">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
            <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Tipo de Contrato</span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-px bg-white/[0.04]">
            {templates.map((tpl, idx) => {
              const firstSelected = idx === 0;
              return <label class="template-card relative cursor-pointer bg-[#010101] p-4 flex flex-col transition-all duration-200 has-checked:bg-white/[0.02] hover:bg-white/[0.015] border border-white/[0.04] group" onclick="selectTemplate({tpl.id},'{tpl.type}')" data-template-id={tpl.id} data-template-type={tpl.type}>
                <input type="radio" name="templateType" value={tpl.type} class="sr-only" checked={firstSelected || undefined} required />
                <input type="hidden" name="template_id" value={tpl.id} class="template-id-input" />
                <div class="flex flex-col gap-2 h-full">
                  <div class="flex items-center gap-2 mb-0.5">
                    <span class="flex items-center justify-center w-7 h-7 border border-white/[0.06] text-white/40">
                      {tpl.type === 'proyecto_unico' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 group-has-checked:text-accent transition-colors"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>}
                      {tpl.type === 'recurrente' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 group-has-checked:text-accent transition-colors"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>}
                      {tpl.type === 'jornada_dedicada' && <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/40 group-has-checked:text-accent transition-colors"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
                    </span>
                    <span class="text-[9px] font-medium text-white/25 uppercase tracking-[0.12em]">{tpl.type === 'proyecto_unico' ? 'Proyecto' : tpl.type === 'recurrente' ? 'Recurrente' : 'Dedicada'}</span>
                  </div>
                  <span class="text-sm font-medium text-white/80 group-has-checked:text-white leading-snug">{tpl.name}</span>
                  <p class="text-[10px] text-white/25 font-body leading-relaxed flex-1">{tpl.description || ''}</p>
                  <span class="text-[9px] text-white/10 font-mono">#{tpl.id}</span>
                </div>
              </label>;
            })}
          </div>
        </div>

        <div class="border-b border-white/[0.04] pb-6 mb-6" data-section="2">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
            <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Datos del Cliente</span>
          </div>

          <!-- Client quick-select -->
          <div class="relative mb-4">
            <div class="flex items-center gap-2 border border-white/[0.04] px-3 py-2.5 transition-all duration-200 focus-within:border-white/[0.08]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-white/20 shrink-0"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              <input id="clientSearch" type="text" autocomplete="off" class="flex-1 bg-transparent text-xs text-white/60 outline-none placeholder:text-white/15 font-body" placeholder="Buscar cliente existente por nombre, RUT o email..." />
            </div>
            <div id="clientResults" class="hidden absolute top-full left-0 right-0 z-50 mt-px border border-white/[0.06] bg-[#070708] max-h-48 overflow-y-auto"></div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Nombre / Empresa <span class="text-red-400/60">*</span></label>
              <input name="client_name" maxlength="255" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" required placeholder="Blast-up Consulting Spa" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">RUT</label>
              <input name="client_rut" maxlength="20" pattern="\d{1,2}\.?\d{3}\.?\d{3}[-]?[\dkK]" title="Formato: 77.670.736-8" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="77.670.736-8" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Nacionalidad</label>
              <input name="client_nationality" maxlength="100" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="Chilena" value="Chilena" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Profesión / Giro</label>
              <input name="client_profession" maxlength="255" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="Ingeniero Comercial / Consultoría" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Email <span class="text-red-400/60">*</span></label>
              <input name="client_email" type="email" maxlength="255" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" required placeholder="contacto@blast-up.cl" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Teléfono</label>
              <input name="client_phone" maxlength="50" pattern="[\+\d\s\-\(\)]{8,20}" title="Formato: +56 9 7547 5781" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="+56 9 7547 5781" />
            </div>
            <div class="sm:col-span-2">
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Dirección <span class="text-white/15 font-normal normal-case">(incluir comuna)</span></label>
              <input name="client_address" autocomplete="off" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="Av. Bosques de Montemar 30, Of. 316, Concón, Región de Valparaíso" />
            </div>
          </div>

          <!-- Save as client checkbox -->
          <div class="mt-4 flex items-center gap-2">
            <input id="saveClient" name="save_client" type="checkbox" class="w-3.5 h-3.5 border-white/[0.08] bg-transparent text-accent focus:ring-accent/30" />
            <label for="saveClient" class="text-[10px] text-white/25 font-body cursor-pointer select-none">Guardar como cliente recurrente</label>
          </div>
        </div>

        <div class="border-b border-white/[0.04] pb-6 mb-6" data-section="2b">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
            <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Datos del Prestador</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">RUT Prestador</label>
              <input name="prestador_rut" maxlength="20" pattern="\d{1,2}\.?\d{3}\.?\d{3}[-]?[\dkK]" title="Formato: 12.345.678-9" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="12.345.678-9" />
            </div>
          </div>
        </div>

        <div class="border-b border-white/[0.04] pb-6 mb-6" data-section="3">
          <div class="flex items-center justify-between mb-5">
            <div class="flex items-center gap-3">
              <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
              <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Servicios</span>
            </div>
            <button type="button" id="addServiceBtn" class="inline-flex items-center gap-1.5 px-3 py-2 bg-white/[0.04] hover:bg-white/[0.07] text-[10px] font-medium text-white/40 tracking-wider uppercase transition-all duration-300">+ Agregar Servicio</button>
          </div>
          <div id="servicesContainer" class="space-y-3">
            <div class="service-row border border-white/[0.04] p-3 sm:p-4 transition-all duration-200">
              <div class="flex flex-col sm:flex-row gap-3">
                <div class="w-full sm:flex-[3]">
                  <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Servicio</label>
                    <select class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body service-select" onchange="updateServicePrice(this)">
                      <option value="">Personalizado...</option>
                      {services.map(s => (
                        <option value={s.slug} data-price={s.promo_price && s.promo_price > 0 ? s.promo_price : s.price} data-price-full={s.price}>{s.name}</option>
                      ))}
                  </select>
                </div>
                <div class="w-full sm:flex-[2]">
                  <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Nombre</label>
                  <input class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body service-name" maxlength="255" placeholder="Desarrollo Web" />
                </div>
                <div class="w-full sm:flex-[2]">
                  <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Valor CLP</label>
                  <input type="number" min="0" max="2147483647" step="1" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-mono service-price" placeholder="290000" oninput="updateTotal()" />
                </div>
                <div class="flex sm:items-end gap-2 pt-1 sm:pt-0 sm:pb-[1px]">
                  <div class="hidden sm:block w-px h-8 bg-white/[0.06] self-center"></div>
                  <button type="button" class="inline-flex items-center justify-center w-9 h-9 text-sm text-white/20 hover:text-red-400/60 transition-colors remove-service" onclick="this.closest('.service-row').remove(); updateTotal();">✕</button>
              </div>
              <div class="mt-2">
                <details class="service-deliverables-details" open>
                  <summary class="text-[10px] font-medium text-white/30 uppercase tracking-wider cursor-pointer hover:text-white/50 transition-colors">Entregables</summary>
                  <textarea class="service-deliverables w-full bg-transparent border border-white/[0.08] py-2 px-3.5 text-xs text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body resize-y mt-1" rows="3" placeholder="Entregable 1&#10;Entregable 2&#10;Entregable 3"></textarea>
                </details>
              </div>
            </div>
          </div>
          </div>
          <div class="flex items-center justify-between pt-4 mt-4 border-t border-white/[0.04]">
            <span class="text-[10px] text-white/20"><span id="serviceCount">1</span> servicio(s)</span>
            <div class="flex items-center gap-2">
              <span class="text-[10px] text-white/25 uppercase tracking-wider">Total estimado</span>
              <span id="totalDisplay" class="text-lg font-bold text-accent font-mono tracking-tight">$0</span>
            </div>
          </div>

          <div id="recurringWarning" class="hidden mt-4 border-l-2 border-sky-400/30 pl-4 py-2">
            <p class="text-[11px] font-medium text-sky-300 mb-1">Servicios recurrentes en esquema de pago único</p>
            <p class="text-[11px] text-sky-300/50 leading-relaxed" id="recurringWarningDetail"></p>
            <p class="text-[10px] text-sky-300/30 mt-1.5">Si el precio es mensual, marcar "is_monthly" en el catálogo o aclarar en cláusulas especiales.</p>
          </div>

          <div id="ivaWarning" class="hidden mt-4 border-l-2 border-amber-400/30 pl-4 py-2">
            <p class="text-[11px] font-medium text-amber-300 mb-1">Validar tratamiento tributario antes de emitir</p>
            <p class="text-[11px] text-amber-300/50 leading-relaxed" id="ivaWarningDetail"></p>
            <p class="text-[10px] text-amber-300/30 mt-1.5">Consultar con contador antes de emitir la primera boleta.</p>
          </div>
        </div>

        <div class="border-b border-white/[0.04] pb-6 mb-6" data-section="4">
          <div class="flex items-center gap-3 mb-5">
            <span class="w-0.5 h-5 bg-white/10 shrink-0"></span>
            <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Condiciones</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Duración</label>
              <div class="flex gap-2">
                <input name="duration_months" type="number" min="1" max="1200" class="w-24 bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body" value="3" />
                <span class="inline-flex items-center text-xs text-white/30">meses</span>
              </div>
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Valor Total (CLP)</label>
              <input name="total_amount" type="number" min="0" max="2147483647" step="1" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-mono" required placeholder="0" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Fecha de Inicio</label>
              <input name="start_date" type="date" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Fecha de Término</label>
              <input name="end_date" type="date" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Modalidad de Pago</label>
              <select name="payment_method" onchange="togglePaymentTerms()" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body appearance-none" style="background-image:url('data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%2712%27 height=%2712%27 viewBox=%270 0 24 24%27 fill=%27none%27 stroke=%27%23fafafa%27 stroke-width=%271.5%27%3E%3Cpath d=%27M6 9l6 6 6-6%27/%3E%3C/svg%3E');background-repeat:no-repeat;background-position:right 4px center;">
                <option value="">Personalizada...</option>
                <option value="contado">Contado</option>
                <option value="50_50">50% Inicio + 50% Entrega</option>
                <option value="hitos">Por Hitos</option>
              </select>
            </div>
            <div id="paymentTermsGroup">
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Términos de Pago</label>
              <input name="payment_terms" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 placeholder:text-white/15 font-body" placeholder="Transferencia mensual anticipada" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Días de Garantía</label>
              <input name="warranty_days" type="number" min="0" max="365" value="15" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body" />
            </div>
            <div>
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Días de Revisión</label>
              <input name="revision_days" type="number" min="0" max="60" value="5" class="w-full bg-transparent border-b border-white/[0.08] py-2.5 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body" />
            </div>
            <div class="sm:col-span-2">
              <label class="flex items-center gap-3 cursor-pointer">
                <input name="subcontracting_allowed" type="checkbox" checked class="w-4 h-4 rounded border-white/[0.08] bg-transparent text-accent focus:ring-accent/30" />
                <div>
                  <span class="block text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Permitir subcontratación</span>
                  <span class="block text-[10px] text-white/20 mt-0.5">El Prestador podrá subcontratar parcialmente con autorización del Cliente</span>
                </div>
              </label>
            </div>
            <div id="scheduleGroup" style="display:none;" class="sm:col-span-2">
              <label class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-2">Jornada / Horario</label>
              <div class="flex flex-wrap items-center gap-1.5 mb-2">
                <span class="text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] mr-1">Días:</span>
                <button type="button" onclick="toggleDay(1)" id="day1" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-accent/40 text-accent transition-all duration-150">Lun</button>
                <button type="button" onclick="toggleDay(2)" id="day2" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-accent/40 text-accent transition-all duration-150">Mar</button>
                <button type="button" onclick="toggleDay(3)" id="day3" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-accent/40 text-accent transition-all duration-150">Mié</button>
                <button type="button" onclick="toggleDay(4)" id="day4" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-accent/40 text-accent transition-all duration-150">Jue</button>
                <button type="button" onclick="toggleDay(5)" id="day5" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-accent/40 text-accent transition-all duration-150">Vie</button>
                <button type="button" onclick="toggleDay(6)" id="day6" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-white/[0.08] text-white/30 transition-all duration-150">Sáb</button>
                <button type="button" onclick="toggleDay(0)" id="day0" class="day-chip px-2.5 py-1 text-[11px] font-medium border border-white/[0.08] text-white/30 transition-all duration-150">Dom</button>
              </div>
              <div class="flex flex-wrap gap-1.5 mb-3">
                <span class="text-[10px] font-medium text-white/20 uppercase tracking-[0.12em] mr-1 self-center">Predefinido:</span>
                <button type="button" onclick="presetDays('lun-vie')" id="preset-lun-vie" class="preset-chip px-2 py-1 text-[10px] font-medium border border-accent/30 text-accent transition-all duration-150">Lun-Vie</button>
                <button type="button" onclick="presetDays('lun-sab')" id="preset-lun-sab" class="preset-chip px-2 py-1 text-[10px] font-medium border border-white/[0.06] text-white/30 transition-all duration-150">Lun-Sáb</button>
                <button type="button" onclick="presetDays('lun-dom')" id="preset-lun-dom" class="preset-chip px-2 py-1 text-[10px] font-medium border border-white/[0.06] text-white/30 transition-all duration-150">Lun-Dom</button>
                <button type="button" onclick="presetDays('finde')" id="preset-finde" class="preset-chip px-2 py-1 text-[10px] font-medium border border-white/[0.06] text-white/30 transition-all duration-150">Sáb-Dom</button>
              </div>
              <div class="flex flex-col sm:flex-row sm:items-end gap-3">
                <div class="flex items-center gap-2">
                  <div>
                    <span class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-1">Desde</span>
                    <input type="time" id="scheduleFrom" value="09:00" onchange="updateScheduleDisplay()" class="w-28 bg-transparent border-b border-white/[0.08] py-2 text-sm text-white outline-none transition-all duration-200 focus:border-accent/40 font-body" />
                  </div>
                  <span class="text-white/20 text-sm pt-5">—</span>
                  <div>
                    <span class="block text-[10px] font-medium text-white/25 uppercase tracking-[0.12em] mb-1">Hasta</span>

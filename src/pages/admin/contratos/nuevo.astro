    // ── 12. CONFIDENCIALIDAD ──
    html += clauseTitle(11, 'CONFIDENCIALIDAD');
    html += clauseText('Se considera Información Confidencial toda aquella comercial, técnica o financiera intercambiada entre las partes.');
    html += clauseItem('a', 'La Parte Receptora mantendrá estricta reserva.');
    html += clauseItem('b', 'Obligación vigente durante el contrato y 3 años después.');
    html += clauseItem('c', 'Solo se usará para los fines del contrato.');
    html += clauseItem('d', 'Excepciones: dominio público, orden judicial.');
    html += clauseItem('e', 'Devolución o destrucción al término.');

    // ── 13. PROTECCIÓN DE DATOS ──
    html += clauseTitle(12, 'PROTECCIÓN DE DATOS PERSONALES');
    html += clauseText('Ambas partes cumplirán la Ley 19.628 sobre Protección de la Vida Privada. Asimismo, tendrán presente lo dispuesto en la Ley 21.719 (publicada el 13-dic-2024), cuya entrada en vigencia está prevista para el 1-dic-2026.');
    html += clauseItem('a', 'Datos usados solo para ejecución del contrato.');
    html += clauseItem('b', 'Medidas de seguridad técnicas y organizativas.');
    html += clauseItem('c', 'Notificar incidentes de seguridad en un plazo máximo de 72 hrs desde que se tome conocimiento, conforme al estándar de la Ley 21.719.');
    html += clauseItem('d', 'Cuando acceda a bases de datos o contactos del Cliente (ej. integraciones CRM), el Prestador actúa como encargado de tratamiento: trata datos solo bajo instrucciones del Cliente, no los usa para fines propios, y al término del contrato los devuelve o elimina.');

    // ── 14. MODIFICACIONES ──
    html += clauseTitle(13, 'MODIFICACIONES');
    html += clauseText('Los cambios al alcance deben solicitarse por escrito (email vale). El Prestador cotizará los servicios adicionales. No ejecutará modificaciones sin aprobación previa.');
    html += clauseBold('Efecto: ', 'Las modificaciones aprobadas modifican el objeto (Art. 1545 CC).');

    // ── 15. SUBCONTRATACIÓN ──
    html += clauseTitle(14, 'SUBCONTRATACIÓN');
    if (subcontracting) {
      html += clauseText('El Prestador podrá subcontratar parcialmente con autorización del Cliente, respondiendo íntegramente por los subcontratistas.');
    } else {
      html += clauseText('El Prestador no podrá subcontratar sin autorización expresa y por escrito del Cliente.');
    }

    // ── 16. GARANTÍA Y RESPONSABILIDAD ──
    html += clauseTitle(15, 'GARANTÍA Y RESPONSABILIDAD');
    html += clauseBold('Período de garantía: ', warrantyDays + ' días corridos desde la entrega conforme.');
    html += clauseBold('Cobertura: ', 'Defectos de implementación y no conformidad con especificaciones.');
    html += clauseBold('Exclusiones: ', 'Modificaciones del Cliente, cambios de requerimiento, problemas de infraestructura.');
    html += clauseBold('Límite: ', 'Responsabilidad total limitada al monto de honorarios pagados. Excluye daños indirectos y lucro cesante. No aplica a dolo o culpa grave (Art. 44 CC).');

    // ── 17. FUERZA MAYOR ──
    html += clauseTitle(16, 'FUERZA MAYOR');
    html += clauseText('Ninguna parte será responsable por incumplimiento debido a caso fortuito o fuerza mayor (Arts. 45, 1545 CC).');
    html += clauseItem('a', 'Causales: desastres naturales, guerra, pandemia, corte de servicios esenciales.');
    html += clauseItem('b', 'Notificar en 24 hrs.');
    html += clauseItem('c', 'Obligaciones suspendidas mientras dure la causal.');

    // ── 18. JURISDICCIÓN ──
    html += clauseTitle(17, 'JURISDICCIÓN Y LEGISLACIÓN APLICABLE');
    html += clauseText('Se rige por las leyes de la República de Chile. Domicilio: Puerto Varas, Región de Los Lagos. Las partes se someten a sus tribunales ordinarios.');
    html += clauseBold('Firma electrónica: ', 'La firma electrónica simple utilizada produce efectos jurídicos entre las partes conforme a la Ley 19.799. No cuenta con la presunción de integridad y autoría de la firma electrónica avanzada (certificada); su valor probatorio será apreciado por el tribunal según las reglas generales.');

    // ── ANEXO A: ENTREGABLES Y PLAZOS ──
    html += '<div style="margin-top:20px;padding-top:16px;border-top:2px solid #e5e7eb;">';
    html += '<h3 style="font-size:13px;font-weight:700;color:#111827;margin:0 0 8px;">ANEXO A — ENTREGABLES Y PLAZOS</h3>';
    html += clauseText('El presente anexo forma parte integrante del contrato y detalla los entregables, plazos y criterios de aceptación de cada servicio contratado.');
    for (var ai = 0; ai < svcs.length; ai++) {
      var asvc = svcs[ai];
      var monthlyTag = asvc.is_monthly ? ' <span style="color:#6b7280;font-weight:400;font-size:10px;">(mensual)</span>' : '';
      html += '<h4 style="font-size:12px;font-weight:600;color:#4f46e5;margin:12px 0 6px;">' + (ai + 1) + '. ' + asvc.name + ' — $' + (asvc.price || 0).toLocaleString('es-CL') + monthlyTag + '</h4>';
      var plazoInicio = startDate || 'la fecha de inicio';
      var plazoFin = endDate || 'la fecha de término';
      if (asvc.is_monthly) {
        html += clauseBold('Modalidad: ', 'Servicio recurrente mensual. El valor de $' + (asvc.price || 0).toLocaleString('es-CL') + ' corresponde a cada mes de servicio. Se factura y paga mensualmente por adelantado.');
      } else {
        html += clauseBold('Plazo de ejecución: ', 'Los entregables se liberarán de forma incremental entre el ' + plazoInicio + ' y el ' + plazoFin + '. Las partes podrán acordar hitos específicos por escrito, los que se entenderán incorporados al presente anexo.');
      }
      if (asvc.deliverables && asvc.deliverables.length > 0) {
        html += '<strong style="font-size:11px;color:#111827;">Entregables:</strong>';
        html += '<ul style="margin:4px 0 8px;padding-left:20px;font-size:11px;color:#374151;line-height:1.6;">';
        for (var di = 0; di < asvc.deliverables.length; di++) {
          html += '<li>' + asvc.deliverables[di] + '</li>';
        }
        html += '</ul>';
      } else {
        html += '<p style="font-size:11px;color:#9ca3af;font-style:italic;margin:2px 0 8px;">Entregables y especificaciones por definir entre las partes. Se entenderán incorporados al presente anexo una vez acordados por escrito.</p>';
      }
      html += '<p style="font-size:10px;color:#6b7280;margin:0 0 4px;"><strong>Criterio de aceptación:</strong> Cada entregable se considerará recibido conforme tras su revisión y aprobación por escrito del Cliente, o transcurrido el plazo de revisión sin observaciones (aprobación tácita).</p>';
      if (asvc.deliverables && asvc.deliverables.some(function(d) { return d.toLowerCase().indexOf('hosting') !== -1 || d.toLowerCase().indexOf('cdn') !== -1; })) {
        html += '<p style="font-size:10px;color:#6b7280;margin:0 0 4px;"><strong>Nota sobre hosting:</strong> El servicio incluye alojamiento web con SSL y CDN por el período indicado en los entregables. Dicho período se contará desde la puesta en producción del sitio (una vez recibido el pago total). Transcurrido el período incluido, la renovación será por cuenta del Cliente. El Prestador no será responsable por caídas imputables al proveedor de infraestructura. El Cliente podrá solicitar migración a un proveedor de su elección. La titularidad del contenido alojado corresponde al Cliente desde el pago total de los honorarios.</p>';
      }
    }
    html += clauseText('Las partes declaran conocer y aceptar el contenido del presente Anexo A, que forma parte integrante del contrato para todos los efectos legales.');
    html += '</div>';

    // ── CLAUSULAS ESPECIALES ──
    if (specialClauses) {
      html += clauseTitle(18, 'CLÁUSULAS ESPECIALES ADICIONALES');
      html += '<p style="font-size:11px;color:#374151;margin:0;line-height:1.6;white-space:pre-wrap;">' + specialClauses + '</p>';
    }

    // ── 19. FIRMAS ──
    html += '<div style="margin-top:24px;padding-top:16px;border-top:2px solid #e5e7eb;">';
    html += '<h3 style="font-size:13px;font-weight:700;color:#4f46e5;margin:0 0 12px;">DÉCIMA NOVENA. — FIRMAS</h3>';
    html += '<p style="font-size:10px;color:#6b7280;margin:0 0 14px;font-style:italic;">"Las partes firman en señal de aprobación, aceptando todas y cada una de las cláusulas del presente contrato."</p>';
    html += '<div style="display:flex;justify-content:space-between;gap:20px;">';
    html += '<div style="flex:1;text-align:center;"><div style="height:50px;border-bottom:1px solid #9ca3af;margin-bottom:4px;"></div><p style="font-size:10px;color:#6b7280;margin:0;">Mtsprz — Soluciones Digitales</p><p style="font-size:9px;color:#9ca3af;margin:2px 0 0;">PRESTADOR</p></div>';
    html += '<div style="flex:1;text-align:center;"><div style="height:50px;border-bottom:1px solid #9ca3af;margin-bottom:4px;"></div><p style="font-size:10px;color:#6b7280;margin:0;">' + clientName + '</p><p style="font-size:9px;color:#9ca3af;margin:2px 0 0;">CLIENTE</p></div>';
    html += '</div></div>';

    document.getElementById("previewDocument").innerHTML = html;
  }

  function openPreview() {
    renderContractPreview();
    document.getElementById("previewModal").classList.remove("hidden");
    document.getElementById("previewModal").classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function closePreview() {
    document.getElementById("previewModal").classList.add("hidden");
    document.getElementById("previewModal").classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.getElementById("previewBtn").addEventListener("click", openPreview);
  document.getElementById("previewSubmitBtn").addEventListener("click", function() {
    closePreview();
    document.getElementById("submitBtn").click();
  });

  document.getElementById("contractForm").addEventListener("submit", async function(e) {
    e.preventDefault();
    var form = this;
    var formData = new FormData(form);
    var btn = document.getElementById("submitBtn");
    btn.disabled = true;
    btn.innerHTML = '<svg class="animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg> Creando...';

    var services = getServices();
    var total = services.reduce(function(sum, s) { return sum + s.price; }, 0);

    // Find the active template_id (only the selected card has a non-empty value)
    var tplId = null;
    document.querySelectorAll("input[name='template_id']").forEach(function(inp) {
      if (inp.value) tplId = parseInt(inp.value);
    });
    var body = {
      template_id: tplId,
      client_name: formData.get("client_name"),
      client_rut: formData.get("client_rut"),
      client_nationality: formData.get("client_nationality") || "Chilena",
      client_profession: formData.get("client_profession"),
      client_email: formData.get("client_email"),
      client_phone: formData.get("client_phone"),
      client_address: formData.get("client_address"),
      prestador_rut: formData.get("prestador_rut") || undefined,
      services: services,
      total_amount: parseInt(formData.get("total_amount")) || total,
      payment_method: formData.get("payment_method"),
      payment_terms: formData.get("payment_terms"),
      warranty_days: parseInt(formData.get("warranty_days")) || 15,
      revision_days: parseInt(formData.get("revision_days")) || 5,
      subcontracting_allowed: formData.get("subcontracting_allowed") === "on",
      start_date: formData.get("start_date"),
      end_date: formData.get("end_date"),
      duration_months: parseInt(formData.get("duration_months")) || 1,
      schedule: formData.get("schedule"),
      special_clauses: formData.get("special_clauses"),
    };

    try {
      var res = await fetch("/api/contracts", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(body),
      });

      // Si la respuesta no es 2xx, intentamos leer el error
      if (!res.ok) {
        try {
          var errorData = await res.json();
          alert("Error: " + (errorData.error || "No se pudo crear el contrato"));
        } catch (_jsonErr) {
          alert("Error del servidor (" + res.status + "). Intenta de nuevo.");
        }
        btn.disabled = false;
        btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Crear y Enviar Contrato';
        return;
      }

      // Respuesta exitosa: intentamos leer el body JSON
      var data;
      try {
        data = await res.json();
      } catch (_jsonErr) {
        data = null;
      }

      // Save client as recurring if checkbox is checked
      if (document.getElementById("saveClient").checked) {
        var clientData = {
          name: formData.get("client_name"),
          company_name: formData.get("client_company") || formData.get("client_name"),
          rut: formData.get("client_rut"),
          email: formData.get("client_email"),
          phone: formData.get("client_phone"),
          address: formData.get("client_address"),
          nationality: formData.get("client_nationality") || "Chilena",
          profession: formData.get("client_profession"),
        };
        // Fire-and-forget: no bloquear redirect
        fetch("/api/clients", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(clientData),
        }).catch(function() {});
      }

      if (data && data.contract && data.contract.id) {
        window.location.href = "/admin/contratos/" + data.contract.id;
      } else {
        window.location.href = "/admin/contratos";
      }
    } catch (_e) {
      alert("Error de conexión: no se pudo enviar la solicitud. Verifica tu conexión a internet.");
      btn.disabled = false;
      btn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg> Crear y Enviar Contrato';
    }
  });
</script>
  <div id="previewModal" class="fixed inset-0 z-[100] bg-[#010101]/90 hidden items-center justify-center p-3 sm:p-6" onclick="if (event.target===this) closePreview()">
    <div class="bg-[#070708] border border-white/[0.04] w-full max-w-3xl max-h-[90vh] flex flex-col overflow-hidden">
      <div class="flex items-center justify-between px-5 sm:px-7 py-4 border-b border-white/[0.04] shrink-0">
        <div>
          <span class="text-[10px] font-medium text-white/30 uppercase tracking-[0.12em]">Vista Previa del Contrato</span>
          <p class="text-[11px] text-white/25 mt-0.5 font-body">Revisa el documento antes de enviarlo</p>
        </div>

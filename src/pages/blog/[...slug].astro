---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const slug = post.id.replace(/\.(md|mdx)$/, "");
const { Content, headings } = await render(post);
const allPosts = await getCollection("blog");

const waPhone = "56966929818";
// CTA contextual según tags del post
const tags = (post.data.tags || []).map((t: string) => t.toLowerCase());
const isAutomatizacion = tags.some((t: string) => ["automatización", "whatsapp", "bot", "crm"].includes(t));
const isSEO = tags.some((t: string) => ["seo", "google maps", "posicionamiento", "seo local"].includes(t));
const ctaConfig = isAutomatizacion
  ? { service: "automatización", url: "/automatizacion", accent: "#06b6d4", gradient: "linear-gradient(135deg,#06b6d4,#0891b2)", waMsg: "Hola! Leí el blog y quiero saber cómo automatizar mi negocio." }
  : isSEO
  ? { service: "SEO local", url: "/seo-local", accent: "#10b981", gradient: "linear-gradient(135deg,#10b981,#059669)", waMsg: "Hola! Leí el blog y quiero posicionar mi negocio en Google." }
  : { service: "desarrollo web", url: "/desarrollo-web", accent: "#6366f1", gradient: "linear-gradient(135deg,#6366f1,#8b5cf6)", waMsg: "Hola! Leí el blog y quiero cotizar una página web." };
const waCtaUrl = `https://wa.me/${waPhone}?text=${encodeURIComponent(ctaConfig.waMsg)}`;
const postTags = post.data.tags || [];
const postTagSet = new Set(postTags.map((t: string) => t.toLowerCase()));
const related = allPosts
  .filter((p) => p.id !== post.id)
  .map((p) => {
    const pTags = (p.data.tags || []).map((t: string) => t.toLowerCase());
    const shared = pTags.filter((t: string) => postTagSet.has(t)).length;
    return { post: p, relevance: shared };
  })
  .sort((a, b) => b.relevance - a.relevance || Math.random() - 0.5)
  .slice(0, 2)
  .map((r) => r.post);

function readingTime(text: string): number {
  const words = text.split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

function extractFAQ(body: string): { question: string; answer: string }[] {
  const results: { question: string; answer: string }[] = [];
  const regex = /^##\s+(.+\?)\s*\n\n([\s\S]*?)(?=\n\n##\s|\n---|\n\[|$)/gm;
  let match;
  while ((match = regex.exec(body)) !== null) {
    const question = match[1].trim();
    const rawAnswer = match[2].trim();
    const answer = rawAnswer.split(/\n\n/)[0].replace(/\n/g, " ").slice(0, 300);
    if (answer.length > 20) {
      results.push({ question, answer });
    }
  }
  return results;
}

// Extract HowTo steps from markdown body
// Supports two formats:
//   ## Paso N: Título
//   ### N. Título  (numbered subsection)
function extractHowToSteps(body: string): { position: number; name: string; text: string }[] {
  const results: { position: number; name: string; text: string }[] = [];

  // Pattern 1: "## Paso N: Título"
  const pasoRegex = /^##\s+Paso\s+(\d+)[:\.]\s+(.+)\n\n([\s\S]*?)(?=\n\n##\s+|\n---|\n\[|$)/gim;
  let match;
  while ((match = pasoRegex.exec(body)) !== null) {
    const position = parseInt(match[1], 10);
    const name = match[2].trim();
    const rawText = match[3].trim();
    const text = rawText.split(/\n\n/)[0].replace(/\n/g, " ").slice(0, 500);
    if (text.length > 20) {
      results.push({ position, name, text });
    }
  }

  // Pattern 2: "### N. Título" (numbered subsections, only if no "Paso" steps found)
  if (results.length === 0) {
    const numberedRegex = /^###\s+(\d+)[\.\)]\s+(.+)\n\n([\s\S]*?)(?=\n\n###\s+|\n\n##\s+|\n---|\n\[|$)/gm;
    while ((match = numberedRegex.exec(body)) !== null) {
      const position = parseInt(match[1], 10);
      const name = match[2].trim();
      const rawText = match[3].trim();
      const text = rawText.split(/\n\n/)[0].replace(/\n/g, " ").slice(0, 500);
      if (text.length > 20) {
        results.push({ position, name, text });
      }
    }
  }

  return results.sort((a, b) => a.position - b.position);
}

const faqItems = extractFAQ(post.body || "");
const hasFAQ = faqItems.length > 0;

const readMin = readingTime(post.body || "");
const postUrl = `https://mtsprz.org/blog/${slug}`;
const shareText = encodeURIComponent(post.data.title);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={postUrl}
  image={post.data.image || undefined}
  breadcrumbs={[
    { name: "Blog", path: "/blog" },
    { name: post.data.title, path: `/blog/${slug}` },
  ]}
  article={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: (post.data.modifiedTime || post.data.pubDate).toISOString(),
    author: post.data.author,
    tags: post.data.tags,
  }}
>
  <Header />
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  {hasFAQ && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "@id": `${postUrl}#faq`,
      "mainEntity": faqItems.map((f) => ({
        "@type": "Question",
        name: f.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: f.answer,
        },
      })),
    })} />
  )}

  {
    (() => {
      const howToSteps = extractHowToSteps(post.body || "");
      if (howToSteps.length >= 2) {
        return <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "HowTo",
          "name": post.data.title,
          "description": post.data.description,
          "step": howToSteps.map((s) => ({
            "@type": "HowToStep",
            "position": s.position,
            "name": s.name,
            "text": s.text,
          })),
        })} />;
      }
      return null;
    })()
  }

  <main>
    <!-- Hero — video background full-bleed -->
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent sm:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent sm:h-48"></div>

      <!-- Contenido central -->
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <div class="text-center px-6 max-w-3xl" style="pointer-events: auto;">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Blog</p>
          <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-[1.0] tracking-[-1.5px] md:tracking-[-2px]">
            {post.data.title}
          </h1>
          <div class="mt-5 flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 text-[11px] md:text-xs text-white/35 font-body tracking-wide">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString("es-CL", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </time>
            <span class="text-white/15">&middot;</span>
            <span>{readMin} min de lectura</span>
            {post.data.modifiedTime && (
              <>
                <span class="text-white/15">&middot;</span>
                <span style="color: #10b981aa;">Actualizado</span>
              </>
            )}
          </div>
        </div>
      </div>

      <!-- Breadcrumb — integrado en hero, esquina inferior -->
      <div class="absolute bottom-8 md:bottom-10 left-0 right-0 z-20 px-6">
        <div class="mx-auto max-w-6xl">
          <Breadcrumbs items={[
            { name: "Blog", path: "/blog" },
            { name: post.data.title, path: `/blog/${slug}` },
          ]} />
        </div>
      </div>
    </section>

    <!-- Article content — editorial layout -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 30% 0%, #6366f110 0%, transparent 50%), radial-gradient(ellipse at 70% 100%, #8b5cf606 0%, transparent 50%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />

      <div class="relative mx-auto max-w-3xl px-6 py-20 md:py-28">
        <div class="reveal-group">
          <!-- Back link -->
          <nav class="reveal-item mb-10 md:mb-12">
            <a
              href="/blog"
              class="inline-flex items-center gap-2 text-[11px] text-white/30 hover:text-white/60 transition-colors font-body tracking-[0.1em] uppercase"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
              Volver al blog
            </a>
          </nav>

          <!-- Author + meta -->
          <div class="reveal-item flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-8 md:pb-10 border-b border-white/[0.06]">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#6366f1] to-[#8b5cf6] flex items-center justify-center text-sm font-bold text-white">
                M
              </div>
              <div>
                <p class="text-sm text-white/70 font-body">{post.data.author}</p>
                <p class="text-[11px] text-white/30 font-body">Mtsprz Soluciones Digitales</p>
              </div>
            </div>
            <div class="flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="text-[10px] text-white/25 font-body tracking-[0.05em] uppercase">{tag}</span>
              ))}
            </div>
          </div>

          <!-- GEO Answer Block — estilo editorial -->
          <div class="reveal-item mt-8 md:mt-10">
            <div class="relative pl-5 md:pl-6 border-l border-[#6366f1]/30">
              <p class="text-[10px] uppercase tracking-[0.2em] text-[#6366f1]/60 font-body font-medium mb-2">Respuesta rápida</p>
              <p class="text-sm md:text-[15px] text-white/60 font-body font-light leading-[1.8]">
                {post.data.description}
              </p>
            </div>
          </div>

          <!-- Article body — prose editorial -->
          <div class="reveal-item mt-10 md:mt-12 prose-blog max-w-none">
            <Content />
          </div>

          <!-- Author footer + sharing — clean editorial -->
          <footer class="reveal-item mt-12 md:mt-16 pt-8 md:pt-10 border-t border-white/[0.06]">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-[#6366f1] to-[#8b5cf6] flex items-center justify-center text-sm font-bold text-white">
                  M
                </div>
                <div>
                  <p class="text-sm text-white/70 font-body">{post.data.author}</p>
                  <p class="text-[11px] text-white/30 font-body">Mtsprz Soluciones Digitales</p>
                </div>
              </div>

              <div class="flex items-center gap-2">
                <span class="text-[10px] text-white/25 font-body uppercase tracking-[0.1em] mr-1">Compartir</span>
                <a
                  href={`https://wa.me/?text=${shareText}%20${encodeURIComponent(postUrl)}`}
                  target="_blank" rel="noopener noreferrer"
                  class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all"
                  aria-label="Compartir en WhatsApp"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
                </a>
                <a
                  href={`https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(postUrl)}`}
                  target="_blank" rel="noopener noreferrer"
                  class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all"
                  aria-label="Compartir en Twitter"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46L20 4"/></svg>
                </a>
                <a
                  href={`https://linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`}
                  target="_blank" rel="noopener noreferrer"
                  class="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all"
                  aria-label="Compartir en LinkedIn"
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                </a>
                <button
                  class="copy-link-btn w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-white/40 hover:text-white hover:border-white/30 transition-all"
                  aria-label="Copiar enlace"
                  data-url={postUrl}
                >
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
                </button>
              </div>
            </div>
          </footer>
        </div>
      </div>

      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />
    </section>

    <!-- Related posts — editorial cards -->
    {
      related.length > 0 && (
        <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
          <div class="absolute inset-0" style="background: #0A0A0A;" />
          <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 70% 0%, #8b5cf608 0%, transparent 50%), radial-gradient(ellipse at 30% 100%, #6366f106 0%, transparent 50%);" />
          <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
          <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />
          <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />

          <div class="relative mx-auto max-w-4xl px-6 py-28 md:py-36">
            <div class="reveal-group">
              <p class="reveal-item text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-8 md:mb-10" style="color: #6366f1aa;">Artículos relacionados</p>

              <div class="reveal-group divide-y divide-white/[0.06]">
                {related.map((r) => {
                  const rSlug = r.id.replace(/\.(md|mdx)$/, "");
                  return (
                    <article class="reveal-item group py-6 md:py-8 first:pt-0 last:pb-0">
                      <a href={`/blog/${rSlug}`} class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 no-underline">
                        <div class="min-w-0 flex-1">
                          <time class="block text-[11px] text-white/30 font-body tracking-wide mb-2">
                            {r.data.pubDate.toLocaleDateString("es-CL", {
                              year: "numeric",
                              month: "long",
                              day: "numeric",
                            })}
                          </time>
                          <h3 class="text-lg md:text-xl font-heading font-bold text-white leading-snug group-hover:text-white/60 transition-colors duration-300 tracking-[-0.5px]">
                            {r.data.title}
                          </h3>
                          <p class="mt-2 text-sm text-white/45 font-body font-light leading-relaxed line-clamp-2">
                            {r.data.description}
                          </p>
                        </div>
                        <div class="shrink-0 pt-1 hidden sm:block">
                          <div class="flex items-center justify-center w-9 h-9 rounded-full border border-white/10 text-white/30 group-hover:text-white group-hover:border-white/30 transition-all duration-300">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
                          </div>
                        </div>
                      </a>
                    </article>
                  );
                })}
              </div>
            </div>
          </div>
        </section>
      )
    }

    <!-- CTA — contextual según tema del post -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-50" style={`background: radial-gradient(ellipse at 50% 0%, ${ctaConfig.accent}28 0%, transparent 50%);`} />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <div class="absolute top-0 left-0 right-0 h-[1px]" style={`background: linear-gradient(90deg, transparent, ${ctaConfig.accent}44, transparent);`} />
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style={`background: linear-gradient(90deg, transparent, ${ctaConfig.accent}22, transparent);`} />

      <div class="relative mx-auto max-w-4xl px-6 py-28 md:py-36 text-center">
        <div class="reveal-group">
          <p class="reveal-item text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-6" style={`color: ${ctaConfig.accent}aa;`}>
            Aplica lo que leíste
          </p>

          <h2 class="reveal-item text-3xl sm:text-4xl md:text-6xl lg:text-7xl font-heading font-bold text-white leading-[0.95] tracking-[-1.5px] md:tracking-[-2px]">
            ¿Tu negocio necesita<br />
            <span class="text-transparent bg-clip-text" style={`background-image: ${ctaConfig.gradient};`}>{ctaConfig.service}?</span>
          </h2>

          <div class="reveal-item mx-auto my-8 w-12 h-[1px]" style={`background: linear-gradient(90deg, transparent, ${ctaConfig.accent}66, transparent);`} />

          <p class="reveal-item mx-auto max-w-lg text-sm md:text-base text-white/50 font-body font-light leading-relaxed">
            Somos Mtsprz — agencia digital del sur de Chile. Conversemos sin compromiso sobre cómo podemos ayudarte.
          </p>

          <div class="reveal-item mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a href={waCtaUrl} target="_blank" rel="noopener noreferrer"
              class="group inline-flex items-center gap-3 px-7 md:px-8 py-3.5 md:py-4 text-xs md:text-sm font-medium tracking-[0.15em] uppercase transition-all"
              style="color:#fff; background:#25D366;">
              <span>WhatsApp</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
            </a>
            <a href={ctaConfig.url}
              class="group inline-flex items-center gap-3 px-7 md:px-8 py-3.5 md:py-4 text-xs md:text-sm font-medium tracking-[0.15em] uppercase transition-all"
              style={`color:#fff; background:${ctaConfig.gradient};`}>
              <span>Ver servicio</span>
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          </div>

          <div class="reveal-item mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3">
            {[
              { label: "Sin compromiso" },
              { label: "Respuesta en 24 hrs" },
              { label: "Sur de Chile" },
            ].map((t) => (
              <span class="inline-flex items-center gap-2 text-[10px] md:text-xs font-medium tracking-[0.1em] uppercase" style="color: rgba(255,255,255,0.25);">
                <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke={ctaConfig.accent} stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                {t.label}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script is:inline>
  (function() {
    var btn = document.querySelector(".copy-link-btn");
    if (!btn) return;
    btn.addEventListener("click", function() {
      var url = btn.getAttribute("data-url");
      navigator.clipboard.writeText(url).then(function() {
        var original = btn.innerHTML;
        btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>';
        setTimeout(function() { btn.innerHTML = original; }, 2000);
      });
    });
  })();
  </script>
</BaseLayout>

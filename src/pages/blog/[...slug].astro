---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";
import { render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
>
  <Header />
  <main class="min-h-screen bg-[#010101] pt-28 pb-20">
    <div class="mx-auto max-w-3xl px-6">
      <div class="reveal-group">
        <time class="reveal-item text-xs text-white/40">
          {post.data.pubDate.toLocaleDateString("es-CL", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </time>
        <h1 class="reveal-item mt-2 text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white leading-[0.9] tracking-[-1px]">
          {post.data.title}
        </h1>
      </div>
      <div class="reveal-group mt-8 max-w-none text-white/70 font-body font-light leading-relaxed prose prose-invert">
        <Content />
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

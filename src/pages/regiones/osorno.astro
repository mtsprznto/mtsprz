---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Card3D from "../../components/Card3D.astro";
import Footer from "../../components/Footer.astro";
---

<BaseLayout
  title="Soluciones Digitales en Osorno"
  description="Mtsprz - Agencia de soluciones digitales en Osorno, Región de Los Lagos. Creamos páginas web, SEO local y automatizaciones para pymes en Osorno."
  canonical="https://mtsprz.org/regiones/osorno"
  breadcrumbs={[{ name: "Osorno", path: "/regiones/osorno" }]}
>
  <Header />
  <main class="min-h-screen bg-[#010101] pt-28 pb-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="reveal-group">
        <p class="reveal-item text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Osorno</p>
        <h1 class="reveal-item text-4xl sm:text-5xl md:text-6xl font-heading font-bold text-white leading-[0.9] tracking-[-2px]">
          Soluciones Digitales en Osorno
        </h1>
        <p class="reveal-item mt-3 text-lg text-white/60 font-body font-light max-w-2xl">
          Ayudamos a pymes y empresas de Osorno a crecer con sitios web profesionales,
          posicionamiento SEO local y automatizaciones inteligentes.
        </p>
      </div>

      <div class="mt-12 md:mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3 reveal-group">
        <Card3D class="reveal-item liquid-glass rounded-[1.25rem] p-6" innerClass="flex flex-col min-h-[250px]">
          <div data-tz="50" class="liquid-glass rounded-[0.75rem] w-10 h-10 flex items-center justify-center shrink-0 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          </div>
          <div class="flex-1" />
          <div data-tz="40" class="mt-6">
            <h2 class="text-xl md:text-2xl font-heading font-bold text-white tracking-[-1px] leading-none">Páginas Web en Osorno</h2>
            <p class="mt-3 text-sm text-white/70 font-body font-light leading-snug">
              Sitios web profesionales optimizados para Google. Diseño responsive y carga ultrarrápida.
            </p>
          </div>
        </Card3D>
        <Card3D class="reveal-item liquid-glass rounded-[1.25rem] p-6" innerClass="flex flex-col min-h-[250px]">
          <div data-tz="50" class="liquid-glass rounded-[0.75rem] w-10 h-10 flex items-center justify-center shrink-0 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          </div>
          <div class="flex-1" />
          <div data-tz="40" class="mt-6">
            <h2 class="text-xl md:text-2xl font-heading font-bold text-white tracking-[-1px] leading-none">SEO Local Osorno</h2>
            <p class="mt-3 text-sm text-white/70 font-body font-light leading-snug">
              Posiciona tu negocio en Google Maps y búsquedas locales en Osorno y toda la provincia.
            </p>
          </div>
        </Card3D>
        <Card3D class="reveal-item liquid-glass rounded-[1.25rem] p-6" innerClass="flex flex-col min-h-[250px]">
          <div data-tz="50" class="liquid-glass rounded-[0.75rem] w-10 h-10 flex items-center justify-center shrink-0 mb-4">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
          </div>
          <div class="flex-1" />
          <div data-tz="40" class="mt-6">
            <h2 class="text-xl md:text-2xl font-heading font-bold text-white tracking-[-1px] leading-none">Automatizaciones</h2>
            <p class="mt-3 text-sm text-white/70 font-body font-light leading-snug">
              Bots de WhatsApp, flujos automatizados y CRM para tu negocio en Osorno.
            </p>
          </div>
        </Card3D>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>

---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Footer from "../../components/Footer.astro";

const waPhone = "56966929818";
const waMsg = encodeURIComponent("Hola, vi la página de Valdivia en Mtsprz y quiero información sobre sus servicios digitales.");
const waUrl = `https://wa.me/${waPhone}?text=${waMsg}`;
const site = "https://mtsprz.org";
---

<BaseLayout
  title="Agencia Digital Valdivia — Páginas Web, SEO Local y Automatización"
  description="Agencia digital en Valdivia: páginas web profesionales, posicionamiento en Google Maps y bots WhatsApp para pymes. Restaurantes, hospedajes, servicios y más. Cotiza gratis."
  canonical="https://mtsprz.org/regiones/valdivia"
  breadcrumbs={[{ name: "Valdivia", path: "/regiones/valdivia" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": `${site}/regiones/valdivia#localbusiness`,
    name: "Mtsprz — Agencia Digital Valdivia",
    description: "Agencia digital en Valdivia. Páginas web, SEO local y automatizaciones para pymes de Valdivia y la Región de Los Ríos.",
    url: `${site}/regiones/valdivia`,
    telephone: "+56975475781",
    email: "contacto@mtsprz.org",
    areaServed: [
      { "@type": "City", name: "Valdivia" },
      { "@type": "AdministrativeArea", name: "Región de Los Ríos" }
    ],
    address: {
      "@type": "PostalAddress",
      addressLocality: "Valdivia",
      addressRegion: "Los Ríos",
      addressCountry: "CL"
    },
    geo: { "@type": "GeoCoordinates", latitude: -39.814, longitude: -73.246 },
    parentOrganization: { "@id": `${site}/#organization` }
  })} />

  <Header />
  <main style="overflow-x:hidden;">

    <!-- HERO -->
    <section style="position:relative; width:100vw; height:100dvh; min-height:100vh; overflow:hidden; background:#010101;">
      <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 60% 70%, #100a1a12 0%, transparent 50%), radial-gradient(ellipse at 25% 25%, #08040e 0%, transparent 60%), linear-gradient(160deg, #010101 0%, #060408 50%, #010101 100%);"></div>
      <div style="position:absolute; inset:0; opacity:0.025; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
      <div style="position:absolute; bottom:0; left:0; right:0; height:55%; background:linear-gradient(to top, #010101 0%, #010101 20%, transparent 100%); z-index:2;"></div>

      <div style="position:absolute; bottom:0; left:0; right:0; z-index:10; padding:0 2.5rem 3.5rem;">
        <p style="font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.25); font-family:var(--font-body); margin-bottom:1rem;">Los Ríos · Chile</p>
        <h1 style="font-size:clamp(4.5rem, 14vw, 16rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.85; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
          VALDIVIA<br /><span style="color:rgba(255,255,255,0.15);">DIGITAL</span>
        </h1>
        <p style="margin-top:1.25rem; font-size:0.75rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); font-weight:300; letter-spacing:0.05em;">
          Diseño web · SEO local · Automatización — sur de Chile
        </p>
        <div style="margin-top:1.75rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
          <a href={waUrl} target="_blank" rel="noopener noreferrer"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.5rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s;"
            onmouseover="this.style.background='#25D366'" onmouseout="this.style.background='#1A1A1A'">
            CONSULTAR AHORA
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/cotizar"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.75rem 1.5rem; background:transparent; color:rgba(255,255,255,0.45); font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:1px solid rgba(255,255,255,0.12); text-decoration:none; transition:all 0.2s;"
            onmouseover="this.style.color='#fff'; this.style.borderColor='rgba(255,255,255,0.4)'" onmouseout="this.style.color='rgba(255,255,255,0.45)'; this.style.borderColor='rgba(255,255,255,0.12)'">
            COTIZAR GRATIS
          </a>
        </div>
      </div>

      <div style="position:absolute; bottom:2rem; right:2.5rem; z-index:20;">
        <Breadcrumbs items={[{ name: "Valdivia", path: "/regiones/valdivia" }]} />
      </div>
    </section>


    <!-- COLUMNAS SERVICIOS — orden diferente: auto primero (full), luego 55/45 -->
    <div class="services-columns-row" style="width:100vw;">

      <!-- Fila 1: AUTOMATIZACIÓN full width arriba (variación respecto a otras ciudades) -->
      <a href="/automatizacion" class="service-col col-auto"
        style="text-decoration:none; cursor:pointer; width:100%;">
        <div style="position:absolute; inset:0; background:linear-gradient(135deg, #080808 0%, #0d0a04 50%, #010101 100%);"></div>
        <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 60% 50%, #1a130418 0%, transparent 60%);"></div>
        <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 10% 20%, #25d36608 0%, transparent 40%);"></div>
        <div style="position:absolute; inset:0; opacity:0.02; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
        <div class="col-hover-overlay" style="position:absolute; inset:0; background:rgba(255,255,255,0.015); opacity:0; transition:opacity 0.4s;"></div>
        <div style="position:absolute; bottom:0; left:0; right:0; height:70%; background:linear-gradient(to top, rgba(1,1,1,0.97) 0%, transparent 100%);"></div>
        <div style="position:relative; z-index:10; padding:2.5rem;">
          <p style="font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.75rem;">01 — AUTOMATIZACIÓN</p>
          <div style="display:flex; flex-wrap:wrap; align-items:flex-end; gap:2.5rem; width:100%;">
            <div>
              <h2 style="font-size:clamp(1.75rem, 4vw, 3.25rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.9; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
                BOT WHATSAPP · CRM · DASHBOARDS
              </h2>
              <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.4); font-family:var(--font-body); font-weight:300; max-width:480px; line-height:1.6;">
                Ideal para hostelería y gastronomía valdiviana. Reservas automáticas, 24/7.
              </p>
            </div>
            <div style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap; margin-left:auto;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em; white-space:nowrap;">VER SOLUCIONES →</span>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.25); font-family:var(--font-body); white-space:nowrap;">Desde $290.000</span>
            </div>
          </div>
        </div>
      </a>

      <!-- Fila 2: 55/45 -->
      <div class="cols-row-2">

        <!-- Col: DESARROLLO WEB — 55% -->
        <a href="/desarrollo-web" class="service-col col-web"
          style="text-decoration:none; cursor:pointer;">
          <div style="position:absolute; inset:0; background:linear-gradient(145deg, #060810 0%, #0a0e1a 40%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 70% 30%, #1a237e18 0%, transparent 60%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 20% 80%, #6366f110 0%, transparent 50%);"></div>
          <div style="position:absolute; inset:0; opacity:0.02; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="col-hover-overlay" style="position:absolute; inset:0; background:rgba(255,255,255,0.02); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:65%; background:linear-gradient(to top, rgba(1,1,1,0.95) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.75rem;">02 — DESARROLLO WEB</p>
            <h2 style="font-size:clamp(2rem, 5vw, 4.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.9; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              PÁGINAS WEB<br />PROFESIONALES
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.4); font-family:var(--font-body); font-weight:300; max-width:340px; line-height:1.6;">
              Para restaurantes, cervecerías, hospedajes y servicios de Valdivia.
            </p>
            <div style="margin-top:1.25rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em;">EXPLORAR SERVICIO →</span>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.25); font-family:var(--font-body);">Desde $290.000</span>
            </div>
          </div>
        </a>

        <!-- Col: SEO LOCAL — 45% -->
        <a href="/seo-local" class="service-col col-seo"
          style="text-decoration:none; cursor:pointer;">
          <div style="position:absolute; inset:0; background:linear-gradient(155deg, #041209 0%, #061510 50%, #010101 100%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 30% 40%, #05301a18 0%, transparent 60%);"></div>
          <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 80% 80%, #10b98108 0%, transparent 50%);"></div>
          <div style="position:absolute; inset:0; opacity:0.02; mix-blend-mode:overlay; background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.85%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E'); background-size:256px;"></div>
          <div class="col-hover-overlay" style="position:absolute; inset:0; background:rgba(255,255,255,0.02); opacity:0; transition:opacity 0.4s;"></div>
          <div style="position:absolute; bottom:0; left:0; right:0; height:65%; background:linear-gradient(to top, rgba(1,1,1,0.95) 0%, transparent 100%);"></div>
          <div style="position:relative; z-index:10; padding:2.5rem;">
            <p style="font-size:0.6rem; letter-spacing:0.2em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:0.75rem;">03 — SEO LOCAL</p>
            <h2 style="font-size:clamp(2rem, 4vw, 3.5rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.9; letter-spacing:-0.03em; text-transform:uppercase; margin:0;">
              GOOGLE<br />MAPS
            </h2>
            <p style="margin-top:0.75rem; font-size:0.75rem; color:rgba(255,255,255,0.4); font-family:var(--font-body); font-weight:300; max-width:280px; line-height:1.6;">
              Aparece cuando turistas y valdivinos te buscan en Google.
            </p>
            <div style="margin-top:1.25rem; display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
              <span style="display:inline-block; padding:0.6rem 1.25rem; background:#1A1A1A; color:#fff; font-size:0.6rem; font-family:var(--font-body); text-transform:uppercase; letter-spacing:0.2em;">VER PLANES →</span>
              <span style="font-size:0.7rem; color:rgba(255,255,255,0.25); font-family:var(--font-body);">Desde $190.000</span>
            </div>
          </div>
        </a>

      </div>

    </div>


    <!-- FAQ -->
    <section style="width:100vw; background:#0A0A0A; position:relative; overflow:hidden;">
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
      <div style="max-width:800px; margin:0 auto; padding:6rem 2.5rem;">
        <div class="reveal-group" style="margin-bottom:3rem;">
          <p class="reveal-item" style="font-size:0.6rem; letter-spacing:0.25em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Preguntas frecuentes</p>
          <h2 class="reveal-item" style="font-size:clamp(2rem,5vw,4rem); font-family:var(--font-heading); font-weight:800; color:#fff; letter-spacing:-0.03em; text-transform:uppercase; line-height:0.92; margin:0;">
            LO QUE<br />NOS PREGUNTAN
          </h2>
        </div>
        <div class="reveal-group" style="border-top:1px solid rgba(255,255,255,0.06);">
          {[
            { q: "¿Hacen páginas web para negocios en Valdivia?", a: "Sí. Trabajamos con restaurantes, cervecerías, hospedajes turísticos, servicios profesionales y comercio de Valdivia. Entendemos la economía local y el turismo de Los Ríos." },
            { q: "¿Cuánto cuesta una página web en Valdivia?", a: "Landing pages desde $290.000, sitios corporativos desde $690.000. Todo incluye diseño, dominio + hosting un año, SEO básico y Google Analytics. Sin costos ocultos." },
            { q: "¿Cómo aparezco en Google cuando buscan en Valdivia?", a: "Optimizamos tu Google Business Profile y aplicamos SEO local para aparecer en búsquedas como 'restaurant Valdivia' o 'hospedaje río Valdivia'. Resultados en 4-8 semanas." },
            { q: "¿Pueden hacer una tienda online para mi negocio valdiviano?", a: "Sí. Creamos tiendas completas con Transbank/Mercado Pago, catálogo de productos, gestión de pedidos y envíos. Desde $1.500.000 con todo incluido." },
          ].map(faq => (
            <details class="reveal-item faq-item" style="border-bottom:1px solid rgba(255,255,255,0.06);">
              <summary style="display:flex; cursor:pointer; align-items:center; justify-content:space-between; gap:1rem; padding:1.5rem 0; font-size:0.875rem; font-family:var(--font-heading); font-weight:600; color:rgba(255,255,255,0.75); list-style:none; transition:color 0.2s;">
                <span>{faq.q}</span>
                <span class="faq-icon" style="flex-shrink:0; width:1.25rem; height:1.25rem; border:1px solid rgba(255,255,255,0.1); border-radius:50%; display:flex; align-items:center; justify-content:center; transition:all 0.3s;">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                </span>
              </summary>
              <p style="padding-bottom:1.5rem; font-size:0.8rem; color:rgba(255,255,255,0.38); font-family:var(--font-body); font-weight:300; line-height:1.8; max-width:600px;">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>


    <!-- CTA FINAL -->
    <section style="position:relative; width:100vw; min-height:70vh; overflow:hidden; background:#010101; display:flex; flex-direction:column; justify-content:flex-end;">
      <div style="position:absolute; inset:0; background:radial-gradient(ellipse at 40% 60%, #6366f10e 0%, transparent 55%);"></div>
      <div style="position:absolute; top:0; left:0; right:0; height:1px; background:linear-gradient(90deg,transparent,rgba(255,255,255,0.05),transparent);"></div>
      <div class="reveal-group" style="position:relative; z-index:10; padding:4rem 2.5rem 4rem;">
        <p class="reveal-item" style="font-size:0.6rem; letter-spacing:0.3em; text-transform:uppercase; color:rgba(255,255,255,0.2); font-family:var(--font-body); margin-bottom:1.25rem;">Valdivia · Los Ríos</p>
        <h2 class="reveal-item" style="font-size:clamp(3rem,10vw,10rem); font-family:var(--font-heading); font-weight:800; color:#fff; line-height:0.85; letter-spacing:-0.04em; text-transform:uppercase; margin:0;">
          TU NEGOCIO,<br /><span style="color:rgba(255,255,255,0.15);">VISIBLE.</span>
        </h2>
        <p class="reveal-item" style="margin-top:1.25rem; font-size:0.78rem; color:rgba(255,255,255,0.3); font-family:var(--font-body); font-weight:300; max-width:320px; line-height:1.7;">
          Cuéntanos qué necesitas. Respuesta en menos de 24 horas.
        </p>
        <div class="reveal-item" style="margin-top:2rem; display:flex; gap:0.75rem; flex-wrap:wrap;">
          <a href={waUrl} target="_blank" rel="noopener noreferrer"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.85rem 1.75rem; background:#1A1A1A; color:#fff; font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; text-decoration:none; transition:background 0.2s;"
            onmouseover="this.style.background='#25D366'" onmouseout="this.style.background='#1A1A1A'">
            WHATSAPP AHORA
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
          <a href="/cotizar"
            style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.85rem 1.75rem; background:transparent; color:rgba(255,255,255,0.4); font-size:0.65rem; font-family:var(--font-body); font-weight:500; text-transform:uppercase; letter-spacing:0.2em; border:1px solid rgba(255,255,255,0.1); text-decoration:none; transition:all 0.2s;"
            onmouseover="this.style.color='#fff'; this.style.borderColor='rgba(255,255,255,0.35)'" onmouseout="this.style.color='rgba(255,255,255,0.4)'; this.style.borderColor='rgba(255,255,255,0.1)'">
            COTIZAR ONLINE
          </a>
        </div>
      </div>
    </section>

  </main>
  <Footer />

  <style>
    .services-columns-row { display: flex; flex-direction: column; width: 100%; }
    .cols-row-2 { display: flex; flex-direction: column; width: 100%; }
    .service-col {
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      min-height: 85vw;
    }
    .col-auto { min-height: 35vw; border-bottom: 1px solid rgba(255,255,255,0.04); }
    @media (min-width: 768px) {
      .cols-row-2 { flex-direction: row; }
      .col-web { width: 55%; min-height: 72vh; }
      .col-seo { width: 45%; min-height: 72vh; border-left: 1px solid rgba(255,255,255,0.04); }
      .col-auto { min-height: 45vh; border-bottom: none; }
    }
    .service-col:hover .col-hover-overlay { opacity: 1 !important; }
    @media (max-width: 640px) {
      .metrics-strip { grid-template-columns: repeat(2, 1fr) !important; }
    }
    .faq-item summary:hover { color: #fff !important; }
    .faq-item[open] summary { color: #fff !important; }
    .faq-item[open] .faq-icon { border-color: rgba(255,255,255,0.3) !important; transform: rotate(45deg); }
  </style>
</BaseLayout>

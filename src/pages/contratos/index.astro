---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Mis Contratos — Mtsprz" description="Portal de contratos">
  <main class="min-h-screen bg-[#010101] px-4 py-8">
    <div class="mx-auto max-w-4xl">
      <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
        <div>
          <h1 class="text-2xl font-heading font-bold text-white tracking-[-1px]">Mis Contratos</h1>
          <p class="text-sm text-white/40 font-body mt-1">Revisa y firma tus contratos</p>
        </div>
        <a href="/" class="text-xs text-white/40 hover:text-white/60 transition-colors font-body">← Volver al sitio</a>
      </div>

      <div id="loadingContracts" style="text-align:center;padding:64px;color:rgba(250,250,250,0.3);font-size:14px;">
        Cargando contratos...
      </div>

      <div id="contractsList" style="display:none;"></div>
    </div>
  </main>
</BaseLayout>

<script is:inline>
  async function loadContracts() {
    try {
      const res = await fetch("/api/contracts");
      const data = await res.json();

      if (!data.contracts || data.contracts.length === 0) {
        document.getElementById("loadingContracts").innerHTML = `
          <div style="padding:48px;text-align:center;">
            <p style="color:rgba(250,250,250,0.4);margin-bottom:16px;">No tienes contratos pendientes</p>
            <a href="/contacto" style="display:inline-block;padding:10px 24px;border-radius:9999px;font-size:13px;font-weight:500;color:#fff;text-decoration:none;background:linear-gradient(135deg,#6366f1,#8b5cf6);">Solicitar Servicios</a>
          </div>
        `;
        return;
      }

      document.getElementById("loadingContracts").style.display = "none";
      document.getElementById("contractsList").style.display = "block";

      document.getElementById("contractsList").innerHTML = data.contracts.map((c) => {
        const statusLabels = {
          draft: "Borrador", pending: "Pendiente de Firma", client_signed: "Firmado por ti",
          completed: "Completado", cancelled: "Cancelado",
        };
        const statusColors = {
          draft: "rgba(250,250,250,0.3)", pending: "#6366f1", client_signed: "#10b981",
          completed: "#10b981", cancelled: "#ef4444",
        };

        return `
          <a href="/contratos/${c.id}" style="display:block;padding:16px 20px;background:#0a0a0b;border:1px solid rgba(255,255,255,0.06);border-radius:16px;margin-bottom:8px;text-decoration:none;transition:border-color 0.2s;">
            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;">
              <div>
                <div style="font-size:13px;font-weight:600;color:#fafafa;font-family:monospace;">${c.contract_number}</div>
                <div style="font-size:13px;color:rgba(250,250,250,0.6);margin-top:2px;">${c.client_name}</div>
              </div>
              <div style="text-align:right;">
                <div style="font-size:12px;padding:3px 10px;border-radius:9999px;background:${statusColors[c.status]}15;color:${statusColors[c.status]};display:inline-block;">
                  ${statusLabels[c.status] || c.status}
                </div>
                <div style="font-size:11px;color:rgba(250,250,250,0.3);margin-top:4px;">${new Date(c.created_at).toLocaleDateString("es-CL")}</div>
              </div>
            </div>
          </a>
        `;
      }).join("");
    } catch {
      document.getElementById("loadingContracts").innerHTML =
        '<p style="color:#ef4444;">Error al cargar contratos. <a href="/login" style="color:#6366f1;">Inicia sesión</a></p>';
    }
  }

  loadContracts();
</script>

---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Contacto — Mtsprz"
  description="Contacta a Mtsprz en Puerto Varas, Región de Los Lagos. Solicita una cotización sin compromiso para tu página web, SEO local o automatización."
  canonical="https://mtsprz.org/contacto"
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ContactPage",
    "@id": "https://mtsprz.org/contacto#contactpage",
    url: "https://mtsprz.org/contacto",
    description: "Formulario de contacto y datos de Mtsprz en Puerto Varas, Región de Los Lagos.",
    mainEntity: {
      "@type": "Organization",
      "@id": "https://mtsprz.org/#organization"
    }
  })} />
  <Header />
  <link rel="preload" as="video" href="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4" fetchpriority="high" />
  <main>
    <!-- Hero — video background full-bleed -->
    <section class="relative w-screen h-[100dvh] md:h-screen overflow-hidden bg-[#010101]">
      <video
        src="https://d8j0ntlcm91z4.cloudfront.net/user_38xzZboKViGWJOttwIXH07lWA1P/hf_20260619_191346_9d19d66e-86a4-47f7-8dc6-712c1788c3b2.mp4"
        autoplay loop muted playsinline
        preload="auto"
        class="z-[1]"
        style="position: absolute !important; top: 0 !important; left: 0 !important; width: 100% !important; height: 100% !important; object-fit: cover !important; object-position: center !important; max-width: none !important; min-width: 0 !important; min-height: 0 !important; margin: 0 !important; padding: 0 !important; border: 0 !important; display: block !important;"
      />
      <div style="position: absolute !important; top: 0; left: 0; width: 100%; height: 24%; z-index: 2;" class="bg-gradient-to-b from-[#010101] to-transparent sm:h-32"></div>
      <div style="position: absolute !important; bottom: 0; left: 0; width: 100%; height: 36%; z-index: 2;" class="bg-gradient-to-t from-[#010101] to-transparent sm:h-48"></div>

      <!-- Contenido central -->
      <div style="position: absolute !important; inset: 0; z-index: 10; display: flex; align-items: center; justify-content: center; pointer-events: none;">
        <div class="text-center px-6" style="pointer-events: auto;">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Contacto</p>
          <h1 class="text-5xl sm:text-7xl md:text-8xl lg:text-9xl font-heading font-bold text-white leading-[0.9] tracking-[-3px] md:tracking-[-4px]">CONTACTO</h1>
          <p class="mt-4 text-white/50 font-body font-light max-w-lg mx-auto text-sm md:text-base">
            Conversemos sin compromiso sobre tu próximo proyecto digital
          </p>
        </div>
      </div>

      <!-- Breadcrumb — integrado en hero, esquina inferior -->
      <div class="absolute bottom-8 md:bottom-10 left-0 right-0 z-20 px-6">
        <div class="mx-auto max-w-6xl">
          <Breadcrumbs items={[{ name: "Contacto", path: "/contacto" }]} />
        </div>
      </div>
    </section>

    <!-- Contact content — editorial layout -->
    <section class="relative bg-[#0A0A0A] w-full overflow-hidden">
      <!-- Background -->
      <div class="absolute inset-0" style="background: #0A0A0A;" />
      <div class="absolute inset-0 opacity-40" style="background: radial-gradient(ellipse at 30% 0%, #6366f110 0%, transparent 50%), radial-gradient(ellipse at 70% 100%, #8b5cf606 0%, transparent 50%);" />
      <div class="absolute inset-0 opacity-[0.012] mix-blend-overlay pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=\'0 0 256 256\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cfilter id=\'noise\'%3E%3CfeTurbulence type=\'fractalNoise\' baseFrequency=\'0.9\' numOctaves=\'4\' stitchTiles=\'stitch\'/%3E%3C/filter%3E%3Crect width=\'100%25\' height=\'100%25\' filter=\'url(%23noise)\' opacity=\'1\'/%3E%3C/svg%3E'); background-repeat: repeat; background-size: 256px 256px;" />
      <div class="absolute top-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f144, transparent);" />
      <div class="absolute bottom-0 left-0 right-0 h-[1px]" style="background: linear-gradient(90deg, transparent, #6366f122, transparent);" />

      <div class="relative mx-auto max-w-5xl px-6 py-28 md:py-36">
        <div class="grid gap-10 md:gap-12 lg:grid-cols-5">
          <!-- Contact info — editorial chips -->
          <div class="reveal-group lg:col-span-2 space-y-6 md:space-y-8">
            <div class="reveal-item">
              <p class="text-[10px] md:text-xs uppercase tracking-[0.25em] font-body font-medium mb-5 md:mb-6" style="color: #6366f1aa;">Información</p>
              <div class="space-y-4">
                <div class="flex items-center gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white/10 shrink-0">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
                  </div>
                  <div>
                    <p class="text-[11px] text-white/30 font-body uppercase tracking-[0.1em]">Teléfono</p>
                    <p class="text-sm text-white/70 font-body">+56975475781</p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white/10 shrink-0">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                  </div>
                  <div>
                    <p class="text-[11px] text-white/30 font-body uppercase tracking-[0.1em]">Email</p>
                    <p class="text-sm text-white/70 font-body">contacto@mtsprz.org</p>
                  </div>
                </div>
                <div class="flex items-center gap-4">
                  <div class="flex items-center justify-center w-10 h-10 rounded-full border border-white/10 shrink-0">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-white/60"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  </div>
                  <div>
                    <p class="text-[11px] text-white/30 font-body uppercase tracking-[0.1em]">Ubicación</p>
                    <p class="text-sm text-white/70 font-body">Puerto Varas, Región de Los Lagos, Chile</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Trust signals -->
            <div class="reveal-item pt-4">
              <div class="flex flex-wrap gap-x-6 gap-y-3">
                {[
                  { label: "Sin compromiso", accent: "#6366f1" },
                  { label: "Respuesta en 24 hrs", accent: "#10b981" },
                  { label: "Atención personalizada", accent: "#6366f1" },
                ].map((t) => (
                  <span class="inline-flex items-center gap-2 text-[10px] md:text-xs font-medium tracking-[0.1em] uppercase" style="color: rgba(255,255,255,0.35);">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke={t.accent} stroke-width="2.5" stroke-linecap="round"><polyline points="20 6 9 17 4 12"/></svg>
                    {t.label}
                  </span>
                ))}
              </div>
            </div>
          </div>

          <!-- Form — minimal editorial -->
          <form id="contact-form" class="reveal-group lg:col-span-3" novalidate>
            <div class="reveal-item space-y-5">
              <div>
                <label for="name" class="block text-[11px] uppercase tracking-[0.1em] font-body font-medium text-white/40 mb-2">Nombre</label>
                <input
                  type="text" id="name" name="name" required
                  class="w-full bg-transparent px-0 py-3 text-sm text-white outline-none border-b border-white/10 transition-all focus:border-[#6366f1]/50 placeholder:text-white/20 font-body"
                  placeholder="Tu nombre"
                />
              </div>
              <div>
                <label for="email" class="block text-[11px] uppercase tracking-[0.1em] font-body font-medium text-white/40 mb-2">Email</label>
                <input
                  type="email" id="email" name="email" required
                  class="w-full bg-transparent px-0 py-3 text-sm text-white outline-none border-b border-white/10 transition-all focus:border-[#6366f1]/50 placeholder:text-white/20 font-body"
                  placeholder="tu@email.com"
                />
              </div>
              <div>
                <label for="message" class="block text-[11px] uppercase tracking-[0.1em] font-body font-medium text-white/40 mb-2">Mensaje</label>
                <textarea
                  id="message" name="message" rows={4} required
                  class="w-full bg-transparent px-0 py-3 text-sm text-white outline-none border-b border-white/10 transition-all focus:border-[#6366f1]/50 placeholder:text-white/20 font-body resize-none"
                  placeholder="Cuéntanos de tu proyecto..."
                ></textarea>
              </div>
              <div id="form-status" class="text-xs font-body hidden"></div>
              <button
                type="submit" id="submit-btn"
                class="group inline-flex items-center gap-3 px-7 py-3.5 text-xs font-medium uppercase tracking-[0.15em] transition-all duration-300"
                style="color: #fff; background: linear-gradient(135deg, #6366f1, #8b5cf6);"
              >
                <span id="btn-text">Enviar mensaje</span>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
              </button>
            </div>
          </form>
        </div>
      </div>
    </section>

    <script>
          const form = document.getElementById("contact-form") as HTMLFormElement;
          const status = document.getElementById("form-status")!;
          const btn = document.getElementById("submit-btn") as HTMLButtonElement;
          const btnText = document.getElementById("btn-text")!;

          form.addEventListener("submit", async (e) => {
            e.preventDefault();
            btn.disabled = true;
            btnText.textContent = "Enviando...";
            status.className = "text-xs font-body hidden";

            try {
              const res = await fetch("/api/contact", {
                method: "POST",
                body: new FormData(form),
              });
              const data = await res.json();

              if (res.ok) {
                status.className = "text-xs font-body text-emerald-400";
                status.textContent = data.message || "Mensaje enviado correctamente";
                form.reset();
              } else {
                status.className = "text-xs font-body text-red-400";
                status.textContent = data.error || "Error al enviar el mensaje";
              }
            } catch {
              status.className = "text-xs font-body text-red-400";
              status.textContent = "Error de conexión. Intenta nuevamente.";
            }

            btn.disabled = false;
            btnText.textContent = "Enviar Mensaje";
          });
        </script>
  </main>
  <Footer />
</BaseLayout>

---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import BlurText from "../components/BlurText.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";
import Footer from "../components/Footer.astro";
import { ArrowUpRight } from "@lucide/astro";
---

<BaseLayout
  title="Nosotros — Agencia Digital en Puerto Varas"
  description="Conoce a Mtsprz, la agencia de soluciones digitales para pymes en la Región de Los Lagos. Desarrollo web, SEO local y automatizaciones con presencia en Puerto Varas, Osorno y Valdivia."
  canonical="https://mtsprz.org/nosotros"
  breadcrumbs={[{ name: "Nosotros", path: "/nosotros" }]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "@id": "https://mtsprz.org/nosotros#aboutpage",
    url: "https://mtsprz.org/nosotros",
    name: "Nosotros — Mtsprz Soluciones Digitales",
    description: "Agencia de soluciones digitales para pymes en la Región de Los Lagos, Chile.",
    mainEntity: { "@id": "https://mtsprz.org/#organization" },
    significantLink: [
      "https://mtsprz.org/servicios",
      "https://mtsprz.org/portafolio",
      "https://mtsprz.org/contacto"
    ]
  })} />
  <Header />
  <Breadcrumbs items={[{ name: "Nosotros", path: "/nosotros" }]} class="mx-auto max-w-6xl px-6 pt-6 pb-2" />

  <main class="bg-[#010101]">
    <!-- Hero -->
    <section class="py-28 md:py-36">
      <div class="mx-auto max-w-4xl px-6 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Nosotros</p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-heading font-bold text-white leading-[0.95] tracking-[-2px]">
          Agencia Digital en la <span class="text-[#6366f1]">Región de Los Lagos</span>
        </h1>
        <p class="mt-6 text-lg text-white/60 font-body font-light max-w-2xl mx-auto">
          Ayudamos a pymes del sur de Chile a crecer con soluciones digitales profesionales,
          cercanas y efectivas.
        </p>
      </div>
    </section>

    <!-- Story -->
    <section class="pb-28 md:pb-36">
      <div class="mx-auto max-w-4xl px-6">
        <div class="liquid-glass rounded-[1.5rem] p-8 md:p-12">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white tracking-[-1px]">Nuestra Historia</h2>
          <div class="mt-6 space-y-4 text-white/60 font-body font-light leading-relaxed text-sm md:text-base">
            <p>
              Mtsprz nació en <strong class="text-white/80">Puerto Varas</strong> con una convicción clara:
              las pymes del sur de Chile merecen acceso a soluciones digitales de calidad sin pagar
              precios de Santiago. Sabemos que un sitio web lento, un mal posicionamiento en Google
              o procesos manuales ineficientes pueden frenar el crecimiento de un negocio local.
            </p>
            <p>
              Desde la <strong class="text-white/80">Región de Los Lagos</strong>, trabajamos con
              emprendedores y empresas de <strong class="text-white/80">Puerto Varas</strong>,
              <strong class="text-white/80">Osorno</strong>,
              <strong class="text-white/80">Valdivia</strong>, Ancud, Castro y todo el sur de Chile.
              Cada proyecto lo abordamos con atención personalizada, porque entendemos las necesidades
              del mercado local.
            </p>
            <p>
              Usamos tecnología moderna —<strong class="text-white/80">Astro</strong>,
              <strong class="text-white/80">Tailwind CSS</strong>, infraestructura en la nube—
              para ofrecer sitios ultrarrápidos, seguros y optimizados para los motores de búsqueda.
              Pero más que tecnología, ofrecemos una <strong class="text-white/80">estrategia digital</strong>
              que impulsa resultados reales para tu negocio.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Values -->
    <section class="pb-28 md:pb-36">
      <div class="mx-auto max-w-6xl px-6">
        <div class="text-center mb-16">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-4">Cómo trabajamos</p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-heading font-bold text-white leading-[1.05] tracking-[-1px]">
            Nuestros Valores
          </h2>
        </div>
        <div class="grid gap-5 sm:grid-cols-3">
          <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-6">
            <div class="w-10 h-10 rounded-lg bg-[#6366f1]/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[#6366f1]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
            </div>
            <h3 class="text-lg font-heading font-semibold text-white">Tecnología Moderna</h3>
            <p class="mt-2 text-sm text-white/50 font-body font-light leading-relaxed">
              Construimos con Astro, Tailwind y las mejores herramientas del ecosistema web.
              Sitios que cargan en menos de 1.5 segundos y puntúan 95+ en PageSpeed Insights.
            </p>
          </div>
          <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-6">
            <div class="w-10 h-10 rounded-lg bg-[#10b981]/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[#10b981]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h3 class="text-lg font-heading font-semibold text-white">Atención Personalizada</h3>
            <p class="mt-2 text-sm text-white/50 font-body font-light leading-relaxed">
              Cada pyme es única. Trabajamos codo a codo contigo para entender tu negocio y
              ofrecerte la solución que realmente necesitas, sin paquetes genéricos.
            </p>
          </div>
          <div class="rounded-xl border border-white/[0.06] bg-[#0a0a0b] p-6">
            <div class="w-10 h-10 rounded-lg bg-[#06b6d4]/10 flex items-center justify-center mb-4">
              <svg class="w-5 h-5 text-[#06b6d4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 12l2 2 4-4"/></svg>
            </div>
            <h3 class="text-lg font-heading font-semibold text-white">Resultados Medibles</h3>
            <p class="mt-2 text-sm text-white/50 font-body font-light leading-relaxed">
              No creemos en promesas vacías. Cada proyecto incluye métricas claras:
              velocidad de carga, posicionamiento en Google, tráfico orgánico y conversiones.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="pb-28 md:pb-36">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <div class="liquid-glass rounded-[1.5rem] p-8 md:p-12">
          <p class="text-xs uppercase tracking-[0.2em] text-white/40 font-body mb-3">Trabajemos juntos</p>
          <h2 class="text-2xl sm:text-3xl font-heading font-bold text-white tracking-[-0.5px]">
            ¿Listo para impulsar tu negocio digital?
          </h2>
          <p class="mt-3 text-sm text-white/50 font-body font-light max-w-md mx-auto">
            Conversemos sin compromiso. Te ayudamos a definir la mejor estrategia digital
            para tu empresa en el sur de Chile.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-4">
            <a
              href="/contacto"
              class="group relative inline-flex items-center gap-2.5 rounded-full px-7 py-3.5 text-sm font-medium text-white transition-all duration-300"
              style="background: linear-gradient(135deg, #6366f1, #8b5cf6);"
            >
              <span class="absolute inset-0 rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300 blur-xl" style="background: #6366f166;" />
              <span class="relative">Contáctanos</span>
              <ArrowUpRight size={16} class="relative transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" stroke-width="2" />
            </a>
            <a href="/servicios" class="text-sm text-white/50 hover:text-white/80 font-body transition-colors">
              Ver servicios →
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
